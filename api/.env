PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/record_tracking
JWT_SECRET=super_secret_key
JWT_EXPIRES=1d

# ── Document field organizer ────────────────────────────────────────────
# Leave LLM_PROVIDER blank (or unset) to keep the original heuristic mode —
# pure offline, no API keys, no recurring cost.
#
# To enable LLM-powered field organization, set LLM_PROVIDER to one of:
#   anthropic | openai | ollama
# and supply the matching key/URL below. Output JSON shape is identical to
# the heuristic, so the frontend doesn't change.
LLM_PROVIDER=
LLM_TIMEOUT_MS=45000

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ollama (local — free, runs on your machine)
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b
# OLLAMA_NUM_GPU: leave blank for auto. Set 0 to force CPU-only (use when the
# model is larger than your GPU's VRAM, e.g. llama3.1 8B on a 4 GB card).
OLLAMA_NUM_GPU=
