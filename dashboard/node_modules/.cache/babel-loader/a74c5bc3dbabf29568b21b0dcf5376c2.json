{"ast":null,"code":"import API from \"@/services/api\";\nexport default {\n  name: \"RegisterPage\",\n  data() {\n    return {\n      form: {\n        username: \"\",\n        email: \"\",\n        password: \"\",\n        confirmPassword: \"\",\n        role: \"admin\",\n        permissions: {\n          createReports: false,\n          editIncidents: false,\n          deleteRecords: false,\n          viewConfidentialData: false\n        },\n        acceptTerms: false\n      },\n      isSubmitting: false,\n      message: {\n        type: \"\",\n        text: \"\"\n      }\n    };\n  },\n  methods: {\n    async handleRegister() {\n      this.message = {\n        type: \"\",\n        text: \"\"\n      };\n      if (!this.form.username || !this.form.email || !this.form.password) {\n        this.message = {\n          type: \"error\",\n          text: \"Username, email, and password are required.\"\n        };\n        return;\n      }\n      if (this.form.password !== this.form.confirmPassword) {\n        this.message = {\n          type: \"error\",\n          text: \"Password confirmation does not match.\"\n        };\n        return;\n      }\n      if (!this.form.acceptTerms) {\n        this.message = {\n          type: \"error\",\n          text: \"Confirm admin access before creating the user.\",\n          text: \"Confirm the selected role and permissions before creating the user.\"\n        };\n        return;\n      }\n      this.isSubmitting = true;\n      try {\n        const response = await API.post(\"/auth/register\", {\n          username: this.form.username,\n          email: this.form.email,\n          password: this.form.password,\n          role: this.form.role,\n          permissions: {\n            createReports: this.form.permissions.createReports,\n            editIncidents: this.form.permissions.editIncidents,\n            deleteRecords: this.form.permissions.deleteRecords,\n            viewConfidentialData: this.form.permissions.viewConfidentialData\n          }\n        });\n        this.message = {\n          type: \"success\",\n          text: response.data.message || \"User created successfully.\"\n        };\n        this.form = {\n          username: \"\",\n          email: \"\",\n          password: \"\",\n          confirmPassword: \"\",\n          role: \"admin\",\n          permissions: {\n            createReports: false,\n            editIncidents: false,\n            deleteRecords: false,\n            viewConfidentialData: false\n          },\n          acceptTerms: false\n        };\n      } catch (error) {\n        this.message = {\n          type: \"error\",\n          text: error.response?.data?.message || \"Unable to save the user right now.\"\n        };\n      } finally {\n        this.isSubmitting = false;\n      }\n    }\n  }\n};","map":{"version":3,"mappings":"AA2NE,OAAOA,GAAE,MAAO,gBAAgB;AAEhC,eAAe;EACbC,IAAI,EAAE,cAAc;EACpBC,IAAIA,GAAG;IACL,OAAO;MACLC,IAAI,EAAE;QACJC,QAAQ,EAAE,EAAE;QACZC,KAAK,EAAE,EAAE;QACTC,QAAQ,EAAE,EAAE;QACZC,eAAe,EAAE,EAAE;QACnBC,IAAI,EAAE,OAAO;QACbC,WAAW,EAAE;UACXC,aAAa,EAAE,KAAK;UACpBC,aAAa,EAAE,KAAK;UACpBC,aAAa,EAAE,KAAK;UACpBC,oBAAoB,EAAE;QACxB,CAAC;QACDC,WAAW,EAAE;MACf,CAAC;MACDC,YAAY,EAAE,KAAK;MACnBC,OAAO,EAAE;QACPC,IAAI,EAAE,EAAE;QACRC,IAAI,EAAE;MACR;IACF,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACP,MAAMC,cAAcA,GAAG;MACrB,IAAI,CAACJ,OAAM,GAAI;QAAEC,IAAI,EAAE,EAAE;QAAEC,IAAI,EAAE;MAAG,CAAC;MAErC,IAAI,CAAC,IAAI,CAACf,IAAI,CAACC,QAAO,IAAK,CAAC,IAAI,CAACD,IAAI,CAACE,KAAI,IAAK,CAAC,IAAI,CAACF,IAAI,CAACG,QAAQ,EAAE;QAClE,IAAI,CAACU,OAAM,GAAI;UACbC,IAAI,EAAE,OAAO;UACbC,IAAI,EAAE;QACR,CAAC;QACD;MACF;MAEA,IAAI,IAAI,CAACf,IAAI,CAACG,QAAO,KAAM,IAAI,CAACH,IAAI,CAACI,eAAe,EAAE;QACpD,IAAI,CAACS,OAAM,GAAI;UACbC,IAAI,EAAE,OAAO;UACbC,IAAI,EAAE;QACR,CAAC;QACD;MACF;MAEA,IAAI,CAAC,IAAI,CAACf,IAAI,CAACW,WAAW,EAAE;QAC1B,IAAI,CAACE,OAAM,GAAI;UACbC,IAAI,EAAE,OAAO;UACbC,IAAI,EAAE,gDAAgD;UACtDA,IAAI,EAAE;QACR,CAAC;QACD;MACF;MAEA,IAAI,CAACH,YAAW,GAAI,IAAI;MAExB,IAAI;QACF,MAAMM,QAAO,GAAI,MAAMrB,GAAG,CAACsB,IAAI,CAAC,gBAAgB,EAAE;UAChDlB,QAAQ,EAAE,IAAI,CAACD,IAAI,CAACC,QAAQ;UAC5BC,KAAK,EAAE,IAAI,CAACF,IAAI,CAACE,KAAK;UACtBC,QAAQ,EAAE,IAAI,CAACH,IAAI,CAACG,QAAQ;UAC5BE,IAAI,EAAE,IAAI,CAACL,IAAI,CAACK,IAAI;UACpBC,WAAW,EAAE;YACXC,aAAa,EAAE,IAAI,CAACP,IAAI,CAACM,WAAW,CAACC,aAAa;YAClDC,aAAa,EAAE,IAAI,CAACR,IAAI,CAACM,WAAW,CAACE,aAAa;YAClDC,aAAa,EAAE,IAAI,CAACT,IAAI,CAACM,WAAW,CAACG,aAAa;YAClDC,oBAAoB,EAAE,IAAI,CAACV,IAAI,CAACM,WAAW,CAACI;UAC9C;QACF,CAAC,CAAC;QAEF,IAAI,CAACG,OAAM,GAAI;UACbC,IAAI,EAAE,SAAS;UACfC,IAAI,EAAEG,QAAQ,CAACnB,IAAI,CAACc,OAAM,IAAK;QACjC,CAAC;QAED,IAAI,CAACb,IAAG,GAAI;UACVC,QAAQ,EAAE,EAAE;UACZC,KAAK,EAAE,EAAE;UACTC,QAAQ,EAAE,EAAE;UACZC,eAAe,EAAE,EAAE;UACnBC,IAAI,EAAE,OAAO;UACbC,WAAW,EAAE;YACXC,aAAa,EAAE,KAAK;YACpBC,aAAa,EAAE,KAAK;YACpBC,aAAa,EAAE,KAAK;YACpBC,oBAAoB,EAAE;UACxB,CAAC;UACDC,WAAW,EAAE;QACf,CAAC;MACH,EAAE,OAAOS,KAAK,EAAE;QACd,IAAI,CAACP,OAAM,GAAI;UACbC,IAAI,EAAE,OAAO;UACbC,IAAI,EACFK,KAAK,CAACF,QAAQ,EAAEnB,IAAI,EAAEc,OAAM,IAC5B;QACJ,CAAC;MACH,UAAU;QACR,IAAI,CAACD,YAAW,GAAI,KAAK;MAC3B;IACF;EACF;AACF,CAAC","names":["API","name","data","form","username","email","password","confirmPassword","role","permissions","createReports","editIncidents","deleteRecords","viewConfidentialData","acceptTerms","isSubmitting","message","type","text","methods","handleRegister","response","post","error"],"sourceRoot":"","sources":["D:\\joremiodotonline\\dashboard\\src\\views\\layouts\\auth\\Register.vue"],"sourcesContent":["<template>\n  <div class=\"min-h-screen bg-slate-950 text-white\">\n    <div class=\"grid min-h-screen lg:grid-cols-[0.95fr_1.05fr]\">\n      <section class=\"hidden lg:block\">\n        <div class=\"flex h-full flex-col justify-between bg-[linear-gradient(145deg,_#020617_0%,_#0f172a_35%,_#312e81_100%)] px-14 py-12\">\n          <button\n            type=\"button\"\n            class=\"flex items-center gap-3 text-left\"\n            @click=\"$router.push('/')\"\n          >\n            <span class=\"flex h-12 w-12 items-center justify-center rounded-2xl bg-white/10 ring-1 ring-white/15 backdrop-blur\">\n              <img\n                src=\"../../../assets/logo/logo_light.png\"\n                alt=\"Joremiodot logo\"\n                class=\"h-8 w-8 object-contain\"\n              />\n            </span>\n            <span>\n              <span class=\"block text-xs uppercase tracking-[0.35em] text-cyan-200/70\">\n                VANTA\n              </span>\n              <span class=\"block text-lg font-semibold\">Admin provisioning</span>\n            </span>\n          </button>\n\n          <div>\n            <p class=\"text-sm font-semibold uppercase tracking-[0.35em] text-cyan-200/70\">\n              Create secure access\n            </p>\n            <h1 class=\"mt-5 text-5xl font-semibold leading-tight\">\n              Add a new admin account for the dashboard.\n            </h1>\n            <p class=\"mt-6 max-w-lg text-base leading-7 text-slate-300\">\n              This form creates a saved user record in MongoDB with the <code>admin</code> role so the account is ready for future authentication wiring.\n            </p>\n          </div>\n\n          <div class=\"grid gap-4\">\n            <div class=\"rounded-3xl border border-white/10 bg-white/5 p-5 text-slate-300\">\n              Username and email are both checked for duplicates before save.\n            </div>\n            <div class=\"rounded-3xl border border-white/10 bg-white/5 p-5 text-slate-300\">\n              Passwords are hashed in the backend before the user document is stored.\n            </div>\n          </div>\n        </div>\n      </section>\n\n      <section class=\"flex items-center justify-center bg-slate-100 px-6 py-10 sm:px-10 lg:px-14\">\n        <div class=\"w-full max-w-2xl rounded-[2rem] border border-slate-200 bg-white p-8 shadow-2xl shadow-slate-900/10 sm:p-10\">\n          <div class=\"mb-8\">\n            <p class=\"text-sm font-semibold uppercase tracking-[0.3em] text-primary/80\">\n              Create account\n            </p>\n            <h2 class=\"mt-3 text-3xl font-semibold text-slate-900\">\n              New User\n            </h2>\n            <p class=\"mt-3 text-base leading-7 text-slate-500\">\n              Fill in the details below to save a new admin account.\n            </p>\n          </div>\n\n          <form class=\"space-y-6\" @submit.prevent=\"handleRegister\">\n            <div\n              v-if=\"message.text\"\n              :class=\"message.type === 'success' ? 'border-emerald-200 bg-emerald-50 text-emerald-700' : 'border-red-200 bg-red-50 text-red-600'\"\n              class=\"rounded-2xl border px-4 py-3 text-sm\"\n            >\n              {{ message.text }}\n            </div>\n\n            <div class=\"grid gap-6 sm:grid-cols-2\">\n              <div>\n                <label for=\"username\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                  Username\n                </label>\n                <input\n                  id=\"username\"\n                  v-model.trim=\"form.username\"\n                  type=\"text\"\n                  class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                  placeholder=\"admin.joremio\"\n                />\n              </div>\n\n              <div>\n                <label for=\"email\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                  Email address\n                </label>\n                <input\n                  id=\"email\"\n                  v-model.trim=\"form.email\"\n                  type=\"email\"\n                  class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                  placeholder=\"admin@agency.gov\"\n                />\n              </div>\n            </div>\n\n            <div class=\"grid gap-6 sm:grid-cols-2\">\n              <div>\n                <label for=\"password\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                  Password\n                </label>\n                <input\n                  id=\"password\"\n                  v-model=\"form.password\"\n                  type=\"password\"\n                  class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                  placeholder=\"Create a strong password\"\n                />\n              </div>\n\n              <div>\n                <label for=\"confirmPassword\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                  Confirm password\n                </label>\n                <input\n                  id=\"confirmPassword\"\n                  v-model=\"form.confirmPassword\"\n                  type=\"password\"\n                  class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                  placeholder=\"Re-enter password\"\n                />\n              </div>\n            </div>\n\n            <div class=\"rounded-2xl bg-slate-50 p-4\">\n              <div class=\"grid gap-6 sm:grid-cols-2\">\n                <div>\n                  <label for=\"role\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                    Role\n                  </label>\n                  <select\n                    id=\"role\"\n                    v-model=\"form.role\"\n                    class=\"w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-slate-900 outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10\"\n                  >\n                    <option value=\"admin\">Admin</option>\n                    <option value=\"officer\">Officer</option>\n                    <option value=\"viewer\">Viewer</option>\n                  </select>\n                </div>\n\n                <div>\n                  <p class=\"mb-2 text-sm font-medium text-slate-700\">Permissions</p>\n                  <div class=\"space-y-3 rounded-2xl border border-slate-200 bg-white p-4\">\n                    <label class=\"flex cursor-pointer items-start gap-3 text-sm text-slate-600\">\n                      <input\n                        v-model=\"form.permissions.createReports\"\n                        type=\"checkbox\"\n                        class=\"mt-1 h-4 w-4 rounded border-slate-300 text-primary focus:ring-primary/30\"\n                      />\n                      <span>Create reports</span>\n                    </label>\n                    <label class=\"flex cursor-pointer items-start gap-3 text-sm text-slate-600\">\n                      <input\n                        v-model=\"form.permissions.editIncidents\"\n                        type=\"checkbox\"\n                        class=\"mt-1 h-4 w-4 rounded border-slate-300 text-primary focus:ring-primary/30\"\n                      />\n                      <span>Edit incidents</span>\n                    </label>\n                    <label class=\"flex cursor-pointer items-start gap-3 text-sm text-slate-600\">\n                      <input\n                        v-model=\"form.permissions.deleteRecords\"\n                        type=\"checkbox\"\n                        class=\"mt-1 h-4 w-4 rounded border-slate-300 text-primary focus:ring-primary/30\"\n                      />\n                      <span>Delete records</span>\n                    </label>\n                    <label class=\"flex cursor-pointer items-start gap-3 text-sm text-slate-600\">\n                      <input\n                        v-model=\"form.permissions.viewConfidentialData\"\n                        type=\"checkbox\"\n                        class=\"mt-1 h-4 w-4 rounded border-slate-300 text-primary focus:ring-primary/30\"\n                      />\n                      <span>View confidential data</span>\n                    </label>\n                  </div>\n                </div>\n              </div>\n            </div>\n\n            <label class=\"flex cursor-pointer items-start gap-3 text-sm text-slate-600\">\n              <input\n                v-model=\"form.acceptTerms\"\n                type=\"checkbox\"\n                class=\"mt-1 h-4 w-4 rounded border-slate-300 text-primary focus:ring-primary/30\"\n              />\n              <span>I confirm this account should be created with the selected role and permissions.</span>\n            </label>\n\n            <button\n              type=\"submit\"\n              class=\"flex w-full items-center justify-center rounded-2xl bg-slate-950 px-4 py-3.5 text-sm font-semibold text-white transition hover:bg-slate-800 disabled:cursor-not-allowed disabled:bg-slate-400\"\n              :disabled=\"isSubmitting\"\n            >\n              {{ isSubmitting ? \"Saving user...\" : \"Save user\" }}\n            </button>\n\n            <p class=\"text-center text-sm text-slate-600\">\n              Already have an account?\n              <button\n                type=\"button\"\n                class=\"ml-2 font-medium text-primary\"\n                @click=\"$router.push('/auth/login')\"\n              >\n                Login here\n              </button>\n            </p>\n          </form>\n        </div>\n      </section>\n    </div>\n  </div>\n</template>\n\n<script>\n  import API from \"@/services/api\";\n\n  export default {\n    name: \"RegisterPage\",\n    data() {\n      return {\n        form: {\n          username: \"\",\n          email: \"\",\n          password: \"\",\n          confirmPassword: \"\",\n          role: \"admin\",\n          permissions: {\n            createReports: false,\n            editIncidents: false,\n            deleteRecords: false,\n            viewConfidentialData: false,\n          },\n          acceptTerms: false,\n        },\n        isSubmitting: false,\n        message: {\n          type: \"\",\n          text: \"\",\n        },\n      };\n    },\n    methods: {\n      async handleRegister() {\n        this.message = { type: \"\", text: \"\" };\n\n        if (!this.form.username || !this.form.email || !this.form.password) {\n          this.message = {\n            type: \"error\",\n            text: \"Username, email, and password are required.\",\n          };\n          return;\n        }\n\n        if (this.form.password !== this.form.confirmPassword) {\n          this.message = {\n            type: \"error\",\n            text: \"Password confirmation does not match.\",\n          };\n          return;\n        }\n\n        if (!this.form.acceptTerms) {\n          this.message = {\n            type: \"error\",\n            text: \"Confirm admin access before creating the user.\",\n            text: \"Confirm the selected role and permissions before creating the user.\",\n          };\n          return;\n        }\n\n        this.isSubmitting = true;\n\n        try {\n          const response = await API.post(\"/auth/register\", {\n            username: this.form.username,\n            email: this.form.email,\n            password: this.form.password,\n            role: this.form.role,\n            permissions: {\n              createReports: this.form.permissions.createReports,\n              editIncidents: this.form.permissions.editIncidents,\n              deleteRecords: this.form.permissions.deleteRecords,\n              viewConfidentialData: this.form.permissions.viewConfidentialData,\n            },\n          });\n\n          this.message = {\n            type: \"success\",\n            text: response.data.message || \"User created successfully.\",\n          };\n\n          this.form = {\n            username: \"\",\n            email: \"\",\n            password: \"\",\n            confirmPassword: \"\",\n            role: \"admin\",\n            permissions: {\n              createReports: false,\n              editIncidents: false,\n              deleteRecords: false,\n              viewConfidentialData: false,\n            },\n            acceptTerms: false,\n          };\n        } catch (error) {\n          this.message = {\n            type: \"error\",\n            text:\n              error.response?.data?.message ||\n              \"Unable to save the user right now.\",\n          };\n        } finally {\n          this.isSubmitting = false;\n        }\n      },\n    },\n  };\n</script>\n"]},"metadata":{},"sourceType":"module"}