{"ast":null,"code":"import { Icon } from \"@iconify/vue\";\nimport MenuAccordion from \"./MenuAccordion.vue\";\nexport default {\n  props: {\n    collapsed: {\n      type: Boolean,\n      default: false\n    }\n  },\n  emits: [\"sidebarToggle\", \"collapseToggle\"],\n  components: {\n    Icon,\n    MenuAccordion\n  }\n};","map":{"version":3,"mappings":"AA0HE,SAASA,IAAG,QAAS,cAAc;AACnC,OAAOC,aAAY,MAAO,qBAAqB;AAC/C,eAAe;EACbC,KAAK,EAAE;IACLC,SAAS,EAAE;MACTC,IAAI,EAAEC,OAAO;MACbC,OAAO,EAAE;IACX;EACF,CAAC;EACDC,KAAK,EAAE,CAAC,eAAe,EAAE,gBAAgB,CAAC;EAC1CC,UAAU,EAAE;IACVR,IAAI;IACJC;EACF;AACF,CAAC","names":["Icon","MenuAccordion","props","collapsed","type","Boolean","default","emits","components"],"sourceRoot":"","sources":["D:\\joremiodotonline\\dashboard\\src\\components\\Sidebar.vue"],"sourcesContent":["<template>\n  <nav class=\"sidebar bg-case-surface flex flex-col h-screen\">\n\n    <!-- Head -->\n    <div\n      class=\"sidebar-head border-b border-case-border flex-shrink-0 flex items-center transition-all duration-300\"\n      :class=\"collapsed ? 'p-3 justify-center' : 'p-4 justify-between'\"\n    >\n      <router-link to=\"/\" exact class=\"flex items-center min-w-0 overflow-hidden\">\n        <img class=\"w-8 flex-shrink-0\" src=\"@/assets/logo/logo.svg\" alt=\"logo\" />\n        <h2\n          v-show=\"!collapsed\"\n          class=\"text-2xl font-normal ml-3 text-white whitespace-nowrap\"\n          translate=\"no\"\n        >\n          VANTA<span class=\"text-primary\">.</span>\n        </h2>\n      </router-link>\n      <button\n        class=\"lg:hidden block text-gray-500 flex-shrink-0\"\n        @click=\"$emit('sidebarToggle')\"\n      >\n        <svg xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\" role=\"img\" width=\"25px\" height=\"25px\" preserveAspectRatio=\"xMidYMid meet\" viewBox=\"0 0 32 32\">\n          <path fill=\"currentColor\" d=\"M7.219 5.781L5.78 7.22L14.563 16L5.78 24.781l1.44 1.439L16 17.437l8.781 8.782l1.438-1.438L17.437 16l8.782-8.781L24.78 5.78L16 14.563z\" />\n        </svg>\n      </button>\n    </div>\n\n    <!-- Nav list -->\n    <div class=\"flex-1 overflow-hidden\" :class=\"collapsed ? 'p-2 mt-2' : 'p-4 mt-4'\">\n      <div class=\"pb-5\">\n        <p\n          v-show=\"!collapsed\"\n          class=\"text-xs font-semibold uppercase tracking-[0.2em] text-gray-600 mb-4\"\n        >\n          Menu\n        </p>\n        <div class=\"wrap-item\" :class=\"{ 'mt-4': !collapsed }\">\n\n          <!-- Dashboard -->\n          <div class=\"item\">\n            <router-link\n              to=\"/\"\n              exact\n              class=\"w-full flex rounded-md box-border p-3 hover:bg-case-elevated hover:text-gray-200 transition-colors text-gray-400\"\n              :class=\"collapsed ? 'justify-center' : 'items-center text-left'\"\n              :title=\"collapsed ? 'Dashboard' : ''\"\n            >\n              <span class=\"text-xl flex-shrink-0\" :class=\"{ 'mr-3': !collapsed }\">\n                <Icon icon=\"bxs:dashboard\" />\n              </span>\n              <span v-show=\"!collapsed\" class=\"w-full\">Dashboard</span>\n            </router-link>\n          </div>\n\n          <!-- Files -->\n          <div class=\"item mt-1\">\n            <router-link\n              to=\"/files\"\n              class=\"w-full flex rounded-md box-border p-3 hover:bg-case-elevated hover:text-gray-200 transition-colors text-gray-400\"\n              :class=\"collapsed ? 'justify-center' : 'items-center text-left'\"\n              :title=\"collapsed ? 'Files' : ''\"\n            >\n              <span class=\"text-xl flex-shrink-0\" :class=\"{ 'mr-3': !collapsed }\">\n                <Icon icon=\"mdi:file-document-multiple-outline\" />\n              </span>\n              <span v-show=\"!collapsed\" class=\"w-full\">Files</span>\n            </router-link>\n          </div>\n\n          <!-- Case accordion -->\n          <div class=\"item mt-1\">\n            <menu-accordion :collapsed=\"collapsed\">\n              <template v-slot:icon><Icon icon=\"gg:components\" /></template>\n              <template v-slot:title>Case</template>\n              <template v-slot:content>\n                <router-link to=\"/records/register\" class=\"w-full text-left block rounded-md p-3 hover:bg-case-elevated hover:text-gray-200 transition-colors\">Records</router-link>\n                <router-link to=\"/component/operation\" class=\"w-full text-left block rounded-md p-3 hover:bg-case-elevated hover:text-gray-200 transition-colors\">Operation</router-link>\n                <router-link to=\"/component/modal\" class=\"w-full text-left block rounded-md p-3 hover:bg-case-elevated hover:text-gray-200 transition-colors\">Reports</router-link>\n              </template>\n            </menu-accordion>\n          </div>\n\n          <!-- System accordion -->\n          <div class=\"item mt-1\">\n            <menu-accordion :collapsed=\"collapsed\">\n              <template v-slot:icon><Icon icon=\"ri:pages-fill\" /></template>\n              <template v-slot:title>System</template>\n              <template v-slot:content>\n                <router-link to=\"/system/settings/general\" class=\"w-full text-left block rounded-md p-3 hover:bg-case-elevated hover:text-gray-200 transition-colors\">General Settings</router-link>\n                <router-link to=\"/system/settings/security\" class=\"w-full text-left block rounded-md p-3 hover:bg-case-elevated hover:text-gray-200 transition-colors\">Security Settings</router-link>\n                <router-link to=\"/system/users/create\" class=\"w-full text-left block rounded-md p-3 hover:bg-case-elevated hover:text-gray-200 transition-colors\">Create Account</router-link>\n                <router-link to=\"/system/users/passwords\" class=\"w-full text-left block rounded-md p-3 hover:bg-case-elevated hover:text-gray-200 transition-colors\">Password Change</router-link>\n                <router-link to=\"/system/users/login-history\" class=\"w-full text-left block rounded-md p-3 hover:bg-case-elevated hover:text-gray-200 transition-colors\">Login History</router-link>\n              </template>\n            </menu-accordion>\n          </div>\n\n        </div>\n      </div>\n    </div>\n\n    <!-- Collapse toggle (desktop only) -->\n    <div class=\"border-t border-case-border flex-shrink-0 hidden lg:block\" :class=\"collapsed ? 'p-2' : 'p-3'\">\n      <button\n        @click=\"$emit('collapseToggle')\"\n        class=\"w-full flex items-center rounded-md p-2 text-gray-500 hover:bg-case-elevated hover:text-gray-300 transition-colors\"\n        :class=\"collapsed ? 'justify-center' : ''\"\n        :title=\"collapsed ? 'Expand sidebar' : ''\"\n      >\n        <Icon\n          :icon=\"collapsed ? 'ic:outline-keyboard-double-arrow-right' : 'ic:outline-keyboard-double-arrow-left'\"\n          class=\"text-xl flex-shrink-0\"\n        />\n        <span v-show=\"!collapsed\" class=\"ml-2 text-xs\">Minimize</span>\n      </button>\n    </div>\n\n  </nav>\n</template>\n\n<script>\n  import { Icon } from \"@iconify/vue\";\n  import MenuAccordion from \"./MenuAccordion.vue\";\n  export default {\n    props: {\n      collapsed: {\n        type: Boolean,\n        default: false,\n      },\n    },\n    emits: [\"sidebarToggle\", \"collapseToggle\"],\n    components: {\n      Icon,\n      MenuAccordion,\n    },\n  };\n</script>\n\n<style scoped>\n.router-link-active {\n  background-color: rgba(217, 119, 6, 0.12);\n  color: #D97706;\n  border-radius: 0.375rem;\n}\n</style>\n"]},"metadata":{},"sourceType":"module"}