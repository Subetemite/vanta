{"ast":null,"code":"import API from \"@/services/api\";\nexport default {\n  name: \"RegisterPage\",\n  data() {\n    return {\n      isSubmitting: false,\n      message: {\n        type: \"\",\n        text: \"\"\n      },\n      form: {\n        username: \"\",\n        email: \"\",\n        password: \"\",\n        confirmPassword: \"\",\n        role: \"officer\",\n        permissions: {\n          createReports: false,\n          editIncidents: false,\n          deleteRecords: false,\n          viewConfidentialData: false\n        },\n        acceptTerms: false\n      }\n    };\n  },\n  methods: {\n    async handleRegister() {\n      this.message = {\n        type: \"\",\n        text: \"\"\n      };\n      if (!this.form.username || !this.form.email || !this.form.password) {\n        this.message = {\n          type: \"error\",\n          text: \"Username, email, and password are required.\"\n        };\n        return;\n      }\n      if (this.form.password !== this.form.confirmPassword) {\n        this.message = {\n          type: \"error\",\n          text: \"Password confirmation does not match.\"\n        };\n        return;\n      }\n      if (!this.form.acceptTerms) {\n        this.message = {\n          type: \"error\",\n          text: \"Confirm the selected role and permissions before creating the user.\"\n        };\n        return;\n      }\n      this.isSubmitting = true;\n      try {\n        const response = await API.post(\"/auth/register\", {\n          username: this.form.username,\n          email: this.form.email,\n          password: this.form.password,\n          role: this.form.role,\n          permissions: {\n            ...this.form.permissions\n          }\n        });\n        this.message = {\n          type: \"success\",\n          text: response.data.message || \"User created successfully.\"\n        };\n        this.form = {\n          username: \"\",\n          email: \"\",\n          password: \"\",\n          confirmPassword: \"\",\n          role: \"officer\",\n          permissions: {\n            createReports: false,\n            editIncidents: false,\n            deleteRecords: false,\n            viewConfidentialData: false\n          },\n          acceptTerms: false\n        };\n      } catch (error) {\n        this.message = {\n          type: \"error\",\n          text: error.response?.data?.message || \"Unable to save the user right now.\"\n        };\n      } finally {\n        this.isSubmitting = false;\n      }\n    }\n  }\n};","map":{"version":3,"mappings":"AAyIE,OAAOA,GAAE,MAAO,gBAAgB;AAEhC,eAAe;EACbC,IAAI,EAAE,cAAc;EACpBC,IAAIA,GAAG;IACL,OAAO;MACLC,YAAY,EAAE,KAAK;MACnBC,OAAO,EAAE;QAAEC,IAAI,EAAE,EAAE;QAAEC,IAAI,EAAE;MAAG,CAAC;MAC/BC,IAAI,EAAE;QACJC,QAAQ,EAAQ,EAAE;QAClBC,KAAK,EAAW,EAAE;QAClBC,QAAQ,EAAQ,EAAE;QAClBC,eAAe,EAAE,EAAE;QACnBC,IAAI,EAAY,SAAS;QACzBC,WAAW,EAAE;UACXC,aAAa,EAAQ,KAAK;UAC1BC,aAAa,EAAS,KAAK;UAC3BC,aAAa,EAAS,KAAK;UAC3BC,oBAAoB,EAAE;QACxB,CAAC;QACDC,WAAW,EAAE;MACf;IACF,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACP,MAAMC,cAAcA,GAAG;MACrB,IAAI,CAAChB,OAAM,GAAI;QAAEC,IAAI,EAAE,EAAE;QAAEC,IAAI,EAAE;MAAG,CAAC;MAErC,IAAI,CAAC,IAAI,CAACC,IAAI,CAACC,QAAO,IAAK,CAAC,IAAI,CAACD,IAAI,CAACE,KAAI,IAAK,CAAC,IAAI,CAACF,IAAI,CAACG,QAAQ,EAAE;QAClE,IAAI,CAACN,OAAM,GAAI;UAAEC,IAAI,EAAE,OAAO;UAAEC,IAAI,EAAE;QAA8C,CAAC;QACrF;MACF;MACA,IAAI,IAAI,CAACC,IAAI,CAACG,QAAO,KAAM,IAAI,CAACH,IAAI,CAACI,eAAe,EAAE;QACpD,IAAI,CAACP,OAAM,GAAI;UAAEC,IAAI,EAAE,OAAO;UAAEC,IAAI,EAAE;QAAwC,CAAC;QAC/E;MACF;MACA,IAAI,CAAC,IAAI,CAACC,IAAI,CAACW,WAAW,EAAE;QAC1B,IAAI,CAACd,OAAM,GAAI;UAAEC,IAAI,EAAE,OAAO;UAAEC,IAAI,EAAE;QAAsE,CAAC;QAC7G;MACF;MAEA,IAAI,CAACH,YAAW,GAAI,IAAI;MACxB,IAAI;QACF,MAAMkB,QAAO,GAAI,MAAMrB,GAAG,CAACsB,IAAI,CAAC,gBAAgB,EAAE;UAChDd,QAAQ,EAAK,IAAI,CAACD,IAAI,CAACC,QAAQ;UAC/BC,KAAK,EAAQ,IAAI,CAACF,IAAI,CAACE,KAAK;UAC5BC,QAAQ,EAAK,IAAI,CAACH,IAAI,CAACG,QAAQ;UAC/BE,IAAI,EAAS,IAAI,CAACL,IAAI,CAACK,IAAI;UAC3BC,WAAW,EAAE;YAAE,GAAG,IAAI,CAACN,IAAI,CAACM;UAAY;QAC1C,CAAC,CAAC;QACF,IAAI,CAACT,OAAM,GAAI;UAAEC,IAAI,EAAE,SAAS;UAAEC,IAAI,EAAEe,QAAQ,CAACnB,IAAI,CAACE,OAAM,IAAK;QAA6B,CAAC;QAC/F,IAAI,CAACG,IAAG,GAAI;UACVC,QAAQ,EAAE,EAAE;UAAEC,KAAK,EAAE,EAAE;UAAEC,QAAQ,EAAE,EAAE;UAAEC,eAAe,EAAE,EAAE;UAC1DC,IAAI,EAAE,SAAS;UACfC,WAAW,EAAE;YAAEC,aAAa,EAAE,KAAK;YAAEC,aAAa,EAAE,KAAK;YAAEC,aAAa,EAAE,KAAK;YAAEC,oBAAoB,EAAE;UAAM,CAAC;UAC9GC,WAAW,EAAE;QACf,CAAC;MACH,EAAE,OAAOK,KAAK,EAAE;QACd,IAAI,CAACnB,OAAM,GAAI;UACbC,IAAI,EAAE,OAAO;UACbC,IAAI,EAAEiB,KAAK,CAACF,QAAQ,EAAEnB,IAAI,EAAEE,OAAM,IAAK;QACzC,CAAC;MACH,UAAU;QACR,IAAI,CAACD,YAAW,GAAI,KAAK;MAC3B;IACF;EACF;AACF,CAAC","names":["API","name","data","isSubmitting","message","type","text","form","username","email","password","confirmPassword","role","permissions","createReports","editIncidents","deleteRecords","viewConfidentialData","acceptTerms","methods","handleRegister","response","post","error"],"sourceRoot":"","sources":["D:\\joremiodotonline\\dashboard\\src\\views\\layouts\\auth\\Register.vue"],"sourcesContent":["<template>\n  <div class=\"min-h-screen bg-case-bg p-6 sm:p-8\">\n    <div class=\"mx-auto max-w-2xl space-y-6\">\n\n      <div class=\"border-b border-case-border pb-5\">\n        <p class=\"text-xs font-semibold uppercase tracking-[0.3em] text-primary\">System / User &amp; Account</p>\n        <h1 class=\"mt-2 text-2xl font-semibold text-white\">Create Account</h1>\n        <p class=\"mt-1 text-sm text-gray-500\">Provision a new user with a role and access permissions.</p>\n      </div>\n\n      <div\n        v-if=\"message.text\"\n        :class=\"message.type === 'success' ? 'border-emerald-800/50 bg-emerald-950/30 text-emerald-400' : 'border-red-900/50 bg-red-950/30 text-red-400'\"\n        class=\"rounded-xl border px-4 py-3 text-sm\"\n      >\n        {{ message.text }}\n      </div>\n\n      <form @submit.prevent=\"handleRegister\" class=\"space-y-6\">\n\n        <section class=\"rounded-xl border border-case-border bg-case-surface p-6\">\n          <h2 class=\"mb-5 text-xs font-semibold uppercase tracking-[0.2em] text-gray-500\">Credentials</h2>\n          <div class=\"grid gap-4 sm:grid-cols-2\">\n            <div>\n              <label for=\"username\" class=\"mb-2 block text-sm font-medium text-gray-400\">Username</label>\n              <input\n                id=\"username\"\n                v-model.trim=\"form.username\"\n                type=\"text\"\n                class=\"w-full rounded-xl border border-case-border bg-case-card px-4 py-3 text-gray-200 outline-none transition placeholder:text-gray-600 focus:border-primary focus:ring-4 focus:ring-primary/10\"\n                placeholder=\"agent.name\"\n              />\n            </div>\n            <div>\n              <label for=\"email\" class=\"mb-2 block text-sm font-medium text-gray-400\">Email address</label>\n              <input\n                id=\"email\"\n                v-model.trim=\"form.email\"\n                type=\"email\"\n                class=\"w-full rounded-xl border border-case-border bg-case-card px-4 py-3 text-gray-200 outline-none transition placeholder:text-gray-600 focus:border-primary focus:ring-4 focus:ring-primary/10\"\n                placeholder=\"agent@agency.gov\"\n              />\n            </div>\n            <div>\n              <label for=\"password\" class=\"mb-2 block text-sm font-medium text-gray-400\">Password</label>\n              <input\n                id=\"password\"\n                v-model=\"form.password\"\n                type=\"password\"\n                class=\"w-full rounded-xl border border-case-border bg-case-card px-4 py-3 text-gray-200 outline-none transition placeholder:text-gray-600 focus:border-primary focus:ring-4 focus:ring-primary/10\"\n                placeholder=\"Create a strong password\"\n              />\n            </div>\n            <div>\n              <label for=\"confirmPassword\" class=\"mb-2 block text-sm font-medium text-gray-400\">Confirm password</label>\n              <input\n                id=\"confirmPassword\"\n                v-model=\"form.confirmPassword\"\n                type=\"password\"\n                class=\"w-full rounded-xl border border-case-border bg-case-card px-4 py-3 text-gray-200 outline-none transition placeholder:text-gray-600 focus:border-primary focus:ring-4 focus:ring-primary/10\"\n                placeholder=\"Re-enter password\"\n              />\n            </div>\n          </div>\n        </section>\n\n        <section class=\"rounded-xl border border-case-border bg-case-surface p-6\">\n          <h2 class=\"mb-5 text-xs font-semibold uppercase tracking-[0.2em] text-gray-500\">Role &amp; Permissions</h2>\n          <div class=\"grid gap-4 sm:grid-cols-2\">\n            <div>\n              <label for=\"role\" class=\"mb-2 block text-sm font-medium text-gray-400\">Role</label>\n              <select\n                id=\"role\"\n                v-model=\"form.role\"\n                class=\"w-full rounded-xl border border-case-border bg-case-card px-4 py-3 text-gray-200 outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10 appearance-none cursor-pointer\"\n              >\n                <option value=\"admin\">Admin</option>\n                <option value=\"officer\">Officer</option>\n                <option value=\"viewer\">Viewer</option>\n              </select>\n            </div>\n            <div>\n              <p class=\"mb-2 text-sm font-medium text-gray-400\">Permissions</p>\n              <div class=\"space-y-2.5 rounded-xl border border-case-border bg-case-card p-4\">\n                <label class=\"flex cursor-pointer items-start gap-3 text-sm text-gray-400\">\n                  <input v-model=\"form.permissions.createReports\"       type=\"checkbox\" class=\"mt-1 h-4 w-4 rounded border-case-border bg-case-elevated text-primary focus:ring-primary/30\" />\n                  <span>Create reports</span>\n                </label>\n                <label class=\"flex cursor-pointer items-start gap-3 text-sm text-gray-400\">\n                  <input v-model=\"form.permissions.editIncidents\"        type=\"checkbox\" class=\"mt-1 h-4 w-4 rounded border-case-border bg-case-elevated text-primary focus:ring-primary/30\" />\n                  <span>Edit incidents</span>\n                </label>\n                <label class=\"flex cursor-pointer items-start gap-3 text-sm text-gray-400\">\n                  <input v-model=\"form.permissions.deleteRecords\"        type=\"checkbox\" class=\"mt-1 h-4 w-4 rounded border-case-border bg-case-elevated text-primary focus:ring-primary/30\" />\n                  <span>Delete records</span>\n                </label>\n                <label class=\"flex cursor-pointer items-start gap-3 text-sm text-gray-400\">\n                  <input v-model=\"form.permissions.viewConfidentialData\" type=\"checkbox\" class=\"mt-1 h-4 w-4 rounded border-case-border bg-case-elevated text-primary focus:ring-primary/30\" />\n                  <span>View confidential data</span>\n                </label>\n              </div>\n            </div>\n          </div>\n        </section>\n\n        <label class=\"flex cursor-pointer items-start gap-3 text-sm text-gray-500\">\n          <input\n            v-model=\"form.acceptTerms\"\n            type=\"checkbox\"\n            class=\"mt-1 h-4 w-4 rounded border-case-border bg-case-card text-primary focus:ring-primary/30\"\n          />\n          <span>I confirm this account should be created with the selected role and permissions.</span>\n        </label>\n\n        <div class=\"flex items-center justify-end gap-3\">\n          <button\n            type=\"button\"\n            @click=\"$router.back()\"\n            class=\"rounded-xl border border-case-border px-4 py-2.5 text-sm font-medium text-gray-400 transition hover:bg-case-elevated hover:text-gray-200\"\n          >\n            Cancel\n          </button>\n          <button\n            type=\"submit\"\n            :disabled=\"isSubmitting\"\n            class=\"rounded-xl bg-primary px-5 py-2.5 text-sm font-semibold text-black transition hover:bg-amber-500 disabled:cursor-not-allowed disabled:opacity-50\"\n          >\n            {{ isSubmitting ? \"Saving...\" : \"Create user\" }}\n          </button>\n        </div>\n\n      </form>\n    </div>\n  </div>\n</template>\n\n<script>\n  import API from \"@/services/api\";\n\n  export default {\n    name: \"RegisterPage\",\n    data() {\n      return {\n        isSubmitting: false,\n        message: { type: \"\", text: \"\" },\n        form: {\n          username:       \"\",\n          email:          \"\",\n          password:       \"\",\n          confirmPassword: \"\",\n          role:           \"officer\",\n          permissions: {\n            createReports:       false,\n            editIncidents:        false,\n            deleteRecords:        false,\n            viewConfidentialData: false,\n          },\n          acceptTerms: false,\n        },\n      };\n    },\n    methods: {\n      async handleRegister() {\n        this.message = { type: \"\", text: \"\" };\n\n        if (!this.form.username || !this.form.email || !this.form.password) {\n          this.message = { type: \"error\", text: \"Username, email, and password are required.\" };\n          return;\n        }\n        if (this.form.password !== this.form.confirmPassword) {\n          this.message = { type: \"error\", text: \"Password confirmation does not match.\" };\n          return;\n        }\n        if (!this.form.acceptTerms) {\n          this.message = { type: \"error\", text: \"Confirm the selected role and permissions before creating the user.\" };\n          return;\n        }\n\n        this.isSubmitting = true;\n        try {\n          const response = await API.post(\"/auth/register\", {\n            username:    this.form.username,\n            email:       this.form.email,\n            password:    this.form.password,\n            role:        this.form.role,\n            permissions: { ...this.form.permissions },\n          });\n          this.message = { type: \"success\", text: response.data.message || \"User created successfully.\" };\n          this.form = {\n            username: \"\", email: \"\", password: \"\", confirmPassword: \"\",\n            role: \"officer\",\n            permissions: { createReports: false, editIncidents: false, deleteRecords: false, viewConfidentialData: false },\n            acceptTerms: false,\n          };\n        } catch (error) {\n          this.message = {\n            type: \"error\",\n            text: error.response?.data?.message || \"Unable to save the user right now.\",\n          };\n        } finally {\n          this.isSubmitting = false;\n        }\n      },\n    },\n  };\n</script>\n"]},"metadata":{},"sourceType":"module"}