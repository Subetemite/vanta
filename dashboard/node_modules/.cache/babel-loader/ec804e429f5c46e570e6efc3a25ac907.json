K,cAAa,GAAIL,OAAO;IAC/B,CAAC;IACDoB,iBAAiBA,CAACJ,IAAI,EAAE;MACtB,OAAO,IAAIK,OAAO,CAAC,CAACC,OAAO,EAAEC,MAAM,KAAK;QACtC,MAAMC,MAAK,GAAI,IAAIC,UAAU,CAAC,CAAC;QAC/BD,MAAM,CAACE,MAAK,GAAI,MAAMJ,OAAO,CAACE,MAAM,CAACG,MAAM,CAAC;QAC5CH,MAAM,CAACI,OAAM,GAAI,MACfL,MAAM,CAAC,IAAIM,KAAK,CAAC,mCAAmC,CAAC,CAAC;QACxDL,MAAM,CAACM,aAAa,CAACd,IAAI,CAAC;MAC5B,CAAC,CAAC;IACJ,CAAC;IACD,MAAMe,YAAYA,GAAG;MACnB,IAAI,CAACzB,OAAM,GAAI;QAAEC,IAAI,EAAE,EAAE;QAAEC,IAAI,EAAE;MAAG,CAAC;MAErC,IACE,CAAC,IAAI,CAACL,IAAI,CAACrC,mBAAmB,CAACC,SAAQ,IACvC,CAAC,IAAI,CAACoC,IAAI,CAACrC,mBAAmB,CAACI,QAAO,IACtC,CAAC,IAAI,CAACiC,IAAI,CAACrC,mBAAmB,CAACK,GAAE,IACjC,CAAC,IAAI,CAACgC,IAAI,CAACrC,mBAAmB,CAACO,SAAQ,EACvC;QACA,IAAI,CAACiC,OAAM,GAAI;UACbC,IAAI,EAAE,OAAO;UACbC,IAAI,EAAE;QACR,CAAC;QACD;MACF;MAEA,IAAI,CAACJ,YAAW,GAAI,IAAI;MAExB,IAAI;QACF,MAAM4B,QAAO,GAAI,MAAMpE,GAAG,CAACqE,IAAI,CAAC,UAAU,EAAE,IAAI,CAAC9B,IAAI,CAAC;QAEtD,IAAI,CAACG,OAAM,GAAI;UACbC,IAAI,EAAE,SAAS;UACfC,IAAI,EACFwB,QAAQ,CAAC9B,IAAI,CAACI,OAAM,IAAK;QAC7B,CAAC;QAED,IAAI,CAACH,IAAG,GAAItC,iBAAiB,CAAC,CAAC;QAC/B,IAAI,CAACwC,cAAa,GAAI,EAAE;MAC1B,EAAE,OAAO6B,KAAK,EAAE;QACd,IAAI,CAAC5B,OAAM,GAAI;UACbC,IAAI,EAAE,OAAO;UACbC,IAAI,EACF0B,KAAK,CAACF,QAAQ,EAAE9B,IAAI,EAAEI,OAAM,IAC5B;QACJ,CAAC;MACH,UAAU;QACR,IAAI,CAACF,YAAW,GAAI,KAAK;MAC3B;IACF;EACF;AACF,CAAC","names":["API","createInitialForm","personalInformation","firstName","middleName","alias","lastName","sex","civilStatus","birthDate","contactNumber","emailAddress","nationality","country","address","operationDetails","operationName","operationAddress","operationDate","disposition","visaStatus","remarks","actions","biometrics","heightCm","weightKg","bloodType","eyeColor","hairColor","complexion","distinguishingMarks","fingerprintCode","profilePhoto","fileName","mimeType","size","dataUrl","name","data","form","isSubmitting","profilePreview","message","type","text","computed","profileSummary","sizeInKb","toFixed","methods","handleProfileUpload","event","file","target","files","value","readFileAsDataUrl","Promise","resolve","reject","reader","FileReader","onload","result","onerror","Error","readAsDataURL","handleSubmit","response","post","error"],"sourceRoot":"","sources":["D:\\joremiodotonline\\dashboard\\src\\views\\records\\RegisterRecord.vue"],"sourcesContent":["<template>\n  <div class=\"min-h-screen bg-slate-100 px-4 py-8 text-slate-900 sm:px-6 lg:px-10\">\n    <div class=\"mx-auto max-w-6xl\">\n      <div class=\"overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-2xl shadow-slate-900/5\">\n        <div class=\"grid lg:grid-cols-[0.9fr_1.1fr]\">\n          <section class=\"bg-[linear-gradient(160deg,_#0f172a_0%,_#1d4ed8_45%,_#38bdf8_100%)] px-8 py-10 text-white sm:px-10 lg:px-12\">\n            <p class=\"text-sm font-semibold uppercase tracking-[0.35em] text-cyan-100/80\">\n              Records\n            </p>\n            <h1 class=\"mt-4 text-4xl font-semibold leading-tight\">\n              -\n            </h1>\n              \n            <div class=\"mt-10 grid gap-4\">\n              <div class=\"rounded-3xl border border-white/15 bg-white/10 p-5 backdrop-blur\">\n                Personal information is grouped for easier retrieval and future reporting.\n              </div>\n              <div class=\"rounded-3xl border border-white/15 bg-white/10 p-5 backdrop-blur\">\n                Biometrics and profile uploads are stored with the same record for a complete registration entry.\n              </div>\n            </div>\n\n            <div v-if=\"profilePreview\" class=\"mt-10\">\n              <p class=\"text-xs font-semibold uppercase tracking-[0.25em] text-cyan-100/80\">\n                Profile preview\n              </p>\n              <div class=\"mt-4 flex items-center gap-4 rounded-3xl border border-white/15 bg-slate-950/20 p-4\">\n                <img\n                  :src=\"profilePreview\"\n                  alt=\"Profile preview\"\n                  class=\"h-24 w-24 rounded-2xl object-cover ring-2 ring-white/20\"\n                />\n                <div class=\"text-sm text-sky-50/90\">\n                  <p class=\"font-medium\">{{ form.profilePhoto.fileName || \"Selected image\" }}</p>\n                  <p class=\"mt-1 text-sky-100/75\">\n                    {{ profileSummary }}\n                  </p>\n                </div>\n              </div>\n            </div>\n          </section>\n\n          <section class=\"px-6 py-8 sm:px-8 lg:px-10\">\n            <div class=\"mb-8\">\n              <p class=\"text-sm font-semibold uppercase tracking-[0.3em] text-primary/80\">\n                INFORMATION ENTRY\n              </p>\n              \n            </div>\n\n            <form class=\"space-y-8\" @submit.prevent=\"handleSubmit\">\n              <div\n                v-if=\"message.text\"\n                :class=\"message.type === 'success' ? 'border-emerald-200 bg-emerald-50 text-emerald-700' : 'border-red-200 bg-red-50 text-red-700'\"\n                class=\"rounded-2xl border px-4 py-3 text-sm\"\n              >\n                {{ message.text }}\n              </div>\n\n              <div>\n                <div class=\"mb-4 flex items-center justify-between gap-4\">\n                  <h3 class=\"text-lg font-semibold text-slate-900\">Personal Information</h3>\n                  <span class=\"rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500\">\n                    Required\n                  </span>\n                </div>\n\n                <div class=\"grid gap-5 sm:grid-cols-2\">\n                  <div>\n                    <label for=\"firstName\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                      First name\n                    </label>\n                    <input\n                      id=\"firstName\"\n                      v-model.trim=\"form.personalInformation.firstName\"\n                      type=\"text\"\n                      class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                      placeholder=\"Juan\"\n                    />\n                  </div>\n\n                  <div>\n                    <label for=\"middleName\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                      Middle name\n                    </label>\n                    <input\n                      id=\"middleName\"\n                      v-model.trim=\"form.personalInformation.middleName\"\n                      type=\"text\"\n                      class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                      placeholder=\"Santos\"\n                    />\n                  </div>\n\n                  <div>\n                    <label for=\"alias\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                      Alias\n                    </label>\n                    <input\n                      id=\"alias\"\n                      v-model.trim=\"form.personalInformation.alias\"\n                      type=\"text\"\n                      class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                      placeholder=\"Jun\"\n                    />\n                  </div>\n\n                  <div>\n                    <label for=\"lastName\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                      Last name\n                    </label>\n                    <input\n                      id=\"lastName\"\n                      v-model.trim=\"form.personalInformation.lastName\"\n                      type=\"text\"\n                      class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                      placeholder=\"Dela Cruz\"\n                    />\n                  </div>\n\n                  <div>\n                    <label for=\"birthDate\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                      Birth date\n                    </label>\n                    <input\n                      id=\"birthDate\"\n                      v-model=\"form.personalInformation.birthDate\"\n                      type=\"date\"\n                      class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                    />\n                  </div>\n\n                  <div>\n                    <label for=\"sex\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                      Sex\n                    </label>\n                    <select\n                      id=\"sex\"\n                      v-model=\"form.personalInformation.sex\"\n                      class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                    >\n                      <option disabled value=\"\">Select sex</option>\n                      <option>Male</option>\n                      <option>Female</option>\n                    </select>\n                  </div>\n\n                  <div>\n                    <label for=\"civilStatus\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                      Civil status\n                    </label>\n                    <select\n                      id=\"civilStatus\"\n                      v-model=\"form.personalInformation.civilStatus\"\n                      class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                    >\n                      <option disabled value=\"\">Select civil status</option>\n                      <option>Single</option>\n                      <option>Married</option>\n                      <option>Widowed</option>\n                      <option>Separated</option>\n                    </select>\n                  </div>\n\n                  <div>\n                    <label for=\"contactNumber\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                      Contact number\n                    </label>\n                    <input\n                      id=\"contactNumber\"\n                      v-model.trim=\"form.personalInformation.contactNumber\"\n                      type=\"text\"\n                      class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                      placeholder=\"09171234567\"\n                    />\n                  </div>\n\n                  <div>\n                    <label for=\"emailAddress\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                      Email address\n                    </label>\n                    <input\n                      id=\"emailAddress\"\n                      v-model.trim=\"form.personalInformation.emailAddress\"\n                      type=\"email\"\n                      class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                      placeholder=\"juan@example.com\"\n                    />\n                  </div>\n\n                  <div>\n                    <label for=\"nationality\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                      Nationality\n                    </label>\n                    <input\n                      id=\"nationality\"\n                      v-model.trim=\"form.personalInformation.nationality\"\n                      type=\"text\"\n                      class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                      placeholder=\"Filipino\"\n                    />\n                  </div>\n\n                  <div>\n                    <label for=\"country\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                      Country\n                    </label>\n                    <input\n                      id=\"country\"\n                      v-model.trim=\"form.personalInformation.country\"\n                      type=\"text\"\n                      class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                      placeholder=\"Philippines\"\n                    />\n                  </div>\n\n                  <div class=\"sm:col-span-2\">\n                    <label for=\"address\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                      Address\n                    </label>\n                    <textarea\n                      id=\"address\"\n                      v-model.trim=\"form.personalInformation.address\"\n                      rows=\"3\"\n                      class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                      placeholder=\"House no., street, barangay, municipality\"\n                    />\n                  </div>\n                </div>\n              </div>\n\n              <div>\n                <div class=\"mb-4 flex items-center justify-between gap-4\">\n                  <h3 class=\"text-lg font-semibold text-slate-900\">Operation Details</h3>\n                  <span class=\"rounded-full bg-indigo-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-indigo-700\">\n                    Additional\n                  </span>\n                </div>\n\n                <div class=\"grid gap-5 sm:grid-cols-2\">\n                  <div>\n                    <label for=\"operationName\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                      Operation name\n                    </label>\n                    <input\n                      id=\"operationName\"\n                      v-model.trim=\"form.operationDetails.operationName\"\n                      type=\"text\"\n                      class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                      placeholder=\"Operation Sunrise\"\n                    />\n                  </div>\n\n                  <div>\n                    <label for=\"operationDate\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                      Operation date\n                    </label>\n                    <input\n                      id=\"operationDate\"\n                      v-model=\"form.operationDetails.operationDate\"\n                      type=\"date\"\n                      class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                    />\n                  </div>\n\n                  <div class=\"sm:col-span-2\">\n                    <label for=\"operationAddress\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                      Operation address\n                    </label>\n                    <textarea\n                      id=\"operationAddress\"\n                      v-model.trim=\"form.operationDetails.operationAddress\"\n                      rows=\"3\"\n                      class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                      placeholder=\"Street, barangay, municipality, province\"\n                    />\n                  </div>\n\n                  <div>\n                    <label for=\"disposition\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                      Disposition\n                    </label>\n                    <input\n                      id=\"disposition\"\n                      v-model.trim=\"form.operationDetails.disposition\"\n                      type=\"text\"\n                      class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                      placeholder=\"For processing\"\n                    />\n                  </div>\n\n                  <div>\n                    <label for=\"visaStatus\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                      Visa status\n                    </label>\n                    <input\n                      id=\"visaStatus\"\n                      v-model.trim=\"form.operationDetails.visaStatus\"\n                      type=\"text\"\n                      class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                      placeholder=\"Valid\"\n                    />\n                  </div>\n\n                  <div class=\"sm:col-span-2\">\n                    <label for=\"remarks\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                      Remarks\n                    </label>\n                    <textarea\n                      id=\"remarks\"\n                      v-model.trim=\"form.operationDetails.remarks\"\n                      rows=\"3\"\n                      class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                      placeholder=\"Additional notes about the operation or person\"\n                    />\n                  </div>\n\n                  <div class=\"sm:col-span-2\">\n                    <label for=\"actions\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                      Actions\n                    </label>\n                    <textarea\n                      id=\"actions\"\n                      v-model.trim=\"form.operationDetails.actions\"\n                      rows=\"3\"\n                      class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                      placeholder=\"Documented actions taken\"\n                    />\n                  </div>\n                </div>\n              </div>\n\n              <div>\n                <div class=\"mb-4 flex items-center justify-between gap-4\">\n                  <h3 class=\"text-lg font-semibold text-slate-900\">Biometrics</h3>\n                  <span class=\"rounded-full bg-sky-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-sky-700\">\n                    Optional\n                  </span>\n                </div>\n\n                <div class=\"grid gap-5 sm:grid-cols-2\">\n                  <div>\n                    <label for=\"heightCm\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                      Height (cm)\n                    </label>\n                    <input\n                      id=\"heightCm\"\n                      v-model=\"form.biometrics.heightCm\"\n                      type=\"number\"\n                      min=\"0\"\n                      step=\"0.01\"\n                      class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                      placeholder=\"165\"\n                    />\n                  </div>\n\n                  <div>\n                    <label for=\"weightKg\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                      Weight (kg)\n                    </label>\n                    <input\n                      id=\"weightKg\"\n                      v-model=\"form.biometrics.weightKg\"\n                      type=\"number\"\n                      min=\"0\"\n                      step=\"0.01\"\n                      class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                      placeholder=\"60\"\n                    />\n                  </div>\n\n                  <div>\n                    <label for=\"bloodType\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                      Blood type\n                    </label>\n                    <input\n                      id=\"bloodType\"\n                      v-model.trim=\"form.biometrics.bloodType\"\n                      type=\"text\"\n                      class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                      placeholder=\"O+\"\n                    />\n                  </div>\n\n                  <div>\n                    <label for=\"fingerprintCode\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                      Fingerprint code\n                    </label>\n                    <input\n                      id=\"fingerprintCode\"\n                      v-model.trim=\"form.biometrics.fingerprintCode\"\n                      type=\"text\"\n                      class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                      placeholder=\"FP-2026-0001\"\n                    />\n                  </div>\n\n                  <div>\n                    <label for=\"eyeColor\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                      Eye color\n                    </label>\n                    <input\n                      id=\"eyeColor\"\n                      v-model.trim=\"form.biometrics.eyeColor\"\n                      type=\"text\"\n                      class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                      placeholder=\"Brown\"\n                    />\n                  </div>\n\n                  <div>\n                    <label for=\"hairColor\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                      Hair color\n                    </label>\n                    <input\n                      id=\"hairColor\"\n                      v-model.trim=\"form.biometrics.hairColor\"\n                      type=\"text\"\n                      class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                      placeholder=\"Black\"\n                    />\n                  </div>\n\n                  <div>\n                    <label for=\"complexion\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                      Complexion\n                    </label>\n                    <input\n                      id=\"complexion\"\n                      v-model.trim=\"form.biometrics.complexion\"\n                      type=\"text\"\n                      class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                      placeholder=\"Fair\"\n                    />\n                  </div>\n\n                  <div class=\"sm:col-span-2\">\n                    <label for=\"distinguishingMarks\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                      Distinguishing marks\n                    </label>\n                    <textarea\n                      id=\"distinguishingMarks\"\n                      v-model.trim=\"form.biometrics.distinguishingMarks\"\n                      rows=\"3\"\n                      class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                      placeholder=\"Birthmark on left cheek, scar on right hand\"\n                    />\n                  </div>\n                </div>\n              </div>\n\n              <div>\n                <div class=\"mb-4 flex items-center justify-between gap-4\">\n                  <h3 class=\"text-lg font-semibold text-slate-900\">Profile Upload</h3>\n                  <span class=\"rounded-full bg-amber-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-amber-700\">\n                    Image\n                  </span>\n                </div>\n\n                <div class=\"rounded-3xl border border-dashed border-slate-300 bg-slate-50 p-5\">\n                  <label for=\"profilePhoto\" class=\"block text-sm font-medium text-slate-700\">\n                    Upload profile photo\n                  </label>\n                  <input\n                    id=\"profilePhoto\"\n                    type=\"file\"\n                    accept=\"image/png,image/jpeg,image/webp\"\n                    class=\"mt-3 block w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-600 file:mr-4 file:rounded-xl file:border-0 file:bg-slate-900 file:px-4 file:py-2 file:text-sm file:font-semibold file:text-white\"\n                    @change=\"handleProfileUpload\"\n                  />\n                  <p class=\"mt-3 text-sm text-slate-500\">\n                    Accepted formats: PNG, JPG, WEBP. Recommended size: 2 MB or below.\n                  </p>\n                </div>\n              </div>\n\n              <button\n                type=\"submit\"\n                class=\"flex w-full items-center justify-center rounded-2xl bg-slate-950 px-4 py-3.5 text-sm font-semibold text-white transition hover:bg-slate-800 disabled:cursor-not-allowed disabled:bg-slate-400\"\n                :disabled=\"isSubmitting\"\n              >\n                {{ isSubmitting ? \"Saving registration...\" : \"Save registration\" }}\n              </button>\n            </form>\n          </section>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\n  import API from \"@/services/api\";\n\n  function createInitialForm() {\n    return {\n      personalInformation: {\n        firstName: \"\",\n        middleName: \"\",\n        alias: \"\",\n        lastName: \"\",\n        sex: \"\",\n        civilStatus: \"\",\n        birthDate: \"\",\n        contactNumber: \"\",\n        emailAddress: \"\",\n        nationality: \"\",\n        country: \"\",\n        address: \"\",\n      },\n      operationDetails: {\n        operationName: \"\",\n        operationAddress: \"\",\n        operationDate: \"\",\n        disposition: \"\",\n        visaStatus: \"\",\n        remarks: \"\",\n        actions: \"\",\n      },\n      biometrics: {\n        heightCm: \"\",\n        weightKg: \"\",\n        bloodType: \"\",\n        eyeColor: \"\",\n        hairColor: \"\",\n        complexion: \"\",\n        distinguishingMarks: \"\",\n        fingerprintCode: \"\",\n      },\n      profilePhoto: {\n        fileName: \"\",\n        mimeType: \"\",\n        size: 0,\n        dataUrl: \"\",\n      },\n    };\n  }\n\n  export default {\n    name: \"RegisterRecord\",\n    data() {\n      return {\n        form: createInitialForm(),\n        isSubmitting: false,\n        profilePreview: \"\",\n        message: {\n          type: \"\",\n          text: \"\",\n        },\n      };\n    },\n    computed: {\n      profileSummary() {\n        if (!this.form.profilePhoto.fileName) {\n          return \"No image selected yet.\";\n        }\n\n        const sizeInKb = this.form.profilePhoto.size\n          ? `${(this.form.profilePhoto.size / 1024).toFixed(1)} KB`\n          : \"Unknown size\";\n\n        return `${this.form.profilePhoto.mimeType || \"Image\"} | ${sizeInKb}`;\n      },\n    },\n    methods: {\n      async handleProfileUpload(event) {\n        this.message = { type: \"\", text: \"\" };\n        const [file] = event.target.files || [];\n\n        if (!file) {\n          this.form.profilePhoto = createInitialForm().profilePhoto;\n          this.profilePreview = \"\";\n          return;\n        }\n\n        if (file.size > 2 * 1024 * 1024) {\n          this.message = {\n            type: \"error\",\n            text: \"Please upload an image that is 2 MB or smaller.\",\n          };\n          event.target.value = \"\";\n          return;\n        }\n\n        const dataUrl = await this.readFileAsDataUrl(file);\n\n        this.form.profilePhoto = {\n          fileName: file.name,\n          mimeType: file.type,\n          size: file.size,\n          dataUrl,\n        };\n        this.profilePreview = dataUrl;\n      },\n      readFileAsDataUrl(file) {\n        return new Promise((resolve, reject) => {\n          const reader = new FileReader();\n          reader.onload = () => resolve(reader.result);\n          reader.onerror = () =>\n            reject(new Error(\"Unable to read the selected file.\"));\n          reader.readAsDataURL(file);\n        });\n      },\n      async handleSubmit() {\n        this.message = { type: \"\", text: \"\" };\n\n        if (\n          !this.form.personalInformation.firstName ||\n          !this.form.personalInformation.lastName ||\n          !this.form.personalInformation.sex ||\n          !this.form.personalInformation.birthDate\n        ) {\n          this.message = {\n            type: \"error\",\n            text: \"First name, last name, sex, and birth date are required.\",\n          };\n          return;\n        }\n\n        this.isSubmitting = true;\n\n        try {\n          const response = await API.post(\"/records\", this.form);\n\n          this.message = {\n            type: \"success\",\n            text:\n              response.data.message || \"Registration saved successfully.\",\n          };\n\n          this.form = createInitialForm();\n          this.profilePreview = \"\";\n        } catch (error) {\n          this.message = {\n            type: \"error\",\n            text:\n              error.response?.data?.message ||\n              \"Unable to save the registration right now.\",\n          };\n        } finally {\n          this.isSubmitting = false;\n        }\n      },\n    },\n  };\n</script>\n"]},"metadata":{},"sourceType":"module"}