{"ast":null,"code":"import API from \"@/services/api\";\nexport default {\n  name: \"RegisterPage\",\n  data() {\n    return {\n      form: {\n        username: \"\",\n        email: \"\",\n        password: \"\",\n        confirmPassword: \"\",\n        acceptTerms: false\n      },\n      isSubmitting: false,\n      message: {\n        type: \"\",\n        text: \"\"\n      }\n    };\n  },\n  methods: {\n    async handleRegister() {\n      this.message = {\n        type: \"\",\n        text: \"\"\n      };\n      if (!this.form.username || !this.form.email || !this.form.password) {\n        this.message = {\n          type: \"error\",\n          text: \"Username, email, and password are required.\"\n        };\n        return;\n      }\n      if (this.form.password !== this.form.confirmPassword) {\n        this.message = {\n          type: \"error\",\n          text: \"Password confirmation does not match.\"\n        };\n        return;\n      }\n      if (!this.form.acceptTerms) {\n        this.message = {\n          type: \"error\",\n          text: \"Confirm admin access before creating the user.\"\n        };\n        return;\n      }\n      this.isSubmitting = true;\n      try {\n        const response = await API.post(\"/auth/register\", {\n          username: this.form.username,\n          email: this.form.email,\n          password: this.form.password,\n          role: \"admin\"\n        });\n        this.message = {\n          type: \"success\",\n          text: response.data.message || \"Admin user created successfully.\"\n        };\n        this.form = {\n          username: \"\",\n          email: \"\",\n          password: \"\",\n          confirmPassword: \"\",\n          acceptTerms: false\n        };\n      } catch (error) {\n        this.message = {\n          type: \"error\",\n          text: error.response?.data?.message || \"Unable to save the admin user right now.\"\n        };\n      } finally {\n        this.isSubmitting = false;\n      }\n    }\n  }\n};","map":{"version":3,"mappings":"AA8KE,OAAOA,GAAE,MAAO,gBAAgB;AAEhC,eAAe;EACbC,IAAI,EAAE,cAAc;EACpBC,IAAIA,GAAG;IACL,OAAO;MACLC,IAAI,EAAE;QACJC,QAAQ,EAAE,EAAE;QACZC,KAAK,EAAE,EAAE;QACTC,QAAQ,EAAE,EAAE;QACZC,eAAe,EAAE,EAAE;QACnBC,WAAW,EAAE;MACf,CAAC;MACDC,YAAY,EAAE,KAAK;MACnBC,OAAO,EAAE;QACPC,IAAI,EAAE,EAAE;QACRC,IAAI,EAAE;MACR;IACF,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACP,MAAMC,cAAcA,GAAG;MACrB,IAAI,CAACJ,OAAM,GAAI;QAAEC,IAAI,EAAE,EAAE;QAAEC,IAAI,EAAE;MAAG,CAAC;MAErC,IAAI,CAAC,IAAI,CAACT,IAAI,CAACC,QAAO,IAAK,CAAC,IAAI,CAACD,IAAI,CAACE,KAAI,IAAK,CAAC,IAAI,CAACF,IAAI,CAACG,QAAQ,EAAE;QAClE,IAAI,CAACI,OAAM,GAAI;UACbC,IAAI,EAAE,OAAO;UACbC,IAAI,EAAE;QACR,CAAC;QACD;MACF;MAEA,IAAI,IAAI,CAACT,IAAI,CAACG,QAAO,KAAM,IAAI,CAACH,IAAI,CAACI,eAAe,EAAE;QACpD,IAAI,CAACG,OAAM,GAAI;UACbC,IAAI,EAAE,OAAO;UACbC,IAAI,EAAE;QACR,CAAC;QACD;MACF;MAEA,IAAI,CAAC,IAAI,CAACT,IAAI,CAACK,WAAW,EAAE;QAC1B,IAAI,CAACE,OAAM,GAAI;UACbC,IAAI,EAAE,OAAO;UACbC,IAAI,EAAE;QACR,CAAC;QACD;MACF;MAEA,IAAI,CAACH,YAAW,GAAI,IAAI;MAExB,IAAI;QACF,MAAMM,QAAO,GAAI,MAAMf,GAAG,CAACgB,IAAI,CAAC,gBAAgB,EAAE;UAChDZ,QAAQ,EAAE,IAAI,CAACD,IAAI,CAACC,QAAQ;UAC5BC,KAAK,EAAE,IAAI,CAACF,IAAI,CAACE,KAAK;UACtBC,QAAQ,EAAE,IAAI,CAACH,IAAI,CAACG,QAAQ;UAC5BW,IAAI,EAAE;QACR,CAAC,CAAC;QAEF,IAAI,CAACP,OAAM,GAAI;UACbC,IAAI,EAAE,SAAS;UACfC,IAAI,EAAEG,QAAQ,CAACb,IAAI,CAACQ,OAAM,IAAK;QACjC,CAAC;QAED,IAAI,CAACP,IAAG,GAAI;UACVC,QAAQ,EAAE,EAAE;UACZC,KAAK,EAAE,EAAE;UACTC,QAAQ,EAAE,EAAE;UACZC,eAAe,EAAE,EAAE;UACnBC,WAAW,EAAE;QACf,CAAC;MACH,EAAE,OAAOU,KAAK,EAAE;QACd,IAAI,CAACR,OAAM,GAAI;UACbC,IAAI,EAAE,OAAO;UACbC,IAAI,EACFM,KAAK,CAACH,QAAQ,EAAEb,IAAI,EAAEQ,OAAM,IAC5B;QACJ,CAAC;MACH,UAAU;QACR,IAAI,CAACD,YAAW,GAAI,KAAK;MAC3B;IACF;EACF;AACF,CAAC","names":["API","name","data","form","username","email","password","confirmPassword","acceptTerms","isSubmitting","message","type","text","methods","handleRegister","response","post","role","error"],"sourceRoot":"","sources":["D:\\joremiodotonline\\dashboard\\src\\views\\layouts\\auth\\Register.vue"],"sourcesContent":["<template>\n  <div class=\"min-h-screen bg-slate-950 text-white\">\n    <div class=\"grid min-h-screen lg:grid-cols-[0.95fr_1.05fr]\">\n      <section class=\"hidden lg:block\">\n        <div class=\"flex h-full flex-col justify-between bg-[linear-gradient(145deg,_#020617_0%,_#0f172a_35%,_#312e81_100%)] px-14 py-12\">\n          <button\n            type=\"button\"\n            class=\"flex items-center gap-3 text-left\"\n            @click=\"$router.push('/')\"\n          >\n            <span class=\"flex h-12 w-12 items-center justify-center rounded-2xl bg-white/10 ring-1 ring-white/15 backdrop-blur\">\n              <img\n                src=\"../../../assets/logo/logo_light.png\"\n                alt=\"Joremiodot logo\"\n                class=\"h-8 w-8 object-contain\"\n              />\n            </span>\n            <span>\n              <span class=\"block text-xs uppercase tracking-[0.35em] text-cyan-200/70\">\n                VANTA\n              </span>\n              <span class=\"block text-lg font-semibold\">Admin provisioning</span>\n            </span>\n          </button>\n\n          <div>\n            <p class=\"text-sm font-semibold uppercase tracking-[0.35em] text-cyan-200/70\">\n              Create secure access\n            </p>\n            <h1 class=\"mt-5 text-5xl font-semibold leading-tight\">\n              Add a new admin account for the dashboard.\n            </h1>\n            <p class=\"mt-6 max-w-lg text-base leading-7 text-slate-300\">\n              This form creates a saved user record in MongoDB with the <code>admin</code> role so the account is ready for future authentication wiring.\n            </p>\n          </div>\n\n          <div class=\"grid gap-4\">\n            <div class=\"rounded-3xl border border-white/10 bg-white/5 p-5 text-slate-300\">\n              Username and email are both checked for duplicates before save.\n            </div>\n            <div class=\"rounded-3xl border border-white/10 bg-white/5 p-5 text-slate-300\">\n              Passwords are hashed in the backend before the user document is stored.\n            </div>\n          </div>\n        </div>\n      </section>\n\n      <section class=\"flex items-center justify-center bg-slate-100 px-6 py-10 sm:px-10 lg:px-14\">\n        <div class=\"w-full max-w-2xl rounded-[2rem] border border-slate-200 bg-white p-8 shadow-2xl shadow-slate-900/10 sm:p-10\">\n          <div class=\"mb-8\">\n            <p class=\"text-sm font-semibold uppercase tracking-[0.3em] text-primary/80\">\n              Create account\n            </p>\n            <h2 class=\"mt-3 text-3xl font-semibold text-slate-900\">\n              New admin user\n            </h2>\n            <p class=\"mt-3 text-base leading-7 text-slate-500\">\n              Fill in the details below to save a new admin account.\n            </p>\n          </div>\n\n          <form class=\"space-y-6\" @submit.prevent=\"handleRegister\">\n            <div\n              v-if=\"message.text\"\n              :class=\"message.type === 'success' ? 'border-emerald-200 bg-emerald-50 text-emerald-700' : 'border-red-200 bg-red-50 text-red-600'\"\n              class=\"rounded-2xl border px-4 py-3 text-sm\"\n            >\n              {{ message.text }}\n            </div>\n\n            <div class=\"grid gap-6 sm:grid-cols-2\">\n              <div>\n                <label for=\"username\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                  Username\n                </label>\n                <input\n                  id=\"username\"\n                  v-model.trim=\"form.username\"\n                  type=\"text\"\n                  class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                  placeholder=\"admin.joremio\"\n                />\n              </div>\n\n              <div>\n                <label for=\"email\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                  Email address\n                </label>\n                <input\n                  id=\"email\"\n                  v-model.trim=\"form.email\"\n                  type=\"email\"\n                  class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                  placeholder=\"admin@agency.gov\"\n                />\n              </div>\n            </div>\n\n            <div class=\"grid gap-6 sm:grid-cols-2\">\n              <div>\n                <label for=\"password\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                  Password\n                </label>\n                <input\n                  id=\"password\"\n                  v-model=\"form.password\"\n                  type=\"password\"\n                  class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                  placeholder=\"Create a strong password\"\n                />\n              </div>\n\n              <div>\n                <label for=\"confirmPassword\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                  Confirm password\n                </label>\n                <input\n                  id=\"confirmPassword\"\n                  v-model=\"form.confirmPassword\"\n                  type=\"password\"\n                  class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                  placeholder=\"Re-enter password\"\n                />\n              </div>\n            </div>\n\n            <div class=\"rounded-2xl bg-slate-50 p-4\">\n              <div class=\"flex items-center justify-between gap-4\">\n                <div>\n                  <p class=\"text-sm font-medium text-slate-700\">Account role</p>\n                  <p class=\"mt-1 text-sm text-slate-500\">This flow saves the user as an admin.</p>\n                </div>\n                <span class=\"rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-primary\">\n                  Admin\n                </span>\n              </div>\n            </div>\n\n            <label class=\"flex cursor-pointer items-start gap-3 text-sm text-slate-600\">\n              <input\n                v-model=\"form.acceptTerms\"\n                type=\"checkbox\"\n                class=\"mt-1 h-4 w-4 rounded border-slate-300 text-primary focus:ring-primary/30\"\n              />\n              <span>I confirm this account should be created with administrator access.</span>\n            </label>\n\n            <button\n              type=\"submit\"\n              class=\"flex w-full items-center justify-center rounded-2xl bg-slate-950 px-4 py-3.5 text-sm font-semibold text-white transition hover:bg-slate-800 disabled:cursor-not-allowed disabled:bg-slate-400\"\n              :disabled=\"isSubmitting\"\n            >\n              {{ isSubmitting ? \"Saving admin user...\" : \"Save admin user\" }}\n            </button>\n\n            <p class=\"text-center text-sm text-slate-600\">\n              Already have an account?\n              <button\n                type=\"button\"\n                class=\"ml-2 font-medium text-primary\"\n                @click=\"$router.push('/auth/login')\"\n              >\n                Login here\n              </button>\n            </p>\n          </form>\n        </div>\n      </section>\n    </div>\n  </div>\n</template>\n\n<script>\n  import API from \"@/services/api\";\n\n  export default {\n    name: \"RegisterPage\",\n    data() {\n      return {\n        form: {\n          username: \"\",\n          email: \"\",\n          password: \"\",\n          confirmPassword: \"\",\n          acceptTerms: false,\n        },\n        isSubmitting: false,\n        message: {\n          type: \"\",\n          text: \"\",\n        },\n      };\n    },\n    methods: {\n      async handleRegister() {\n        this.message = { type: \"\", text: \"\" };\n\n        if (!this.form.username || !this.form.email || !this.form.password) {\n          this.message = {\n            type: \"error\",\n            text: \"Username, email, and password are required.\",\n          };\n          return;\n        }\n\n        if (this.form.password !== this.form.confirmPassword) {\n          this.message = {\n            type: \"error\",\n            text: \"Password confirmation does not match.\",\n          };\n          return;\n        }\n\n        if (!this.form.acceptTerms) {\n          this.message = {\n            type: \"error\",\n            text: \"Confirm admin access before creating the user.\",\n          };\n          return;\n        }\n\n        this.isSubmitting = true;\n\n        try {\n          const response = await API.post(\"/auth/register\", {\n            username: this.form.username,\n            email: this.form.email,\n            password: this.form.password,\n            role: \"admin\",\n          });\n\n          this.message = {\n            type: \"success\",\n            text: response.data.message || \"Admin user created successfully.\",\n          };\n\n          this.form = {\n            username: \"\",\n            email: \"\",\n            password: \"\",\n            confirmPassword: \"\",\n            acceptTerms: false,\n          };\n        } catch (error) {\n          this.message = {\n            type: \"error\",\n            text:\n              error.response?.data?.message ||\n              \"Unable to save the admin user right now.\",\n          };\n        } finally {\n          this.isSubmitting = false;\n        }\n      },\n    },\n  };\n</script>\n"]},"metadata":{},"sourceType":"module"}