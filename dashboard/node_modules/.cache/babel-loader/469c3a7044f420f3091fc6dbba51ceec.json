{"ast":null,"code":"import \"core-js/modules/esnext.iterator.constructor.js\";\nimport \"core-js/modules/esnext.iterator.filter.js\";\nimport API from \"@/services/api\";\nimport ConfirmationDialog from \"@/components/ConfirmationDialog.vue\";\nimport FormField from \"@/components/FormField.vue\";\nimport FormSection from \"@/components/FormSection.vue\";\nimport ProfileUploadSection from \"@/components/ProfileUploadSection.vue\";\nimport { createConfirmationDialogState, createRecordConfirmationDialog, resolveConfirmation } from \"@/helper/record-confirmation\";\nimport { createEmptyProfilePhoto, createFormFromRecord, createInitialForm, fieldClass, selectOptions } from \"@/helper/record-form\";\nimport { createProfilePhotoFromFile } from \"@/helper/record-upload\";\nimport { formatPersonMeta, formatPersonName, getPersonInitials } from \"@/helper/record-person\";\nexport default {\n  name: \"RegisterRecord\",\n  components: {\n    ConfirmationDialog,\n    FormField,\n    FormSection,\n    ProfileUploadSection\n  },\n  data() {\n    return {\n      form: createInitialForm(),\n      selectedRecordId: \"\",\n      isSubmitting: false,\n      profilePreview: \"\",\n      people: [],\n      peopleSearch: \"\",\n      isLoadingPeople: false,\n      peopleError: \"\",\n      confirmationDialog: createConfirmationDialogState(),\n      confirmationResolver: null,\n      fieldClass,\n      selectOptions,\n      message: {\n        type: \"\",\n        text: \"\"\n      }\n    };\n  },\n  computed: {\n    isEditing() {\n      return Boolean(this.selectedRecordId);\n    },\n    filteredPeople() {\n      const keyword = this.peopleSearch.toLowerCase();\n      if (!keyword) {\n        return this.people;\n      }\n      return this.people.filter(person => {\n        const info = person.personalInformation || {};\n        const haystack = [info.firstName, info.middleName, info.lastName, info.alias, info.nationality, info.country].filter(Boolean).join(\" \").toLowerCase();\n        return haystack.includes(keyword);\n      });\n    },\n    profileSummary() {\n      if (!this.form.profilePhoto.fileName) {\n        return \"No image selected yet.\";\n      }\n      const sizeInKb = this.form.profilePhoto.size ? `${(this.form.profilePhoto.size / 1024).toFixed(1)} KB` : \"Unknown size\";\n      return `${this.form.profilePhoto.mimeType || \"Image\"} | ${sizeInKb}`;\n    }\n  },\n  methods: {\n    async loadPeople() {\n      this.isLoadingPeople = true;\n      this.peopleError = \"\";\n      try {\n        const response = await API.get(\"/records\");\n        this.people = Array.isArray(response.data) ? response.data : [];\n      } catch (error) {\n        this.peopleError = error.response?.data?.message || \"Unable to load registered people right now.\";\n      } finally {\n        this.isLoadingPeople = false;\n      }\n    },\n    formatPersonName,\n    getPersonInitials,\n    formatPersonMeta,\n    selectPerson(person) {\n      this.message = {\n        type: \"\",\n        text: \"\"\n      };\n      this.selectedRecordId = person._id;\n      this.form = createFormFromRecord(person);\n      this.profilePreview = person.profilePhoto?.dataUrl || \"\";\n    },\n    resetFormState() {\n      this.selectedRecordId = \"\";\n      this.form = createInitialForm();\n      this.profilePreview = \"\";\n      this.message = {\n        type: \"\",\n        text: \"\"\n      };\n    },\n    openConfirmationDialog() {\n      this.confirmationDialog = createRecordConfirmationDialog(this.isEditing);\n      return new Promise(resolve => {\n        this.confirmationResolver = resolve;\n      });\n    },\n    closeConfirmationDialog(confirmed) {\n      this.confirmationDialog = createConfirmationDialogState();\n      resolveConfirmation(this.confirmationResolver, confirmed);\n      this.confirmationResolver = null;\n    },\n    async handleProfileUpload(event) {\n      this.message = {\n        type: \"\",\n        text: \"\"\n      };\n      const [file] = event.target.files || [];\n      if (!file) {\n        this.form.profilePhoto = createEmptyProfilePhoto();\n        this.profilePreview = \"\";\n        return;\n      }\n      if (file.size > 2 * 1024 * 1024) {\n        this.message = {\n          type: \"error\",\n          text: \"Please upload an image that is 2 MB or smaller.\"\n        };\n        event.target.value = \"\";\n        return;\n      }\n      this.form.profilePhoto = await createProfilePhotoFromFile(file);\n      this.profilePreview = this.form.profilePhoto.dataUrl;\n    },\n    async handleSubmit() {\n      this.message = {\n        type: \"\",\n        text: \"\"\n      };\n      if (!this.form.personalInformation.firstName || !this.form.personalInformation.lastName || !this.form.personalInformation.sex || !this.form.personalInformation.birthDate) {\n        this.message = {\n          type: \"error\",\n          text: \"First name, last name, sex, and birth date are required.\"\n        };\n        return;\n      }\n      const confirmed = await this.openConfirmationDialog();\n      if (!confirmed) {\n        return;\n      }\n      this.isSubmitting = true;\n      try {\n        const response = this.isEditing ? await API.put(`/records/${this.selectedRecordId}`, this.form) : await API.post(\"/records\", this.form);\n        this.message = {\n          type: \"success\",\n          text: response.data.message || (this.isEditing ? \"Registration updated successfully.\" : \"Registration saved successfully.\")\n        };\n        await this.loadPeople();\n        if (this.isEditing && response.data.record) {\n          this.selectPerson(response.data.record);\n        } else {\n          this.resetFormState();\n        }\n      } catch (error) {\n        this.message = {\n          type: \"error\",\n          text: error.response?.data?.message || \"Unable to save the registration right now.\"\n        };\n      } finally {\n        this.isSubmitting = false;\n      }\n    }\n  },\n  mounted() {\n    this.loadPeople();\n  }\n};","map":{"version":3,"mappings":";;AA6fE,OAAOA,GAAE,MAAO,gBAAgB;AAChC,OAAOC,kBAAiB,MAAO,qCAAqC;AACpE,OAAOC,SAAQ,MAAO,4BAA4B;AAClD,OAAOC,WAAU,MAAO,8BAA8B;AACtD,OAAOC,oBAAmB,MAAO,uCAAuC;AACxE,SACEC,6BAA6B,EAC7BC,8BAA8B,EAC9BC,mBAAmB,QACd,8BAA8B;AACrC,SACEC,uBAAuB,EACvBC,oBAAoB,EACpBC,iBAAiB,EACjBC,UAAU,EACVC,aAAa,QACR,sBAAsB;AAC7B,SAASC,0BAAyB,QAAS,wBAAwB;AACnE,SACEC,gBAAgB,EAChBC,gBAAgB,EAChBC,iBAAiB,QACZ,wBAAwB;AAE/B,eAAe;EACbC,IAAI,EAAE,gBAAgB;EACtBC,UAAU,EAAE;IACVjB,kBAAkB;IAClBC,SAAS;IACTC,WAAW;IACXC;EACF,CAAC;EACDe,IAAIA,GAAG;IACL,OAAO;MACLC,IAAI,EAAEV,iBAAiB,CAAC,CAAC;MACzBW,gBAAgB,EAAE,EAAE;MACpBC,YAAY,EAAE,KAAK;MACnBC,cAAc,EAAE,EAAE;MAClBC,MAAM,EAAE,EAAE;MACVC,YAAY,EAAE,EAAE;MAChBC,eAAe,EAAE,KAAK;MACtBC,WAAW,EAAE,EAAE;MACfC,kBAAkB,EAAEvB,6BAA6B,CAAC,CAAC;MACnDwB,oBAAoB,EAAE,IAAI;MAC1BlB,UAAU;MACVC,aAAa;MACbkB,OAAO,EAAE;QACPC,IAAI,EAAE,EAAE;QACRC,IAAI,EAAE;MACR;IACF,CAAC;EACH,CAAC;EACDC,QAAQ,EAAE;IACRC,SAASA,GAAG;MACV,OAAOC,OAAO,CAAC,IAAI,CAACd,gBAAgB,CAAC;IACvC,CAAC;IACDe,cAAcA,GAAG;MACf,MAAMC,OAAM,GAAI,IAAI,CAACZ,YAAY,CAACa,WAAW,CAAC,CAAC;MAE/C,IAAI,CAACD,OAAO,EAAE;QACZ,OAAO,IAAI,CAACb,MAAM;MACpB;MAEA,OAAO,IAAI,CAACA,MAAM,CAACe,MAAM,CAAEC,MAAM,IAAK;QACpC,MAAMC,IAAG,GAAID,MAAM,CAACE,mBAAkB,IAAK,CAAC,CAAC;QAC7C,MAAMC,QAAO,GAAI,CACfF,IAAI,CAACG,SAAS,EACdH,IAAI,CAACI,UAAU,EACfJ,IAAI,CAACK,QAAQ,EACbL,IAAI,CAACM,KAAK,EACVN,IAAI,CAACO,WAAW,EAChBP,IAAI,CAACQ,OAAO,CACd,CACGV,MAAM,CAACJ,OAAO,EACde,IAAI,CAAC,GAAG,EACRZ,WAAW,CAAC,CAAC;QAEhB,OAAOK,QAAQ,CAACQ,QAAQ,CAACd,OAAO,CAAC;MACnC,CAAC,CAAC;IACJ,CAAC;IACDe,cAAcA,GAAG;MACf,IAAI,CAAC,IAAI,CAAChC,IAAI,CAACiC,YAAY,CAACC,QAAQ,EAAE;QACpC,OAAO,wBAAwB;MACjC;MAEA,MAAMC,QAAO,GAAI,IAAI,CAACnC,IAAI,CAACiC,YAAY,CAACG,IAAG,GACvC,GAAG,CAAC,IAAI,CAACpC,IAAI,CAACiC,YAAY,CAACG,IAAG,GAAI,IAAI,EAAEC,OAAO,CAAC,CAAC,CAAC,KAAI,GACtD,cAAc;MAElB,OAAO,GAAG,IAAI,CAACrC,IAAI,CAACiC,YAAY,CAACK,QAAO,IAAK,OAAO,MAAMH,QAAQ,EAAE;IACtE;EACF,CAAC;EACDI,OAAO,EAAE;IACP,MAAMC,UAAUA,GAAG;MACjB,IAAI,CAAClC,eAAc,GAAI,IAAI;MAC3B,I