{"ast":null,"code":"import { Icon } from \"@iconify/vue\";\nimport API from \"@/services/api\";\nexport default {\n  name: \"SoctaHandbook\",\n  components: {\n    Icon\n  },\n  data() {\n    return {\n      entries: [],\n      loading: false,\n      error: \"\"\n    };\n  },\n  methods: {\n    formatDate(d) {\n      if (!d) return \"—\";\n      return new Date(d).toLocaleDateString(\"en-US\", {\n        month: \"short\",\n        day: \"numeric\",\n        year: \"numeric\"\n      });\n    },\n    async load() {\n      this.loading = true;\n      this.error = \"\";\n      try {\n        const res = await API.get(\"/cases/entries/socta-handbook\");\n        this.entries = Array.isArray(res.data) ? res.data : [];\n      } catch (err) {\n        this.error = err.response?.data?.message || \"Unable to load handbook.\";\n      } finally {\n        this.loading = false;\n      }\n    },\n    openCreate() {\n      // TODO: wire to chapter-create modal/route once form is built\n    }\n  },\n  mounted() {\n    this.load();\n  }\n};","map":{"version":3,"mappings":"AAwDE,SAASA,IAAG,QAAS,cAAc;AACnC,OAAOC,GAAE,MAAO,gBAAgB;AAEhC,eAAe;EACbC,IAAI,EAAE,eAAe;EACrBC,UAAU,EAAE;IAAEH;EAAK,CAAC;EACpBI,IAAIA,GAAG;IACL,OAAO;MACLC,OAAO,EAAE,EAAE;MACXC,OAAO,EAAE,KAAK;MACdC,KAAK,EAAE;IACT,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACPC,UAAUA,CAACC,CAAC,EAAE;MACZ,IAAI,CAACA,CAAC,EAAE,OAAO,GAAG;MAClB,OAAO,IAAIC,IAAI,CAACD,CAAC,CAAC,CAACE,kBAAkB,CAAC,OAAO,EAAE;QAAEC,KAAK,EAAE,OAAO;QAAEC,GAAG,EAAE,SAAS;QAAEC,IAAI,EAAE;MAAU,CAAC,CAAC;IACrG,CAAC;IACD,MAAMC,IAAIA,GAAG;MACX,IAAI,CAACV,OAAM,GAAI,IAAI;MACnB,IAAI,CAACC,KAAI,GAAI,EAAE;MACf,IAAI;QACF,MAAMU,GAAE,GAAI,MAAMhB,GAAG,CAACiB,GAAG,CAAC,+BAA+B,CAAC;QAC1D,IAAI,CAACb,OAAM,GAAIc,KAAK,CAACC,OAAO,CAACH,GAAG,CAACb,IAAI,IAAIa,GAAG,CAACb,IAAG,GAAI,EAAE;MACxD,EAAE,OAAOiB,GAAG,EAAE;QACZ,IAAI,CAACd,KAAI,GAAIc,GAAG,CAACC,QAAQ,EAAElB,IAAI,EAAEmB,OAAM,IAAK,0BAA0B;MACxE,UAAU;QACR,IAAI,CAACjB,OAAM,GAAI,KAAK;MACtB;IACF,CAAC;IACDkB,UAAUA,GAAG;MACX;IAAA;EAEJ,CAAC;EACDC,OAAOA,GAAG;IACR,IAAI,CAACT,IAAI,CAAC,CAAC;EACb;AACF,CAAC","names":["Icon","API","name","components","data","entries","loading","error","methods","formatDate","d","Date","toLocaleDateString","month","day","year","load","res","get","Array","isArray","err","response","message","openCreate","mounted"],"sourceRoot":"","sources":["D:\\joremiodotonline\\dashboard\\src\\views\\cases\\SoctaHandbook.vue"],"sourcesContent":["<template>\n  <div class=\"min-h-screen bg-case-bg p-3 sm:p-5 space-y-5\">\n\n    <header class=\"flex flex-wrap items-end justify-between gap-4\">\n      <div>\n        <p class=\"text-[10px] font-semibold uppercase tracking-[0.35em] text-primary\">Case Monitoring</p>\n        <h1 class=\"mt-2 text-2xl font-semibold text-white\">SOCTA Handbook</h1>\n        <p class=\"mt-1 text-xs text-gray-500 max-w-2xl\">\n          Serious and Organized Crime Threat Assessment — reference handbook, methodology\n          references and uploaded chapters.\n        </p>\n      </div>\n      <button\n        @click=\"openCreate\"\n        class=\"rounded-md bg-primary px-3 py-2 text-xs font-semibold text-black hover:bg-primary/90 transition-colors flex items-center gap-2\">\n        <Icon icon=\"mdi:plus\" class=\"text-base\" /> Add Chapter\n      </button>\n    </header>\n\n    <section class=\"bg-case-surface border border-case-border rounded-xl\">\n      <header class=\"flex items-center justify-between border-b border-case-border px-5 py-3\">\n        <h2 class=\"text-sm font-semibold text-white\">Chapters &amp; References</h2>\n        <Icon icon=\"bi:three-dots-vertical\" class=\"text-gray-700\" />\n      </header>\n      <div class=\"p-5\">\n        <div v-if=\"loading\" class=\"space-y-2\">\n          <div v-for=\"i in 4\" :key=\"i\" class=\"h-12 animate-pulse rounded-lg bg-case-elevated\"></div>\n        </div>\n        <div v-else-if=\"error\" class=\"rounded-md border border-red-900/50 bg-red-950/30 p-4 text-xs text-red-400\">\n          {{ error }}\n        </div>\n        <ul v-else-if=\"entries.length\" class=\"divide-y divide-case-border\">\n          <li\n            v-for=\"entry in entries\"\n            :key=\"entry._id\"\n            class=\"py-3 flex items-start justify-between gap-3 hover:bg-case-card transition-colors px-2 rounded\">\n            <div class=\"flex items-start gap-3 min-w-0\">\n              <Icon icon=\"mdi:book-open-page-variant-outline\" class=\"text-primary text-lg flex-shrink-0 mt-0.5\" />\n              <div class=\"min-w-0\">\n                <p class=\"text-sm text-gray-200 truncate\">{{ entry.title }}</p>\n                <p v-if=\"entry.description\" class=\"text-[11px] text-gray-500 mt-0.5 line-clamp-1\">{{ entry.description }}</p>\n              </div>\n            </div>\n            <p class=\"text-[11px] text-gray-600 flex-shrink-0\">{{ formatDate(entry.createdAt) }}</p>\n          </li>\n        </ul>\n        <div v-else class=\"py-12 flex flex-col items-center justify-center text-center\">\n          <Icon icon=\"mdi:book-open-page-variant-outline\" class=\"text-3xl text-gray-700 mb-2\" />\n          <p class=\"text-xs text-gray-500\">SOCTA handbook is empty. Upload the first chapter to get started.</p>\n        </div>\n      </div>\n    </section>\n  </div>\n</template>\n\n<script>\n  import { Icon } from \"@iconify/vue\";\n  import API from \"@/services/api\";\n\n  export default {\n    name: \"SoctaHandbook\",\n    components: { Icon },\n    data() {\n      return {\n        entries: [],\n        loading: false,\n        error: \"\",\n      };\n    },\n    methods: {\n      formatDate(d) {\n        if (!d) return \"—\";\n        return new Date(d).toLocaleDateString(\"en-US\", { month: \"short\", day: \"numeric\", year: \"numeric\" });\n      },\n      async load() {\n        this.loading = true;\n        this.error = \"\";\n        try {\n          const res = await API.get(\"/cases/entries/socta-handbook\");\n          this.entries = Array.isArray(res.data) ? res.data : [];\n        } catch (err) {\n          this.error = err.response?.data?.message || \"Unable to load handbook.\";\n        } finally {\n          this.loading = false;\n        }\n      },\n      openCreate() {\n        // TODO: wire to chapter-create modal/route once form is built\n      },\n    },\n    mounted() {\n      this.load();\n    },\n  };\n</script>\n"]},"metadata":{},"sourceType":"module"}