{"ast":null,"code":"import \"core-js/modules/esnext.iterator.constructor.js\";\nimport \"core-js/modules/esnext.iterator.filter.js\";\nimport \"core-js/modules/esnext.iterator.for-each.js\";\nimport \"core-js/modules/esnext.iterator.map.js\";\nimport \"core-js/modules/esnext.iterator.reduce.js\";\nimport { Icon } from \"@iconify/vue\";\nimport API from \"@/services/api\";\nconst MONTH_LABELS = [\"Jan\", \"Feb\", \"Mar\", \"Apr\", \"May\", \"Jun\", \"Jul\", \"Aug\", \"Sep\", \"Oct\", \"Nov\", \"Dec\"];\nconst CHART_FONT = \"Lexend, sans-serif\";\nconst LABEL_STYLE = {\n  colors: \"#64748b\",\n  fontSize: \"10px\",\n  fontFamily: CHART_FONT\n};\nconst GRID_OPTS = {\n  borderColor: \"#252830\",\n  strokeDashArray: 4,\n  xaxis: {\n    lines: {\n      show: false\n    }\n  }\n};\nexport default {\n  name: \"Dashboard\",\n  data() {\n    return {\n      recentRecords: [],\n      isLoadingRecords: false,\n      chartReady: false,\n      recordsError: \"\"\n    };\n  },\n  computed: {\n    // ── Stat cards ───────────────────────────────────────────────────\n    totalCases() {\n      return new Set(this.recentRecords.map(r => r.operationDetails?.operationName?.trim()).filter(Boolean)).size;\n    },\n    personsWithCases() {\n      return this.recentRecords.filter(r => r.operationDetails?.operationName?.trim()).length;\n    },\n    avgDaysOpen() {\n      if (!this.recentRecords.length) return 0;\n      const now = Date.now();\n      const total = this.recentRecords.reduce((sum, r) => {\n        return sum + (r.createdAt ? Math.floor((now - new Date(r.createdAt)) / 86400000) : 0);\n      }, 0);\n      return Math.round(total / this.recentRecords.length);\n    },\n    // ── Table ─────────────────────────────────────────────────────\n    tableRecords() {\n      return this.recentRecords.slice(0, 8);\n    },\n    // ── Monthly buckets ───────────────────────────────────────────\n    monthlySeries() {\n      const now = new Date();\n      const labels = [],\n        persons = [],\n        cases = [];\n      for (let i = 11; i >= 0; i--) {\n        const d = new Date(now.getFullYear(), now.getMonth() - i, 1);\n        labels.push(MONTH_LABELS[d.getMonth()]);\n        const inMonth = this.recentRecords.filter(r => {\n          if (!r.createdAt) return false;\n          const rd = new Date(r.createdAt);\n          return rd.getFullYear() === d.getFullYear() && rd.getMonth() === d.getMonth();\n        });\n        persons.push(inMonth.length);\n        cases.push(new Set(inMonth.map(r => r.operationDetails?.operationName?.trim()).filter(Boolean)).size);\n      }\n      return {\n        labels,\n        persons,\n        cases\n      };\n    },\n    // ── Line chart ────────────────────────────────────────────────\n    lineChartOptions() {\n      return {\n        chart: {\n          type: \"line\",\n          background: \"transparent\",\n          toolbar: {\n            show: false\n          },\n          zoom: {\n            enabled: false\n          },\n          fontFamily: CHART_FONT,\n          animations: {\n            enabled: true,\n            speed: 500\n          }\n        },\n        colors: [\"#D97706\"],\n        stroke: {\n          curve: \"straight\",\n          width: 2\n        },\n        markers: {\n          size: 5,\n          strokeWidth: 0,\n          hover: {\n            size: 7\n          }\n        },\n        dataLabels: {\n          enabled: true,\n          style: {\n            fontSize: \"10px\",\n            fontFamily: CHART_FONT,\n            colors: [\"#D97706\"]\n          },\n          background: {\n            enabled: true,\n            foreColor: \"#fff\",\n            padding: 3,\n            borderRadius: 3,\n            borderWidth: 0,\n            opacity: 0\n          },\n          offsetY: -9\n        },\n        grid: GRID_OPTS,\n        xaxis: {\n          categories: this.monthlySeries.labels,\n          labels: {\n            style: LABEL_STYLE\n          },\n          axisBorder: {\n            show: false\n          },\n          axisTicks: {\n            show: false\n          }\n        },\n        yaxis: {\n          labels: {\n            style: LABEL_STYLE,\n            formatter: v => Math.round(v)\n          },\n          min: 0\n        },\n        legend: {\n          show: false\n        },\n        tooltip: {\n          theme: \"dark\",\n          style: {\n            fontFamily: CHART_FONT\n          }\n        }\n      };\n    },\n    lineChartSeries() {\n      return [{\n        name: \"Registrations\",\n        data: this.monthlySeries.persons\n      }];\n    },\n    // ── Bar chart - top 5 operations ──────────────────────────────\n    topOperations() {\n      const ops = {};\n      this.recentRecords.forEach(r => {\n        const op = r.operationDetails?.operationName?.trim();\n        if (!op) return;\n        if (!ops[op]) ops[op] = {\n          active: 0,\n          closed: 0\n        };\n        const isDisposed = !!r.operationDetails?.disposition?.trim();\n        isDisposed ? ops[op].closed++ : ops[op].active++;\n      });\n      return Object.entries(ops).sort((a, b) => b[1].active + b[1].closed - (a[1].active + a[1].closed)).slice(0, 5);\n    },\n    barChartOptions() {\n      const cats = this.topOperations.map(([name]) => name.length > 10 ? name.slice(0, 10) + \"…\" : name);\n      return {\n        chart: {\n          type: \"bar\",\n          background: \"transparent\",\n          toolbar: {\n            show: false\n          },\n          fontFamily: CHART_FONT,\n          stacked: true,\n          animations: {\n            enabled: true,\n            speed: 500\n          }\n        },\n        colors: [\"#06b6d4\", \"#D97706\"],\n        plotOptions: {\n          bar: {\n            columnWidth: \"50%\",\n            borderRadius: 2,\n            borderRadiusApplication: \"end\"\n          }\n        },\n        grid: GRID_OPTS,\n        xaxis: {\n          categories: cats,\n          labels: {\n            style: {\n              ...LABEL_STYLE,\n              fontSize: \"9px\"\n            },\n            rotate: -25,\n            trim: false\n          },\n          axisBorder: {\n            show: false\n          },\n          axisTicks: {\n            show: false\n          }\n        },\n        yaxis: {\n          labels: {\n            style: LABEL_STYLE,\n            formatter: v => Math.round(v)\n          },\n          min: 0\n        },\n        legend: {\n          show: false\n        },\n        dataLabels: {\n          enabled: false\n        },\n        tooltip: {\n          theme: \"dark\",\n          style: {\n            fontFamily: CHART_FONT\n          }\n        }\n      };\n    },\n    barChartSeries() {\n      return [{\n        name: \"Active\",\n        data: this.topOperations.map(([, v]) => v.active)\n      }, {\n        name: \"Closed\",\n        data: this.topOperations.map(([, v]) => v.closed)\n      }];\n    },\n    // ── Heatmap - activity by day & time ─────────────────────────\n    heatmapSeries() {\n      const periods = [{\n        label: \"Night\",\n        hours: [0, 1, 2, 3, 4, 5]\n      }, {\n        label: \"Eve\",\n        hours: [18, 19, 20, 21, 22, 23]\n      }, {\n        label: \"Aft\",\n        hours: [12, 13, 14, 15, 16, 17]\n      }, {\n        label: \"Morn\",\n        hours: [6, 7, 8, 9, 10, 11]\n      }];\n      const days = [\"Sun\", \"Mon\", \"Tue\", \"Wed\", \"Thu\", \"Fri\", \"Sat\"];\n      return periods.map(period => ({\n        name: period.label,\n        data: days.map((day, dayIdx) => ({\n          x: day,\n          y: this.recentRecords.filter(r => {\n            if (!r.createdAt) return false;\n            const d = new Date(r.createdAt);\n            return d.getDay() === dayIdx && period.hours.includes(d.getHours());\n          }).length\n        }))\n      }));\n    },\n    heatmapOptions() {\n      return {\n        chart: {\n          type: \"heatmap\",\n          background: \"transparent\",\n          toolbar: {\n            show: false\n          },\n          fontFamily: CHART_FONT,\n          animations: {\n            enabled: false\n          }\n        },\n        dataLabels: {\n          enabled: true,\n          style: {\n            colors: [\"#e2e8f0\"],\n            fontSize: \"11px\",\n            fontFamily: CHART_FONT\n          }\n        },\n        plotOptions: {\n          heatmap: {\n            radius: 3,\n            useFillColorAsStroke: false,\n            colorScale: {\n              ranges: [{\n                from: 0,\n                to: 0,\n                color: \"#1c1f28\",\n                name: \"0\"\n              }, {\n                from: 1,\n                to: 2,\n                color: \"#7f1d1d\",\n                name: \"1–2\"\n              }, {\n                from: 3,\n                to: 5,\n                color: \"#b91c1c\",\n                name: \"3–5\"\n              }, {\n                from: 6,\n                to: 999,\n                color: \"#ef4444\",\n                name: \"6+\"\n              }]\n            }\n          }\n        },\n        xaxis: {\n          labels: {\n            style: LABEL_STYLE\n          },\n          axisBorder: {\n            show: false\n          },\n          axisTicks: {\n            show: false\n          }\n        },\n        yaxis: {\n          labels: {\n            style: LABEL_STYLE\n          }\n        },\n        legend: {\n          show: false\n        },\n        tooltip: {\n          theme: \"dark\",\n          style: {\n            fontFamily: CHART_FONT\n          }\n        },\n        grid: {\n          padding: {\n            right: 0,\n            top: 0\n          }\n        }\n      };\n    }\n  },\n  components: {\n    Icon\n  },\n  methods: {\n    async loadRecentRecords() {\n      this.isLoadingRecords = true;\n      this.chartReady = false;\n      this.recordsError = \"\";\n      try {\n        const res = await API.get(\"/records\");\n        this.recentRecords = Array.isArray(res.data) ? res.data : [];\n      } catch (err) {\n        this.recordsError = err.response?.data?.message || \"Unable to load records.\";\n      } finally {\n        this.isLoadingRecords = false;\n        await this.$nextTick();\n        this.chartReady = true;\n      }\n    },\n    formatRecordName(r) {\n      const i = r.personalInformation || {};\n      return [i.firstName, i.middleName, i.lastName].filter(Boolean).join(\" \");\n    },\n    formatRecordCreatedAt(r) {\n      return r.createdAt ? new Date(r.createdAt).toLocaleDateString() : \"—\";\n    }\n  },\n  mounted() {\n    this.loadRecentRecords();\n  }\n};","map":{"version":3,"mappings":";;;;;AA4NE,SAASA,IAAG,QAAS,cAAc;AACnC,OAAOC,GAAE,MAAO,gBAAgB;AAEhC,MAAMC,YAAW,GAAI,CAAC,KAAK,EAAC,KAAK,EAAC,KAAK,EAAC,KAAK,EAAC,KAAK,EAAC,KAAK,EAAC,KAAK,EAAC,KAAK,EAAC,KAAK,EAAC,KAAK,EAAC,KAAK,EAAC,KAAK,CAAC;AAE9F,MAAMC,UAAS,GAAI,oBAAoB;AACvC,MAAMC,WAAU,GAAI;EAAEC,MAAM,EAAE,SAAS;EAAEC,QAAQ,EAAE,MAAM;EAAEC,UAAU,EAAEJ;AAAW,CAAC;AACnF,MAAMK,SAAQ,GAAI;EAAEC,WAAW,EAAE,SAAS;EAAEC,eAAe,EAAE,CAAC;EAAEC,KAAK,EAAE;IAAEC,KAAK,EAAE;MAAEC,IAAI,EAAE;IAAM;EAAE;AAAE,CAAC;AAEnG,eAAe;EACbC,IAAI,EAAE,WAAW;EACjBC,IAAIA,GAAG;IACL,OAAO;MACLC,aAAa,EAAE,EAAE;MACjBC,gBAAgB,EAAE,KAAK;MACvBC,UAAU,EAAE,KAAK;MACjBC,YAAY,EAAE;IAChB,CAAC;EACH,CAAC;EAEDC,QAAQ,EAAE;IACR;IACAC,UAAUA,GAAG;MACX,OAAO,IAAIC,GAAG,CACZ,IAAI,CAACN,aAAa,CAACO,GAAG,CAAEC,CAAC,IAAKA,CAAC,CAACC,gBAAgB,EAAEC,aAAa,EAAEC,IAAI,CAAC,CAAC,CAAC,CAACC,MAAM,CAACC,OAAO,CACzF,CAAC,CAACC,IAAI;IACR,CAAC;IACDC,gBAAgBA,GAAG;MACjB,OAAO,IAAI,CAACf,aAAa,CAACY,MAAM,CAAEJ,CAAC,IAAKA,CAAC,CAACC,gBAAgB,EAAEC,aAAa,EAAEC,IAAI,CAAC,CAAC,CAAC,CAACK,MAAM;IAC3F,CAAC;IACDC,WAAWA,GAAG;MACZ,IAAI,CAAC,IAAI,CAACjB,aAAa,CAACgB,MAAM,EAAE,OAAO,CAAC;MACxC,MAAME,GAAE,GAAIC,IAAI,CAACD,GAAG,CAAC,CAAC;MACtB,MAAME,KAAI,GAAI,IAAI,CAACpB,aAAa,CAACqB,MAAM,CAAC,CAACC,GAAG,EAAEd,CAAC,KAAK;QAClD,OAAOc,GAAE,IAAKd,CAAC,CAACe,SAAQ,GAAIC,IAAI,CAACC,KAAK,CAAC,CAACP,GAAE,GAAI,IAAIC,IAAI,CAAC