s","get","Array","isArray","err","response","message","$nextTick","formatRecordName","personalInformation","firstName","middleName","lastName","join","formatRecordCreatedAt","toLocaleDateString","mounted"],"sourceRoot":"","sources":["D:\\joremiodotonline\\dashboard\\src\\views\\Dashboard.vue"],"sourcesContent":["<template>\n  <div class=\"min-h-screen p-5 space-y-4\">\n\n    <!-- ── Filter bar ───────────────────────────────────────────────────── -->\n    <div class=\"flex flex-wrap items-center gap-3\">\n      <button class=\"flex items-center gap-2 rounded-md border border-case-border bg-case-surface px-4 py-2 text-sm text-primary hover:bg-case-elevated transition-colors\">\n        <Icon icon=\"ic:outline-folder-open\" class=\"text-base\" />\n        Case Reports\n      </button>\n      <select class=\"rounded-md border border-case-border bg-case-surface px-3 py-2 text-sm text-gray-400 focus:border-primary focus:outline-none appearance-none pr-8 cursor-pointer\">\n        <option value=\"\">Severity</option>\n        <option>Low</option>\n        <option>Medium</option>\n        <option>High</option>\n      </select>\n      <select class=\"rounded-md border border-case-border bg-case-surface px-3 py-2 text-sm text-gray-400 focus:border-primary focus:outline-none appearance-none pr-8 cursor-pointer\">\n        <option value=\"\">Case Category</option>\n      </select>\n    </div>\n\n    <!-- ── 3-column grid ────────────────────────────────────────────────── -->\n    <div class=\"grid grid-cols-1 lg:grid-cols-[170px_1fr_290px] gap-4 items-start\">\n\n      <!-- ── LEFT: Stat cards ─────────────────────────────────────────── -->\n      <div class=\"grid grid-cols-2 lg:grid-cols-1 gap-3\">\n\n        <!-- Open Records -->\n        <div class=\"bg-case-surface border border-case-border rounded-xl p-4\">\n          <div class=\"flex items-center justify-between mb-3\">\n            <p class=\"text-[10px] font-medium uppercase tracking-[0.2em] text-gray-600\">Open Records</p>\n            <div class=\"flex gap-1 text-gray-700\">\n              <button class=\"hover:text-gray-500 transition-colors\"><Icon icon=\"bi:filter\" /></button>\n              <button class=\"hover:text-gray-500 transition-colors\"><Icon icon=\"bi:three-dots-vertical\" /></button>\n            </div>\n          </div>\n          <div v-if=\"isLoadingRecords\" class=\"h-10 flex items-center\">\n            <div class=\"h-2 w-12 animate-pulse rounded-full bg-case-elevated\"></div>\n          </div>\n          <p v-else class=\"text-4xl font-bold text-cyan-400 leading-none\">{{ recentRecords.length }}</p>\n        </div>\n\n        <!-- Active Operations -->\n        <div class=\"bg-case-surface border border-case-border rounded-xl p-4\">\n          <div class=\"flex items-center justify-between mb-3\">\n            <p class=\"text-[10px] font-medium uppercase tracking-[0.2em] text-gray-600\">Active Ops</p>\n            <div class=\"flex gap-1 text-gray-700\">\n              <button class=\"hover:text-gray-500 transition-colors\"><Icon icon=\"bi:filter\" /></button>\n              <button class=\"hover:text-gray-500 transition-colors\"><Icon icon=\"bi:three-dots-vertical\" /></button>\n            </div>\n          </div>\n          <div v-if=\"isLoadingRecords\" class=\"h-10 flex items-center\">\n            <div class=\"h-2 w-12 animate-pulse rounded-full bg-case-elevated\"></div>\n          </div>\n          <p v-else class=\"text-4xl font-bold text-primary leading-none\">{{ totalCases }}</p>\n        </div>\n\n        <!-- Persons with Cases -->\n        <div class=\"bg-case-surface border border-case-border rounded-xl p-4\">\n          <div class=\"flex items-center justify-between mb-3\">\n            <p class=\"text-[10px] font-medium uppercase tracking-[0.2em] text-gray-600\">Persons w/ Cases</p>\n            <div class=\"flex gap-1 text-gray-700\">\n              <button class=\"hover:text-gray-500 transition-colors\"><Icon icon=\"bi:filter\" /></button>\n              <button class=\"hover:text-gray-500 transition-colors\"><Icon icon=\"bi:three-dots-vertical\" /></button>\n            </div>\n          </div>\n          <div v-if=\"isLoadingRecords\" class=\"h-10 flex items-center\">\n            <div class=\"h-2 w-12 animate-pulse rounded-full bg-case-elevated\"></div>\n          </div>\n          <template v-else>\n            <p class=\"text-4xl font-bold text-gray-200 leading-none\">{{ personsWithCases }}</p>\n            <p class=\"mt-2 text-[10px] text-gray-600\">\n              <span class=\"text-primary\">●</span> of {{ recentRecords.length }} registered\n            </p>\n          </template>\n        </div>\n\n        <!-- Avg Days to Close -->\n        <div class=\"bg-case-surface border border-case-border rounded-xl p-4\">\n          <div class=\"flex items-center justify-between mb-3\">\n            <p class=\"text-[10px] font-medium uppercase tracking-[0.2em] text-gray-600\">Days to Close (Avg)</p>\n            <div class=\"flex gap-1 text-gray-700\">\n              <button class=\"hover:text-gray-500 transition-colors\"><Icon icon=\"bi:filter\" /></button>\n              <button class=\"hover:text-gray-500 transition-colors\"><Icon icon=\"bi:three-dots-vertical\" /></button>\n            </div>\n          </div>\n          <div v-if=\"isLoadingRecords\" class=\"h-10 flex items-center\">\n            <div class=\"h-2 w-12 animate-pulse rounded-full bg-case-elevated\"></div>\n          </div>\n          <template v-else>\n            <p class=\"text-4xl font-bold text-gray-200 leading-none\">{{ avgDaysOpen }}</p>\n            <p class=\"mt-2 text-[10px] text-gray-600\">\n              <span class=\"text-primary\">●</span> Equal to last month\n            </p>\n          </template>\n        </div>\n      </div>\n\n      <!-- ── MIDDLE: Line chart + Table ───────────────────────────────── -->\n      <div class=\"space-y-4\">\n\n        <!-- Line chart -->\n        <div class=\"bg-case-surface border border-case-border rounded-xl p-5\">\n          <div class=\"flex items-center justify-between mb-4\">\n            <h3 class=\"text-sm font-semibold text-white\">Cases Registered by Month</h3>\n            <div class=\"flex gap-2 text-gray-700\">\n              <button class=\"hover:text-gray-500 transition-colors\"><Icon icon=\"bi:arrows-angle-expand\" /></button>\n              <button class=\"hover:text-gray-500 transition-colors\"><Icon icon=\"bi:filter\" /></button>\n              <button class=\"hover:text-gray-500 transition-colors\"><Icon icon=\"bi:three-dots-vertical\" /></button>\n            </div>\n          </div>\n          <div v-if=\"isLoadingRecords\" class=\"h-[200px] flex items-center justify-center\">\n            <div class=\"h-2 w-24 animate-pulse rounded-full bg-case-elevated\"></div>\n          </div>\n          <apexchart\n            v-else-if=\"chartReady\"\n            type=\"line\"\n            height=\"200\"\n            :options=\"lineChartOptions\"\n            :series=\"lineChartSeries\"\n          />\n        </div>\n\n        <!-- Table -->\n        <div class=\"bg-case-surface border border-case-border rounded-xl p-5\">\n          <div class=\"flex items-center justify-between mb-4\">\n            <h3 class=\"text-sm font-semibold text-white\">Recent Case Records</h3>\n            <div class=\"flex gap-2 text-gray-700\">\n              <button class=\"hover:text-gray-500 transition-colors\"><Icon icon=\"bi:filter\" /></button>\n              <button class=\"hover:text-gray-500 transition-colors\"><Icon icon=\"bi:three-dots-vertical\" /></button>\n            </div>\n          </div>\n          <div v-if=\"isLoadingRecords\" class=\"space-y-2\">\n            <div v-for=\"i in 4\" :key=\"i\" class=\"h-9 animate-pulse rounded-lg bg-case-elevated\"></div>\n          </div>\n          <table v-else class=\"w-full text-sm\">\n            <thead>\n              <tr class=\"border-b border-case-border\">\n                <th class=\"py-2.5 px-3 text-left text-[10px] uppercase tracking-[0.18em] text-gray-600 font-medium\">\n                  <span class=\"flex items-center gap-1\"><Icon icon=\"bi:list\" class=\"text-xs\" /> Person</span>\n                </th>\n                <th class=\"py-2.5 px-3 text-left text-[10px] uppercase tracking-[0.18em] text-gray-600 font-medium\">\n                  <span class=\"flex items-center gap-1\"><Icon icon=\"bi:hash\" class=\"text-xs\" /> Operation</span>\n                </th>\n                <th class=\"py-2.5 px-3 text-right text-[10px] uppercase tracking-[0.18em] text-gray-600 font-medium\">\n                  <span class=\"flex items-center justify-end gap-1\"><Icon icon=\"bi:calculator\" class=\"text-xs\" /> Date Added</span>\n                </th>\n              </tr>\n            </thead>\n            <tbody>\n              <tr\n                v-for=\"record in tableRecords\"\n                :key=\"record._id\"\n                class=\"border-b border-case-border/40 hover:bg-case-card transition-colors cursor-pointer\"\n              >\n                <td class=\"py-2.5 px-3 text-gray-300 font-medium\">{{ formatRecordName(record) || \"—\" }}</td>\n                <td class=\"py-2.5 px-3 text-gray-500 max-w-[160px]\">\n                  <span class=\"truncate block\">{{ record.operationDetails?.operationName || \"—\" }}</span>\n                </td>\n                <td class=\"py-2.5 px-3 text-gray-600 text-right text-xs\">{{ formatRecordCreatedAt(record) }}</td>\n              </tr>\n              <tr v-if=\"!tableRecords.length\">\n                <td colspan=\"3\" class=\"py-8 text-center text-gray-600 text-xs\">No records available</td>\n              </tr>\n            </tbody>\n          </table>\n        </div>\n      </div>\n\n      <!-- ── RIGHT: Bar chart + Heatmap ───────────────────────────────── -->\n      <div class=\"space-y-4\">\n\n        <!-- Bar chart - Top 5 Operations -->\n        <div class=\"bg-case-surface border border-case-border rounded-xl p-5\">\n          <div class=\"flex items-center justify-between mb-2\">\n            <h3 class=\"text-sm font-semibold text-white\">Top 5 Operations</h3>\n            <button class=\"text-gray-700 hover:text-gray-500 transition-colors\">\n              <Icon icon=\"bi:three-dots-vertical\" />\n            </button>\n          </div>\n          <div class=\"flex gap-4 mb-3\">\n            <span class=\"flex items-center gap-1.5 text-[10px] text-gray-500\">\n              <span class=\"inline-block h-2.5 w-4 rounded-sm bg-cyan-500\"></span> Active\n            </span>\n            <span class=\"flex items-center gap-1.5 text-[10px] text-gray-500\">\n              <span class=\"inline-block h-2.5 w-4 rounded-sm bg-primary\"></span> Closed\n            </span>\n          </div>\n          <div v-if=\"isLoadingRecords\" class=\"h-[200px] flex items-center justify-center\">\n            <div class=\"h-2 w-24 animate-pulse rounded-full bg-case-elevated\"></div>\n          </div>\n          <apexchart\n            v-else-if=\"chartReady\"\n            type=\"bar\"\n            height=\"200\"\n            :options=\"barChartOptions\"\n            :series=\"barChartSeries\"\n          />\n        </div>\n\n        <!-- Heatmap - Activity by day & time -->\n        <div class=\"bg-case-surface border border-case-border rounded-xl p-5\">\n          <h3 class=\"text-sm font-semibold text-white mb-4\">Activity Heatmap</h3>\n          <div v-if=\"isLoadingRecords\" class=\"h-[200px] flex items-center justify-center\">\n            <div class=\"h-2 w-24 animate-pulse rounded-full bg-case-elevated\"></div>\n          </div>\n          <apexchart\n            v-else-if=\"chartReady\"\n            type=\"heatmap\"\n            height=\"200\"\n            :options=\"heatmapOptions\"\n            :series=\"heatmapSeries\"\n          />\n        </div>\n      </div>\n\n    </div>\n  </div>\n</template>\n\n<script>\n  import { Icon } from \"@iconify/vue\";\n  import API from \"@/services/api\";\n\n  const MONTH_LABELS = [\"Jan\",\"Feb\",\"Mar\",\"Apr\",\"May\",\"Jun\",\"Jul\",\"Aug\",\"Sep\",\"Oct\",\"Nov\",\"Dec\"];\n\n  const CHART_FONT = \"Lexend, sans-serif\";\n  const LABEL_STYLE = { colors: \"#64748b\", fontSize: \"10px\", fontFamily: CHART_FONT };\n  const GRID_OPTS = { borderColor: \"#252830\", strokeDashArray: 4, xaxis: { lines: { show: false } } };\n\n  export default {\n    name: \"Dashboard\",\n    data() {\n      return {\n        recentRecords: [],\n        isLoadingRecords: false,\n        chartReady: false,\n        recordsError: \"\",\n      };\n    },\n\n    computed: {\n      // ── Stat cards ───────────────────────────────────────────────────\n      totalCases() {\n        return new Set(\n          this.recentRecords.map((r) => r.operationDetails?.operationName?.trim()).filter(Boolean)\n        ).size;\n      },\n      personsWithCases() {\n        return this.recentRecords.filter((r) => r.operationDetails?.operationName?.trim()).length;\n      },\n      avgDaysOpen() {\n        if (!this.recentRecords.length) return 0;\n        const now = Date.now();\n        const total = this.recentRecords.reduce((sum, r) => {\n          return sum + (r.createdAt ? Math.floor((now - new Date(r.createdAt)) / 86400000) : 0);\n        }, 0);\n        return Math.round(total / this.recentRecords.length);\n      },\n\n      // ── Table ─────────────────────────────────────────────────────\n      tableRecords() {\n        return this.recentRecords.slice(0, 8);\n      },\n\n      // ── Monthly buckets ───────────────────────────────────────────\n      monthlySeries() {\n        const now = new Date();\n        const labels = [], persons = [], cases = [];\n        for (let i = 11; i >= 0; i--) {\n          const d = new Date(now.getFullYear(), now.getMonth() - i, 1);\n          labels.push(MONTH_LABELS[d.getMonth()]);\n          const inMonth = this.recentRecords.filter((r) => {\n            if (!r.createdAt) return false;\n            const rd = new Date(r.createdAt);\n            return rd.getFullYear() === d.getFullYear() && rd.getMonth() === d.getMonth();\n          });\n          persons.push(inMonth.length);\n          cases.push(\n            new Set(inMonth.map((r) => r.operationDetails?.operationName?.trim()).filter(Boolean)).size\n          );\n        }\n        return { labels, persons, cases };\n      },\n\n      // ── Line chart ────────────────────────────────────────────────\n      lineChartOptions() {\n        return {\n          chart: {\n            type: \"line\",\n            background: \"transparent\",\n            toolbar: { show: false },\n            zoom: { enabled: false },\n            fontFamily: CHART_FONT,\n            animations: { enabled: true, speed: 500 },\n          },\n          colors: [\"#D97706\"],\n          stroke: { curve: \"straight\", width: 2 },\n          markers: { size: 5, strokeWidth: 0, hover: { size: 7 } },\n          dataLabels: {\n            enabled: true,\n            style: { fontSize: \"10px\", fontFamily: CHART_FONT, colors: [\"#D97706\"] },\n            background: {\n              enabled: true,\n              foreColor: \"#fff\",\n              padding: 3,\n              borderRadius: 3,\n              borderWidth: 0,\n              opacity: 0,\n            },\n            offsetY: -9,\n          },\n          grid: GRID_OPTS,\n          xaxis: {\n            categories: this.monthlySeries.labels,\n            labels: { style: LABEL_STYLE },\n            axisBorder: { show: false },\n            axisTicks: { show: false },\n          },\n          yaxis: {\n            labels: { style: LABEL_STYLE, formatter: (v) => Math.round(v) },\n            min: 0,\n          },\n          legend: { show: false },\n          tooltip: { theme: \"dark\", style: { fontFamily: CHART_FONT } },\n        };\n      },\n      lineChartSeries() {\n        return [{ name: \"Registrations\", data: this.monthlySeries.persons }];\n      },\n\n      // ── Bar chart - top 5 operations ──────────────────────────────\n      topOperations() {\n        const ops = {};\n        this.recentRecords.forEach((r) => {\n          const op = r.operationDetails?.operationName?.trim();\n          if (!op) return;\n          if (!ops[op]) ops[op] = { active: 0, closed: 0 };\n          const isDisposed = !!r.operationDetails?.disposition?.trim();\n          isDisposed ? ops[op].closed++ : ops[op].active++;\n        });\n        return Object.entries(ops)\n          .sort((a, b) => (b[1].active + b[1].closed) - (a[1].active + a[1].closed))\n          .slice(0, 5);\n      },\n      barChartOptions() {\n        const cats = this.topOperations.map(([name]) =>\n          name.length > 10 ? name.slice(0, 10) + \"…\" : name\n        );\n        return {\n          chart: {\n            type: \"bar\",\n            background: \"transparent\",\n            toolbar: { show: false },\n            fontFamily: CHART_FONT,\n            stacked: true,\n            animations: { enabled: true, speed: 500 },\n          },\n          colors: [\"#06b6d4\", \"#D97706\"],\n          plotOptions: {\n            bar: { columnWidth: \"50%\", borderRadius: 2, borderRadiusApplication: \"end\" },\n          },\n          grid: GRID_OPTS,\n          xaxis: {\n            categories: cats,\n            labels: { style: { ...LABEL_STYLE, fontSize: \"9px\" }, rotate: -25, trim: false },\n            axisBorder: { show: false },\n            axisTicks: { show: false },\n          },\n          yaxis: {\n            labels: { style: LABEL_STYLE, formatter: (v) => Math.round(v) },\n            min: 0,\n          },\n          legend: { show: false },\n          dataLabels: { enabled: false },\n          tooltip: { theme: \"dark\", style: { fontFamily: CHART_FONT } },\n        };\n      },\n      barChartSeries() {\n        return [\n          { name: \"Active\", data: this.topOperations.map(([, v]) => v.active) },\n          { name: \"Closed\", data: this.topOperations.map(([, v]) => v.closed) },\n        ];\n      },\n\n      // ── Heatmap - activity by day & time ─────────────────────────\n      heatmapSeries() {\n        const periods = [\n          { label: \"Night\", hours: [0, 1, 2, 3, 4, 5] },\n          { label: \"Eve\",   hours: [18, 19, 20, 21, 22, 23] },\n          { label: \"Aft\",   hours: [12, 13, 14, 15, 16, 17] },\n          { label: \"Morn\",  hours: [6,  7,  8,  9,  10, 11] },\n        ];\n        const days = [\"Sun\", \"Mon\", \"Tue\", \"Wed\", \"Thu\", \"Fri\", \"Sat\"];\n        return periods.map((period) => ({\n          name: period.label,\n          data: days.map((day, dayIdx) => ({\n            x: day,\n            y: this.recentRecords.filter((r) => {\n              if (!r.createdAt) return false;\n              const d = new Date(r.createdAt);\n              return d.getDay() === dayIdx && period.hours.includes(d.getHours());\n            }).length,\n          })),\n        }));\n      },\n      heatmapOptions() {\n        return {\n          chart: {\n            type: \"heatmap\",\n            background: \"transparent\",\n            toolbar: { show: false },\n            fontFamily: CHART_FONT,\n            animations: { enabled: false },\n          },\n          dataLabels: {\n            enabled: true,\n            style: { colors: [\"#e2e8f0\"], fontSize: \"11px\", fontFamily: CHART_FONT },\n          },\n          plotOptions: {\n            heatmap: {\n              radius: 3,\n              useFillColorAsStroke: false,\n              colorScale: {\n                ranges: [\n                  { from: 0, to: 0,   color: \"#1c1f28\", name: \"0\"   },\n                  { from: 1, to: 2,   color: \"#7f1d1d\", name: \"1–2\" },\n                  { from: 3, to: 5,   color: \"#b91c1c\", name: \"3–5\" },\n                  { from: 6, to: 999, color: \"#ef4444\", name: \"6+\"  },\n                ],\n              },\n            },\n          },\n          xaxis: {\n            labels: { style: LABEL_STYLE },\n            axisBorder: { show: false },\n            axisTicks: { show: false },\n          },\n          yaxis: { labels: { style: LABEL_STYLE } },\n          legend: { show: false },\n          tooltip: { theme: \"dark\", style: { fontFamily: CHART_FONT } },\n          grid: { padding: { right: 0, top: 0 } },\n        };\n      },\n    },\n\n    components: { Icon },\n\n    methods: {\n      async loadRecentRecords() {\n        this.isLoadingRecords = true;\n        this.chartReady = false;\n        this.recordsError = \"\";\n        try {\n          const res = await API.get(\"/records\");\n          this.recentRecords = Array.isArray(res.data) ? res.data : [];\n        } catch (err) {\n          this.recordsError = err.response?.data?.message || \"Unable to load records.\";\n        } finally {\n          this.isLoadingRecords = false;\n          await this.$nextTick();\n          this.chartReady = true;\n        }\n      },\n\n      formatRecordName(r) {\n        const i = r.personalInformation || {};\n        return [i.firstName, i.middleName, i.lastName].filter(Boolean).join(\" \");\n      },\n      formatRecordCreatedAt(r) {\n        return r.createdAt ? new Date(r.createdAt).toLocaleDateString() : \"—\";\n      },\n    },\n\n    mounted() {\n      this.loadRecentRecords();\n    },\n  };\n</script>\n"]},"metadata":{},"sourceType":"module"}