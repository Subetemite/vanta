MAAMnC,GAAG,CAACoH,GAAG,CAAC,YAAY,IAAI,CAAC/F,gBAAgB,EAAE,EAAE,IAAI,CAACD,IAAI,IAC5D,MAAMpB,GAAG,CAACqH,IAAI,CAAC,UAAU,EAAE,IAAI,CAACjG,IAAI,CAAC;QAEzC,MAAMkG,cAAa,GACjBlD,QAAQ,CAACjD,IAAI,CAACY,OAAM,KACnB,IAAI,CAACI,SAAQ,GACV,oCAAmC,GACnC,kCAAkC,CAAC;QAEzC,MAAM,IAAI,CAACgC,UAAU,CAAC,CAAC;QACvB,IAAI,IAAI,CAAChC,SAAQ,IAAKiC,QAAQ,CAACjD,IAAI,CAACoG,MAAM,EAAE;UAC1C,IAAI,CAACtB,YAAY,CAAC7B,QAAQ,CAACjD,IAAI,CAACoG,MAAM,EAAE;YAAEpB,eAAe,EAAE;UAAK,CAAC,CAAC;QACpE,OAAO;UACL,IAAI,CAACG,cAAc,CAAC;YAAEH,eAAe,EAAE;UAAK,CAAC,CAAC;QAChD;QACA,MAAM,IAAI,CAACtC,UAAU,CAAC,SAAS,EAAEyD,cAAc,CAAC;MAClD,EAAE,OAAO9C,KAAK,EAAE;QACd,MAAM,IAAI,CAACX,UAAU,CACnB,OAAO,EACPW,KAAK,CAACJ,QAAQ,EAAEjD,IAAI,EAAEY,OAAM,IAC1B,4CACJ,CAAC;MACH,UAAU;QACR,IAAI,CAACT,YAAW,GAAI,KAAK;MAC3B;IACF;EACF,CAAC;EACDkG,OAAOA,GAAG;IACR,IAAI,CAACrD,UAAU,CAAC,CAAC;IACjB,IAAI,CAACM,cAAc,CAAC,CAAC;EACvB;AACF,CAAC","names":["nextTick","API","ConfirmationDialog","FormField","FormSection","ProfileUploadSection","createConfirmationDialogState","createRecordConfirmationDialog","resolveConfirmation","createEmptyProfilePhoto","createFormFromRecord","createInitialForm","fieldClass","selectOptions","createProfilePhotoFromFile","formatPersonMeta","formatPersonName","getPersonInitials","name","components","data","form","selectedRecordId","isSubmitting","profilePreview","people","operationOptions","peopleSearch","isLoadingPeople","peopleError","confirmationDialog","confirmationResolver","message","type","text","computed","isEditing","Boolean","filteredPeople","keyword","toLowerCase","filter","person","info","personalInformation","haystack","firstName","middleName","lastName","alias","nationality","country","join","includes","profileSummary","profilePhoto","fileName","sizeInKb","size","toFixed","mimeType","methods","setMessage","$refs","messageBanner","scrollIntoView","behavior","block","loadPeople","response","get","Array","isArray","error","loadOperations","formatOperationOption","operation","operationCodeName","operationId","formatOperationDateForRecord","value","date","Date","Number","isNaN","getTime","toISOString","slice","handleOperationSelection","selectedOperation","find","operationDetails","operationName","operationDate","actualDateTime","plannedDateTime","operationAddress","fullAddress","selectPerson","options","preserveMessage","_id","dataUrl","resetFormState","openConfirmationDialog","Promise","resolve","closeConfirmationDialog","confirmed","handleProfileUpload","event","file","target","files","handleSubmit","sex","birthDate","put","post","successMessage","record","mounted"],"sourceRoot":"","sources":["D:\\joremiodotonline\\dashboard\\src\\views\\records\\RegisterRecord.vue"],"sourcesContent":["<template>\n  <div class=\"min-h-screen bg-case-bg\">\n    <div class=\"mx-auto max-w-[1800px]\">\n      <div class=\"overflow-hidden lg:grid lg:grid-cols-[0.95fr_1.25fr] lg:min-h-screen\">\n        <section class=\"bg-case-surface border-b lg:border-b-0 lg:border-r border-case-border px-8 py-10 sm:px-10 lg:px-12\">\n            <p class=\"text-sm font-semibold uppercase tracking-[0.35em] text-primary\">\n              Records\n            </p>\n             \n\n            <div class=\"mt-8\">\n              <label for=\"peopleSearch\" class=\"text-xs font-semibold uppercase tracking-[0.25em] text-cyan-100/80\">\n                Search  \n              </label>\n              <input\n                id=\"peopleSearch\"\n                v-model.trim=\"peopleSearch\"\n                type=\"text\"\n                class=\"mt-3 w-full rounded-xl border border-case-border bg-case-card px-4 py-3 text-gray-200 placeholder:text-gray-600 outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10\"\n                placeholder=\"Search by name, alias, nationality, or country\"\n              />\n            </div>\n\n            <div class=\"records-scrollbar mt-8 max-h-[34rem] overflow-y-auto pr-1\">\n              <div\n                v-if=\"isLoadingPeople\"\n                class=\"rounded-xl border border-case-border bg-case-card p-5 text-sm text-gray-500\"\n              >\n                Loading registered people...\n              </div>\n              <div\n                v-else-if=\"peopleError\"\n                class=\"rounded-xl border border-red-900/50 bg-red-950/30 p-5 text-sm text-red-400\"\n              >\n                {{ peopleError }}\n              </div>\n              <div\n                v-else-if=\"!filteredPeople.length\"\n                class=\"rounded-xl border border-case-border bg-case-card p-5 text-sm text-gray-500\"\n              >\n                No matching people found.\n              </div>\n              <div\n                v-for=\"person in filteredPeople\"\n                :key=\"person._id\"\n                class=\"mt-4 flex w-full items-center gap-4 rounded-xl border p-4 text-left transition cursor-pointer first:mt-0\"\n                :class=\"selectedRecordId === person._id ? 'border-primary/40 bg-primary/5 ring-1 ring-primary/20' : 'border-case-border bg-case-card hover:bg-case-elevated'\"\n                role=\"button\"\n                tabindex=\"0\"\n                @click=\"selectPerson(person)\"\n              >\n                <img\n                  v-if=\"person.profilePhoto?.dataUrl\"\n                  :src=\"person.profilePhoto.dataUrl\"\n                  :alt=\"formatPersonName(person)\"\n                  class=\"h-16 w-16 rounded-2xl object-cover ring-2 ring-white/20\"\n                />\n                <div\n                  v-else\n                  class=\"flex h-16 w-16 items-center justify-center rounded-xl bg-case-elevated text-sm font-semibold uppercase text-gray-400 ring-1 ring-case-border\"\n                >\n                  {{ getPersonInitials(person) }}\n                </div>\n                <div class=\"text-sm\">\n                  <p class=\"font-medium text-gray-200\">{{ formatPersonName(person) }}</p>\n                  <p class=\"mt-1 text-gray-500\">{{ formatPersonMeta(person) }}</p>\n                </div>\n              </div>\n            </div>\n          </section>\n\n          <section class=\"bg-case-bg px-6 py-8 sm:px-8 lg:px-10\">\n            <div class=\"mb-8\">\n              <p class=\"text-xs font-semibold uppercase tracking-[0.3em] text-primary\">\n                Information Entry\n              </p>\n              <h2 class=\"mt-3 text-2xl font-semibold text-white\">\n                {{ isEditing ? \"Edit record\" : \"Record details\" }}\n              </h2>\n              <p class=\"mt-2 text-sm leading-7 text-gray-500\">\n                {{ isEditing ? \"Update the selected person and save the latest information.\" : \"Create a new registration record.\" }}\n              </p>\n              <div v-if=\"isEditing\" class=\"mt-4 flex flex-wrap items-center gap-3\">\n                <span class=\"rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-primary\">\n                  Editing selected record\n                </span>\n                <button\n                  type=\"button\"\n                  class=\"rounded-full border border-case-border px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-gray-400 transition hover:bg-case-elevated hover:text-gray-200\"\n                  @click=\"resetFormState\"\n                >\n                  New record\n                </button>\n              </div>\n            </div>\n\n            <form class=\"space-y-8\" @submit.prevent=\"handleSubmit\">\n              <div\n                ref=\"messageBanner\"\n                v-if=\"message.text\"\n                :class=\"message.type === 'success' ? 'border-emerald-800/50 bg-emerald-950/30 text-emerald-400' : 'border-red-900/50 bg-red-950/30 text-red-400'\"\n                class=\"rounded-xl border px-4 py-3 text-sm\"\n              >\n                {{ message.text }}\n              </div>\n\n              <FormSection\n                title=\"Personal Information\"\n                badge-text=\"Required\"\n                badge-class=\"bg-primary/10 text-primary\"\n              >\n                <div class=\"grid gap-5 sm:grid-cols-2\">\n                  <FormField label=\"First name\" for-id=\"firstName\">\n                    <input\n                      id=\"firstName\"\n                      v-model.trim=\"form.personalInformation.firstName\"\n                      type=\"text\"\n                      :class=\"fieldClass\"\n                      placeholder=\"Juan\"\n                    />\n                  </FormField>\n\n                  <FormField label=\"Middle name\" for-id=\"middleName\">\n                    <input\n                      id=\"middleName\"\n                      v-model.trim=\"form.personalInformation.middleName\"\n                      type=\"text\"\n                      :class=\"fieldClass\"\n                      placeholder=\"Santos\"\n                    />\n                  </FormField>\n\n                  <FormField label=\"Alias\" for-id=\"alias\">\n                    <input\n                      id=\"alias\"\n                      v-model.trim=\"form.personalInformation.alias\"\n                      type=\"text\"\n                      :class=\"fieldClass\"\n                      placeholder=\"Jun\"\n                    />\n                  </FormField>\n\n                  <FormField label=\"Last name\" for-id=\"lastName\">\n                    <input\n                      id=\"lastName\"\n                      v-model.trim=\"form.personalInformation.lastName\"\n                      type=\"text\"\n                      :class=\"fieldClass\"\n                      placeholder=\"Dela Cruz\"\n                    />\n                  </FormField>\n\n                  <FormField label=\"Birth date\" for-id=\"birthDate\">\n                    <input\n                      id=\"birthDate\"\n                      v-model=\"form.personalInformation.birthDate\"\n                      type=\"date\"\n                      :class=\"fieldClass\"\n                    />\n                  </FormField>\n\n                  <FormField label=\"Sex\" for-id=\"sex\">\n                    <select\n                      id=\"sex\"\n                      v-model=\"form.personalInformation.sex\"\n                      :class=\"fieldClass\"\n                    >\n                      <option disabled value=\"\">Select sex</option>\n                      <option\n                        v-for=\"sex in selectOptions.sex\"\n                        :key=\"sex\"\n                        :value=\"sex\"\n                      >\n                        {{ sex }}\n                      </option>\n                    </select>\n                  </FormField>\n\n                  <FormField label=\"Civil status\" for-id=\"civilStatus\">\n                    <select\n                      id=\"civilStatus\"\n                      v-model=\"form.personalInformation.civilStatus\"\n                      :class=\"fieldClass\"\n                    >\n                      <option disabled value=\"\">Select civil status</option>\n                      <option\n                        v-for=\"civilStatus in selectOptions.civilStatus\"\n                        :key=\"civilStatus\"\n                        :value=\"civilStatus\"\n                      >\n                        {{ civilStatus }}\n                      </option>\n                    </select>\n                  </FormField>\n\n                  <FormField label=\"Contact number\" for-id=\"contactNumber\">\n                    <input\n                      id=\"contactNumber\"\n                      v-model.trim=\"form.personalInformation.contactNumber\"\n                      type=\"text\"\n                      :class=\"fieldClass\"\n                      placeholder=\"09171234567\"\n                    />\n                  </FormField>\n\n                  <FormField label=\"Email address\" for-id=\"emailAddress\">\n                    <input\n                      id=\"emailAddress\"\n                      v-model.trim=\"form.personalInformation.emailAddress\"\n                      type=\"email\"\n                      :class=\"fieldClass\"\n                      placeholder=\"juan@example.com\"\n                    />\n                  </FormField>\n\n                  <FormField label=\"Nationality\" for-id=\"nationality\">\n                    <select\n                      id=\"nationality\"\n                      v-model=\"form.personalInformation.nationality\"\n                      :class=\"fieldClass\"\n                    >\n                      <option disabled value=\"\">Select nationality</option>\n                      <option\n                        v-for=\"nationality in selectOptions.nationality\"\n                        :key=\"nationality\"\n                        :value=\"nationality\"\n                      >\n                        {{ nationality }}\n                      </option>\n                    </select>\n                  </FormField>\n\n                  <FormField label=\"Country\" for-id=\"country\">\n                    <select\n                      id=\"country\"\n                      v-model=\"form.personalInformation.country\"\n                      :class=\"fieldClass\"\n                    >\n                      <option disabled value=\"\">Select country</option>\n                      <option\n                        v-for=\"country in selectOptions.country\"\n                        :key=\"country\"\n                        :value=\"country\"\n                      >\n                        {{ country }}\n                      </option>\n                    </select>\n                  </FormField>\n\n                  <FormField label=\"Address\" for-id=\"address\" wrapper-class=\"sm:col-span-2\">\n                    <textarea\n                      id=\"address\"\n                      v-model.trim=\"form.personalInformation.address\"\n                      rows=\"3\"\n                      :class=\"fieldClass\"\n                      placeholder=\"House no., street, barangay, municipality\"\n                    />\n                  </FormField>\n                </div>\n              </FormSection>\n\n              <FormSection\n                title=\"Operation Details\"\n                badge-text=\"Additional\"\n                badge-class=\"bg-case-elevated text-gray-400\"\n              >\n                <div class=\"grid gap-5 sm:grid-cols-2\">\n                  <FormField label=\"Operation name\" for-id=\"operationName\">\n                    <select\n                      id=\"operationName\"\n                      v-model=\"form.operationDetails.operationName\"\n                      @change=\"handleOperationSelection\"\n                      :class=\"fieldClass\"\n                    >\n                      <option disabled value=\"\">Select operation</option>\n                      <option\n                        v-for=\"operation in operationOptions\"\n                        :key=\"operation._id\"\n                        :value=\"operation.operationCodeName\"\n                      >\n                        {{ formatOperationOption(operation) }}\n                      </option>\n                    </select>\n                  </FormField>\n\n                  <FormField label=\"Operation date\" for-id=\"operationDate\">\n                    <input\n                      id=\"operationDate\"\n                      v-model=\"form.operationDetails.operationDate\"\n                      type=\"date\"\n                      :class=\"fieldClass\"\n                    />\n                  </FormField>\n\n                  <FormField label=\"Operation address\" for-id=\"operationAddress\" wrapper-class=\"sm:col-span-2\">\n                    <textarea\n                      id=\"operationAddress\"\n                      v-model.trim=\"form.operationDetails.operationAddress\"\n                      rows=\"3\"\n                      :class=\"fieldClass\"\n                      placeholder=\"Street, barangay, municipality, province\"\n                    />\n                  </FormField>\n\n                  <FormField label=\"Disposition\" for-id=\"disposition\">\n                    <select\n                      id=\"disposition\"\n                      v-model=\"form.operationDetails.disposition\"\n                      :class=\"fieldClass\"\n                    >\n                      <option disabled value=\"\">Select disposition</option>\n                      <option\n                        v-for=\"disposition in selectOptions.disposition\"\n                        :key=\"disposition\"\n                        :value=\"disposition\"\n                      >\n                        {{ disposition }}\n                      </option>\n                    </select>\n                  </FormField>\n\n                  <FormField label=\"Visa status\" for-id=\"visaStatus\">\n                    <select\n                      id=\"visaStatus\"\n                      v-model=\"form.operationDetails.visaStatus\"\n                      :class=\"fieldClass\"\n                    >\n                      <option disabled value=\"\">Select visa status</option>\n                      <option\n                        v-for=\"visaStatus in selectOptions.visaStatus\"\n                        :key=\"visaStatus\"\n                        :value=\"visaStatus\"\n                      >\n                        {{ visaStatus }}\n                      </option>\n                    </select>\n                  </FormField>\n\n                  <FormField label=\"Remarks\" for-id=\"remarks\" wrapper-class=\"sm:col-span-2\">\n                    <textarea\n                      id=\"remarks\"\n                      v-model.trim=\"form.operationDetails.remarks\"\n                      rows=\"3\"\n                      :class=\"fieldClass\"\n                      placeholder=\"Additional notes about the operation or person\"\n                    />\n                  </FormField>\n\n                  <FormField label=\"Actions\" for-id=\"actions\" wrapper-class=\"sm:col-span-2\">\n                    <textarea\n                      id=\"actions\"\n                      v-model.trim=\"form.operationDetails.actions\"\n                      rows=\"3\"\n                      :class=\"fieldClass\"\n                      placeholder=\"Documented actions taken\"\n                    />\n                  </FormField>\n                </div>\n              </FormSection>\n\n              <FormSection\n                title=\"Biometrics\"\n                badge-text=\"Optional\"\n                badge-class=\"bg-cyan-900/20 text-cyan-400\"\n              >\n                <div class=\"grid gap-5 sm:grid-cols-2\">\n                  <FormField label=\"Height (cm)\" for-id=\"heightCm\">\n                    <input\n                      id=\"heightCm\"\n                      v-model=\"form.biometrics.heightCm\"\n                      type=\"number\"\n                      min=\"0\"\n                      step=\"0.01\"\n                      :class=\"fieldClass\"\n                      placeholder=\"165\"\n                    />\n                  </FormField>\n\n                  <FormField label=\"Weight (kg)\" for-id=\"weightKg\">\n                    <input\n                      id=\"weightKg\"\n                      v-model=\"form.biometrics.weightKg\"\n                      type=\"number\"\n                      min=\"0\"\n                      step=\"0.01\"\n                      :class=\"fieldClass\"\n                      placeholder=\"60\"\n                    />\n                  </FormField>\n\n                  <FormField label=\"Blood type\" for-id=\"bloodType\">\n                    <select\n                      id=\"bloodType\"\n                      v-model=\"form.biometrics.bloodType\"\n                      :class=\"fieldClass\"\n                    >\n                      <option disabled value=\"\">Select blood type</option>\n                      <option\n                        v-for=\"bloodType in selectOptions.bloodType\"\n                        :key=\"bloodType\"\n                        :value=\"bloodType\"\n                      >\n                        {{ bloodType }}\n                      </option>\n                    </select>\n                  </FormField>\n\n                  <FormField label=\"Fingerprint code\" for-id=\"fingerprintCode\">\n                    <input\n                      id=\"fingerprintCode\"\n                      v-model.trim=\"form.biometrics.fingerprintCode\"\n                      type=\"text\"\n                      :class=\"fieldClass\"\n                      placeholder=\"FP-2026-0001\"\n                    />\n                  </FormField>\n\n                  <FormField label=\"Eye color\" for-id=\"eyeColor\">\n                    <select\n                      id=\"eyeColor\"\n                      v-model=\"form.biometrics.eyeColor\"\n                      :class=\"fieldClass\"\n                    >\n                      <option disabled value=\"\">Select eye color</option>\n                      <option\n                        v-for=\"eyeColor in selectOptions.eyeColor\"\n                        :key=\"eyeColor\"\n                        :value=\"eyeColor\"\n                      >\n                        {{ eyeColor }}\n                      </option>\n                    </select>\n                  </FormField>\n\n                  <FormField label=\"Hair color\" for-id=\"hairColor\">\n                    <select\n                      id=\"hairColor\"\n                      v-model=\"form.biometrics.hairColor\"\n                      :class=\"fieldClass\"\n                    >\n                      <option disabled value=\"\">Select hair color</option>\n                      <option\n                        v-for=\"hairColor in selectOptions.hairColor\"\n                        :key=\"hairColor\"\n                        :value=\"hairColor\"\n                      >\n                        {{ hairColor }}\n                      </option>\n                    </select>\n                  </FormField>\n\n                  <FormField label=\"Complexion\" for-id=\"complexion\">\n                    <select\n                      id=\"complexion\"\n                      v-model=\"form.biometrics.complexion\"\n                      :class=\"fieldClass\"\n                    >\n                      <option disabled value=\"\">Select complexion</option>\n                      <option\n                        v-for=\"complexion in selectOptions.complexion\"\n                        :key=\"complexion\"\n                        :value=\"complexion\"\n                      >\n                        {{ complexion }}\n                      </option>\n                    </select>\n                  </FormField>\n\n                  <FormField label=\"Distinguishing marks\" for-id=\"distinguishingMarks\" wrapper-class=\"sm:col-span-2\">\n                    <textarea\n                      id=\"distinguishingMarks\"\n                      v-model.trim=\"form.biometrics.distinguishingMarks\"\n                      rows=\"3\"\n                      :class=\"fieldClass\"\n                      placeholder=\"Birthmark on left cheek, scar on right hand\"\n                    />\n                  </FormField>\n                </div>\n              </FormSection>\n\n              <ProfileUploadSection\n                :file-name=\"form.profilePhoto.fileName\"\n                :profile-summary=\"profileSummary\"\n                :profile-preview=\"profilePreview\"\n                @change=\"handleProfileUpload\"\n              />\n\n              <button\n                type=\"submit\"\n                class=\"flex w-full items-center justify-center rounded-xl bg-primary px-4 py-3.5 text-sm font-semibold text-black transition hover:bg-amber-500 disabled:cursor-not-allowed disabled:opacity-50\"\n                :disabled=\"isSubmitting\"\n              >\n                {{ isSubmitting ? \"Saving registration...\" : \"Save registration\" }}\n              </button>\n            </form>\n          </section>\n      </div>\n    </div>\n\n    <ConfirmationDialog\n      :visible=\"confirmationDialog.visible\"\n      :title=\"confirmationDialog.title\"\n      :description=\"confirmationDialog.description\"\n      :confirm-text=\"confirmationDialog.confirmText\"\n      @cancel=\"closeConfirmationDialog(false)\"\n      @confirm=\"closeConfirmationDialog(true)\"\n    />\n  </div>\n</template>\n\n<script>\n  import { nextTick } from \"vue\";\n  import API from \"@/services/api\";\n  import ConfirmationDialog from \"@/components/ConfirmationDialog.vue\";\n  import FormField from \"@/components/FormField.vue\";\n  import FormSection from \"@/components/FormSection.vue\";\n  import ProfileUploadSection from \"@/components/ProfileUploadSection.vue\";\n  import {\n    createConfirmationDialogState,\n    createRecordConfirmationDialog,\n    resolveConfirmation,\n  } from \"@/helper/record-confirmation\";\n  import {\n    createEmptyProfilePhoto,\n    createFormFromRecord,\n    createInitialForm,\n    fieldClass,\n    selectOptions,\n  } from \"@/helper/record-form\";\n  import { createProfilePhotoFromFile } from \"@/helper/record-upload\";\n  import {\n    formatPersonMeta,\n    formatPersonName,\n    getPersonInitials,\n  } from \"@/helper/record-person\";\n\n  export default {\n    name: \"RegisterRecord\",\n    components: {\n      ConfirmationDialog,\n      FormField,\n      FormSection,\n      ProfileUploadSection,\n    },\n    data() {\n      return {\n        form: createInitialForm(),\n        selectedRecordId: \"\",\n        isSubmitting: false,\n        profilePreview: \"\",\n        people: [],\n        operationOptions: [],\n        peopleSearch: \"\",\n        isLoadingPeople: false,\n        peopleError: \"\",\n        confirmationDialog: createConfirmationDialogState(),\n        confirmationResolver: null,\n        fieldClass,\n        selectOptions,\n        message: {\n          type: \"\",\n          text: \"\",\n        },\n      };\n    },\n    computed: {\n      isEditing() {\n        return Boolean(this.selectedRecordId);\n      },\n      filteredPeople() {\n        const keyword = this.peopleSearch.toLowerCase();\n\n        if (!keyword) {\n          return this.people;\n        }\n\n        return this.people.filter((person) => {\n          const info = person.personalInformation || {};\n          const haystack = [\n            info.firstName,\n            info.middleName,\n            info.lastName,\n            info.alias,\n            info.nationality,\n            info.country,\n          ]\n            .filter(Boolean)\n            .join(\" \")\n            .toLowerCase();\n\n          return haystack.includes(keyword);\n        });\n      },\n      profileSummary() {\n        if (!this.form.profilePhoto.fileName) {\n          return \"No image selected yet.\";\n        }\n\n        const sizeInKb = this.form.profilePhoto.size\n          ? `${(this.form.profilePhoto.size / 1024).toFixed(1)} KB`\n          : \"Unknown size\";\n\n        return `${this.form.profilePhoto.mimeType || \"Image\"} | ${sizeInKb}`;\n      },\n    },\n    methods: {\n      async setMessage(type, text) {\n        this.message = { type, text };\n        await nextTick();\n        this.$refs.messageBanner?.scrollIntoView({\n          behavior: \"smooth\",\n          block: \"center\",\n        });\n      },\n      async loadPeople() {\n        this.isLoadingPeople = true;\n        this.peopleError = \"\";\n\n        try {\n          const response = await API.get(\"/records\");\n          this.people = Array.isArray(response.data) ? response.data : [];\n        } catch (error) {\n          this.peopleError =\n            error.response?.data?.message ||\n            \"Unable to load registered people right now.\";\n        } finally {\n          this.isLoadingPeople = false;\n        }\n      },\n      async loadOperations() {\n        try {\n          const response = await API.get(\"/operations\");\n          this.operationOptions = Array.isArray(response.data) ? response.data : [];\n        } catch (error) {\n          this.operationOptions = [];\n        }\n      },\n      formatPersonName,\n      getPersonInitials,\n      formatPersonMeta,\n      formatOperationOption(operation) {\n        return [operation.operationCodeName, operation.operationId ? `(${operation.operationId})` : null]\n          .filter(Boolean)\n          .join(\" \");\n      },\n      formatOperationDateForRecord(value) {\n        if (!value) {\n          return \"\";\n        }\n\n        const date = new Date(value);\n        if (Number.isNaN(date.getTime())) {\n          return \"\";\n        }\n\n        return date.toISOString().slice(0, 10);\n      },\n      handleOperationSelection() {\n        const selectedOperation = this.operationOptions.find(\n          (operation) =>\n            operation.operationCodeName === this.form.operationDetails.operationName\n        );\n\n        if (!selectedOperation) {\n          return;\n        }\n\n        this.form.operationDetails.operationDate = this.formatOperationDateForRecord(\n          selectedOperation.actualDateTime || selectedOperation.plannedDateTime\n        );\n        this.form.operationDetails.operationAddress =\n          selectedOperation.fullAddress || \"\";\n      },\n      selectPerson(person, options = {}) {\n        const { preserveMessage = false } = options;\n        if (!preserveMessage) {\n          this.message = { type: \"\", text: \"\" };\n        }\n        this.selectedRecordId = person._id;\n        this.form = createFormFromRecord(person);\n        this.profilePreview = person.profilePhoto?.dataUrl || \"\";\n      },\n      resetFormState(options = {}) {\n        const { preserveMessage = false } = options;\n        this.selectedRecordId = \"\";\n        this.form = createInitialForm();\n        this.profilePreview = \"\";\n        if (!preserveMessage) {\n          this.message = { type: \"\", text: \"\" };\n        }\n      },\n      openConfirmationDialog() {\n        this.confirmationDialog = createRecordConfirmationDialog(this.isEditing);\n\n        return new Promise((resolve) => {\n          this.confirmationResolver = resolve;\n        });\n      },\n      closeConfirmationDialog(confirmed) {\n        this.confirmationDialog = createConfirmationDialogState();\n        resolveConfirmation(this.confirmationResolver, confirmed);\n        this.confirmationResolver = null;\n      },\n      async handleProfileUpload(event) {\n        this.message = { type: \"\", text: \"\" };\n        const [file] = event.target.files || [];\n\n        if (!file) {\n          this.form.profilePhoto = createEmptyProfilePhoto();\n          this.profilePreview = \"\";\n          return;\n        }\n\n        if (file.size > 2 * 1024 * 1024) {\n          await this.setMessage(\"error\", \"Please upload an image that is 2 MB or smaller.\");\n          event.target.value = \"\";\n          return;\n        }\n\n        this.form.profilePhoto = await createProfilePhotoFromFile(file);\n        this.profilePreview = this.form.profilePhoto.dataUrl;\n      },\n      async handleSubmit() {\n        this.message = { type: \"\", text: \"\" };\n\n        if (\n          !this.form.personalInformation.firstName ||\n          !this.form.personalInformation.lastName ||\n          !this.form.personalInformation.sex ||\n          !this.form.personalInformation.birthDate\n        ) {\n          await this.setMessage(\"error\", \"First name, last name, sex, and birth date are required.\");\n          return;\n        }\n\n        const confirmed = await this.openConfirmationDialog();\n\n        if (!confirmed) {\n          return;\n        }\n\n        this.isSubmitting = true;\n\n        try {\n          const response = this.isEditing\n            ? await API.put(`/records/${this.selectedRecordId}`, this.form)\n            : await API.post(\"/records\", this.form);\n\n          const successMessage =\n            response.data.message ||\n            (this.isEditing\n              ? \"Registration updated successfully.\"\n              : \"Registration saved successfully.\");\n\n          await this.loadPeople();\n          if (this.isEditing && response.data.record) {\n            this.selectPerson(response.data.record, { preserveMessage: true });\n          } else {\n            this.resetFormState({ preserveMessage: true });\n          }\n          await this.setMessage(\"success\", successMessage);\n        } catch (error) {\n          await this.setMessage(\n            \"error\",\n            error.response?.data?.message ||\n              \"Unable to save the registration right now.\"\n          );\n        } finally {\n          this.isSubmitting = false;\n        }\n      },\n    },\n    mounted() {\n      this.loadPeople();\n      this.loadOperations();\n    },\n  };\n</script>\n\n<style scoped>\n  .records-scrollbar {\n    scrollbar-width: thin;\n    scrollbar-color: rgba(125, 211, 252, 0.6) rgba(255, 255, 255, 0.06);\n  }\n\n  .records-scrollbar::-webkit-scrollbar {\n    width: 10px;\n  }\n\n  .records-scrollbar::-webkit-scrollbar-track {\n    border-radius: 9999px;\n    background: rgba(255, 255, 255, 0.06);\n  }\n\n  .records-scrollbar::-webkit-scrollbar-thumb {\n    border: 2px solid transparent;\n    border-radius: 9999px;\n    background: linear-gradient(180deg, rgba(125, 211, 252, 0.85), rgba(59, 130, 246, 0.75));\n    background-clip: padding-box;\n  }\n\n  .records-scrollbar::-webkit-scrollbar-thumb:hover {\n    background: linear-gradient(180deg, rgba(165, 243, 252, 0.95), rgba(96, 165, 250, 0.85));\n    background-clip: padding-box;\n  }\n</style>\n"]},"metadata":{},"sourceType":"module"}