{"ast":null,"code":"import { Icon } from \"@iconify/vue\";\nconst MODULES = [{\n  key: \"admin\",\n  title: \"ADMIN\",\n  icon: \"mdi:account-multiple-outline\",\n  to: \"/admin\",\n  description: \"Personnel, timekeeping, calendar of activities, and documents tracking system.\",\n  features: [\"HRIS\", \"Daily Time Record\", \"OPCR\", \"Calendar\", \"Documents Tracking\"]\n}, {\n  key: \"cases\",\n  title: \"Case Management\",\n  icon: \"mdi:shield-search\",\n  to: \"/cases\",\n  description: \"Economic sabotage, ANTI-POGO, organized crime, graft & corruption.\",\n  features: [\"4-Focus Operations\", \"18 Crime Clusters\", \"Inter-Agency\", \"SOCTA Handbook\"]\n}, {\n  key: \"logistics\",\n  title: \"Assets Management\",\n  icon: \"mdi:truck-fast-outline\",\n  to: \"/logistics\",\n  description: \"Asset, supply, vehicle and operational support tracking.\",\n  features: [\"Inventory\", \"Fleet & Vehicles\", \"Requisitions\", \"Suppliers\", \"Maintenance\"]\n}, {\n  key: \"operations\",\n  title: \"Operations\",\n  icon: \"mdi:target\",\n  to: \"/operations\",\n  description: \"Mission planning, deployments, situation reports and after-action reviews.\",\n  features: [\"Missions\", \"Deployments\", \"SITREPs\", \"After-Action Reports\"]\n}, {\n  key: \"social\",\n  title: \"Communication\",\n  icon: \"mdi:account-search-outline\",\n  to: \"/social\",\n  description: \"Social account monitoring, posts, alerts and analyst campaigns.\",\n  features: [\"Accounts\", \"Posts\", \"Alerts\", \"Campaigns\"]\n}];\nexport default {\n  name: \"ModulesHome\",\n  components: {\n    Icon\n  },\n  computed: {\n    currentUser() {\n      try {\n        return JSON.parse(localStorage.getItem(\"auth_user\") || \"null\");\n      } catch {\n        return null;\n      }\n    },\n    isAdmin() {\n      return this.currentUser?.role === \"admin\";\n    },\n    allModules() {\n      return MODULES;\n    },\n    visibleModules() {\n      if (this.isAdmin) return MODULES;\n      return MODULES.filter(m => this.hasAccess(m.key));\n    }\n  },\n  methods: {\n    hasAccess(moduleKey) {\n      const user = this.currentUser;\n      if (!user) return false;\n      if (user.role === \"admin\") return true;\n      return Boolean(user.modulePermissions?.[moduleKey]);\n    }\n  }\n};","map":{"version":3,"mappings":"AAgEE,SAASA,IAAG,QAAS,cAAc;AAEnC,MAAMC,OAAM,GAAI,CACd;EACEC,GAAG,EAAE,OAAO;EACZC,KAAK,EAAE,OAAO;EACdC,IAAI,EAAE,8BAA8B;EACpCC,EAAE,EAAE,QAAQ;EACZC,WAAW,EAAE,gFAAgF;EAC7FC,QAAQ,EAAE,CAAC,MAAM,EAAE,mBAAmB,EAAE,MAAM,EAAE,UAAU,EAAE,oBAAoB;AAClF,CAAC,EACD;EACEL,GAAG,EAAE,OAAO;EACZC,KAAK,EAAE,iBAAiB;EACxBC,IAAI,EAAE,mBAAmB;EACzBC,EAAE,EAAE,QAAQ;EACZC,WAAW,EAAE,oEAAoE;EACjFC,QAAQ,EAAE,CAAC,oBAAoB,EAAE,mBAAmB,EAAE,cAAc,EAAE,gBAAgB;AACxF,CAAC,EACD;EACEL,GAAG,EAAE,WAAW;EAChBC,KAAK,EAAE,mBAAmB;EAC1BC,IAAI,EAAE,wBAAwB;EAC9BC,EAAE,EAAE,YAAY;EAChBC,WAAW,EAAE,0DAA0D;EACvEC,QAAQ,EAAE,CAAC,WAAW,EAAE,kBAAkB,EAAE,cAAc,EAAE,WAAW,EAAE,aAAa;AACxF,CAAC,EACD;EACEL,GAAG,EAAE,YAAY;EACjBC,KAAK,EAAE,YAAY;EACnBC,IAAI,EAAE,YAAY;EAClBC,EAAE,EAAE,aAAa;EACjBC,WAAW,EAAE,4EAA4E;EACzFC,QAAQ,EAAE,CAAC,UAAU,EAAE,aAAa,EAAE,SAAS,EAAE,sBAAsB;AACzE,CAAC,EACD;EACEL,GAAG,EAAE,QAAQ;EACbC,KAAK,EAAE,eAAe;EACtBC,IAAI,EAAE,4BAA4B;EAClCC,EAAE,EAAE,SAAS;EACbC,WAAW,EAAE,iEAAiE;EAC9EC,QAAQ,EAAE,CAAC,UAAU,EAAE,OAAO,EAAE,QAAQ,EAAE,WAAW;AACvD,CAAC,CACF;AAED,eAAe;EACbC,IAAI,EAAE,aAAa;EACnBC,UAAU,EAAE;IAAET;EAAK,CAAC;EACpBU,QAAQ,EAAE;IACRC,WAAWA,GAAG;MACZ,IAAI;QACF,OAAOC,IAAI,CAACC,KAAK,CAACC,YAAY,CAACC,OAAO,CAAC,WAAW,KAAK,MAAM,CAAC;MAChE,EAAE,MAAM;QACN,OAAO,IAAI;MACb;IACF,CAAC;IACDC,OAAOA,GAAG;MACR,OAAO,IAAI,CAACL,WAAW,EAAEM,IAAG,KAAM,OAAO;IAC3C,CAAC;IACDC,UAAUA,GAAG;MACX,OAAOjB,OAAO;IAChB,CAAC;IACDkB,cAAcA,GAAG;MACf,IAAI,IAAI,CAACH,OAAO,EAAE,OAAOf,OAAO;MAChC,OAAOA,OAAO,CAACmB,MAAM,CAAEC,CAAC,IAAK,IAAI,CAACC,SAAS,CAACD,CAAC,CAACnB,GAAG,CAAC,CAAC;IACrD;EACF,CAAC;EACDqB,OAAO,EAAE;IACPD,SAASA,CAACE,SAAS,EAAE;MACnB,MAAMC,IAAG,GAAI,IAAI,CAACd,WAAW;MAC7B,IAAI,CAACc,IAAI,EAAE,OAAO,KAAK;MACvB,IAAIA,IAAI,CAACR,IAAG,KAAM,OAAO,EAAE,OAAO,IAAI;MACtC,OAAOS,OAAO,CAACD,IAAI,CAACE,iBAAiB,GAAGH,SAAS,CAAC,CAAC;IACrD;EACF;AACF,CAAC","names":["Icon","MODULES","key","title","icon","to","description","features","name","components","computed","currentUser","JSON","parse","localStorage","getItem","isAdmin","role","allModules","visibleModules","filter","m","hasAccess","methods","moduleKey","user","Boolean","modulePermissions"],"sourceRoot":"","sources":["D:\\joremiodotonline\\dashboard\\src\\views\\ModulesHome.vue"],"sourcesContent":["<template>\n  <div class=\"min-h-screen bg-case-bg px-6 py-10 sm:px-10 lg:px-12\">\n    <header class=\"mb-10 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between\">\n      <div>\n        <p class=\"text-xs uppercase tracking-[0.35em] text-primary\">VANTA Platform</p>\n        <h1 class=\"mt-2 text-2xl font-semibold text-white sm:text-3xl\">\n          {{ isAdmin ? \"Administrator Console\" : \"Pick a module\" }}\n        </h1>\n        <p class=\"mt-1 text-sm text-gray-500\">\n          <template v-if=\"isAdmin\">\n            Full access to all {{ allModules.length }} modules.\n          </template>\n          <template v-else>\n            You have access to {{ visibleModules.length }} module<span v-if=\"visibleModules.length !== 1\">s</span>.\n          </template>\n        </p>\n      </div>\n      <span\n        v-if=\"currentUser\"\n        class=\"inline-flex items-center gap-2 self-start rounded-full border border-case-border bg-case-surface px-3 py-1.5 text-xs text-gray-300 sm:self-auto\"\n      >\n        <span class=\"h-1.5 w-1.5 rounded-full\" :class=\"isAdmin ? 'bg-primary' : 'bg-emerald-400'\"></span>\n        {{ currentUser.username || currentUser.email || \"Signed in\" }}\n        <span class=\"text-[10px] uppercase tracking-[0.2em] text-gray-500\">{{ currentUser.role || \"user\" }}</span>\n      </span>\n    </header>\n\n    <div v-if=\"!visibleModules.length\" class=\"rounded-2xl border border-case-border bg-case-surface p-10 text-center\">\n      <Icon icon=\"mdi:lock-outline\" class=\"mx-auto text-4xl text-gray-600\" />\n      <h2 class=\"mt-3 text-lg font-semibold text-white\">No modules assigned</h2>\n      <p class=\"mt-1 text-sm text-gray-500\">\n        Your account hasn't been granted access to any modules yet. Please contact an administrator.\n      </p>\n    </div>\n\n    <div v-else class=\"grid gap-5 sm:grid-cols-2 lg:grid-cols-3\">\n      <router-link\n        v-for=\"mod in visibleModules\"\n        :key=\"mod.key\"\n        :to=\"mod.to\"\n        class=\"group relative flex flex-col rounded-2xl border border-case-border bg-case-surface p-6 cursor-pointer transition hover:border-primary/40 hover:bg-case-card\"\n      >\n        <div class=\"flex items-center justify-between\">\n          <span class=\"flex h-11 w-11 items-center justify-center rounded-xl bg-primary/10 text-primary\">\n            <Icon :icon=\"mod.icon\" class=\"text-2xl\" />\n          </span>\n          <span class=\"text-[10px] font-semibold uppercase tracking-[0.2em] text-gray-600 transition group-hover:text-primary\">\n            Open <Icon icon=\"mdi:arrow-right\" class=\"ml-0.5 inline-block align-text-bottom text-sm\" />\n          </span>\n        </div>\n        <h2 class=\"mt-5 text-lg font-semibold text-white\">{{ mod.title }}</h2>\n        <p class=\"mt-2 text-sm leading-relaxed text-gray-500\">{{ mod.description }}</p>\n        <ul class=\"mt-4 space-y-1 text-xs text-gray-600\">\n          <li v-for=\"f in mod.features\" :key=\"f\" class=\"flex items-center gap-2\">\n            <span class=\"h-1 w-1 rounded-full bg-primary/60\"></span>\n            {{ f }}\n          </li>\n        </ul>\n      </router-link>\n    </div>\n  </div>\n</template>\n\n<script>\n  import { Icon } from \"@iconify/vue\";\n\n  const MODULES = [\n    {\n      key: \"admin\",\n      title: \"ADMIN\",\n      icon: \"mdi:account-multiple-outline\",\n      to: \"/admin\",\n      description: \"Personnel, timekeeping, calendar of activities, and documents tracking system.\",\n      features: [\"HRIS\", \"Daily Time Record\", \"OPCR\", \"Calendar\", \"Documents Tracking\"],\n    },\n    {\n      key: \"cases\",\n      title: \"Case Management\",\n      icon: \"mdi:shield-search\",\n      to: \"/cases\",\n      description: \"Economic sabotage, ANTI-POGO, organized crime, graft & corruption.\",\n      features: [\"4-Focus Operations\", \"18 Crime Clusters\", \"Inter-Agency\", \"SOCTA Handbook\"],\n    },\n    {\n      key: \"logistics\",\n      title: \"Assets Management\",\n      icon: \"mdi:truck-fast-outline\",\n      to: \"/logistics\",\n      description: \"Asset, supply, vehicle and operational support tracking.\",\n      features: [\"Inventory\", \"Fleet & Vehicles\", \"Requisitions\", \"Suppliers\", \"Maintenance\"],\n    },\n    {\n      key: \"operations\",\n      title: \"Operations\",\n      icon: \"mdi:target\",\n      to: \"/operations\",\n      description: \"Mission planning, deployments, situation reports and after-action reviews.\",\n      features: [\"Missions\", \"Deployments\", \"SITREPs\", \"After-Action Reports\"],\n    },\n    {\n      key: \"social\",\n      title: \"Communication\",\n      icon: \"mdi:account-search-outline\",\n      to: \"/social\",\n      description: \"Social account monitoring, posts, alerts and analyst campaigns.\",\n      features: [\"Accounts\", \"Posts\", \"Alerts\", \"Campaigns\"],\n    },\n  ];\n\n  export default {\n    name: \"ModulesHome\",\n    components: { Icon },\n    computed: {\n      currentUser() {\n        try {\n          return JSON.parse(localStorage.getItem(\"auth_user\") || \"null\");\n        } catch {\n          return null;\n        }\n      },\n      isAdmin() {\n        return this.currentUser?.role === \"admin\";\n      },\n      allModules() {\n        return MODULES;\n      },\n      visibleModules() {\n        if (this.isAdmin) return MODULES;\n        return MODULES.filter((m) => this.hasAccess(m.key));\n      },\n    },\n    methods: {\n      hasAccess(moduleKey) {\n        const user = this.currentUser;\n        if (!user) return false;\n        if (user.role === \"admin\") return true;\n        return Boolean(user.modulePermissions?.[moduleKey]);\n      },\n    },\n  };\n</script>\n"]},"metadata":{},"sourceType":"module"}