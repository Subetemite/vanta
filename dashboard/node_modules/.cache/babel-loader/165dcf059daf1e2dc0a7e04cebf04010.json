{"ast":null,"code":"// Vue components\nimport Sidebar from \"@/components/Sidebar\";\nimport Header from \"@/components/Header\";\n// npm-js\nimport Scrollbar from \"smooth-scrollbar\";\nexport default {\n  name: \"App\",\n  data() {\n    return {\n      sidebarDark: false,\n      sidebar: false\n    };\n  },\n  components: {\n    Header,\n    Sidebar\n  },\n  methods: {\n    open() {\n      this.sidebar = true;\n    },\n    close() {\n      this.sidebar = false;\n    }\n  },\n  watch: {\n    $route() {\n      this.sidebar = false;\n    }\n  },\n  mounted() {\n    Scrollbar.init(document.querySelector(\"#body-scroll\"));\n  }\n};","map":{"version":3,"mappings":"AAoDE;AACA,OAAOA,OAAM,MAAO,sBAAsB;AAC1C,OAAOC,MAAK,MAAO,qBAAqB;AACxC;AACA,OAAOC,SAAQ,MAAO,kBAAkB;AAExC,eAAe;EACbC,IAAI,EAAE,KAAK;EAEXC,IAAIA,GAAG;IACL,OAAO;MACLC,WAAW,EAAE,KAAK;MAClBC,OAAO,EAAE;IACX,CAAC;EACH,CAAC;EAEDC,UAAU,EAAE;IACVN,MAAM;IACND;EACF,CAAC;EACDQ,OAAO,EAAE;IACPC,IAAIA,GAAG;MACL,IAAI,CAACH,OAAM,GAAI,IAAI;IACrB,CAAC;IACDI,KAAKA,GAAG;MACN,IAAI,CAACJ,OAAM,GAAI,KAAK;IACtB;EACF,CAAC;EACDK,KAAK,EAAE;IACLC,MAAMA,GAAG;MACP,IAAI,CAACN,OAAM,GAAI,KAAK;IACtB;EACF,CAAC;EACDO,OAAOA,GAAG;IACRX,SAAS,CAACY,IAAI,CAACC,QAAQ,CAACC,aAAa,CAAC,cAAc,CAAC,CAAC;EACxD;AACF,CAAC","names":["Sidebar","Header","Scrollbar","name","data","sidebarDark","sidebar","components","methods","open","close","watch","$route","mounted","init","document","querySelector"],"sourceRoot":"","sources":["D:\\joremiodotonline\\dashboard\\src\\App.vue"],"sourcesContent":["<template>\n  <!-- App -->\n  <div class=\"flex bg-case-bg font-lexend\">\n    <div\n      v-if=\"!$route.meta.hideNav\"\n      class=\"lg:block\"\n      :class=\"{ 'lg:block hidden': !sidebar, block: sidebar }\"\n    >\n      <div\n        class=\"lg:flex-auto w-sidebar bg-case-surface border-r border-case-border lg:z-0 z-20 overflow-auto lg:relative fixed\"\n      >\n        <perfect-scrollbar class=\"h-screen\">\n          <Sidebar\n            v-if=\"!$route.meta.hideNav\"\n            @sidebarToggle=\"close\"\n          />\n          <!-- <sidebarlist\n            v-if=\"!$route.meta.hideNav\"\n            @sidebarToggle=\"close\"\n          /> -->\n        </perfect-scrollbar>\n      </div>\n    </div>\n\n    <!-- Mobile sidebar overlay -->\n    <div\n      v-if=\"sidebar && !$route.meta.hideNav\"\n      class=\"lg:hidden fixed inset-0 bg-black/60 z-10 backdrop-blur-sm\"\n      @click=\"close\"\n    ></div>\n\n    <div\n      class=\"flex-auto min-w-0 overflow-auto h-screen transition-colors\"\n      id=\"body-scroll\"\n    >\n      <Header\n        v-if=\"!$route.meta.hideNav\"\n        @sidebarToggle=\"open\"\n      />\n\n      <transition\n        name=\"slide-up\"\n        mode=\"out-in\"\n      >\n        <router-view />\n      </transition>\n    </div>\n  </div>\n  <!-- End app -->\n</template>\n\n<script>\n  // Vue components\n  import Sidebar from \"@/components/Sidebar\";\n  import Header from \"@/components/Header\";\n  // npm-js\n  import Scrollbar from \"smooth-scrollbar\";\n\n  export default {\n    name: \"App\",\n\n    data() {\n      return {\n        sidebarDark: false,\n        sidebar: false,\n      };\n    },\n\n    components: {\n      Header,\n      Sidebar,\n    },\n    methods: {\n      open() {\n        this.sidebar = true;\n      },\n      close() {\n        this.sidebar = false;\n      },\n    },\n    watch: {\n      $route() {\n        this.sidebar = false;\n      },\n    },\n    mounted() {\n      Scrollbar.init(document.querySelector(\"#body-scroll\"));\n    },\n  };\n</script>\n\n<style>\n  /*\n  Enter and leave animations can use different\n  durations and timing functions.\n*/\n  .slide-up-enter-active {\n    transition: all 0.3s ease-out;\n  }\n\n  .slide-up-leave-active {\n    transition: all 0.8s cubic-bezier(1, 0.5, 0.8, 1);\n  }\n\n  .slide-up-enter-from,\n  .slide-up-leave-to {\n    transform: translateY(20px);\n    opacity: 0;\n  }\n</style>\n"]},"metadata":{},"sourceType":"module"}