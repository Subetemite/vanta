{"ast":null,"code":"import API from \"@/services/api\";\nexport default {\n  name: \"FilesView\",\n  data() {\n    return {\n      selectedFile: null,\n      isDragOver: false,\n      isUploading: false,\n      isLoadingFiles: false,\n      statusMessage: \"\",\n      statusType: \"success\",\n      filesError: \"\",\n      uploadedFiles: []\n    };\n  },\n  methods: {\n    async loadFiles() {\n      this.isLoadingFiles = true;\n      this.filesError = \"\";\n      try {\n        const response = await API.get(\"/files\");\n        this.uploadedFiles = Array.isArray(response.data.files) ? response.data.files : [];\n      } catch (error) {\n        this.filesError = error.response?.data?.message || \"Unable to load files right now.\";\n      } finally {\n        this.isLoadingFiles = false;\n      }\n    },\n    handleFileChange(event) {\n      const [file] = event.target.files || [];\n      this.setSelectedFile(file);\n    },\n    handleFileDrop(event) {\n      const [file] = event.dataTransfer?.files || [];\n      this.setDragOver(false);\n      this.setSelectedFile(file);\n    },\n    setDragOver(value) {\n      this.isDragOver = value;\n    },\n    triggerFilePicker() {\n      this.$refs.fileInput?.click();\n    },\n    setSelectedFile(file) {\n      this.statusMessage = \"\";\n      this.statusType = \"success\";\n      if (!file) {\n        this.selectedFile = null;\n        return;\n      }\n      if (file.size > 5 * 1024 * 1024) {\n        this.selectedFile = null;\n        this.statusType = \"error\";\n        this.statusMessage = \"Please choose a file that is 5 MB or smaller.\";\n        if (this.$refs.fileInput) {\n          this.$refs.fileInput.value = \"\";\n        }\n        return;\n      }\n      this.selectedFile = file;\n    },\n    clearSelection() {\n      this.selectedFile = null;\n      this.isDragOver = false;\n      this.statusMessage = \"\";\n      this.statusType = \"success\";\n      if (this.$refs.fileInput) {\n        this.$refs.fileInput.value = \"\";\n      }\n    },\n    readFileAsDataUrl(file) {\n      return new Promise((resolve, reject) => {\n        const reader = new FileReader();\n        reader.onload = () => resolve(reader.result);\n        reader.onerror = () => reject(new Error(\"Unable to read the selected file.\"));\n        reader.readAsDataURL(file);\n      });\n    },\n    async uploadSelectedFile() {\n      if (!this.selectedFile || this.isUploading) {\n        return;\n      }\n      this.isUploading = true;\n      this.statusMessage = \"\";\n      this.statusType = \"success\";\n      try {\n        const contentBase64 = await this.readFileAsDataUrl(this.selectedFile);\n        const response = await API.post(\"/files\", {\n          fileName: this.selectedFile.name,\n          mimeType: this.selectedFile.type,\n          contentBase64\n        });\n        this.statusMessage = response.data.message || \"File uploaded successfully.\";\n        this.uploadedFiles = response.data.file ? [response.data.file, ...this.uploadedFiles] : this.uploadedFiles;\n        this.clearSelection();\n      } catch (error) {\n        this.statusType = \"error\";\n        this.statusMessage = error.response?.data?.message || \"Unable to upload the file.\";\n      } finally {\n        this.isUploading = false;\n      }\n    },\n    formatFileSize(size = 0) {\n      if (size < 1024) {\n        return `${size} B`;\n      }\n      if (size < 1024 * 1024) {\n        return `${(size / 1024).toFixed(1)} KB`;\n      }\n      return `${(size / (1024 * 1024)).toFixed(2)} MB`;\n    },\n    formatDate(value) {\n      if (!value) {\n        return \"Unknown date\";\n      }\n      return new Date(value).toLocaleString();\n    }\n  },\n  mounted() {\n    this.loadFiles();\n  }\n};","map":{"version":3,"mappings":"AA2PE,OAAOA,GAAE,MAAO,gBAAgB;AAEhC,eAAe;EACbC,IAAI,EAAE,WAAW;EACjBC,IAAIA,GAAG;IACL,OAAO;MACLC,YAAY,EAAE,IAAI;MAClBC,UAAU,EAAE,KAAK;MACjBC,WAAW,EAAE,KAAK;MAClBC,cAAc,EAAE,KAAK;MACrBC,aAAa,EAAE,EAAE;MACjBC,UAAU,EAAE,SAAS;MACrBC,UAAU,EAAE,EAAE;MACdC,aAAa,EAAE;IACjB,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACP,MAAMC,SAASA,GAAG;MAChB,IAAI,CAACN,cAAa,GAAI,IAAI;MAC1B,IAAI,CAACG,UAAS,GAAI,EAAE;MAEpB,IAAI;QACF,MAAMI,QAAO,GAAI,MAAMb,GAAG,CAACc,GAAG,CAAC,QAAQ,CAAC;QACxC,IAAI,CAACJ,aAAY,GAAIK,KAAK,CAACC,OAAO,CAACH,QAAQ,CAACX,IAAI,CAACe,KAAK,IAClDJ,QAAQ,CAACX,IAAI,CAACe,KAAI,GAClB,EAAE;MACR,EAAE,OAAOC,KAAK,EAAE;QACd,IAAI,CAACT,UAAS,GACZS,KAAK,CAACL,QAAQ,EAAEX,IAAI,EAAEiB,OAAM,IAAK,iCAAiC;MACtE,UAAU;QACR,IAAI,CAACb,cAAa,GAAI,KAAK;MAC7B;IACF,CAAC;IACDc,gBAAgBA,CAACC,KAAK,EAAE;MACtB,MAAM,CAACC,IAAI,IAAID,KAAK,CAACE,MAAM,CAACN,KAAI,IAAK,EAAE;MACvC,IAAI,CAACO,eAAe,CAACF,IAAI,CAAC;IAC5B,CAAC;IACDG,cAAcA,CAACJ,KAAK,EAAE;MACpB,MAAM,CAACC,IAAI,IAAID,KAAK,CAACK,YAAY,EAAET,KAAI,IAAK,EAAE;MAC9C,IAAI,CAACU,WAAW,CAAC,KAAK,CAAC;MACvB,IAAI,CAACH,eAAe,CAACF,IAAI,CAAC;IAC5B,CAAC;IACDK,WAAWA,CAACC,KAAK,EAAE;MACjB,IAAI,CAACxB,UAAS,GAAIwB,KAAK;IACzB,CAAC;IACDC,iBAAiBA,GAAG;MAClB,IAAI,CAACC,KAAK,CAACC,SAAS,EAAEC,KAAK,CAAC,CAAC;IAC/B,CAAC;IACDR,eAAeA,CAACF,IAAI,EAAE;MACpB,IAAI,CAACf,aAAY,GAAI,EAAE;MACvB,IAAI,CAACC,UAAS,GAAI,SAAS;MAE3B,IAAI,CAACc,IAAI,EAAE;QACT,IAAI,CAACnB,YAAW,GAAI,IAAI;QACxB;MACF;MAEA,IAAImB,IAAI,CAACW,IAAG,GAAI,IAAI,IAAG,GAAI,IAAI,EAAE;QAC/B,IAAI,CAAC9B,YAAW,GAAI,IAAI;QACxB,IAAI,CAACK,UAAS,GAAI,OAAO;QACzB,IAAI,CAACD,aAAY,GAAI,+CAA+C;QAEpE,IAAI,IAAI,CAACuB,KAAK,CAACC,SAAS,EAAE;UACxB,IAAI,CAACD,KAAK,CAACC,SAAS,CAACH,KAAI,GAAI,EAAE;QACjC;QAEA;MACF;MAEA,IAAI,CAACzB,YAAW,GAAImB,IAAI;IAC1B,CAAC;IACDY,cAAcA,GAAG;MACf,IAAI,CAAC/B,YAAW,GAAI,IAAI;MACxB,IAAI,CAACC,UAAS,GAAI,KAAK;MACvB,IAAI,CAACG,aAAY,GAAI,EAAE;MACvB,IAAI,CAACC,UAAS,GAAI,SAAS;MAE3B,IAAI,IAAI,CAACsB,KAAK,CAACC,SAAS,EAAE;QACxB,IAAI,CAACD,KAAK,CAACC,SAAS,CAACH,KAAI,GAAI,EAAE;MACjC;IACF,CAAC;IACDO,iBAAiBA,CAACb,IAAI,EAAE;MACtB,OAAO,IAAIc,OAAO,CAAC,CAACC,OAAO,EAAEC,MAAM,KAAK;QACtC,MAAMC,MAAK,GAAI,IAAIC,UAAU,CAAC,CAAC;QAE/BD,MAAM,CAACE,MAAK,GAAI,MAAMJ,OAAO,CAACE,MAAM,CAACG,MAAM,CAAC;QAC5CH,MAAM,CAACI,OAAM,GAAI,MACfL,MAAM,CAAC,IAAIM,KAAK,CAAC,mCAAmC,CAAC,CAAC;QACxDL,MAAM,CAACM,aAAa,CAACvB,IAAI,CAAC;MAC5B,CAAC,CAAC;IACJ,CAAC;IACD,MAAMwB,kBAAkBA,GAAG;MACzB,IAAI,CAAC,IAAI,CAAC3C,YAAW,IAAK,IAAI,CAACE,WAAW,EAAE;QAC1C;MACF;MAEA,IAAI,CAACA,WAAU,GAAI,IAAI;MACvB,IAAI,CAACE,aAAY,GAAI,EAAE;MACvB,IAAI,CAACC,UAAS,GAAI,SAAS;MAE3B,IAAI;QACF,MAAMuC,aAAY,GAAI,MAAM,IAAI,CAACZ,iBAAiB,CAAC,IAAI,CAAChC,YAAY,CAAC;QAErE,MAAMU,QAAO,GAAI,MAAMb,GAAG,CAACgD,IAAI,CAAC,QAAQ,EAAE;UACxCC,QAAQ,EAAE,IAAI,CAAC9C,YAAY,CAACF,IAAI;UAChCiD,QAAQ,EAAE,IAAI,CAAC/C,YAAY,CAACgD,IAAI;UAChCJ;QACF,CAAC,CAAC;QAEF,IAAI,CAACxC,aAAY,GACfM,QAAQ,CAACX,IAAI,CAACiB,OAAM,IAAK,6BAA6B;QACxD,IAAI,CAACT,aAAY,GAAIG,QAAQ,CAACX,IAAI,CAACoB,IAAG,GAClC,CAACT,QAAQ,CAACX,IAAI,CAACoB,IAAI,EAAE,GAAG,IAAI,CAACZ,aAAa,IAC1C,IAAI,CAACA,aAAa;QACtB,IAAI,CAACwB,cAAc,CAAC,CAAC;MACvB,EAAE,OAAOhB,KAAK,EAAE;QACd,IAAI,CAACV,UAAS,GAAI,OAAO;QACzB,IAAI,CAACD,aAAY,GACfW,KAAK,CAACL,QAAQ,EAAEX,IAAI,EAAEiB,OAAM,IAAK,4BAA4B;MACjE,UAAU;QACR,IAAI,CAACd,WAAU,GAAI,KAAK;MAC1B;IACF,CAAC;IACD+C,cAAcA,CAACnB,IAAG,GAAI,CAAC,EAAE;MACvB,IAAIA,IAAG,GAAI,IAAI,EAAE;QACf,OAAO,GAAGA,IAAI,IAAI;MACpB;MAEA,IAAIA,IAAG,GAAI,IAAG,GAAI,IAAI,EAAE;QACtB,OAAO,GAAG,CAACA,IAAG,GAAI,IAAI,EAAEoB,OAAO,CAAC,CAAC,CAAC,KAAK;MACzC;MAEA,OAAO,GAAG,CAACpB,IAAG,IAAK,IAAG,GAAI,IAAI,CAAC,EAAEoB,OAAO,CAAC,CAAC,CAAC,KAAK;IAClD,CAAC;IACDC,UAAUA,CAAC1B,KAAK,EAAE;MAChB,IAAI,CAACA,KAAK,EAAE;QACV,OAAO,cAAc;MACvB;MAEA,OAAO,IAAI2B,IAAI,CAAC3B,KAAK,CAAC,CAAC4B,cAAc,CAAC,CAAC;IACzC;EACF,CAAC;EACDC,OAAOA,GAAG;IACR,IAAI,CAAC7C,SAAS,CAAC,CAAC;EAClB;AACF,CAAC","names":["API","name","data","selectedFile","isDragOver","isUploading","isLoadingFiles","statusMessage","statusType","filesError","uploadedFiles","methods","loadFiles","response","get","Array","isArray","files","error","message","handleFileChange","event","file","target","setSelectedFile","handleFileDrop","dataTransfer","setDragOver","value","triggerFilePicker","$refs","fileInput","click","size","clearSelection","readFileAsDataUrl","Promise","resolve","reject","reader","FileReader","onload","result","onerror","Error","readAsDataURL","uploadSelectedFile","contentBase64","post","fileName","mimeType","type","formatFileSize","toFixed","formatDate","Date","toLocaleString","mounted"],"sourceRoot":"","sources":["D:\\joremiodotonline\\dashboard\\src\\views\\Files.vue"],"sourcesContent":["<template>\n  <div class=\"p-4\">\n    <div\n      class=\"rounded-md border bg-white p-6 dark:border-gray-700 dark:bg-gray-800\"\n    >\n      <div class=\"flex items-start justify-between gap-4\">\n        <div>\n          <p class=\"text-sm font-medium uppercase tracking-[0.2em] text-primary\">\n            Files\n          </p>\n          <h1 class=\"mt-2 text-2xl font-semibold text-gray-800 dark:text-gray-100\">\n            File Management\n          </h1>\n          <p class=\"mt-2 max-w-2xl text-sm text-gray-500 dark:text-gray-400\">\n            Upload a file from this page and it will be saved on the API server\n            with metadata stored in the database.\n          </p>\n        </div>\n        <span\n          class=\"rounded-full bg-gray-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-gray-500 dark:bg-gray-700 dark:text-gray-300\"\n        >\n          Server Uploads\n        </span>\n      </div>\n\n      <div class=\"mt-6 grid gap-6 lg:grid-cols-[1.1fr_0.9fr]\">\n        <div\n          class=\"rounded-md border border-dashed border-gray-300 p-5 dark:border-gray-600\"\n        >\n          <div class=\"flex items-center justify-between gap-4\">\n            <div>\n              <h2 class=\"text-sm font-semibold text-gray-800 dark:text-gray-100\">\n                Upload File\n              </h2>\n              <p class=\"mt-2 text-sm text-gray-500 dark:text-gray-400\">\n                Accepted limit: 5 MB. The file is sent to the server and saved\n                under the API uploads folder.\n              </p>\n            </div>\n            <span\n              class=\"rounded-full bg-sky-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-sky-700\"\n            >\n              API Save\n            </span>\n          </div>\n\n          <div class=\"mt-5 rounded-md bg-gray-50 p-4 dark:bg-gray-900/50\">\n            <div\n              class=\"cursor-pointer rounded-xl border-2 border-dashed p-6 text-center transition\"\n              :class=\"\n                isDragOver\n                  ? 'border-primary bg-primary/5'\n                  : 'border-gray-300 bg-white dark:border-gray-600 dark:bg-gray-800'\n              \"\n              @click=\"triggerFilePicker\"\n              @dragenter.prevent=\"setDragOver(true)\"\n              @dragover.prevent=\"setDragOver(true)\"\n              @dragleave.prevent=\"setDragOver(false)\"\n              @drop.prevent=\"handleFileDrop\"\n            >\n              <p class=\"text-sm font-semibold text-gray-800 dark:text-gray-100\">\n                Drag and drop a file here\n              </p>\n              <p class=\"mt-2 text-sm text-gray-500 dark:text-gray-400\">\n                or click to browse from your device\n              </p>\n              <p class=\"mt-3 text-xs uppercase tracking-[0.18em] text-gray-400\">\n                Maximum file size: 5 MB\n              </p>\n            </div>\n\n            <input\n              ref=\"fileInput\"\n              type=\"file\"\n              class=\"hidden\"\n              @change=\"handleFileChange\"\n            />\n\n            <button\n              type=\"button\"\n              class=\"mt-4 rounded-md border border-gray-300 bg-white px-4 py-3 text-sm font-semibold text-gray-700 transition hover:bg-gray-100 dark:border-gray-600 dark:bg-gray-800 dark:text-gray-200 dark:hover:bg-gray-700\"\n              @click=\"triggerFilePicker\"\n            >\n              Browse Files\n            </button>\n\n            <div\n              v-if=\"selectedFile\"\n              class=\"mt-4 rounded-md border border-gray-200 bg-white p-4 text-sm dark:border-gray-700 dark:bg-gray-800\"\n            >\n              <p class=\"font-semibold text-gray-800 dark:text-gray-100\">\n                {{ selectedFile.name }}\n              </p>\n              <p class=\"mt-1 text-gray-500 dark:text-gray-400\">\n                {{ formatFileSize(selectedFile.size) }} |\n                {{ selectedFile.type || \"Unknown type\" }}\n              </p>\n            </div>\n\n            <p\n              v-if=\"statusMessage\"\n              class=\"mt-4 text-sm\"\n              :class=\"statusType === 'error' ? 'text-red-500' : 'text-emerald-600'\"\n            >\n              {{ statusMessage }}\n            </p>\n\n            <div class=\"mt-5 flex gap-3\">\n              <button\n                type=\"button\"\n                class=\"rounded-md bg-primary px-5 py-3 text-sm font-semibold text-white transition hover:bg-primary/90 disabled:cursor-not-allowed disabled:opacity-60\"\n                :disabled=\"!selectedFile || isUploading\"\n                @click=\"uploadSelectedFile\"\n              >\n                {{ isUploading ? \"Uploading...\" : \"Upload to Server\" }}\n              </button>\n              <button\n                type=\"button\"\n                class=\"rounded-md border border-gray-300 px-5 py-3 text-sm font-semibold text-gray-700 transition hover:bg-gray-100 dark:border-gray-600 dark:text-gray-200 dark:hover:bg-gray-700\"\n                :disabled=\"isUploading\"\n                @click=\"clearSelection\"\n              >\n                Clear\n              </button>\n            </div>\n          </div>\n        </div>\n        <div\n          class=\"rounded-md border border-gray-200 p-5 dark:border-gray-700\"\n        >\n          <div class=\"flex items-center justify-between gap-4\">\n            <div>\n              <h2 class=\"text-sm font-semibold text-gray-800 dark:text-gray-100\">\n                Upload Summary\n              </h2>\n              <p class=\"mt-2 text-sm text-gray-500 dark:text-gray-400\">\n                Recent files already saved on the server.\n              </p>\n            </div>\n            <button\n              type=\"button\"\n              class=\"rounded-md border border-gray-300 px-3 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-gray-600 transition hover:bg-gray-100 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700\"\n              :disabled=\"isLoadingFiles\"\n              @click=\"loadFiles\"\n            >\n              Refresh\n            </button>\n          </div>\n\n          <div class=\"mt-5 grid gap-4 md:grid-cols-2 lg:grid-cols-1\">\n            <div class=\"rounded-md bg-gray-50 p-4 dark:bg-gray-900/50\">\n              <p class=\"text-xs uppercase tracking-[0.18em] text-gray-400\">\n                Total Saved Files\n              </p>\n              <p class=\"mt-2 text-3xl font-semibold text-gray-800 dark:text-gray-100\">\n                {{ uploadedFiles.length }}\n              </p>\n            </div>\n            <div class=\"rounded-md bg-gray-50 p-4 dark:bg-gray-900/50\">\n              <p class=\"text-xs uppercase tracking-[0.18em] text-gray-400\">\n                Latest Upload\n              </p>\n              <p class=\"mt-2 text-sm font-semibold text-gray-800 dark:text-gray-100\">\n                {{ uploadedFiles[0]?.originalName || \"No uploads yet\" }}\n              </p>\n              <p class=\"mt-1 text-xs text-gray-500 dark:text-gray-400\">\n                {{ uploadedFiles[0] ? formatDate(uploadedFiles[0].createdAt) : \"Waiting for first file\" }}\n              </p>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"mt-6 rounded-md border border-gray-200 p-5 dark:border-gray-700\">\n        <div class=\"flex items-center justify-between gap-4\">\n          <div>\n            <h2 class=\"text-sm font-semibold text-gray-800 dark:text-gray-100\">\n              Saved Files\n            </h2>\n            <p class=\"mt-2 text-sm text-gray-500 dark:text-gray-400\">\n              Files listed here have already been written to the server.\n            </p>\n          </div>\n        </div>\n\n        <div\n          v-if=\"isLoadingFiles\"\n          class=\"mt-5 rounded-md bg-gray-50 px-4 py-6 text-sm text-gray-500 dark:bg-gray-900/50 dark:text-gray-400\"\n        >\n          Loading uploaded files...\n        </div>\n        <div\n          v-else-if=\"filesError\"\n          class=\"mt-5 rounded-md bg-red-50 px-4 py-6 text-sm text-red-500\"\n        >\n          {{ filesError }}\n        </div>\n        <div\n          v-else-if=\"!uploadedFiles.length\"\n          class=\"mt-5 rounded-md bg-gray-50 px-4 py-6 text-sm text-gray-500 dark:bg-gray-900/50 dark:text-gray-400\"\n        >\n          No files have been uploaded yet.\n        </div>\n        <div v-else class=\"mt-5 overflow-x-auto\">\n          <table class=\"min-w-full divide-y divide-gray-200 dark:divide-gray-700\">\n            <thead>\n              <tr class=\"text-left text-xs uppercase tracking-[0.18em] text-gray-400\">\n                <th class=\"px-3 py-3 font-semibold\">File</th>\n                <th class=\"px-3 py-3 font-semibold\">Size</th>\n                <th class=\"px-3 py-3 font-semibold\">Uploaded By</th>\n                <th class=\"px-3 py-3 font-semibold\">Date</th>\n                <th class=\"px-3 py-3 font-semibold\">Open</th>\n              </tr>\n            </thead>\n            <tbody class=\"divide-y divide-gray-100 dark:divide-gray-800\">\n              <tr\n                v-for=\"file in uploadedFiles\"\n                :key=\"file.id\"\n                class=\"text-sm text-gray-700 dark:text-gray-200\"\n              >\n                <td class=\"px-3 py-4\">\n                  <p class=\"font-semibold\">{{ file.originalName }}</p>\n                  <p class=\"mt-1 text-xs text-gray-500 dark:text-gray-400\">\n                    {{ file.mimeType || \"Unknown type\" }}\n                  </p>\n                </td>\n                <td class=\"px-3 py-4\">{{ formatFileSize(file.size) }}</td>\n                <td class=\"px-3 py-4\">\n                  {{ file.uploadedBy?.username || file.uploadedBy?.email || \"Unknown\" }}\n                </td>\n                <td class=\"px-3 py-4\">{{ formatDate(file.createdAt) }}</td>\n                <td class=\"px-3 py-4\">\n                  <a\n                    :href=\"file.url\"\n                    target=\"_blank\"\n                    rel=\"noreferrer\"\n                    class=\"font-semibold text-primary hover:underline\"\n                  >\n                    View\n                  </a>\n                </td>\n              </tr>\n            </tbody>\n          </table>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\n  import API from \"@/services/api\";\n\n  export default {\n    name: \"FilesView\",\n    data() {\n      return {\n        selectedFile: null,\n        isDragOver: false,\n        isUploading: false,\n        isLoadingFiles: false,\n        statusMessage: \"\",\n        statusType: \"success\",\n        filesError: \"\",\n        uploadedFiles: [],\n      };\n    },\n    methods: {\n      async loadFiles() {\n        this.isLoadingFiles = true;\n        this.filesError = \"\";\n\n        try {\n          const response = await API.get(\"/files\");\n          this.uploadedFiles = Array.isArray(response.data.files)\n            ? response.data.files\n            : [];\n        } catch (error) {\n          this.filesError =\n            error.response?.data?.message || \"Unable to load files right now.\";\n        } finally {\n          this.isLoadingFiles = false;\n        }\n      },\n      handleFileChange(event) {\n        const [file] = event.target.files || [];\n        this.setSelectedFile(file);\n      },\n      handleFileDrop(event) {\n        const [file] = event.dataTransfer?.files || [];\n        this.setDragOver(false);\n        this.setSelectedFile(file);\n      },\n      setDragOver(value) {\n        this.isDragOver = value;\n      },\n      triggerFilePicker() {\n        this.$refs.fileInput?.click();\n      },\n      setSelectedFile(file) {\n        this.statusMessage = \"\";\n        this.statusType = \"success\";\n\n        if (!file) {\n          this.selectedFile = null;\n          return;\n        }\n\n        if (file.size > 5 * 1024 * 1024) {\n          this.selectedFile = null;\n          this.statusType = \"error\";\n          this.statusMessage = \"Please choose a file that is 5 MB or smaller.\";\n\n          if (this.$refs.fileInput) {\n            this.$refs.fileInput.value = \"\";\n          }\n\n          return;\n        }\n\n        this.selectedFile = file;\n      },\n      clearSelection() {\n        this.selectedFile = null;\n        this.isDragOver = false;\n        this.statusMessage = \"\";\n        this.statusType = \"success\";\n\n        if (this.$refs.fileInput) {\n          this.$refs.fileInput.value = \"\";\n        }\n      },\n      readFileAsDataUrl(file) {\n        return new Promise((resolve, reject) => {\n          const reader = new FileReader();\n\n          reader.onload = () => resolve(reader.result);\n          reader.onerror = () =>\n            reject(new Error(\"Unable to read the selected file.\"));\n          reader.readAsDataURL(file);\n        });\n      },\n      async uploadSelectedFile() {\n        if (!this.selectedFile || this.isUploading) {\n          return;\n        }\n\n        this.isUploading = true;\n        this.statusMessage = \"\";\n        this.statusType = \"success\";\n\n        try {\n          const contentBase64 = await this.readFileAsDataUrl(this.selectedFile);\n\n          const response = await API.post(\"/files\", {\n            fileName: this.selectedFile.name,\n            mimeType: this.selectedFile.type,\n            contentBase64,\n          });\n\n          this.statusMessage =\n            response.data.message || \"File uploaded successfully.\";\n          this.uploadedFiles = response.data.file\n            ? [response.data.file, ...this.uploadedFiles]\n            : this.uploadedFiles;\n          this.clearSelection();\n        } catch (error) {\n          this.statusType = \"error\";\n          this.statusMessage =\n            error.response?.data?.message || \"Unable to upload the file.\";\n        } finally {\n          this.isUploading = false;\n        }\n      },\n      formatFileSize(size = 0) {\n        if (size < 1024) {\n          return `${size} B`;\n        }\n\n        if (size < 1024 * 1024) {\n          return `${(size / 1024).toFixed(1)} KB`;\n        }\n\n        return `${(size / (1024 * 1024)).toFixed(2)} MB`;\n      },\n      formatDate(value) {\n        if (!value) {\n          return \"Unknown date\";\n        }\n\n        return new Date(value).toLocaleString();\n      },\n    },\n    mounted() {\n      this.loadFiles();\n    },\n  };\n</script>\n"]},"metadata":{},"sourceType":"module"}