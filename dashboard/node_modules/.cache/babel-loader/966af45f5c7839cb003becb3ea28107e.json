{"ast":null,"code":"import API from \"@/services/api\";\nimport ConfirmationDialog from \"@/components/ConfirmationDialog.vue\";\nimport { createConfirmationDialogState, resolveConfirmation } from \"@/helper/record-confirmation\";\nfunction emptyForm() {\n  return {\n    employeeId: \"\",\n    firstName: \"\",\n    middleName: \"\",\n    lastName: \"\",\n    suffix: \"\",\n    birthDate: \"\",\n    email: \"\",\n    contactNumber: \"\",\n    address: \"\",\n    position: \"\",\n    department: \"\",\n    dateHired: \"\",\n    status: \"Active\",\n    notes: \"\"\n  };\n}\nexport default {\n  name: \"AdminHrisEmployeeForm\",\n  components: {\n    ConfirmationDialog\n  },\n  data() {\n    return {\n      form: emptyForm(),\n      statusOptions: [\"Active\", \"On Leave\", \"Resigned\", \"Retired\", \"Terminated\"],\n      isSubmitting: false,\n      errorMessage: \"\",\n      confirmationDialog: createConfirmationDialogState(),\n      confirmationResolver: null\n    };\n  },\n  computed: {\n    employeeId() {\n      return this.$route.params.id || null;\n    },\n    isEditing() {\n      return Boolean(this.employeeId);\n    }\n  },\n  methods: {\n    openConfirmationDialog({\n      title,\n      description,\n      confirmText\n    }) {\n      this.confirmationDialog = {\n        visible: true,\n        title,\n        description,\n        confirmText\n      };\n      return new Promise(resolve => {\n        this.confirmationResolver = resolve;\n      });\n    },\n    closeConfirmationDialog(confirmed) {\n      this.confirmationDialog = createConfirmationDialogState();\n      resolveConfirmation(this.confirmationResolver, confirmed);\n      this.confirmationResolver = null;\n    },\n    async loadEmployee() {\n      if (!this.isEditing) return;\n      try {\n        const res = await API.get(`/admin/hris/employees/${this.employeeId}`);\n        const e = res.data?.employee;\n        if (!e) {\n          this.errorMessage = \"Employee not found.\";\n          return;\n        }\n        this.form = {\n          employeeId: e.employeeId || \"\",\n          firstName: e.firstName || \"\",\n          middleName: e.middleName || \"\",\n          lastName: e.lastName || \"\",\n          suffix: e.suffix || \"\",\n          birthDate: e.birthDate ? String(e.birthDate).slice(0, 10) : \"\",\n          email: e.email || \"\",\n          contactNumber: e.contactNumber || \"\",\n          address: e.address || \"\",\n          position: e.position || \"\",\n          department: e.department || \"\",\n          dateHired: e.dateHired ? String(e.dateHired).slice(0, 10) : \"\",\n          status: e.status || \"Active\",\n          notes: e.notes || \"\"\n        };\n      } catch (err) {\n        this.errorMessage = err.response?.data?.message || \"Unable to load employee.\";\n      }\n    },\n    async handleSubmit() {\n      this.errorMessage = \"\";\n      const fullName = `${this.form.firstName} ${this.form.lastName}`.trim();\n      const confirmed = await this.openConfirmationDialog(this.isEditing ? {\n        title: \"Update employee?\",\n        description: `This will apply your changes to ${fullName}.`,\n        confirmText: \"Yes, update\"\n      } : {\n        title: \"Save new employee?\",\n        description: `This will create a new employee record for ${fullName}.`,\n        confirmText: \"Yes, save\"\n      });\n      if (!confirmed) return;\n      this.isSubmitting = true;\n      try {\n        if (this.isEditing) {\n          await API.put(`/admin/hris/employees/${this.employeeId}`, this.form);\n          this.$router.push(`/admin/hris/${this.employeeId}`);\n        } else {\n          const res = await API.post(\"/admin/hris/employees\", this.form);\n          const newId = res.data?.employee?.id;\n          this.$router.push(newId ? `/admin/hris/${newId}` : \"/admin/hris\");\n        }\n      } catch (err) {\n        this.errorMessage = err.response?.data?.message || \"Unable to save the employee.\";\n      } finally {\n        this.isSubmitting = false;\n      }\n    }\n  },\n  mounted() {\n    this.loadEmployee();\n  }\n};","map":{"version":3,"mappings":"AA0IE,OAAOA,GAAE,MAAO,gBAAgB;AAChC,OAAOC,kBAAiB,MAAO,qCAAqC;AACpE,SACEC,6BAA6B,EAC7BC,mBAAmB,QACd,8BAA8B;AAErC,SAASC,SAASA,GAAG;EACnB,OAAO;IACLC,UAAU,EAAE,EAAE;IACdC,SAAS,EAAE,EAAE;IACbC,UAAU,EAAE,EAAE;IACdC,QAAQ,EAAE,EAAE;IACZC,MAAM,EAAE,EAAE;IACVC,SAAS,EAAE,EAAE;IACbC,KAAK,EAAE,EAAE;IACTC,aAAa,EAAE,EAAE;IACjBC,OAAO,EAAE,EAAE;IACXC,QAAQ,EAAE,EAAE;IACZC,UAAU,EAAE,EAAE;IACdC,SAAS,EAAE,EAAE;IACbC,MAAM,EAAE,QAAQ;IAChBC,KAAK,EAAE;EACT,CAAC;AACH;AAEA,eAAe;EACbC,IAAI,EAAE,uBAAuB;EAC7BC,UAAU,EAAE;IAAEnB;EAAmB,CAAC;EAClCoB,IAAIA,GAAG;IACL,OAAO;MACLC,IAAI,EAAElB,SAAS,CAAC,CAAC;MACjBmB,aAAa,EAAE,CAAC,QAAQ,EAAE,UAAU,EAAE,UAAU,EAAE,SAAS,EAAE,YAAY,CAAC;MAC1EC,YAAY,EAAE,KAAK;MACnBC,YAAY,EAAE,EAAE;MAChBC,kBAAkB,EAAExB,6BAA6B,CAAC,CAAC;MACnDyB,oBAAoB,EAAE;IACxB,CAAC;EACH,CAAC;EACDC,QAAQ,EAAE;IACRvB,UAAUA,GAAG;MACX,OAAO,IAAI,CAACwB,MAAM,CAACC,MAAM,CAACC,EAAC,IAAK,IAAI;IACtC,CAAC;IACDC,SAASA,GAAG;MACV,OAAOC,OAAO,CAAC,IAAI,CAAC5B,UAAU,CAAC;IACjC;EACF,CAAC;EACD6B,OAAO,EAAE;IACPC,sBAAsBA,CAAC;MAAEC,KAAK;MAAEC,WAAW;MAAEC;IAAY,CAAC,EAAE;MAC1D,IAAI,CAACZ,kBAAiB,GAAI;QAAEa,OAAO,EAAE,IAAI;QAAEH,KAAK;QAAEC,WAAW;QAAEC;MAAY,CAAC;MAC5E,OAAO,IAAIE,OAAO,CAAEC,OAAO,IAAK;QAC9B,IAAI,CAACd,oBAAmB,GAAIc,OAAO;MACrC,CAAC,CAAC;IACJ,CAAC;IACDC,uBAAuBA,CAACC,SAAS,EAAE;MACjC,IAAI,CAACjB,kBAAiB,GAAIxB,6BAA6B,CAAC,CAAC;MACzDC,mBAAmB,CAAC,IAAI,CAACwB,oBAAoB,EAAEgB,SAAS,CAAC;MACzD,IAAI,CAAChB,oBAAmB,GAAI,IAAI;IAClC,CAAC;IACD,MAAMiB,YAAYA,GAAG;MACnB,IAAI,CAAC,IAAI,CAACZ,SAAS,EAAE;MACrB,IAAI;QACF,MAAMa,GAAE,GAAI,MAAM7C,GAAG,CAAC8C,GAAG,CAAC,yBAAyB,IAAI,CAACzC,UAAU,EAAE,CAAC;QACrE,MAAM0C,IAAIF,GAAG,CAACxB,IAAI,EAAE2B,QAAQ;QAC5B,IAAI,CAACD,CAAC,EAAE;UACN,IAAI,CAACtB,YAAW,GAAI,qBAAqB;UACzC;QACF;QACA,IAAI,CAACH,IAAG,GAAI;UACVjB,UAAU,EAAE0C,CAAC,CAAC1C,UAAS,IAAK,EAAE;UAC9BC,SAAS,EAAEyC,CAAC,CAACzC,SAAQ,IAAK,EAAE;UAC5BC,UAAU,EAAEwC,CAAC,CAACxC,UAAS,IAAK,EAAE;UAC9BC,QAAQ,EAAEuC,CAAC,CAACvC,QAAO,IAAK,EAAE;UAC1BC,MAAM,EAAEsC,CAAC,CAACtC,MAAK,IAAK,EAAE;UACtBC,SAAS,EAAEqC,CAAC,CAACrC,SAAQ,GAAIuC,MAAM,CAACF,CAAC,CAACrC,SAAS,CAAC,CAACwC,KAAK,CAAC,CAAC,EAAE,EAAE,IAAI,EAAE;UAC9DvC,KAAK,EAAEoC,CAAC,CAACpC,KAAI,IAAK,EAAE;UACpBC,aAAa,EAAEmC,CAAC,CAACnC,aAAY,IAAK,EAAE;UACpCC,OAAO,EAAEkC,CAAC,CAAClC,OAAM,IAAK,EAAE;UACxBC,QAAQ,EAAEiC,CAAC,CAACjC,QAAO,IAAK,EAAE;UAC1BC,UAAU,EAAEgC,CAAC,CAAChC,UAAS,IAAK,EAAE;UAC9BC,SAAS,EAAE+B,CAAC,CAAC/B,SAAQ,GAAIiC,MAAM,CAACF,CAAC,CAAC/B,SAAS,CAAC,CAACkC,KAAK,CAAC,CAAC,EAAE,EAAE,IAAI,EAAE;UAC9DjC,MAAM,EAAE8B,CAAC,CAAC9B,MAAK,IAAK,QAAQ;UAC5BC,KAAK,EAAE6B,CAAC,CAAC7B,KAAI,IAAK;QACpB,CAAC;MACH,EAAE,OAAOiC,GAAG,EAAE;QACZ,IAAI,CAAC1B,YAAW,GAAI0B,GAAG,CAACC,QAAQ,EAAE/B,IAAI,EAAEgC,OAAM,IAAK,0BAA0B;MAC/E;IACF,CAAC;IACD,MAAMC,YAAYA,GAAG;MACnB,IAAI,CAAC7B,YAAW,GAAI,EAAE;MAEtB,MAAM8B,QAAO,GAAI,GAAG,IAAI,CAACjC,IAAI,CAAChB,SAAS,IAAI,IAAI,CAACgB,IAAI,CAACd,QAAQ,EAAE,CAACgD,IAAI,CAAC,CAAC;MACtE,MAAMb,SAAQ,GAAI,MAAM,IAAI,CAACR,sBAAsB,CACjD,IAAI,CAACH,SAAQ,GACT;QACEI,KAAK,EAAE,kBAAkB;QACzBC,WAAW,EAAE,mCAAmCkB,QAAQ,GAAG;QAC3DjB,WAAW,EAAE;MACf,IACA;QACEF,KAAK,EAAE,oBAAoB;QAC3BC,WAAW,EAAE,8CAA8CkB,QAAQ,GAAG;QACtEjB,WAAW,EAAE;MACf,CACN,CAAC;MACD,IAAI,CAACK,SAAS,EAAE;MAEhB,IAAI,CAACnB,YAAW,GAAI,IAAI;MACxB,IAAI;QACF,IAAI,IAAI,CAACQ,SAAS,EAAE;UAClB,MAAMhC,GAAG,CAACyD,GAAG,CAAC,yBAAyB,IAAI,CAACpD,UAAU,EAAE,EAAE,IAAI,CAACiB,IAAI,CAAC;UACpE,IAAI,CAACoC,OAAO,CAACC,IAAI,CAAC,eAAe,IAAI,CAACtD,UAAU,EAAE,CAAC;QACrD,OAAO;UACL,MAAMwC,GAAE,GAAI,MAAM7C,GAAG,CAAC4D,IAAI,CAAC,uBAAuB,EAAE,IAAI,CAACtC,IAAI,CAAC;UAC9D,MAAMuC,KAAI,GAAIhB,GAAG,CAACxB,IAAI,EAAE2B,QAAQ,EAAEjB,EAAE;UACpC,IAAI,CAAC2B,OAAO,CAACC,IAAI,CAACE,KAAI,GAAI,eAAeA,KAAK,EAAC,GAAI,aAAa,CAAC;QACnE;MACF,EAAE,OAAOV,GAAG,EAAE;QACZ,IAAI,CAAC1B,YAAW,GAAI0B,GAAG,CAACC,QAAQ,EAAE/B,IAAI,EAAEgC,OAAM,IAAK,8BAA8B;MACnF,UAAU;QACR,IAAI,CAAC7B,YAAW,GAAI,KAAK;MAC3B;IACF;EACF,CAAC;EACDsC,OAAOA,GAAG;IACR,IAAI,CAAClB,YAAY,CAAC,CAAC;EACrB;AACF,CAAC","names":["API","ConfirmationDialog","createConfirmationDialogState","resolveConfirmation","emptyForm","employeeId","firstName","middleName","lastName","suffix","birthDate","email","contactNumber","address","position","department","dateHired","status","notes","name","components","data","form","statusOptions","isSubmitting","errorMessage","confirmationDialog","confirmationResolver","computed","$route","params","id","isEditing","Boolean","methods","openConfirmationDialog","title","description","confirmText","visible","Promise","resolve","closeConfirmationDialog","confirmed","loadEmployee","res","get","e","employee","String","slice","err","response","message","handleSubmit","fullName","trim","put","$router","push","post","newId","mounted"],"sourceRoot":"","sources":["D:\\joremiodotonline\\dashboard\\src\\views\\admin\\hris\\EmployeeForm.vue"],"sourcesContent":["<template>\n  <div class=\"min-h-screen bg-case-bg px-6 py-8 sm:px-10 lg:px-12\">\n    <header class=\"mb-6 flex items-center justify-between\">\n      <p class=\"text-xs uppercase tracking-[0.35em] text-primary\">ADMIN / HRIS</p>\n      <button\n        type=\"button\"\n        class=\"rounded-xl border border-case-border bg-case-surface px-4 py-2 text-sm text-gray-300 hover:bg-case-card\"\n        @click=\"$router.push(isEditing ? `/admin/hris/${employeeId}` : '/admin/hris')\"\n      >\n        Back\n      </button>\n    </header>\n\n    <h2 class=\"mb-4 inline-block rounded-md bg-primary/10 px-4 py-1.5 text-sm font-semibold uppercase tracking-[0.25em] text-primary\">\n      {{ isEditing ? \"Edit Employee\" : \"New Employee\" }}\n    </h2>\n\n    <form class=\"space-y-6\" @submit.prevent=\"handleSubmit\">\n      <div class=\"rounded-2xl border border-case-border bg-case-surface p-5 sm:p-6\">\n        <h3 class=\"mb-4 text-sm font-semibold uppercase tracking-[0.25em] text-gray-300\">Identification</h3>\n        <div class=\"grid gap-4 sm:grid-cols-2\">\n          <div>\n            <label class=\"mb-1 block text-xs font-medium uppercase tracking-[0.2em] text-gray-500\">\n              Employee ID <span class=\"text-primary\">*</span>\n            </label>\n            <input\n              v-model=\"form.employeeId\"\n              type=\"text\"\n              required\n              class=\"w-full rounded-xl border border-case-border bg-case-card px-3 py-2 text-sm text-gray-200 outline-none focus:border-primary\"\n              placeholder=\"e.g. EMP-2026-001\"\n            />\n          </div>\n          <div>\n            <label class=\"mb-1 block text-xs font-medium uppercase tracking-[0.2em] text-gray-500\">Status</label>\n            <select\n              v-model=\"form.status\"\n              class=\"w-full rounded-xl border border-case-border bg-case-card px-3 py-2 text-sm text-gray-200 outline-none focus:border-primary\"\n            >\n              <option v-for=\"opt in statusOptions\" :key=\"opt\" :value=\"opt\">{{ opt }}</option>\n            </select>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"rounded-2xl border border-case-border bg-case-surface p-5 sm:p-6\">\n        <h3 class=\"mb-4 text-sm font-semibold uppercase tracking-[0.25em] text-gray-300\">Personal Details</h3>\n        <div class=\"grid gap-4 sm:grid-cols-2 lg:grid-cols-4\">\n          <div>\n            <label class=\"mb-1 block text-xs font-medium uppercase tracking-[0.2em] text-gray-500\">First Name <span class=\"text-primary\">*</span></label>\n            <input v-model=\"form.firstName\" type=\"text\" required class=\"w-full rounded-xl border border-case-border bg-case-card px-3 py-2 text-sm text-gray-200 outline-none focus:border-primary\" />\n          </div>\n          <div>\n            <label class=\"mb-1 block text-xs font-medium uppercase tracking-[0.2em] text-gray-500\">Middle Name</label>\n            <input v-model=\"form.middleName\" type=\"text\" class=\"w-full rounded-xl border border-case-border bg-case-card px-3 py-2 text-sm text-gray-200 outline-none focus:border-primary\" />\n          </div>\n          <div>\n            <label class=\"mb-1 block text-xs font-medium uppercase tracking-[0.2em] text-gray-500\">Last Name <span class=\"text-primary\">*</span></label>\n            <input v-model=\"form.lastName\" type=\"text\" required class=\"w-full rounded-xl border border-case-border bg-case-card px-3 py-2 text-sm text-gray-200 outline-none focus:border-primary\" />\n          </div>\n          <div>\n            <label class=\"mb-1 block text-xs font-medium uppercase tracking-[0.2em] text-gray-500\">Suffix</label>\n            <input v-model=\"form.suffix\" type=\"text\" placeholder=\"Jr., Sr., III\" class=\"w-full rounded-xl border border-case-border bg-case-card px-3 py-2 text-sm text-gray-200 outline-none focus:border-primary\" />\n          </div>\n          <div>\n            <label class=\"mb-1 block text-xs font-medium uppercase tracking-[0.2em] text-gray-500\">Birth Date</label>\n            <input v-model=\"form.birthDate\" type=\"date\" class=\"w-full rounded-xl border border-case-border bg-case-card px-3 py-2 text-sm text-gray-200 outline-none focus:border-primary\" />\n          </div>\n          <div>\n            <label class=\"mb-1 block text-xs font-medium uppercase tracking-[0.2em] text-gray-500\">Email</label>\n            <input v-model=\"form.email\" type=\"email\" class=\"w-full rounded-xl border border-case-border bg-case-card px-3 py-2 text-sm text-gray-200 outline-none focus:border-primary\" />\n          </div>\n          <div>\n            <label class=\"mb-1 block text-xs font-medium uppercase tracking-[0.2em] text-gray-500\">Contact No.</label>\n            <input v-model=\"form.contactNumber\" type=\"text\" class=\"w-full rounded-xl border border-case-border bg-case-card px-3 py-2 text-sm text-gray-200 outline-none focus:border-primary\" />\n          </div>\n          <div class=\"sm:col-span-2 lg:col-span-4\">\n            <label class=\"mb-1 block text-xs font-medium uppercase tracking-[0.2em] text-gray-500\">Address</label>\n            <input v-model=\"form.address\" type=\"text\" class=\"w-full rounded-xl border border-case-border bg-case-card px-3 py-2 text-sm text-gray-200 outline-none focus:border-primary\" />\n          </div>\n        </div>\n      </div>\n\n      <div class=\"rounded-2xl border border-case-border bg-case-surface p-5 sm:p-6\">\n        <h3 class=\"mb-4 text-sm font-semibold uppercase tracking-[0.25em] text-gray-300\">Employment</h3>\n        <div class=\"grid gap-4 sm:grid-cols-3\">\n          <div>\n            <label class=\"mb-1 block text-xs font-medium uppercase tracking-[0.2em] text-gray-500\">Position</label>\n            <input v-model=\"form.position\" type=\"text\" class=\"w-full rounded-xl border border-case-border bg-case-card px-3 py-2 text-sm text-gray-200 outline-none focus:border-primary\" />\n          </div>\n          <div>\n            <label class=\"mb-1 block text-xs font-medium uppercase tracking-[0.2em] text-gray-500\">Department</label>\n            <input v-model=\"form.department\" type=\"text\" class=\"w-full rounded-xl border border-case-border bg-case-card px-3 py-2 text-sm text-gray-200 outline-none focus:border-primary\" />\n          </div>\n          <div>\n            <label class=\"mb-1 block text-xs font-medium uppercase tracking-[0.2em] text-gray-500\">Date Hired</label>\n            <input v-model=\"form.dateHired\" type=\"date\" class=\"w-full rounded-xl border border-case-border bg-case-card px-3 py-2 text-sm text-gray-200 outline-none focus:border-primary\" />\n          </div>\n        </div>\n      </div>\n\n      <div class=\"rounded-2xl border border-case-border bg-case-surface p-5 sm:p-6\">\n        <h3 class=\"mb-4 text-sm font-semibold uppercase tracking-[0.25em] text-gray-300\">Notes</h3>\n        <textarea\n          v-model=\"form.notes\"\n          rows=\"3\"\n          class=\"w-full rounded-xl border border-case-border bg-case-card px-3 py-2 text-sm text-gray-200 outline-none focus:border-primary\"\n          placeholder=\"Any internal notes about this employee.\"\n        ></textarea>\n      </div>\n\n      <div v-if=\"errorMessage\" class=\"rounded-2xl border border-red-900/50 bg-red-950/30 px-4 py-3 text-sm text-red-400\">\n        {{ errorMessage }}\n      </div>\n\n      <div class=\"flex justify-end\">\n        <button\n          type=\"submit\"\n          class=\"rounded-xl bg-primary px-6 py-3 text-sm font-semibold text-black transition hover:bg-amber-500 disabled:cursor-not-allowed disabled:opacity-50\"\n          :disabled=\"isSubmitting\"\n        >\n          {{ isSubmitting ? \"Submitting...\" : (isEditing ? \"SAVE\" : \"SUBMIT\") }}\n        </button>\n      </div>\n    </form>\n\n    <ConfirmationDialog\n      :visible=\"confirmationDialog.visible\"\n      :title=\"confirmationDialog.title\"\n      :description=\"confirmationDialog.description\"\n      :confirm-text=\"confirmationDialog.confirmText\"\n      @cancel=\"closeConfirmationDialog(false)\"\n      @confirm=\"closeConfirmationDialog(true)\"\n    />\n  </div>\n</template>\n\n<script>\n  import API from \"@/services/api\";\n  import ConfirmationDialog from \"@/components/ConfirmationDialog.vue\";\n  import {\n    createConfirmationDialogState,\n    resolveConfirmation,\n  } from \"@/helper/record-confirmation\";\n\n  function emptyForm() {\n    return {\n      employeeId: \"\",\n      firstName: \"\",\n      middleName: \"\",\n      lastName: \"\",\n      suffix: \"\",\n      birthDate: \"\",\n      email: \"\",\n      contactNumber: \"\",\n      address: \"\",\n      position: \"\",\n      department: \"\",\n      dateHired: \"\",\n      status: \"Active\",\n      notes: \"\",\n    };\n  }\n\n  export default {\n    name: \"AdminHrisEmployeeForm\",\n    components: { ConfirmationDialog },\n    data() {\n      return {\n        form: emptyForm(),\n        statusOptions: [\"Active\", \"On Leave\", \"Resigned\", \"Retired\", \"Terminated\"],\n        isSubmitting: false,\n        errorMessage: \"\",\n        confirmationDialog: createConfirmationDialogState(),\n        confirmationResolver: null,\n      };\n    },\n    computed: {\n      employeeId() {\n        return this.$route.params.id || null;\n      },\n      isEditing() {\n        return Boolean(this.employeeId);\n      },\n    },\n    methods: {\n      openConfirmationDialog({ title, description, confirmText }) {\n        this.confirmationDialog = { visible: true, title, description, confirmText };\n        return new Promise((resolve) => {\n          this.confirmationResolver = resolve;\n        });\n      },\n      closeConfirmationDialog(confirmed) {\n        this.confirmationDialog = createConfirmationDialogState();\n        resolveConfirmation(this.confirmationResolver, confirmed);\n        this.confirmationResolver = null;\n      },\n      async loadEmployee() {\n        if (!this.isEditing) return;\n        try {\n          const res = await API.get(`/admin/hris/employees/${this.employeeId}`);\n          const e = res.data?.employee;\n          if (!e) {\n            this.errorMessage = \"Employee not found.\";\n            return;\n          }\n          this.form = {\n            employeeId: e.employeeId || \"\",\n            firstName: e.firstName || \"\",\n            middleName: e.middleName || \"\",\n            lastName: e.lastName || \"\",\n            suffix: e.suffix || \"\",\n            birthDate: e.birthDate ? String(e.birthDate).slice(0, 10) : \"\",\n            email: e.email || \"\",\n            contactNumber: e.contactNumber || \"\",\n            address: e.address || \"\",\n            position: e.position || \"\",\n            department: e.department || \"\",\n            dateHired: e.dateHired ? String(e.dateHired).slice(0, 10) : \"\",\n            status: e.status || \"Active\",\n            notes: e.notes || \"\",\n          };\n        } catch (err) {\n          this.errorMessage = err.response?.data?.message || \"Unable to load employee.\";\n        }\n      },\n      async handleSubmit() {\n        this.errorMessage = \"\";\n\n        const fullName = `${this.form.firstName} ${this.form.lastName}`.trim();\n        const confirmed = await this.openConfirmationDialog(\n          this.isEditing\n            ? {\n                title: \"Update employee?\",\n                description: `This will apply your changes to ${fullName}.`,\n                confirmText: \"Yes, update\",\n              }\n            : {\n                title: \"Save new employee?\",\n                description: `This will create a new employee record for ${fullName}.`,\n                confirmText: \"Yes, save\",\n              }\n        );\n        if (!confirmed) return;\n\n        this.isSubmitting = true;\n        try {\n          if (this.isEditing) {\n            await API.put(`/admin/hris/employees/${this.employeeId}`, this.form);\n            this.$router.push(`/admin/hris/${this.employeeId}`);\n          } else {\n            const res = await API.post(\"/admin/hris/employees\", this.form);\n            const newId = res.data?.employee?.id;\n            this.$router.push(newId ? `/admin/hris/${newId}` : \"/admin/hris\");\n          }\n        } catch (err) {\n          this.errorMessage = err.response?.data?.message || \"Unable to save the employee.\";\n        } finally {\n          this.isSubmitting = false;\n        }\n      },\n    },\n    mounted() {\n      this.loadEmployee();\n    },\n  };\n</script>\n"]},"metadata":{},"sourceType":"module"}