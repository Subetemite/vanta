{"ast":null,"code":"import { Icon } from \"@iconify/vue\";\nimport API from \"@/services/api\";\nexport default {\n  name: \"AdminDocuments\",\n  components: {\n    Icon\n  },\n  data() {\n    return {\n      records: [],\n      search: \"\",\n      searchTimer: null,\n      isLoading: false,\n      errorMessage: \"\",\n      clockTime: \"\",\n      clockDate: \"\",\n      clockTimer: null\n    };\n  },\n  methods: {\n    async loadRecords() {\n      this.isLoading = true;\n      this.errorMessage = \"\";\n      try {\n        const path = this.search.trim() ? `/admin/documents?q=${encodeURIComponent(this.search.trim())}` : \"/admin/documents\";\n        const res = await API.get(path);\n        this.records = Array.isArray(res.data?.records) ? res.data.records : [];\n      } catch (err) {\n        this.errorMessage = err.response?.data?.message || \"Unable to load records.\";\n      } finally {\n        this.isLoading = false;\n      }\n    },\n    onSearchInput() {\n      clearTimeout(this.searchTimer);\n      this.searchTimer = setTimeout(() => this.loadRecords(), 300);\n    },\n    latestLine(record) {\n      const lines = record.lines || [];\n      return lines[lines.length - 1] || {};\n    },\n    formatDate(value) {\n      if (!value) return \"—\";\n      const d = new Date(value);\n      if (Number.isNaN(d.getTime())) return \"—\";\n      return d.toISOString().slice(0, 10);\n    },\n    tickClock() {\n      const now = new Date();\n      this.clockTime = now.toLocaleTimeString([], {\n        hour: \"2-digit\",\n        minute: \"2-digit\",\n        second: \"2-digit\"\n      });\n      this.clockDate = now.toLocaleDateString([], {\n        weekday: \"short\",\n        year: \"numeric\",\n        month: \"short\",\n        day: \"numeric\"\n      });\n    }\n  },\n  mounted() {\n    this.tickClock();\n    this.clockTimer = setInterval(this.tickClock, 1000);\n    this.loadRecords();\n  },\n  beforeUnmount() {\n    clearInterval(this.clockTimer);\n    clearTimeout(this.searchTimer);\n  }\n};","map":{"version":3,"mappings":"AA6HE,SAASA,IAAG,QAAS,cAAc;AACnC,OAAOC,GAAE,MAAO,gBAAgB;AAEhC,eAAe;EACbC,IAAI,EAAE,gBAAgB;EACtBC,UAAU,EAAE;IAAEH;EAAK,CAAC;EACpBI,IAAIA,GAAG;IACL,OAAO;MACLC,OAAO,EAAE,EAAE;MACXC,MAAM,EAAE,EAAE;MACVC,WAAW,EAAE,IAAI;MACjBC,SAAS,EAAE,KAAK;MAChBC,YAAY,EAAE,EAAE;MAChBC,SAAS,EAAE,EAAE;MACbC,SAAS,EAAE,EAAE;MACbC,UAAU,EAAE;IACd,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACP,MAAMC,WAAWA,GAAG;MAClB,IAAI,CAACN,SAAQ,GAAI,IAAI;MACrB,IAAI,CAACC,YAAW,GAAI,EAAE;MACtB,IAAI;QACF,MAAMM,IAAG,GAAI,IAAI,CAACT,MAAM,CAACU,IAAI,CAAC,IAC1B,sBAAsBC,kBAAkB,CAAC,IAAI,CAACX,MAAM,CAACU,IAAI,CAAC,CAAC,CAAC,EAAC,GAC7D,kBAAkB;QACtB,MAAME,GAAE,GAAI,MAAMjB,GAAG,CAACkB,GAAG,CAACJ,IAAI,CAAC;QAC/B,IAAI,CAACV,OAAM,GAAIe,KAAK,CAACC,OAAO,CAACH,GAAG,CAACd,IAAI,EAAEC,OAAO,IAAIa,GAAG,CAACd,IAAI,CAACC,OAAM,GAAI,EAAE;MACzE,EAAE,OAAOiB,GAAG,EAAE;QACZ,IAAI,CAACb,YAAW,GAAIa,GAAG,CAACC,QAAQ,EAAEnB,IAAI,EAAEoB,OAAM,IAAK,yBAAyB;MAC9E,UAAU;QACR,IAAI,CAAChB,SAAQ,GAAI,KAAK;MACxB;IACF,CAAC;IACDiB,aAAaA,GAAG;MACdC,YAAY,CAAC,IAAI,CAACnB,WAAW,CAAC;MAC9B,IAAI,CAACA,WAAU,GAAIoB,UAAU,CAAC,MAAM,IAAI,CAACb,WAAW,CAAC,CAAC,EAAE,GAAG,CAAC;IAC9D,CAAC;IACDc,UAAUA,CAACC,MAAM,EAAE;MACjB,MAAMC,KAAI,GAAID,MAAM,CAACC,KAAI,IAAK,EAAE;MAChC,OAAOA,KAAK,CAACA,KAAK,CAACC,MAAK,GAAI,CAAC,KAAK,CAAC,CAAC;IACtC,CAAC;IACDC,UAAUA,CAACC,KAAK,EAAE;MAChB,IAAI,CAACA,KAAK,EAAE,OAAO,GAAG;MACtB,MAAMC,IAAI,IAAIC,IAAI,CAACF,KAAK,CAAC;MACzB,IAAIG,MAAM,CAACC,KAAK,CAACH,CAAC,CAACI,OAAO,CAAC,CAAC,CAAC,EAAE,OAAO,GAAG;MACzC,OAAOJ,CAAC,CAACK,WAAW,CAAC,CAAC,CAACC,KAAK,CAAC,CAAC,EAAE,EAAE,CAAC;IACrC,CAAC;IACDC,SAASA,GAAG;MACV,MAAMC,GAAE,GAAI,IAAIP,IAAI,CAAC,CAAC;MACtB,IAAI,CAACzB,SAAQ,GAAIgC,GAAG,CAACC,kBAAkB,CAAC,EAAE,EAAE;QAAEC,IAAI,EAAE,SAAS;QAAEC,MAAM,EAAE,SAAS;QAAEC,MAAM,EAAE;MAAU,CAAC,CAAC;MACtG,IAAI,CAACnC,SAAQ,GAAI+B,GAAG,CAACK,kBAAkB,CAAC,EAAE,EAAE;QAAEC,OAAO,EAAE,OAAO;QAAEC,IAAI,EAAE,SAAS;QAAEC,KAAK,EAAE,OAAO;QAAEC,GAAG,EAAE;MAAU,CAAC,CAAC;IACpH;EACF,CAAC;EACDC,OAAOA,GAAG;IACR,IAAI,CAACX,SAAS,CAAC,CAAC;IAChB,IAAI,CAAC7B,UAAS,GAAIyC,WAAW,CAAC,IAAI,CAACZ,SAAS,EAAE,IAAI,CAAC;IACnD,IAAI,CAAC3B,WAAW,CAAC,CAAC;EACpB,CAAC;EACDwC,aAAaA,GAAG;IACdC,aAAa,CAAC,IAAI,CAAC3C,UAAU,CAAC;IAC9Bc,YAAY,CAAC,IAAI,CAACnB,WAAW,CAAC;EAChC;AACF,CAAC","names":["Icon","API","name","components","data","records","search","searchTimer","isLoading","errorMessage","clockTime","clockDate","clockTimer","methods","loadRecords","path","trim","encodeURIComponent","res","get","Array","isArray","err","response","message","onSearchInput","clearTimeout","setTimeout","latestLine","record","lines","length","formatDate","value","d","Date","Number","isNaN","getTime","toISOString","slice","tickClock","now","toLocaleTimeString","hour","minute","second","toLocaleDateString","weekday","year","month","day","mounted","setInterval","beforeUnmount","clearInterval"],"sourceRoot":"","sources":["D:\\joremiodotonline\\dashboard\\src\\views\\admin\\documents\\Documents.vue"],"sourcesContent":["<template>\n  <div class=\"min-h-screen bg-case-bg px-6 py-8 sm:px-10 lg:px-12\">\n    <header class=\"mb-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between\">\n      <div>\n        <p class=\"text-xs uppercase tracking-[0.35em] text-primary\">ADMIN / Documents Tracking System</p>\n      </div>\n      <div class=\"rounded-2xl border border-case-border bg-case-surface px-5 py-3 text-right\">\n        <p class=\"text-xs uppercase tracking-[0.25em] text-gray-500\">Time &amp; Date</p>\n        <p class=\"mt-1 text-lg font-semibold text-white tabular-nums\">{{ clockTime }}</p>\n        <p class=\"text-xs text-gray-500\">{{ clockDate }}</p>\n      </div>\n    </header>\n\n    <div class=\"mb-8 grid gap-4 sm:grid-cols-2\">\n      <button\n        type=\"button\"\n        class=\"group flex items-center justify-between rounded-2xl border border-case-border bg-case-surface p-5 text-left transition hover:border-primary/40 hover:bg-case-card\"\n        @click=\"$router.push('/admin/documents/new')\"\n      >\n        <div>\n          <p class=\"text-xs uppercase tracking-[0.25em] text-primary\">Create</p>\n          <p class=\"mt-1 text-lg font-semibold text-white\">New Record</p>\n          <p class=\"mt-1 text-xs text-gray-500\">Encode a new routing record.</p>\n        </div>\n        <span class=\"flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary\">\n          <Icon icon=\"mdi:plus-circle-outline\" class=\"text-2xl\" />\n        </span>\n      </button>\n\n      <div class=\"rounded-2xl border border-case-border bg-case-surface p-5\">\n        <p class=\"text-xs uppercase tracking-[0.25em] text-primary\">Search / Update</p>\n        <p class=\"mt-1 text-sm text-gray-500\">Find a record by control number, subject, or encoder.</p>\n        <div class=\"mt-3 flex items-center rounded-xl border border-case-border bg-case-card px-3 py-2\">\n          <Icon icon=\"mdi:magnify\" class=\"text-lg text-gray-500\" />\n          <input\n            v-model=\"search\"\n            type=\"search\"\n            placeholder=\"Search records...\"\n            class=\"w-full bg-transparent px-2 py-1 text-sm text-gray-200 outline-none placeholder:text-gray-600\"\n            @input=\"onSearchInput\"\n          />\n        </div>\n      </div>\n    </div>\n\n    <section>\n      <div class=\"mb-3 flex items-center justify-between\">\n        <h2 class=\"text-sm font-semibold uppercase tracking-[0.25em] text-gray-400\">Latest Records</h2>\n        <button\n          type=\"button\"\n          class=\"text-xs text-gray-500 hover:text-gray-300\"\n          @click=\"loadRecords\"\n        >\n          Refresh\n        </button>\n      </div>\n\n      <div v-if=\"errorMessage\" class=\"mb-3 rounded-2xl border border-red-900/50 bg-red-950/30 px-4 py-3 text-sm text-red-400\">\n        {{ errorMessage }}\n      </div>\n\n      <div class=\"overflow-hidden rounded-2xl border border-case-border bg-case-surface\">\n        <table class=\"w-full text-left text-sm\">\n          <thead class=\"bg-case-elevated text-xs uppercase tracking-[0.2em] text-gray-500\">\n            <tr>\n              <th class=\"px-4 py-3 font-medium\">Encoder</th>\n              <th class=\"px-4 py-3 font-medium\">PAOCC Control No</th>\n              <th class=\"px-4 py-3 font-medium\">Subject</th>\n              <th class=\"px-4 py-3 font-medium\">From (Latest)</th>\n              <th class=\"px-4 py-3 font-medium\">To (Latest)</th>\n              <th class=\"px-4 py-3 font-medium\">Sender's Name</th>\n              <th class=\"px-4 py-3 font-medium\">Date</th>\n              <th class=\"px-4 py-3 font-medium\">File</th>\n              <th class=\"px-4 py-3 text-right font-medium\">Actions</th>\n            </tr>\n          </thead>\n          <tbody class=\"divide-y divide-case-border text-gray-300\">\n            <tr v-if=\"isLoading\">\n              <td colspan=\"9\" class=\"px-4 py-6 text-center text-gray-500\">Loading records...</td>\n            </tr>\n            <tr v-else-if=\"!records.length\">\n              <td colspan=\"9\" class=\"px-4 py-6 text-center text-gray-500\">No records yet.</td>\n            </tr>\n            <tr\n              v-for=\"record in records\"\n              :key=\"record.id\"\n              class=\"hover:bg-case-card transition-colors\"\n            >\n              <td class=\"px-4 py-3 text-gray-500\">{{ record.encoder?.code || record.encoder?.username || '—' }}</td>\n              <td class=\"px-4 py-3 font-medium text-white tabular-nums\">{{ record.controlNumber }}</td>\n              <td class=\"px-4 py-3\">{{ record.subject }}</td>\n              <td class=\"px-4 py-3 text-gray-400\">{{ latestLine(record).from || '—' }}</td>\n              <td class=\"px-4 py-3 text-gray-400\">{{ latestLine(record).to || '—' }}</td>\n              <td class=\"px-4 py-3 text-gray-400\">{{ latestLine(record).senderName || '—' }}</td>\n              <td class=\"px-4 py-3 text-gray-400 tabular-nums\">{{ formatDate(latestLine(record).date) }}</td>\n              <td class=\"px-4 py-3\">\n                <a\n                  v-if=\"record.attachedFile?.url\"\n                  :href=\"record.attachedFile.url\"\n                  target=\"_blank\"\n                  rel=\"noopener\"\n                  class=\"text-primary hover:underline\"\n                >\n                  link\n                </a>\n                <span v-else class=\"text-gray-600\">—</span>\n              </td>\n              <td class=\"px-4 py-3 text-right\">\n                <button\n                  type=\"button\"\n                  class=\"rounded-md bg-primary/10 px-3 py-1 text-xs font-semibold text-primary transition hover:bg-primary/20\"\n                  @click=\"$router.push(`/admin/documents/${record.id}`)\"\n                >\n                  View\n                </button>\n              </td>\n            </tr>\n          </tbody>\n        </table>\n      </div>\n    </section>\n  </div>\n</template>\n\n<script>\n  import { Icon } from \"@iconify/vue\";\n  import API from \"@/services/api\";\n\n  export default {\n    name: \"AdminDocuments\",\n    components: { Icon },\n    data() {\n      return {\n        records: [],\n        search: \"\",\n        searchTimer: null,\n        isLoading: false,\n        errorMessage: \"\",\n        clockTime: \"\",\n        clockDate: \"\",\n        clockTimer: null,\n      };\n    },\n    methods: {\n      async loadRecords() {\n        this.isLoading = true;\n        this.errorMessage = \"\";\n        try {\n          const path = this.search.trim()\n            ? `/admin/documents?q=${encodeURIComponent(this.search.trim())}`\n            : \"/admin/documents\";\n          const res = await API.get(path);\n          this.records = Array.isArray(res.data?.records) ? res.data.records : [];\n        } catch (err) {\n          this.errorMessage = err.response?.data?.message || \"Unable to load records.\";\n        } finally {\n          this.isLoading = false;\n        }\n      },\n      onSearchInput() {\n        clearTimeout(this.searchTimer);\n        this.searchTimer = setTimeout(() => this.loadRecords(), 300);\n      },\n      latestLine(record) {\n        const lines = record.lines || [];\n        return lines[lines.length - 1] || {};\n      },\n      formatDate(value) {\n        if (!value) return \"—\";\n        const d = new Date(value);\n        if (Number.isNaN(d.getTime())) return \"—\";\n        return d.toISOString().slice(0, 10);\n      },\n      tickClock() {\n        const now = new Date();\n        this.clockTime = now.toLocaleTimeString([], { hour: \"2-digit\", minute: \"2-digit\", second: \"2-digit\" });\n        this.clockDate = now.toLocaleDateString([], { weekday: \"short\", year: \"numeric\", month: \"short\", day: \"numeric\" });\n      },\n    },\n    mounted() {\n      this.tickClock();\n      this.clockTimer = setInterval(this.tickClock, 1000);\n      this.loadRecords();\n    },\n    beforeUnmount() {\n      clearInterval(this.clockTimer);\n      clearTimeout(this.searchTimer);\n    },\n  };\n</script>\n"]},"metadata":{},"sourceType":"module"}