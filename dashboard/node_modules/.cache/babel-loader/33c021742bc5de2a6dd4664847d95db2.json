m,\n          fromEmployeeId: line.fromEmployeeId,\n          to: line.to,\n          toEmployeeId: line.toEmployeeId,\n          actionRequested: line.actionRequested,\n          date: line.date,\n          senderName: line.senderName\n        })),\n        attachedFile: this.uploadedFile\n      };\n      try {\n        if (this.isEditing) {\n          await API.put(`/admin/documents/${this.recordId}`, payload);\n          this.$router.push(`/admin/documents/${this.recordId}`);\n        } else {\n          await API.post(\"/admin/documents\", payload);\n          this.$router.push(\"/admin/documents\");\n        }\n      } catch (err) {\n        this.errorMessage = err.response?.data?.message || \"Unable to save the record.\";\n      } finally {\n        this.isSubmitting = false;\n      }\n    }\n  },\n  mounted() {\n    this.loadEmployees();\n    this.loadRecord();\n  }\n};","map":{"version":3,"mappings":";;;;;AAsRE,OAAOA,GAAE,MAAO,gBAAgB;AAChC,OAAOC,kBAAiB,MAAO,qCAAqC;AACpE,SACEC,6BAA6B,EAC7BC,mBAAmB,QACd,8BAA8B;AAErC,MAAMC,cAAa,GAAI,CACrB,eAAe,EACf,gBAAgB,EAChB,yBAAyB,EACzB,6BAA6B,EAC7B,gBAAgB,EAChB,6BAA6B,EAC7B,qBAAqB,EACrB,kBAAkB,EAClB,iBAAiB,EACjB,yBAAyB,EACzB,eAAe,EACf,oBAAoB,EACpB,2BAA2B,EAC3B,WAAW,CACZ;AAED,MAAMC,SAAQ,GAAI,CAAC;AAEnB,SAASC,SAASA,GAAG;EACnB,OAAO;IACLC,IAAI,EAAE,EAAE;IACRC,cAAc,EAAE,EAAE;IAClBC,EAAE,EAAE,EAAE;IACNC,YAAY,EAAE,EAAE;IAChBC,eAAe,EAAE,EAAE;IACnBC,IAAI,EAAE,EAAE;IACRC,UAAU,EAAE,EAAE;IACdC,oBAAoB,EAAE;EACxB,CAAC;AACH;AAEA,SAASC,UAAUA,GAAG;EACpB,OAAOC,KAAK,CAACT,IAAI,CAAC;IAAEU,MAAM,EAAEZ;EAAU,CAAC,EAAE,MAAMC,SAAS,CAAC,CAAC,CAAC;AAC7D;AAEA,SAASY,YAAYA,CAACC,IAAI,EAAE;EAC1B,OAAOC,OAAO,CACZ,CAACD,IAAI,CAACZ,IAAG,IAAK,EAAE,EAAEc,IAAI,CAAC,KACvB,CAACF,IAAI,CAACV,EAAC,IAAK,EAAE,EAAEY,IAAI,CAAC,KACrB,CAACF,IAAI,CAACP,IAAG,IAAK,EAAE,EAAES,IAAI,CAAC,KACvB,CAACF,IAAI,CAACN,UAAS,IAAK,EAAE,EAAEQ,IAAI,CAAC,KAC7B,CAACF,IAAI,CAACR,eAAc,IAAK,EAAE,EAAEU,IAAI,CAAC,CACpC,CAAC;AACH;AAEA,eAAe;EACbC,IAAI,EAAE,mBAAmB;EACzBC,UAAU,EAAE;IAAEtB;EAAmB,CAAC;E