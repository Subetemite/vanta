,qBAAqB,CAAC,CAAC;MAC1C,MAAMS,IAAG,GAAI5B,IAAI,CAAC6B,GAAG,CAACX,IAAI,CAAClC,KAAI,GAAI2C,IAAI,CAAC3C,KAAK,EAAE,CAAC,CAAC;MACjD,MAAM8C,IAAG,GAAI9B,IAAI,CAAC6B,GAAG,CAACX,IAAI,CAAChC,MAAK,GAAIyC,IAAI,CAACzC,MAAM,EAAE,CAAC,CAAC;MACnD,MAAM6C,EAAC,GAAI/B,IAAI,CAACgC,GAAG,CAAChC,IAAI,CAAC6B,GAAG,CAACjB,KAAK,CAACU,OAAM,GAAIJ,IAAI,CAACnC,IAAG,GAAI4C,IAAI,CAACN,OAAO,EAAE,CAAC,CAAC,EAAEO,IAAI,CAAC;MAChF,MAAMK,EAAC,GAAIjC,IAAI,CAACgC,GAAG,CAAChC,IAAI,CAAC6B,GAAG,CAACjB,KAAK,CAACa,OAAM,GAAIP,IAAI,CAACpC,GAAE,GAAI6C,IAAI,CAACH,OAAO,EAAE,CAAC,CAAC,EAAEM,IAAI,CAAC;MAC/E,IAAI,CAAClH,eAAc,GAAI;QACrB,GAAG,IAAI,CAACA,eAAe;QACvB,CAAC+G,IAAI,CAACP,EAAE,GAAG;UACTtC,GAAG,EAAE,GAAImD,EAAC,GAAIf,IAAI,CAAChC,MAAM,GAAI,GAAG,GAAG;UACnCH,IAAI,EAAE,GAAIgD,EAAC,GAAIb,IAAI,CAAClC,KAAK,GAAI,GAAG,GAAG;UACnCA,KAAK,EAAE2C,IAAI,CAAC3C,KAAK;UACjBE,MAAM,EAAEyC,IAAI,CAACzC;QACf;MACF,CAAC;IACH,CAAC;IACDgD,cAAcA,GAAG;MACf,IAAI,CAACrH,gBAAe,GAAI,IAAI;IAC9B,CAAC;IACDsH,gBAAgBA,CAACf,EAAE,EAAE;MACnB,OAAO,IAAI,CAACvG,gBAAgB,EAAEuG,EAAC,KAAMA,EAAE;IACzC;EACF,CAAC;EACDgB,OAAOA,GAAG;IACRC,MAAM,CAACC,gBAAgB,CAAC,aAAa,EAAE,IAAI,CAACZ,gBAAgB,CAAC;IAC7DW,MAAM,CAACC,gBAAgB,CAAC,WAAW,EAAE,IAAI,CAACJ,cAAc,CAAC;IACzD,IAAI,CAACnF,iBAAiB,CAAC,CAAC;EAC1B,CAAC;EACDwF,aAAaA,GAAG;IACdF,MAAM,CAACG,mBAAmB,CAAC,aAAa,EAAE,IAAI,CAACd,gBAAgB,CAAC;IAChEW,MAAM,CAACG,mBAAmB,CAAC,WAAW,EAAE,IAAI,CAACN,cAAc,CAAC;EAC9D;AACF,CAAC","names":["Icon","API","name","data","recentRecords","recentRecordsSearch","isLoadingRecords","recordsError","bubblePositions","activeBubbleDrag","selectedBubbleRecordId","bubbleDisplayLimit","computed","selectedBubbleRecord","find","r","_id","filteredRecentRecords","q","trim","toLowerCase","filter","info","personalInformation","op","operationDetails","firstName","middleName","lastName","alias","operationName","Boolean","some","v","includes","bubbleRecords","slice","sel","rest","linkedOperationRecords","opName","components","methods","loadRecentRecords","res","get","Array","isArray","initializeBubblePositions","err","response","message","formatRecordName","i","join","getRecordInitials","map","charAt","formatRecordMeta","createdAt","Date","toLocaleDateString","formatRecordCreatedAt","formatOperationDate","operationDate","getBubbleSubtitle","getLinkedRecordSummary","nationality","getBubbleStyle","index","record","stored","bubble","getBubbleConfig","top","left","width","size","height","animationDelay","animationDuration","focusLayout","fallback","getGeneratedBubbleLayout","isSelected","sizePattern","columns","columnGap","rowGap","baseLeft","baseTop","row","Math","floor","col","length","leftOffset","topOffset","next","forEach","idx","selectRecordForBubble","$nextTick","startBubbleDrag","event","board","$refs","bubbleBoard","preventDefault","pos","rect","getBoundingClientRect","id","offsetX","clientX","parseFloat","offsetY","clientY","handleBubbleDrag","drag","maxX","max","maxY","nx","min","ny","stopBubbleDrag","isBubbleDragging","mounted","window","addEventListener","beforeUnmount","removeEventListener"],"sourceRoot":"","sources":["D:\\joremiodotonline\\dashboard\\src\\views\\Dashboard.vue"],"sourcesContent":["<template>\n  <div class=\"dashboard min-h-screen p-5 space-y-5\">\n\n    <!-- ── Top bar ─────────────────────────────────────────────────────── -->\n    <div class=\"flex flex-wrap items-center justify-between gap-4\">\n      <div>\n        <h1 class=\"text-xl font-semibold text-white tracking-wide\">Operations Overview</h1>\n        <p class=\"text-sm text-gray-600 mt-0.5\">\n          Active subject board\n          <span v-if=\"recentRecords.length\" class=\"text-primary font-medium\">\n            · {{ recentRecords.length }} registered\n          </span>\n        </p>\n      </div>\n      <button\n        class=\"flex items-center gap-2 rounded-lg bg-primary px-5 py-2.5 text-sm font-semibold text-black hover:bg-amber-500 transition-colors\"\n      >\n        <Icon icon=\"ic:twotone-plus\" class=\"text-xl\" />\n        Create New Report\n      </button>\n    </div>\n\n    <!-- ── Main two-column grid ────────────────────────────────────────── -->\n    <div class=\"grid grid-cols-1 lg:grid-cols-[1fr_360px] gap-4 items-stretch\">\n\n      <!-- Subject Board ──────────────────────────────────────────────── -->\n      <div class=\"bg-case-surface border border-case-border rounded-xl flex flex-col overflow-hidden\">\n        <!-- board header -->\n        <div class=\"px-5 py-4 flex items-center justify-between border-b border-case-border flex-shrink-0\">\n          <div>\n            <h2 class=\"text-sm font-semibold text-white uppercase tracking-[0.15em]\">Subject Board</h2>\n            <p class=\"text-xs text-gray-600 mt-0.5\">Drag to reposition — click to expand</p>\n          </div>\n          <span class=\"rounded-full bg-amber-900/30 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-primary\">\n            {{ bubbleRecords.length }} subjects\n          </span>\n        </div>\n\n        <!-- bubble area -->\n        <div class=\"p-4 flex-1 min-h-0\">\n          <div\n            v-if=\"isLoadingRecords\"\n            class=\"flex h-full min-h-[560px] items-center justify-center rounded-xl bg-case-card text-sm text-gray-600\"\n          >\n            Loading subject board...\n          </div>\n          <div\n            v-else-if=\"recordsError\"\n            class=\"flex h-full min-h-[560px] items-center justify-center rounded-xl bg-red-950/20 px-6 text-sm text-red-400\"\n          >\n            {{ recordsError }}\n          </div>\n          <div\n            v-else-if=\"!bubbleRecords.length\"\n            class=\"flex h-full min-h-[560px] flex-col items-center justify-center gap-3 rounded-xl bg-case-card text-sm text-gray-600\"\n          >\n            <Icon icon=\"ic:outline-person-search\" class=\"text-4xl text-gray-700\" />\n            No registered subjects yet.\n          </div>\n          <div\n            v-else\n            ref=\"bubbleBoard\"\n            class=\"relative w-full h-[560px] rounded-xl overflow-hidden border border-amber-900/15\n                   bg-[radial-gradient(ellipse_at_50%_40%,_rgba(217,119,6,0.06),_transparent_55%),linear-gradient(160deg,_#0d0f12_0%,_#111318_50%,_#0d0f12_100%)]\"\n          >\n            <!-- decorative rings -->\n            <div class=\"pointer-events-none absolute inset-0\">\n              <div class=\"absolute left-1/2 top-1/2 h-[280px] w-[280px] -translate-x-1/2 -translate-y-1/2 rounded-full border border-amber-800/8\"></div>\n              <div class=\"absolute left-1/2 top-1/2 h-[420px] w-[420px] -translate-x-1/2 -translate-y-1/2 rounded-full border border-amber-800/5\"></div>\n              <!-- crosshair center -->\n              <div class=\"absolute left-1/2 top-1/2 h-[1px] w-8 -translate-x-1/2 -translate-y-1/2 bg-amber-800/20\"></div>\n              <div class=\"absolute left-1/2 top-1/2 h-8 w-[1px] -translate-x-1/2 -translate-y-1/2 bg-amber-800/20\"></div>\n            </div>\n\n            <div\n              v-for=\"(record, index) in bubbleRecords\"\n              :key=\"record._id\"\n              class=\"absolute flex cursor-grab select-none border text-center shadow-lg backdrop-blur-sm transition-shadow duration-300 active:cursor-grabbing\"\n              :class=\"[\n                record._id === selectedBubbleRecordId\n                  ? 'z-20 flex-col overflow-hidden rounded-[2rem] border-amber-700/35 bg-case-card shadow-xl shadow-amber-500/8 ring-1 ring-amber-700/20'\n                  : 'z-10 flex-col items-center justify-center rounded-full border-amber-800/20 bg-case-card/80 shadow-black/30 hover:border-amber-700/40 hover:scale-[1.04]',\n                record._id === selectedBubbleRecordId\n                  ? 'bubble-static'\n                  : !isBubbleDragging(record._id)\n                    ? 'bubble-float'\n                    : 'bubble-dragging',\n              ]\"\n              :style=\"getBubbleStyle(index, record)\"\n              @pointerdown=\"startBubbleDrag($event, record, index)\"\n            >\n              <!-- expanded card -->\n              <template v-if=\"record._id === selectedBubbleRecordId\">\n                <div class=\"flex h-[52%] w-full items-center justify-center overflow-hidden bg-case-elevated px-4 py-4\">\n                  <img\n                    v-if=\"record.profilePhoto?.dataUrl\"\n                    :src=\"record.profilePhoto.dataUrl\"\n                    :alt=\"formatRecordName(record)\"\n                    class=\"h-full max-h-full w-full rounded-2xl object-cover object-top shadow-md shadow-black/40\"\n                  />\n                  <div\n                    v-else\n                    class=\"flex h-full w-full items-center justify-center rounded-2xl bg-case-bg text-5xl font-semibold uppercase text-gray-600\"\n                  >\n                    {{ getRecordInitials(record) }}\n                  </div>\n                </div>\n                <div class=\"flex h-[48%] w-full flex-col justify-between px-5 py-4 text-left overflow-hidden\">\n                  <div>\n                    <p class=\"text-[10px] font-semibold uppercase tracking-[0.28em] text-primary truncate\">\n                      {{ getBubbleSubtitle(record) }}\n                    </p>\n                    <h3 class=\"mt-1.5 text-lg font-semibold leading-snug text-white truncate\">\n                      {{ formatRecordName(record) }}\n                    </h3>\n                    <p class=\"mt-0.5 text-xs text-gray-500 truncate\">{{ formatRecordMeta(record) }}</p>\n                  </div>\n                  <div class=\"grid grid-cols-2 gap-2 text-xs mt-2\">\n                    <div class=\"rounded-xl bg-case-elevated px-3 py-2\">\n                      <p class=\"text-[9px] uppercase tracking-[0.2em] text-gray-600\">Alias</p>\n                      <p class=\"mt-0.5 truncate font-medium text-gray-200\">{{ record.personalInformation?.alias || \"None\" }}</p>\n                    </div>\n                    <div class=\"rounded-xl bg-case-elevated px-3 py-2\">\n                      <p class=\"text-[9px] uppercase tracking-[0.2em] text-gray-600\">Sex</p>\n                      <p class=\"mt-0.5 truncate font-medium text-gray-200\">{{ record.personalInformation?.sex || \"N/A\" }}</p>\n                    </div>\n                    <div class=\"rounded-xl bg-case-elevated px-3 py-2\">\n                      <p class=\"text-[9px] uppercase tracking-[0.2em] text-gray-600\">Nationality</p>\n                      <p class=\"mt-0.5 truncate font-medium text-gray-200\">{{ record.personalInformation?.nationality || \"N/A\" }}</p>\n                    </div>\n                    <div class=\"rounded-xl bg-case-elevated px-3 py-2\">\n                      <p class=\"text-[9px] uppercase tracking-[0.2em] text-gray-600\">Date Added</p>\n                      <p class=\"mt-0.5 truncate font-medium text-gray-200\">{{ formatRecordCreatedAt(record) }}</p>\n                    </div>\n                  </div>\n                </div>\n              </template>\n\n              <!-- collapsed bubble -->\n              <template v-else>\n                <img\n                  v-if=\"record.profilePhoto?.dataUrl\"\n                  :src=\"record.profilePhoto.dataUrl\"\n                  :alt=\"formatRecordName(record)\"\n                  class=\"mb-1.5 h-11 w-11 rounded-full object-cover ring-2 ring-amber-800/25\"\n                />\n                <div\n                  v-else\n                  class=\"mb-1.5 flex h-11 w-11 items-center justify-center rounded-full bg-case-elevated text-xs font-semibold uppercase text-gray-500 ring-2 ring-amber-800/15\"\n                >\n                  {{ getRecordInitials(record) }}\n                </div>\n                <p class=\"max-w-[88%] overflow-hidden text-ellipsis whitespace-nowrap text-[11px] font-medium leading-4 text-gray-400\">\n                  {{ formatRecordName(record) }}\n                </p>\n              </template>\n            </div>\n          </div>\n        </div>\n\n        <!-- board footer -->\n        <div class=\"px-5 py-3 flex items-center justify-between border-t border-case-border flex-shrink-0\">\n          <select\n            class=\"bg-case-elevated border border-case-border px-3 py-2 rounded-md text-sm text-gray-400 focus:outline-none focus:border-primary\"\n          >\n            <option value=\"\">Last 3 years</option>\n          </select>\n          <button class=\"text-xs uppercase tracking-widest border-b border-red-800/60 text-red-500/80 hover:text-red-400 hover:border-red-600 transition-colors pb-0.5\">\n            Crime Report\n          </button>\n        </div>\n      </div>\n\n      <!-- Recent Registrations ───────────────────────────────────────── -->\n      <div class=\"bg-case-surface border border-case-border rounded-xl flex flex-col overflow-hidden\">\n        <!-- panel header -->\n        <div class=\"px-5 py-4 border-b border-case-border flex-shrink-0\">\n          <h2 class=\"text-sm font-semibold text-white uppercase tracking-[0.15em]\">Recent Registrations</h2>\n          <p class=\"text-xs text-gray-600 mt-0.5\">Latest records from the registration form</p>\n        </div>\n\n        <!-- search -->\n        <div class=\"px-4 pt-4 pb-2 flex-shrink-0\">\n          <label class=\"relative block\">\n            <span class=\"pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3 text-gray-600\">\n              <Icon icon=\"ic:round-search\" class=\"text-lg\" />\n            </span>\n            <input\n              v-model.trim=\"recentRecordsSearch\"\n              type=\"text\"\n              placeholder=\"Search subjects...\"\n              class=\"w-full rounded-lg border border-case-border bg-case-card py-2.5 pl-10 pr-4 text-sm text-gray-200 outline-none transition placeholder:text-gray-600 focus:border-primary focus:ring-2 focus:ring-primary/10\"\n            />\n          </label>\n        </div>\n\n        <!-- scrollable list -->\n        <perfect-scrollbar class=\"flex-1 min-h-0 divide-y divide-case-border\">\n          <div v-if=\"isLoadingRecords\" class=\"px-5 py-6 text-sm text-gray-600 text-center\">\n            Loading registrations...\n          </div>\n          <div v-else-if=\"recordsError\" class=\"px-5 py-6 text-sm text-red-400 text-center\">\n            {{ recordsError }}\n          </div>\n          <div v-else-if=\"!filteredRecentRecords.length\" class=\"px-5 py-10 text-sm text-gray-600 text-center\">\n            {{ recentRecordsSearch ? \"No results matched your search.\" : \"No registrations found yet.\" }}\n          </div>\n          <button\n            v-for=\"record in filteredRecentRecords\"\n            :key=\"record._id\"\n            type=\"button\"\n            class=\"w-full px-4 py-3 text-left transition-colors flex items-center gap-4\"\n            :class=\"record._id === selectedBubbleRecordId\n              ? 'bg-amber-900/15 border-l-2 border-primary'\n              : 'hover:bg-case-card border-l-2 border-transparent'\"\n            @click=\"selectRecordForBubble(record)\"\n          >\n            <img\n              v-if=\"record.profilePhoto?.dataUrl\"\n              class=\"h-12 w-12 flex-shrink-0 rounded-lg object-cover\"\n              :src=\"record.profilePhoto.dataUrl\"\n              :alt=\"formatRecordName(record)\"\n            />\n            <div\n              v-else\n              class=\"flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-lg bg-case-elevated text-sm font-semibold uppercase text-gray-500\"\n            >\n              {{ getRecordInitials(record) }}\n            </div>\n            <div class=\"min-w-0 flex-1\">\n              <p class=\"truncate text-sm font-medium text-gray-200\">{{ formatRecordName(record) }}</p>\n              <p class=\"truncate text-xs text-gray-600 mt-0.5\">{{ formatRecordMeta(record) }}</p>\n            </div>\n          </button>\n        </perfect-scrollbar>\n      </div>\n    </div>\n\n    <!-- ── Operation Details ───────────────────────────────────────────── -->\n    <div class=\"bg-case-surface border border-case-border rounded-xl p-5\">\n      <div class=\"flex items-center justify-between mb-4\">\n        <div>\n          <h2 class=\"text-sm font-semibold text-white uppercase tracking-[0.15em]\">Operation Details</h2>\n          <p class=\"text-xs text-gray-600 mt-0.5\">Linked records for the currently selected subject</p>\n        </div>\n        <span\n          v-if=\"selectedBubbleRecord\"\n          class=\"rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold text-primary truncate max-w-[200px]\"\n        >\n          {{ selectedBubbleRecord.operationDetails?.operationName || \"No operation\" }}\n        </span>\n      </div>\n\n      <div\n        v-if=\"!selectedBubbleRecord\"\n        class=\"rounded-xl bg-case-card px-6 py-12 text-sm text-gray-600 text-center flex flex-col items-center gap-2\"\n      >\n        <Icon icon=\"ic:outline-manage-search\" class=\"text-3xl text-gray-700\" />\n        Select a subject from the board to view operation details and linked people.\n      </div>\n\n      <div v-else class=\"grid gap-4 lg:grid-cols-[1.3fr_1fr]\">\n        <!-- operation info grid -->\n        <div class=\"rounded-xl border border-case-border bg-case-card p-4\">\n          <div class=\"grid gap-3 sm:grid-cols-2\">\n            <div class=\"rounded-xl bg-case-elevated px-4 py-3\">\n              <p class=\"text-[10px] uppercase tracking-[0.22em] text-gray-600\">Operation Name</p>\n              <p class=\"mt-1.5 text-sm font-semibold text-gray-100\">\n                {{ selectedBubbleRecord.operationDetails?.operationName || \"No operation assigned\" }}\n              </p>\n            </div>\n            <div class=\"rounded-xl bg-case-elevated px-4 py-3\">\n              <p class=\"text-[10px] uppercase tracking-[0.22em] text-gray-600\">Operation Date</p>\n              <p class=\"mt-1.5 text-sm font-semibold text-gray-100\">\n                {{ formatOperationDate(selectedBubbleRecord) }}\n              </p>\n            </div>\n            <div class=\"rounded-xl bg-case-elevated px-4 py-3 sm:col-span-2\">\n              <p class=\"text-[10px] uppercase tracking-[0.22em] text-gray-600\">Operation Address</p>\n              <p class=\"mt-1.5 text-sm font-semibold text-gray-100\">\n                {{ selectedBubbleRecord.operationDetails?.operationAddress || \"No address available\" }}\n              </p>\n            </div>\n            <div class=\"rounded-xl bg-case-elevated px-4 py-3\">\n              <p class=\"text-[10px] uppercase tracking-[0.22em] text-gray-600\">Disposition</p>\n              <p class=\"mt-1.5 text-sm font-semibold text-gray-100\">\n                {{ selectedBubbleRecord.operationDetails?.disposition || \"No disposition\" }}\n              </p>\n            </div>\n            <div class=\"rounded-xl bg-case-elevated px-4 py-3\">\n              <p class=\"text-[10px] uppercase tracking-[0.22em] text-gray-600\">Visa Status</p>\n              <p class=\"mt-1.5 text-sm font-semibold text-gray-100\">\n                {{ selectedBubbleRecord.operationDetails?.visaStatus || \"No visa status\" }}\n              </p>\n            </div>\n            <div class=\"rounded-xl bg-case-elevated px-4 py-3 sm:col-span-2\">\n              <p class=\"text-[10px] uppercase tracking-[0.22em] text-gray-600\">Remarks</p>\n              <p class=\"mt-1.5 text-sm leading-relaxed text-gray-400\">\n                {{ selectedBubbleRecord.operationDetails?.remarks || \"No remarks available.\" }}\n              </p>\n            </div>\n          </div>\n        </div>\n\n        <!-- linked people -->\n        <div class=\"rounded-xl border border-case-border bg-case-card p-4 flex flex-col\">\n          <div class=\"flex items-center justify-between mb-3 flex-shrink-0\">\n            <div>\n              <h3 class=\"text-sm font-semibold text-gray-100\">Linked People</h3>\n              <p class=\"text-xs text-gray-600 mt-0.5\">Same operation · {{ linkedOperationRecords.length }} found</p>\n            </div>\n            <span class=\"rounded-full bg-amber-900/30 px-3 py-1 text-xs font-semibold text-primary\">\n              {{ linkedOperationRecords.length }}\n            </span>\n          </div>\n\n          <div\n            v-if=\"!linkedOperationRecords.length\"\n            class=\"flex-1 flex flex-col items-center justify-center rounded-xl bg-case-elevated py-8 text-sm text-gray-600 text-center gap-2\"\n          >\n            <Icon icon=\"bi:people\" class=\"text-2xl text-gray-700\" />\n            No linked people for this operation yet.\n          </div>\n\n          <div v-else class=\"flex-1 overflow-y-auto space-y-2 min-h-0\">\n            <button\n              v-for=\"record in linkedOperationRecords\"\n              :key=\"record._id\"\n              type=\"button\"\n              class=\"flex w-full items-center gap-3 rounded-xl border border-case-border bg-case-elevated px-3 py-2.5 text-left transition hover:border-amber-700/40 hover:bg-amber-900/10\"\n              @click=\"selectRecordForBubble(record)\"\n            >\n              <img\n                v-if=\"record.profilePhoto?.dataUrl\"\n                class=\"h-10 w-10 flex-shrink-0 rounded-lg object-cover\"\n                :src=\"record.profilePhoto.dataUrl\"\n                :alt=\"formatRecordName(record)\"\n              />\n              <div\n                v-else\n                class=\"flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-case-bg text-xs font-semibold uppercase text-gray-500\"\n              >\n                {{ getRecordInitials(record) }}\n              </div>\n              <div class=\"min-w-0 flex-1\">\n                <p class=\"truncate text-sm font-semibold text-gray-100\">{{ formatRecordName(record) }}</p>\n                <p class=\"truncate text-xs text-gray-500\">{{ getLinkedRecordSummary(record) }}</p>\n              </div>\n            </button>\n          </div>\n        </div>\n      </div>\n    </div>\n\n  </div>\n</template>\n\n<script>\n  import { Icon } from \"@iconify/vue\";\n  import API from \"@/services/api\";\n\n  export default {\n    name: \"Dashboard\",\n    data() {\n      return {\n        recentRecords: [],\n        recentRecordsSearch: \"\",\n        isLoadingRecords: false,\n        recordsError: \"\",\n        bubblePositions: {},\n        activeBubbleDrag: null,\n        selectedBubbleRecordId: \"\",\n        bubbleDisplayLimit: 31,\n      };\n    },\n    computed: {\n      selectedBubbleRecord() {\n        return (\n          this.recentRecords.find(\n            (r) => r._id === this.selectedBubbleRecordId\n          ) || null\n        );\n      },\n      filteredRecentRecords() {\n        const q = this.recentRecordsSearch.trim().toLowerCase();\n        if (!q) return this.recentRecords;\n        return this.recentRecords.filter((r) => {\n          const info = r.personalInformation || {};\n          const op = r.operationDetails || {};\n          return [info.firstName, info.middleName, info.lastName, info.alias, op.operationName]\n            .filter(Boolean)\n            .some((v) => v.toLowerCase().includes(q));\n        });\n      },\n      bubbleRecords() {\n        if (!this.selectedBubbleRecordId) {\n          return this.recentRecords.slice(0, this.bubbleDisplayLimit);\n        }\n        const sel = this.recentRecords.find((r) => r._id === this.selectedBubbleRecordId);\n        const rest = this.recentRecords.filter((r) => r._id !== this.selectedBubbleRecordId);\n        return [sel, ...rest].filter(Boolean).slice(0, this.bubbleDisplayLimit);\n      },\n      linkedOperationRecords() {\n        const opName = this.selectedBubbleRecord?.operationDetails?.operationName?.trim();\n        if (!opName) return [];\n        return this.recentRecords.filter((r) => {\n          return (\n            r._id !== this.selectedBubbleRecordId &&\n            r.operationDetails?.operationName?.trim() === opName\n          );\n        });\n      },\n    },\n    components: { Icon },\n    methods: {\n      async loadRecentRecords() {\n        this.isLoadingRecords = true;\n        this.recordsError = \"\";\n        try {\n          const res = await API.get(\"/records\");\n          this.recentRecords = Array.isArray(res.data) ? res.data : [];\n          this.selectedBubbleRecordId =\n            this.selectedBubbleRecordId &&\n            this.recentRecords.some((r) => r._id === this.selectedBubbleRecordId)\n              ? this.selectedBubbleRecordId\n              : this.recentRecords[0]?._id || \"\";\n          this.initializeBubblePositions();\n        } catch (err) {\n          this.recordsError = err.response?.data?.message || \"Unable to load registrations.\";\n        } finally {\n          this.isLoadingRecords = false;\n        }\n      },\n\n      formatRecordName(r) {\n        const i = r.personalInformation || {};\n        return [i.firstName, i.middleName, i.lastName].filter(Boolean).join(\" \");\n      },\n      getRecordInitials(r) {\n        const i = r.personalInformation || {};\n        return (\n          [i.firstName, i.lastName].filter(Boolean).map((v) => v.charAt(0)).join(\"\").slice(0, 2) || \"NA\"\n        );\n      },\n      formatRecordMeta(r) {\n        const i = r.personalInformation || {};\n        const op = r.operationDetails || {};\n        return [\n          i.alias ? `Alias: ${i.alias}` : null,\n          op.operationName || null,\n          r.createdAt ? new Date(r.createdAt).toLocaleDateString() : \"No date\",\n        ].filter(Boolean).join(\" · \");\n      },\n      formatRecordCreatedAt(r) {\n        return r.createdAt ? new Date(r.createdAt).toLocaleDateString() : \"No date\";\n      },\n      formatOperationDate(r) {\n        const v = r?.operationDetails?.operationDate;\n        return v ? new Date(v).toLocaleDateString() : \"No operation date\";\n      },\n      getBubbleSubtitle(r) {\n        return r.operationDetails?.operationName || \"Recent registration\";\n      },\n      getLinkedRecordSummary(r) {\n        const i = r.personalInformation || {};\n        return [\n          i.alias ? `Alias: ${i.alias}` : null,\n          i.nationality || null,\n          this.formatRecordCreatedAt(r),\n        ].filter(Boolean).join(\" · \");\n      },\n\n      getBubbleStyle(index, record) {\n        const stored = record?._id ? this.bubblePositions[record._id] : null;\n        const bubble = stored || this.getBubbleConfig(index);\n        return {\n          top: bubble.top,\n          left: bubble.left,\n          width: `${bubble.width || bubble.size}px`,\n          height: `${bubble.height || bubble.size}px`,\n          animationDelay: `${index * 0.8}s`,\n          animationDuration: `${6 + index * 0.6}s`,\n        };\n      },\n      getBubbleConfig(index) {\n        const focusLayout = { top: \"4%\", left: \"47%\", width: 255, height: 420 };\n        const fallback = { top: \"35%\", left: \"40%\", size: 105 };\n        if (this.selectedBubbleRecordId && index === 0) return focusLayout;\n        if (this.selectedBubbleRecordId) {\n          return this.getGeneratedBubbleLayout(index - 1, true) || fallback;\n        }\n        return this.getGeneratedBubbleLayout(index, false) || fallback;\n      },\n      getGeneratedBubbleLayout(index, isSelected) {\n        const sizePattern = isSelected ? [76, 68, 72, 66, 70] : [82, 74, 78, 70, 76, 72];\n        const columns = isSelected ? 4 : 6;\n        const columnGap = isSelected ? 11 : 14;\n        const rowGap = isSelected ? 12 : 14;\n        const baseLeft = isSelected ? 2 : 4;\n        const baseTop = isSelected ? 5 : 4;\n        const row = Math.floor(index / columns);\n        const col = index % columns;\n        const size = sizePattern[index % sizePattern.length];\n        const leftOffset = row % 2 === 0 ? 0 : isSelected ? 4 : 3;\n        const topOffset = isSelected ? [0, 3, 1, 4][col % 4] : col % 2 === 0 ? 0 : 2;\n        return {\n          top: `${baseTop + row * rowGap + topOffset}%`,\n          left: `${baseLeft + col * columnGap + leftOffset}%`,\n          size,\n        };\n      },\n\n      initializeBubblePositions() {\n        const next = {};\n        this.bubbleRecords.forEach((r, idx) => {\n          next[r._id] = this.bubblePositions[r._id] || this.getBubbleConfig(idx);\n        });\n        this.bubblePositions = next;\n      },\n      selectRecordForBubble(record) {\n        this.selectedBubbleRecordId = record._id;\n        this.$nextTick(() => this.initializeBubblePositions());\n      },\n      startBubbleDrag(event, record, index) {\n        const board = this.$refs.bubbleBoard;\n        if (!board) return;\n        event.preventDefault();\n        const pos = this.bubblePositions[record._id] || this.getBubbleConfig(index);\n        const rect = board.getBoundingClientRect();\n        this.activeBubbleDrag = {\n          id: record._id,\n          width: pos.width || pos.size,\n          height: pos.height || pos.size,\n          offsetX: event.clientX - rect.left - (parseFloat(pos.left) / 100) * rect.width,\n          offsetY: event.clientY - rect.top - (parseFloat(pos.top) / 100) * rect.height,\n        };\n      },\n      handleBubbleDrag(event) {\n        const board = this.$refs.bubbleBoard;\n        const drag = this.activeBubbleDrag;\n        if (!board || !drag) return;\n        const rect = board.getBoundingClientRect();\n        const maxX = Math.max(rect.width - drag.width, 0);\n        const maxY = Math.max(rect.height - drag.height, 0);\n        const nx = Math.min(Math.max(event.clientX - rect.left - drag.offsetX, 0), maxX);\n        const ny = Math.min(Math.max(event.clientY - rect.top - drag.offsetY, 0), maxY);\n        this.bubblePositions = {\n          ...this.bubblePositions,\n          [drag.id]: {\n            top: `${(ny / rect.height) * 100}%`,\n            left: `${(nx / rect.width) * 100}%`,\n            width: drag.width,\n            height: drag.height,\n          },\n        };\n      },\n      stopBubbleDrag() {\n        this.activeBubbleDrag = null;\n      },\n      isBubbleDragging(id) {\n        return this.activeBubbleDrag?.id === id;\n      },\n    },\n    mounted() {\n      window.addEventListener(\"pointermove\", this.handleBubbleDrag);\n      window.addEventListener(\"pointerup\", this.stopBubbleDrag);\n      this.loadRecentRecords();\n    },\n    beforeUnmount() {\n      window.removeEventListener(\"pointermove\", this.handleBubbleDrag);\n      window.removeEventListener(\"pointerup\", this.stopBubbleDrag);\n    },\n  };\n</script>\n\n<style scoped>\n.bubble-float {\n  animation-name: bubbleFloat;\n  animation-timing-function: ease-in-out;\n  animation-iteration-count: infinite;\n}\n.bubble-dragging,\n.bubble-static {\n  animation: none;\n}\n\n@keyframes bubbleFloat {\n  0%   { transform: translate3d(0, 0, 0); }\n  25%  { transform: translate3d(7px, -10px, 0); }\n  50%  { transform: translate3d(-5px, 8px, 0); }\n  75%  { transform: translate3d(9px, 3px, 0); }\n  100% { transform: translate3d(0, 0, 0); }\n}\n</style>\n"]},"metadata":{},"sourceType":"module"}