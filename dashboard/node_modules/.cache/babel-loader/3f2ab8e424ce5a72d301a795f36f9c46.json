{"ast":null,"code":"import \"core-js/modules/esnext.iterator.constructor.js\";\nimport \"core-js/modules/esnext.iterator.filter.js\";\nimport \"core-js/modules/esnext.iterator.find.js\";\nimport { Icon } from \"@iconify/vue\";\nimport API from \"@/services/api\";\nconst FOCUS_AREAS = [{\n  key: \"anti-illegal-drugs\",\n  tag: \"F1\",\n  title: \"Anti-Illegal Drugs\",\n  subtitle: \"Counter-narcotics operations\",\n  icon: \"mdi:pill\"\n}, {\n  key: \"anti-criminality\",\n  tag: \"F2\",\n  title: \"Anti-Criminality\",\n  subtitle: \"General criminality response\",\n  icon: \"mdi:shield-alert-outline\"\n}, {\n  key: \"internal-security\",\n  tag: \"F3\",\n  title: \"Internal Security\",\n  subtitle: \"Insurgency / terrorism focus\",\n  icon: \"mdi:shield-account-outline\"\n}, {\n  key: \"transnational-crime\",\n  tag: \"F4\",\n  title: \"Transnational Crime\",\n  subtitle: \"Cross-border criminal networks\",\n  icon: \"mdi:earth\"\n}];\nexport default {\n  name: \"FocusOperations\",\n  components: {\n    Icon\n  },\n  data() {\n    return {\n      focusAreas: FOCUS_AREAS,\n      activeFocus: FOCUS_AREAS[0].key,\n      entries: [],\n      loading: false,\n      error: \"\"\n    };\n  },\n  computed: {\n    activeFocusTitle() {\n      return this.focusAreas.find(f => f.key === this.activeFocus)?.title || \"\";\n    },\n    filteredEntries() {\n      return this.entries.filter(e => e.subCategory === this.activeFocus);\n    }\n  },\n  methods: {\n    countFor(key) {\n      return this.entries.filter(e => e.subCategory === key).length;\n    },\n    formatDate(d) {\n      if (!d) return \"—\";\n      return new Date(d).toLocaleDateString(\"en-US\", {\n        month: \"short\",\n        day: \"numeric\",\n        year: \"numeric\"\n      });\n    },\n    async load() {\n      this.loading = true;\n      this.error = \"\";\n      try {\n        const res = await API.get(\"/cases/entries/focus-operations\");\n        this.entries = Array.isArray(res.data) ? res.data : [];\n      } catch (err) {\n        this.error = err.response?.data?.message || \"Unable to load focus operations.\";\n      } finally {\n        this.loading = false;\n      }\n    },\n    openCreate() {\n      // TODO: wire to entry-create modal/route once form is built\n    }\n  },\n  mounted() {\n    this.load();\n  }\n};","map":{"version":3,"mappings":";;;AAyGE,SAASA,IAAG,QAAS,cAAc;AACnC,OAAOC,GAAE,MAAO,gBAAgB;AAEhC,MAAMC,WAAU,GAAI,CAClB;EAAEC,GAAG,EAAE,oBAAoB;EAAEC,GAAG,EAAE,IAAI;EAAEC,KAAK,EAAE,oBAAoB;EAAEC,QAAQ,EAAE,8BAA8B;EAAEC,IAAI,EAAE;AAAW,CAAC,EACjI;EAAEJ,GAAG,EAAE,kBAAkB;EAAEC,GAAG,EAAE,IAAI;EAAEC,KAAK,EAAE,kBAAkB;EAAEC,QAAQ,EAAE,8BAA8B;EAAEC,IAAI,EAAE;AAA2B,CAAC,EAC7I;EAAEJ,GAAG,EAAE,mBAAmB;EAAEC,GAAG,EAAE,IAAI;EAAEC,KAAK,EAAE,mBAAmB;EAAEC,QAAQ,EAAE,8BAA8B;EAAEC,IAAI,EAAE;AAA6B,CAAC,EACjJ;EAAEJ,GAAG,EAAE,qBAAqB;EAAEC,GAAG,EAAE,IAAI;EAAEC,KAAK,EAAE,qBAAqB;EAAEC,QAAQ,EAAE,gCAAgC;EAAEC,IAAI,EAAE;AAAY,CAAC,CACvI;AAED,eAAe;EACbC,IAAI,EAAE,iBAAiB;EACvBC,UAAU,EAAE;IAAET;EAAK,CAAC;EACpBU,IAAIA,GAAG;IACL,OAAO;MACLC,UAAU,EAAET,WAAW;MACvBU,WAAW,EAAEV,WAAW,CAAC,CAAC,CAAC,CAACC,GAAG;MAC/BU,OAAO,EAAE,EAAE;MACXC,OAAO,EAAE,KAAK;MACdC,KAAK,EAAE;IACT,CAAC;EACH,CAAC;EACDC,QAAQ,EAAE;IACRC,gBAAgBA,GAAG;MACjB,OAAO,IAAI,CAACN,UAAU,CAACO,IAAI,CAAEC,CAAC,IAAKA,CAAC,CAAChB,GAAE,KAAM,IAAI,CAACS,WAAW,CAAC,EAAEP,KAAI,IAAK,EAAE;IAC7E,CAAC;IACDe,eAAeA,GAAG;MAChB,OAAO,IAAI,CAACP,OAAO,CAACQ,MAAM,CAAEC,CAAC,IAAKA,CAAC,CAACC,WAAU,KAAM,IAAI,CAACX,WAAW,CAAC;IACvE;EACF,CAAC;EACDY,OAAO,EAAE;IACPC,QAAQA,CAACtB,GAAG,EAAE;MACZ,OAAO,IAAI,CAACU,OAAO,CAACQ,MAAM,CAAEC,CAAC,IAAKA,CAAC,CAACC,WAAU,KAAMpB,GAAG,CAAC,CAACuB,MAAM;IACjE,CAAC;IACDC,UAAUA,CAACC,CAAC,EAAE;MACZ,IAAI,CAACA,CAAC,EAAE,OAAO,GAAG;MAClB,OAAO,IAAIC,IAAI,CAACD,CAAC,CAAC,CAACE,kBAAkB,CAAC,OAAO,EAAE;QAAEC,KAAK,EAAE,OAAO;QAAEC,GAAG,EAAE,SAAS;QAAEC,IAAI,EAAE;MAAU,CAAC,CAAC;IACrG,CAAC;IACD,MAAMC,IAAIA,GAAG;MACX,IAAI,CAACpB,OAAM,GAAI,IAAI;MACnB,IAAI,CAACC,KAAI,GAAI,EAAE;MACf,IAAI;QACF,MAAMoB,GAAE,GAAI,MAAMlC,GAAG,CAACmC,GAAG,CAAC,iCAAiC,CAAC;QAC5D,IAAI,CAACvB,OAAM,GAAIwB,KAAK,CAACC,OAAO,CAACH,GAAG,CAACzB,IAAI,IAAIyB,GAAG,CAACzB,IAAG,GAAI,EAAE;MACxD,EAAE,OAAO6B,GAAG,EAAE;QACZ,IAAI,CAACxB,KAAI,GAAIwB,GAAG,CAACC,QAAQ,EAAE9B,IAAI,EAAE+B,OAAM,IAAK,kCAAkC;MAChF,UAAU;QACR,IAAI,CAAC3B,OAAM,GAAI,KAAK;MACtB;IACF,CAAC;IACD4B,UAAUA,GAAG;MACX;IAAA;EAEJ,CAAC;EACDC,OAAOA,GAAG;IACR,IAAI,CAACT,IAAI,CAAC,CAAC;EACb;AACF,CAAC","names":["Icon","API","FOCUS_AREAS","key","tag","title","subtitle","icon","name","components","data","focusAreas","activeFocus","entries","loading","error","computed","activeFocusTitle","find","f","filteredEntries","filter","e","subCategory","methods","countFor","length","formatDate","d","Date","toLocaleDateString","month","day","year","load","res","get","Array","isArray","err","response","message","openCreate","mounted"],"sourceRoot":"","sources":["D:\\joremiodotonline\\dashboard\\src\\views\\cases\\FocusOperations.vue"],"sourcesContent":["<template>\n  <div class=\"min-h-screen bg-case-bg p-3 sm:p-5 space-y-5\">\n\n    <!-- ── Page header ─────────────────────────────────────────────────── -->\n    <header class=\"flex flex-wrap items-end justify-between gap-4\">\n      <div>\n        <p class=\"text-[10px] font-semibold uppercase tracking-[0.35em] text-primary\">Case Monitoring</p>\n        <h1 class=\"mt-2 text-2xl font-semibold text-white\">4-Focus Operations</h1>\n        <p class=\"mt-1 text-xs text-gray-500 max-w-xl\">\n          Strategic operations grouped under the four primary focus areas. Records and operational\n          activity feed into the entries below.\n        </p>\n      </div>\n      <div class=\"flex flex-wrap items-center gap-2\">\n        <router-link\n          to=\"/cases/records\"\n          class=\"rounded-md border border-case-border bg-case-surface px-3 py-2 text-xs font-medium text-gray-300 hover:bg-case-elevated transition-colors flex items-center gap-2\">\n          <Icon icon=\"mdi:account-box-outline\" class=\"text-base\" /> Records\n        </router-link>\n        <router-link\n          to=\"/cases/operations\"\n          class=\"rounded-md border border-case-border bg-case-surface px-3 py-2 text-xs font-medium text-gray-300 hover:bg-case-elevated transition-colors flex items-center gap-2\">\n          <Icon icon=\"mdi:target\" class=\"text-base\" /> Operations\n        </router-link>\n        <button\n          @click=\"openCreate\"\n          class=\"rounded-md bg-primary px-3 py-2 text-xs font-semibold text-black hover:bg-primary/90 transition-colors flex items-center gap-2\">\n          <Icon icon=\"mdi:plus\" class=\"text-base\" /> New Focus Entry\n        </button>\n      </div>\n    </header>\n\n    <!-- ── Focus tiles ─────────────────────────────────────────────────── -->\n    <section class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3\">\n      <button\n        v-for=\"focus in focusAreas\"\n        :key=\"focus.key\"\n        @click=\"activeFocus = focus.key\"\n        class=\"text-left bg-case-surface border border-case-border rounded-xl p-4 hover:border-primary/40 hover:bg-case-card transition-colors\"\n        :class=\"{ 'border-primary/60 bg-case-card ring-1 ring-primary/20': activeFocus === focus.key }\">\n        <div class=\"flex items-center justify-between mb-3\">\n          <Icon :icon=\"focus.icon\" class=\"text-xl text-primary\" />\n          <span class=\"text-[10px] uppercase tracking-[0.2em] text-gray-600\">{{ focus.tag }}</span>\n        </div>\n        <p class=\"text-sm font-semibold text-white\">{{ focus.title }}</p>\n        <p class=\"text-[11px] text-gray-500 mt-1\">{{ focus.subtitle }}</p>\n        <p class=\"mt-3 text-2xl font-bold text-primary leading-none\">{{ countFor(focus.key) }}</p>\n        <p class=\"text-[10px] text-gray-600 mt-1\">entries logged</p>\n      </button>\n    </section>\n\n    <!-- ── Entries list ────────────────────────────────────────────────── -->\n    <section class=\"bg-case-surface border border-case-border rounded-xl\">\n      <header class=\"flex items-center justify-between border-b border-case-border px-5 py-3\">\n        <div>\n          <h2 class=\"text-sm font-semibold text-white\">{{ activeFocusTitle }} — Entries</h2>\n          <p class=\"text-[10px] text-gray-600\">Recent activity for this focus area.</p>\n        </div>\n        <Icon icon=\"bi:three-dots-vertical\" class=\"text-gray-700\" />\n      </header>\n      <div class=\"p-5\">\n        <div v-if=\"loading\" class=\"space-y-2\">\n          <div v-for=\"i in 4\" :key=\"i\" class=\"h-9 animate-pulse rounded-lg bg-case-elevated\"></div>\n        </div>\n        <div v-else-if=\"error\" class=\"rounded-md border border-red-900/50 bg-red-950/30 p-4 text-xs text-red-400\">\n          {{ error }}\n        </div>\n        <table v-else-if=\"filteredEntries.length\" class=\"w-full text-sm\">\n          <thead>\n            <tr class=\"border-b border-case-border\">\n              <th class=\"py-2.5 px-3 text-left text-[10px] uppercase tracking-[0.18em] text-gray-600 font-medium\">Title</th>\n              <th class=\"py-2.5 px-3 text-left text-[10px] uppercase tracking-[0.18em] text-gray-600 font-medium\">Lead Agency</th>\n              <th class=\"py-2.5 px-3 text-left text-[10px] uppercase tracking-[0.18em] text-gray-600 font-medium\">Status</th>\n              <th class=\"py-2.5 px-3 text-right text-[10px] uppercase tracking-[0.18em] text-gray-600 font-medium\">Date</th>\n            </tr>\n          </thead>\n          <tbody>\n            <tr v-for=\"entry in filteredEntries\" :key=\"entry._id\"\n              class=\"border-b border-case-border/40 hover:bg-case-card transition-colors\">\n              <td class=\"py-2.5 px-3 text-gray-300 font-medium\">{{ entry.title }}</td>\n              <td class=\"py-2.5 px-3 text-gray-500\">{{ entry.leadAgency || \"—\" }}</td>\n              <td class=\"py-2.5 px-3\">\n                <span class=\"rounded-full bg-case-elevated px-2 py-0.5 text-[10px] uppercase tracking-wide text-gray-400\">\n                  {{ entry.status || \"open\" }}\n                </span>\n              </td>\n              <td class=\"py-2.5 px-3 text-gray-600 text-right text-xs\">{{ formatDate(entry.createdAt) }}</td>\n            </tr>\n          </tbody>\n        </table>\n        <div v-else class=\"py-12 flex flex-col items-center justify-center text-center\">\n          <Icon icon=\"mdi:folder-search-outline\" class=\"text-3xl text-gray-700 mb-2\" />\n          <p class=\"text-xs text-gray-500\">No entries yet for {{ activeFocusTitle }}.</p>\n          <button\n            @click=\"openCreate\"\n            class=\"mt-3 text-xs text-primary hover:underline\">\n            Add the first entry\n          </button>\n        </div>\n      </div>\n    </section>\n  </div>\n</template>\n\n<script>\n  import { Icon } from \"@iconify/vue\";\n  import API from \"@/services/api\";\n\n  const FOCUS_AREAS = [\n    { key: \"anti-illegal-drugs\", tag: \"F1\", title: \"Anti-Illegal Drugs\", subtitle: \"Counter-narcotics operations\", icon: \"mdi:pill\" },\n    { key: \"anti-criminality\", tag: \"F2\", title: \"Anti-Criminality\", subtitle: \"General criminality response\", icon: \"mdi:shield-alert-outline\" },\n    { key: \"internal-security\", tag: \"F3\", title: \"Internal Security\", subtitle: \"Insurgency / terrorism focus\", icon: \"mdi:shield-account-outline\" },\n    { key: \"transnational-crime\", tag: \"F4\", title: \"Transnational Crime\", subtitle: \"Cross-border criminal networks\", icon: \"mdi:earth\" },\n  ];\n\n  export default {\n    name: \"FocusOperations\",\n    components: { Icon },\n    data() {\n      return {\n        focusAreas: FOCUS_AREAS,\n        activeFocus: FOCUS_AREAS[0].key,\n        entries: [],\n        loading: false,\n        error: \"\",\n      };\n    },\n    computed: {\n      activeFocusTitle() {\n        return this.focusAreas.find((f) => f.key === this.activeFocus)?.title || \"\";\n      },\n      filteredEntries() {\n        return this.entries.filter((e) => e.subCategory === this.activeFocus);\n      },\n    },\n    methods: {\n      countFor(key) {\n        return this.entries.filter((e) => e.subCategory === key).length;\n      },\n      formatDate(d) {\n        if (!d) return \"—\";\n        return new Date(d).toLocaleDateString(\"en-US\", { month: \"short\", day: \"numeric\", year: \"numeric\" });\n      },\n      async load() {\n        this.loading = true;\n        this.error = \"\";\n        try {\n          const res = await API.get(\"/cases/entries/focus-operations\");\n          this.entries = Array.isArray(res.data) ? res.data : [];\n        } catch (err) {\n          this.error = err.response?.data?.message || \"Unable to load focus operations.\";\n        } finally {\n          this.loading = false;\n        }\n      },\n      openCreate() {\n        // TODO: wire to entry-create modal/route once form is built\n      },\n    },\n    mounted() {\n      this.load();\n    },\n  };\n</script>\n"]},"metadata":{},"sourceType":"module"}