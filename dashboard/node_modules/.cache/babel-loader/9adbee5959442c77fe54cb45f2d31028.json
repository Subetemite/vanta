ity(ev) {\n      const confirmed = await this.openConfirmationDialog({\n        title: \"Delete activity?\",\n        description: `Activity \"${ev.title}\" will be permanently removed.`,\n        confirmText: \"Yes, delete\"\n      });\n      if (!confirmed) return;\n      try {\n        await API.delete(`/admin/calendar/activities/${ev.id}`);\n        this.closeDayDetail();\n        await this.loadFeed();\n      } catch (err) {\n        this.errorMessage = err.response?.data?.message || \"Unable to delete activity.\";\n      }\n    }\n  },\n  mounted() {\n    const now = new Date();\n    this.viewYear = now.getUTCFullYear();\n    this.viewMonth = now.getUTCMonth();\n    this.loadEmployees();\n    this.loadFeed();\n  }\n};\nfunction startOfDay(d) {\n  return new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate()));\n}","map":{"version":3,"mappings":";;;AAyME,OAAOA,GAAE,MAAO,gBAAgB;AAChC,OAAOC,kBAAiB,MAAO,qCAAqC;AACpE,SAASC,6BAA6B,EAAEC,mBAAkB,QAAS,8BAA8B;AAEjG,MAAMC,cAAa,GAAI,CAAC,SAAS,EAAE,YAAY,EAAE,UAAU,EAAE,SAAS,EAAE,OAAO,EAAE,OAAO,CAAC;AACzF,MAAMC,QAAO,GAAI,CAAC,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,CAAC;AAClE,MAAMC,WAAU,GAAI,CAAC,SAAS,EAAE,UAAU,EAAE,OAAO,EAAE,OAAO,EAAE,KAAK,EAAE,MAAM,EAAE,MAAM,EAAE,QAAQ,EAAE,WAAW,EAAE,SAAS,EAAE,UAAU,EAAE,UAAU,CAAC;AAE9I,SAASC,GAAGA,CAACC,IAAI,EAAE;EACjB,OAAO,GAAGA,IAAI,CAACC,cAAc,CAAC,CAAC,IAAIC,MAAM,CAACF,IAAI,CAACG,WAAW,CAAC,IAAI,CAAC,CAAC,CAACC,QAAQ,CAAC,CAAC,EAAE,GAAG,CAAC,IAAIF,MAAM,CAACF,IAAI,CAACK,UAAU,CAAC,CAAC,CAAC,CAACD,QAAQ,CAAC,CAAC,EAAE,GAAG,CAAC,EAAE;AACpI;AAEA,SAASE,iBAAiBA,GAAG;EAC3B,OAAO;IACLC,OAAO,EAAE,KAAK;IACdC,SAAS,EAAE,EAAE;IACbC,KAAK,EAAE,EAAE;IACTC,IAAI,EAAEd,cAAc,CAAC,CAAC,CAAC;IACvBe,SAAS,EAAE,EAAE;IACbC,OAAO,EAAE,EAAE;IACXC,SAAS,EAAE,EAAE;IACbC,OAAO,EAAE,EAAE;IACXC,QAAQ,EAAE,EAAE;IACZC,WAAW,EAAE,EAAE;IACfC,SAAS,EAAE,EAAE;IACbC,YAAY,EAAE,KAAK;IACnBC,KAAK,EAAE;EACT,CAAC;AACH;AAEA,eAAe;EACbC,IAAI,EAAE,eAAe;EACrBC,UAAU,EAAE;IAAE5B;EAAmB,CAAC;EAClC6B,IAAIA,GAAG;IA