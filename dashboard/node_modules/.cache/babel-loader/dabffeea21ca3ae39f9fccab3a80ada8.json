{"ast":null,"code":"import { Icon } from \"@iconify/vue\";\nconst MODULES = [{\n  key: \"hris\",\n  title: \"HRIS\",\n  icon: \"mdi:account-multiple-outline\",\n  to: \"/hris\",\n  description: \"Timekeeping, calendar of activities, and documents routing.\",\n  features: [\"Daily Time Record\", \"Calendar of Activities\", \"Documents Routing\"]\n}, {\n  key: \"cases\",\n  title: \"Case Monitoring\",\n  icon: \"mdi:shield-search\",\n  to: \"/cases\",\n  description: \"Economic sabotage, ANTI-POGO, organized crime, graft & corruption.\",\n  features: [\"Records\", \"Operations\", \"Reports\"]\n}, {\n  key: \"logistics\",\n  title: \"Logistics & Support\",\n  icon: \"mdi:truck-fast-outline\",\n  to: \"/logistics\",\n  description: \"Asset, supply, and operational support tracking.\",\n  features: [\"Coming soon\"]\n}];\nexport default {\n  name: \"ModulesHome\",\n  components: {\n    Icon\n  },\n  computed: {\n    currentUser() {\n      try {\n        return JSON.parse(localStorage.getItem(\"auth_user\") || \"null\");\n      } catch {\n        return null;\n      }\n    },\n    allModules() {\n      return MODULES;\n    },\n    availableModules() {\n      return MODULES.filter(m => this.hasAccess(m.key));\n    }\n  },\n  methods: {\n    hasAccess(moduleKey) {\n      const user = this.currentUser;\n      if (!user) return false;\n      if (user.role === \"admin\") return true;\n      return Boolean(user.modulePermissions?.[moduleKey]);\n    }\n  }\n};","map":{"version":3,"mappings":"AA8CE,SAASA,IAAG,QAAS,cAAc;AAEnC,MAAMC,OAAM,GAAI,CACd;EACEC,GAAG,EAAE,MAAM;EACXC,KAAK,EAAE,MAAM;EACbC,IAAI,EAAE,8BAA8B;EACpCC,EAAE,EAAE,OAAO;EACXC,WAAW,EAAE,6DAA6D;EAC1EC,QAAQ,EAAE,CAAC,mBAAmB,EAAE,wBAAwB,EAAE,mBAAmB;AAC/E,CAAC,EACD;EACEL,GAAG,EAAE,OAAO;EACZC,KAAK,EAAE,iBAAiB;EACxBC,IAAI,EAAE,mBAAmB;EACzBC,EAAE,EAAE,QAAQ;EACZC,WAAW,EAAE,oEAAoE;EACjFC,QAAQ,EAAE,CAAC,SAAS,EAAE,YAAY,EAAE,SAAS;AAC/C,CAAC,EACD;EACEL,GAAG,EAAE,WAAW;EAChBC,KAAK,EAAE,qBAAqB;EAC5BC,IAAI,EAAE,wBAAwB;EAC9BC,EAAE,EAAE,YAAY;EAChBC,WAAW,EAAE,kDAAkD;EAC/DC,QAAQ,EAAE,CAAC,aAAa;AAC1B,CAAC,CACF;AAED,eAAe;EACbC,IAAI,EAAE,aAAa;EACnBC,UAAU,EAAE;IAAET;EAAK,CAAC;EACpBU,QAAQ,EAAE;IACRC,WAAWA,GAAG;MACZ,IAAI;QACF,OAAOC,IAAI,CAACC,KAAK,CAACC,YAAY,CAACC,OAAO,CAAC,WAAW,KAAK,MAAM,CAAC;MAChE,EAAE,MAAM;QACN,OAAO,IAAI;MACb;IACF,CAAC;IACDC,UAAUA,GAAG;MACX,OAAOf,OAAO;IAChB,CAAC;IACDgB,gBAAgBA,GAAG;MACjB,OAAOhB,OAAO,CAACiB,MAAM,CAAEC,CAAC,IAAK,IAAI,CAACC,SAAS,CAACD,CAAC,CAACjB,GAAG,CAAC,CAAC;IACrD;EACF,CAAC;EACDmB,OAAO,EAAE;IACPD,SAASA,CAACE,SAAS,EAAE;MACnB,MAAMC,IAAG,GAAI,IAAI,CAACZ,WAAW;MAC7B,IAAI,CAACY,IAAI,EAAE,OAAO,KAAK;MACvB,IAAIA,IAAI,CAACC,IAAG,KAAM,OAAO,EAAE,OAAO,IAAI;MACtC,OAAOC,OAAO,CAACF,IAAI,CAACG,iBAAiB,GAAGJ,SAAS,CAAC,CAAC;IACrD;EACF;AACF,CAAC","names":["Icon","MODULES","key","title","icon","to","description","features","name","components","computed","currentUser","JSON","parse","localStorage","getItem","allModules","availableModules","filter","m","hasAccess","methods","moduleKey","user","role","Boolean","modulePermissions"],"sourceRoot":"","sources":["D:\\joremiodotonline\\dashboard\\src\\views\\ModulesHome.vue"],"sourcesContent":["<template>\n  <div class=\"min-h-screen bg-case-bg px-6 py-10 sm:px-10 lg:px-12\">\n    <header class=\"mb-10\">\n      <p class=\"text-xs uppercase tracking-[0.35em] text-primary\">VANTA Platform</p>\n      <h1 class=\"mt-2 text-2xl font-semibold text-white sm:text-3xl\">Pick a module</h1>\n      <p class=\"mt-1 text-sm text-gray-500\">\n        You have access to {{ availableModules.length }} of {{ allModules.length }} modules.\n      </p>\n    </header>\n\n    <div class=\"grid gap-5 sm:grid-cols-2 lg:grid-cols-3\">\n      <router-link\n        v-for=\"mod in allModules\"\n        :key=\"mod.key\"\n        :to=\"hasAccess(mod.key) ? mod.to : ''\"\n        :event=\"hasAccess(mod.key) ? 'click' : ''\"\n        class=\"group relative flex flex-col rounded-2xl border border-case-border bg-case-surface p-6 transition\"\n        :class=\"hasAccess(mod.key)\n          ? 'hover:border-primary/40 hover:bg-case-card cursor-pointer'\n          : 'opacity-50 cursor-not-allowed'\"\n      >\n        <div class=\"flex items-center justify-between\">\n          <span class=\"flex h-11 w-11 items-center justify-center rounded-xl bg-primary/10 text-primary\">\n            <Icon :icon=\"mod.icon\" class=\"text-2xl\" />\n          </span>\n          <span\n            v-if=\"!hasAccess(mod.key)\"\n            class=\"rounded-full bg-case-elevated px-2.5 py-1 text-[10px] font-semibold uppercase tracking-[0.2em] text-gray-500\"\n          >\n            No access\n          </span>\n        </div>\n        <h2 class=\"mt-5 text-lg font-semibold text-white\">{{ mod.title }}</h2>\n        <p class=\"mt-2 text-sm leading-relaxed text-gray-500\">{{ mod.description }}</p>\n        <ul class=\"mt-4 space-y-1 text-xs text-gray-600\">\n          <li v-for=\"f in mod.features\" :key=\"f\" class=\"flex items-center gap-2\">\n            <span class=\"h-1 w-1 rounded-full bg-primary/60\"></span>\n            {{ f }}\n          </li>\n        </ul>\n      </router-link>\n    </div>\n  </div>\n</template>\n\n<script>\n  import { Icon } from \"@iconify/vue\";\n\n  const MODULES = [\n    {\n      key: \"hris\",\n      title: \"HRIS\",\n      icon: \"mdi:account-multiple-outline\",\n      to: \"/hris\",\n      description: \"Timekeeping, calendar of activities, and documents routing.\",\n      features: [\"Daily Time Record\", \"Calendar of Activities\", \"Documents Routing\"],\n    },\n    {\n      key: \"cases\",\n      title: \"Case Monitoring\",\n      icon: \"mdi:shield-search\",\n      to: \"/cases\",\n      description: \"Economic sabotage, ANTI-POGO, organized crime, graft & corruption.\",\n      features: [\"Records\", \"Operations\", \"Reports\"],\n    },\n    {\n      key: \"logistics\",\n      title: \"Logistics & Support\",\n      icon: \"mdi:truck-fast-outline\",\n      to: \"/logistics\",\n      description: \"Asset, supply, and operational support tracking.\",\n      features: [\"Coming soon\"],\n    },\n  ];\n\n  export default {\n    name: \"ModulesHome\",\n    components: { Icon },\n    computed: {\n      currentUser() {\n        try {\n          return JSON.parse(localStorage.getItem(\"auth_user\") || \"null\");\n        } catch {\n          return null;\n        }\n      },\n      allModules() {\n        return MODULES;\n      },\n      availableModules() {\n        return MODULES.filter((m) => this.hasAccess(m.key));\n      },\n    },\n    methods: {\n      hasAccess(moduleKey) {\n        const user = this.currentUser;\n        if (!user) return false;\n        if (user.role === \"admin\") return true;\n        return Boolean(user.modulePermissions?.[moduleKey]);\n      },\n    },\n  };\n</script>\n"]},"metadata":{},"sourceType":"module"}