,"subject","lines","actionOptions","uploadedFile","isUploading","uploadError","isSubmitting","errorMessage","computed","currentUser","JSON","parse","localStorage","getItem","encoderCode","u","employee","employeeId","username","toUpperCase","generatedControlPreview","now","Date","getFullYear","getMonth","getDate","methods","addLine","push","removeLine","idx","splice","formatBytes","bytes","units","i","n","toFixed","handleFileSelect","event","file","target","files","size","base64","fileToBase64","res","post","fileName","mimeType","type","contentBase64","f","id","Error","originalName","url","err","response","message","Promise","resolve","reject","reader","FileReader","onload","result","onerror","readAsDataURL","handleSubmit","attachedFile","$router"],"sourceRoot":"","sources":["D:\\joremiodotonline\\dashboard\\src\\views\\hris\\documents\\NewRecord.vue"],"sourcesContent":["<template>\n  <div class=\"min-h-screen bg-case-bg px-6 py-8 sm:px-10 lg:px-12\">\n    <header class=\"mb-6 flex items-center justify-between\">\n      <div>\n        <p class=\"text-xs uppercase tracking-[0.35em] text-primary\">HRIS / Documents</p>\n        <h1 class=\"mt-2 text-2xl font-semibold text-white\">\n          User <span class=\"text-primary\">{{ encoderCode }}</span> Dashboard\n        </h1>\n      </div>\n      <button\n        type=\"button\"\n        class=\"rounded-xl border border-case-border bg-case-surface px-4 py-2 text-sm text-gray-300 hover:bg-case-card\"\n        @click=\"$router.push('/hris/documents')\"\n      >\n        Back\n      </button>\n    </header>\n\n    <h2 class=\"mb-4 inline-block rounded-md bg-primary/10 px-4 py-1.5 text-sm font-semibold uppercase tracking-[0.25em] text-primary\">\n      New Record\n    </h2>\n\n    <form class=\"space-y-6\" @submit.prevent=\"handleSubmit\">\n      <div class=\"rounded-2xl border border-case-border bg-case-surface p-5 sm:p-6\">\n        <div class=\"grid gap-4 sm:grid-cols-2\">\n          <div>\n            <label class=\"mb-1 block text-xs font-medium uppercase tracking-[0.2em] text-gray-500\">Control Number</label>\n            <input\n              type=\"text\"\n              :value=\"generatedControlPreview\"\n              disabled\n              class=\"w-full rounded-xl border border-case-border bg-case-card px-3 py-2 text-sm text-gray-500\"\n            />\n            <p class=\"mt-1 text-[11px] text-gray-600\">Generated on submit.</p>\n          </div>\n          <div>\n            <label class=\"mb-1 block text-xs font-medium uppercase tracking-[0.2em] text-gray-500\">\n              Subject <span class=\"text-primary\">*</span>\n            </label>\n            <input\n              v-model=\"form.subject\"\n              type=\"text\"\n              required\n              class=\"w-full rounded-xl border border-case-border bg-case-card px-3 py-2 text-sm text-gray-200 outline-none focus:border-primary\"\n              placeholder=\"e.g. TWG MEETING\"\n            />\n          </div>\n        </div>\n      </div>\n\n      <div\n        v-for=\"(line, idx) in form.lines\"\n        :key=\"idx\"\n        class=\"rounded-2xl border border-case-border bg-case-surface p-5 sm:p-6\"\n      >\n        <div class=\"mb-4 flex items-center justify-between\">\n          <h3 class=\"text-sm font-semibold uppercase tracking-[0.25em] text-gray-300\">Line {{ idx + 1 }}</h3>\n          <button\n            v-if=\"form.lines.length > 1\"\n            type=\"button\"\n            class=\"text-xs text-gray-500 hover:text-red-400\"\n            @click=\"removeLine(idx)\"\n          >\n            Remove\n          </button>\n        </div>\n\n        <div class=\"grid gap-4 sm:grid-cols-2 lg:grid-cols-3\">\n          <div>\n            <label class=\"mb-1 block text-xs font-medium uppercase tracking-[0.2em] text-gray-500\">From <span class=\"text-primary\">*</span></label>\n            <input\n              v-model=\"line.from\"\n              type=\"text\"\n              required\n              class=\"w-full rounded-xl border border-case-border bg-case-card px-3 py-2 text-sm text-gray-200 outline-none focus:border-primary\"\n              placeholder=\"Office name\"\n            />\n          </div>\n          <div>\n            <label class=\"mb-1 block text-xs font-medium uppercase tracking-[0.2em] text-gray-500\">To <span class=\"text-primary\">*</span></label>\n            <input\n              v-model=\"line.to\"\n              type=\"text\"\n              required\n              class=\"w-full rounded-xl border border-case-border bg-case-card px-3 py-2 text-sm text-gray-200 outline-none focus:border-primary\"\n              placeholder=\"Office name\"\n            />\n          </div>\n          <div>\n            <label class=\"mb-1 block text-xs font-medium uppercase tracking-[0.2em] text-gray-500\">Action Requested <span class=\"text-primary\">*</span></label>\n            <select\n              v-model=\"line.actionRequested\"\n              required\n              class=\"w-full rounded-xl border border-case-border bg-case-card px-3 py-2 text-sm text-gray-200 outline-none focus:border-primary\"\n            >\n              <option v-for=\"opt in actionOptions\" :key=\"opt\" :value=\"opt\">{{ opt }}</option>\n            </select>\n          </div>\n          <div>\n            <label class=\"mb-1 block text-xs font-medium uppercase tracking-[0.2em] text-gray-500\">Date <span class=\"text-primary\">*</span></label>\n            <input\n              v-model=\"line.date\"\n              type=\"date\"\n              required\n              class=\"w-full rounded-xl border border-case-border bg-case-card px-3 py-2 text-sm text-gray-200 outline-none focus:border-primary\"\n            />\n          </div>\n          <div>\n            <label class=\"mb-1 block text-xs font-medium uppercase tracking-[0.2em] text-gray-500\">Sender's Name <span class=\"text-primary\">*</span></label>\n            <input\n              v-model=\"line.senderName\"\n              type=\"text\"\n              required\n              class=\"w-full rounded-xl border border-case-border bg-case-card px-3 py-2 text-sm text-gray-200 outline-none focus:border-primary\"\n              placeholder=\"Originator\"\n            />\n          </div>\n          <div class=\"sm:col-span-2 lg:col-span-1\">\n            <label class=\"mb-1 block text-xs font-medium uppercase tracking-[0.2em] text-gray-500\">Additional Remarks</label>\n            <input\n              v-model=\"line.additionalRemarks\"\n              type=\"text\"\n              class=\"w-full rounded-xl border border-case-border bg-case-card px-3 py-2 text-sm text-gray-200 outline-none focus:border-primary\"\n              placeholder=\"Optional\"\n            />\n          </div>\n        </div>\n      </div>\n\n      <div class=\"flex flex-wrap items-center gap-3\">\n        <button\n          type=\"button\"\n          class=\"rounded-xl bg-blue-600/80 px-4 py-2 text-sm font-semibold text-white transition hover:bg-blue-600 disabled:cursor-not-allowed disabled:opacity-50\"\n          :disabled=\"form.lines.length >= 5\"\n          @click=\"addLine\"\n        >\n          + ADD LINE\n        </button>\n        <span class=\"text-xs text-gray-500\">{{ form.lines.length }} / 5 lines</span>\n      </div>\n\n      <div class=\"rounded-2xl border border-case-border bg-case-surface p-5 sm:p-6\">\n        <label class=\"mb-2 block text-xs font-medium uppercase tracking-[0.2em] text-gray-500\">\n          Attached File <span class=\"text-primary\">*</span>\n        </label>\n        <div class=\"flex items-center gap-3\">\n          <input\n            ref=\"fileInput\"\n            type=\"file\"\n            class=\"hidden\"\n            @change=\"handleFileSelect\"\n          />\n          <button\n            type=\"button\"\n            class=\"rounded-xl border border-case-border bg-case-card px-4 py-2 text-sm text-gray-300 hover:bg-case-elevated\"\n            @click=\"$refs.fileInput.click()\"\n          >\n            {{ uploadedFile ? 'Replace file' : 'Choose file' }}\n          </button>\n          <p v-if=\"uploadedFile\" class=\"truncate text-xs text-gray-400\">\n            {{ uploadedFile.originalName }} ({{ formatBytes(uploadedFile.size) }})\n          </p>\n          <p v-else class=\"text-xs text-gray-600\">No file chosen.</p>\n        </div>\n        <p v-if=\"isUploading\" class=\"mt-2 text-xs text-primary\">Uploading...</p>\n        <p v-if=\"uploadError\" class=\"mt-2 text-xs text-red-400\">{{ uploadError }}</p>\n      </div>\n\n      <div v-if=\"errorMessage\" class=\"rounded-2xl border border-red-900/50 bg-red-950/30 px-4 py-3 text-sm text-red-400\">\n        {{ errorMessage }}\n      </div>\n\n      <div class=\"flex justify-end\">\n        <button\n          type=\"submit\"\n          class=\"rounded-xl bg-primary px-6 py-3 text-sm font-semibold text-black transition hover:bg-amber-500 disabled:cursor-not-allowed disabled:opacity-50\"\n          :disabled=\"isSubmitting || isUploading || !uploadedFile\"\n        >\n          {{ isSubmitting ? \"Submitting...\" : \"SUBMIT\" }}\n        </button>\n      </div>\n    </form>\n  </div>\n</template>\n\n<script>\n  import API from \"@/services/api\";\n\n  function emptyLine() {\n    return {\n      from: \"\",\n      to: \"\",\n      actionRequested: \"Review\",\n      date: \"\",\n      senderName: \"\",\n      additionalRemarks: \"\",\n    };\n  }\n\n  function pad(value, width) {\n    const str = String(value);\n    return str.length >= width ? str : \"0\".repeat(width - str.length) + str;\n  }\n\n  export default {\n    name: \"HrisDocumentsNew\",\n    data() {\n      return {\n        form: {\n          subject: \"\",\n          lines: [emptyLine()],\n        },\n        actionOptions: [\"Review\", \"Approve\", \"Sign\", \"Forward\", \"File\", \"Noted\", \"Other\"],\n        uploadedFile: null,\n        isUploading: false,\n        uploadError: \"\",\n        isSubmitting: false,\n        errorMessage: \"\",\n      };\n    },\n    computed: {\n      currentUser() {\n        try {\n          return JSON.parse(localStorage.getItem(\"auth_user\") || \"null\");\n        } catch {\n          return null;\n        }\n      },\n      encoderCode() {\n        const u = this.currentUser;\n        return u?.employee?.employeeId || u?.username?.toUpperCase() || \"—\";\n      },\n      generatedControlPreview() {\n        const now = new Date();\n        return `${now.getFullYear()}${pad(now.getMonth() + 1, 2)}${pad(now.getDate(), 2)}-####`;\n      },\n    },\n    methods: {\n      addLine() {\n        if (this.form.lines.length >= 5) return;\n        this.form.lines.push(emptyLine());\n      },\n      removeLine(idx) {\n        this.form.lines.splice(idx, 1);\n      },\n      formatBytes(bytes) {\n        if (!bytes) return \"0 B\";\n        const units = [\"B\", \"KB\", \"MB\", \"GB\"];\n        let i = 0;\n        let n = bytes;\n        while (n >= 1024 && i < units.length - 1) {\n          n /= 1024;\n          i++;\n        }\n        return `${n.toFixed(1)} ${units[i]}`;\n      },\n      async handleFileSelect(event) {\n        const [file] = event.target.files || [];\n        if (!file) return;\n\n        if (file.size > 5 * 1024 * 1024) {\n          this.uploadError = \"Please choose a file 5 MB or smaller.\";\n          event.target.value = \"\";\n          return;\n        }\n\n        this.uploadError = \"\";\n        this.isUploading = true;\n\n        try {\n          const base64 = await this.fileToBase64(file);\n          const res = await API.post(\"/files\", {\n            fileName: file.name,\n            mimeType: file.type,\n            contentBase64: base64,\n          });\n          const f = res.data?.file;\n          if (!f?.id) throw new Error(\"Upload returned no file id.\");\n          this.uploadedFile = {\n            id: f.id,\n            originalName: f.originalName,\n            url: f.url,\n            mimeType: f.mimeType,\n            size: f.size,\n          };\n        } catch (err) {\n          this.uploadError = err.response?.data?.message || err.message || \"Upload failed.\";\n        } finally {\n          this.isUploading = false;\n          event.target.value = \"\";\n        }\n      },\n      fileToBase64(file) {\n        return new Promise((resolve, reject) => {\n          const reader = new FileReader();\n          reader.onload = () => resolve(reader.result);\n          reader.onerror = reject;\n          reader.readAsDataURL(file);\n        });\n      },\n      async handleSubmit() {\n        this.errorMessage = \"\";\n\n        if (!this.uploadedFile) {\n          this.errorMessage = \"An attached file is required.\";\n          return;\n        }\n\n        this.isSubmitting = true;\n\n        try {\n          await API.post(\"/hris/documents\", {\n            subject: this.form.subject,\n            lines: this.form.lines,\n            attachedFile: this.uploadedFile,\n          });\n          this.$router.push(\"/hris/documents\");\n        } catch (err) {\n          this.errorMessage = err.response?.data?.message || \"Unable to save the record.\";\n        } finally {\n          this.isSubmitting = false;\n        }\n      },\n    },\n  };\n</script>\n"]},"metadata":{},"sourceType":"module"}