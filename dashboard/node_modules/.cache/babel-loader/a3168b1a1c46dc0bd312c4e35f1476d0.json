{"ast":null,"code":"import FormSection from \"@/components/FormSection.vue\";\nexport default {\n  name: \"ProfileUploadSection\",\n  components: {\n    FormSection\n  },\n  emits: [\"change\"],\n  props: {\n    fileName: {\n      type: String,\n      default: \"\"\n    },\n    profileSummary: {\n      type: String,\n      required: true\n    },\n    profilePreview: {\n      type: String,\n      default: \"\"\n    }\n  }\n};","map":{"version":3,"mappings":"AA4CE,OAAOA,WAAU,MAAO,8BAA8B;AAEtD,eAAe;EACbC,IAAI,EAAE,sBAAsB;EAC5BC,UAAU,EAAE;IACVF;EACF,CAAC;EACDG,KAAK,EAAE,CAAC,QAAQ,CAAC;EACjBC,KAAK,EAAE;IACLC,QAAQ,EAAE;MACRC,IAAI,EAAEC,MAAM;MACZC,OAAO,EAAE;IACX,CAAC;IACDC,cAAc,EAAE;MACdH,IAAI,EAAEC,MAAM;MACZG,QAAQ,EAAE;IACZ,CAAC;IACDC,cAAc,EAAE;MACdL,IAAI,EAAEC,MAAM;MACZC,OAAO,EAAE;IACX;EACF;AACF,CAAC","names":["FormSection","name","components","emits","props","fileName","type","String","default","profileSummary","required","profilePreview"],"sourceRoot":"","sources":["D:\\joremiodotonline\\dashboard\\src\\components\\ProfileUploadSection.vue"],"sourcesContent":["<template>\n  <FormSection\n    title=\"Profile Upload\"\n    badge-text=\"Image\"\n    badge-class=\"bg-amber-50 text-amber-700\"\n  >\n    <div class=\"rounded-3xl border border-dashed border-blue-200 bg-blue-50/70 p-5\">\n      <div class=\"grid gap-4 sm:grid-cols-[1.2fr_0.8fr] sm:items-start\">\n        <div>\n          <label for=\"profilePhoto\" class=\"block text-sm font-medium text-slate-700\">\n            Upload profile photo\n          </label>\n          <input\n            id=\"profilePhoto\"\n            type=\"file\"\n            accept=\"image/png,image/jpeg,image/webp\"\n            class=\"mt-3 block w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-600 file:mr-4 file:rounded-xl file:border-0 file:bg-blue-950 file:px-4 file:py-2 file:text-sm file:font-semibold file:text-white\"\n            @change=\"$emit('change', $event)\"\n          />\n          <p class=\"mt-3 text-sm text-slate-500\">\n            Accepted formats: PNG, JPG, WEBP. Recommended size: 2 MB or below.\n          </p>\n        </div>\n\n        <div class=\"rounded-2xl border border-blue-100 bg-white p-4 shadow-sm shadow-blue-100/60\">\n          <p class=\"text-sm text-slate-900\">\n            <span class=\"font-medium\">{{ fileName || \"Selected image\" }}</span>\n          </p>\n          <p class=\"mt-1 text-sm text-slate-500\">\n            {{ profileSummary }}\n          </p>\n          <img\n            v-if=\"profilePreview\"\n            :src=\"profilePreview\"\n            alt=\"Profile preview\"\n            class=\"mt-3 h-24 w-24 rounded-2xl object-cover\"\n          />\n        </div>\n      </div>\n    </div>\n  </FormSection>\n</template>\n\n<script>\n  import FormSection from \"@/components/FormSection.vue\";\n\n  export default {\n    name: \"ProfileUploadSection\",\n    components: {\n      FormSection,\n    },\n    emits: [\"change\"],\n    props: {\n      fileName: {\n        type: String,\n        default: \"\",\n      },\n      profileSummary: {\n        type: String,\n        required: true,\n      },\n      profilePreview: {\n        type: String,\n        default: \"\",\n      },\n    },\n  };\n</script>\n"]},"metadata":{},"sourceType":"module"}