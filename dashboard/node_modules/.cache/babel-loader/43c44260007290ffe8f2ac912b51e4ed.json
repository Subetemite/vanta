    <span class=\"mr-2\"> 15.9% </span\n                ><span>\n                  <Icon icon=\"akar-icons:arrow-down\" />\n                </span>\n              </h2>\n            </span>\n            <span class=\"\">\n              <h2 class=\"text-green-500 flex\">\n                <span class=\"mr-2\"> 87.9% </span\n                ><span>\n                  <Icon icon=\"akar-icons:arrow-up\" />\n                </span>\n              </h2>\n            </span>\n          </div>\n        </div>\n\n        <div class=\"px-5 pb-5\">\n          <div\n            v-if=\"isLoadingRecords\"\n            class=\"flex h-[260px] items-center justify-center rounded-3xl bg-slate-50 text-sm text-gray-500 dark:bg-gray-900/40 dark:text-gray-400\"\n          >\n            Loading registration bubbles...\n          </div>\n          <div\n            v-else-if=\"recordsError\"\n            class=\"flex h-[260px] items-center justify-center rounded-3xl bg-red-50 px-6 text-sm text-red-500\"\n          >\n            {{ recordsError }}\n          </div>\n          <div\n            v-else-if=\"!bubbleRecords.length\"\n            class=\"flex h-[260px] items-center justify-center rounded-3xl bg-slate-50 text-sm text-gray-500 dark:bg-gray-900/40 dark:text-gray-400\"\n          >\n            No registered data available yet.\n          </div>\n          <div\n            v-else\n            class=\"relative h-[260px] overflow-hidden rounded-[2rem] bg-[radial-gradient(circle_at_top,_rgba(59,130,246,0.2),_transparent_45%),linear-gradient(135deg,_rgba(15,23,42,0.06),_rgba(59,130,246,0.12))]\"\n          >\n            <div\n              v-for=\"(record, index) in bubbleRecords\"\n              :key=\"record._id\"\n              class=\"absolute flex flex-col items-center justify-center rounded-full border border-white/60 bg-white/80 p-3 text-center shadow-lg shadow-slate-900/10 backdrop-blur-sm dark:border-white/10 dark:bg-slate-900/70\"\n              :style=\"getBubbleStyle(index)\"\n            >\n              <img\n                v-if=\"record.profilePhoto?.dataUrl\"\n                :src=\"record.profilePhoto.dataUrl\"\n                :alt=\"formatRecordName(record)\"\n                class=\"mb-2 h-12 w-12 rounded-full object-cover ring-2 ring-white/80\"\n              />\n              <div\n                v-else\n                class=\"mb-2 flex h-12 w-12 items-center justify-center rounded-full bg-slate-200 text-xs font-semibold uppercase text-slate-600 ring-2 ring-white/80 dark:bg-gray-700 dark:text-gray-300\"\n              >\n                {{ getRecordInitials(record) }}\n              </div>\n              <p class=\"max-w-[90%] overflow-hidden text-ellipsis whitespace-nowrap text-xs font-semibold leading-4 text-slate-800 dark:text-gray-100\">\n                {{ formatRecordName(record) }}\n              </p>\n            </div>\n          </div>\n        </div>\n        <br />\n        <hr />\n        <div class=\"wrapper-button p-5 flex justify-between mt-3\">\n          <select\n            name=\"\"\n            id=\"\"\n            class=\"dark:bg-gray-800 dark:hover:bg-gray-700 dark:border-gray-700 border max-w-lg px-4 py-3 block rounded-md text-gray-500 dark:text-gray-400\"\n          >\n            <option value=\"\">Last 3 years</option>\n          </select>\n          <button class=\"uppercase border-b border-red-600 text-red-600\">\n            Crime Report\n          </button>\n        </div>\n      </div>\n      <div\n        class=\"bg-white dark:bg-gray-800 p-5 lg:mt-0 mt-4 lg:w-2/4 border dark:border-gray-700 rounded-md w-full\"\n      >\n        <div class=\"\">\n          <h2 class=\"text-lg font-semibold dark:text-gray-200\">\n            RECENT REGISTRATIONS\n          </h2>\n          <p class=\"text-gray-400\">latest records saved from the registration form</p>\n        </div>\n        <perfect-scrollbar class=\"divide-y h-96 mt-5 dark:divide-gray-700\">\n          <div\n            v-if=\"isLoading