{"ast":null,"code":"import API from \"@/services/api\";\nfunction createInitialForm() {\n  return {\n    operationId: \"\",\n    operationCodeName: \"\",\n    operationType: \"\",\n    objective: \"\",\n    plannedDateTime: \"\",\n    actualDateTime: \"\",\n    fullAddress: \"\",\n    cityDistrict: \"\",\n    operationCommander: \"\",\n    teamLeader: \"\"\n  };\n}\nexport default {\n  name: \"OperationRegistration\",\n  data() {\n    return {\n      form: createInitialForm(),\n      isSubmitting: false,\n      message: {\n        type: \"\",\n        text: \"\"\n      }\n    };\n  },\n  methods: {\n    async handleSubmit() {\n      this.message = {\n        type: \"\",\n        text: \"\"\n      };\n      if (!this.form.operationId || !this.form.operationCodeName || !this.form.operationType) {\n        this.message = {\n          type: \"error\",\n          text: \"Operation ID, operation code name, and operation type are required.\"\n        };\n        return;\n      }\n      this.isSubmitting = true;\n      try {\n        const response = await API.post(\"/operations\", this.form);\n        this.message = {\n          type: \"success\",\n          text: response.data.message || \"Operation registration saved successfully.\"\n        };\n        this.form = createInitialForm();\n      } catch (error) {\n        this.message = {\n          type: \"error\",\n          text: error.response?.data?.message || \"Unable to save the operation right now.\"\n        };\n      } finally {\n        this.isSubmitting = false;\n      }\n    }\n  }\n};","map":{"version":3,"mappings":"AA4OE,OAAOA,GAAE,MAAO,gBAAgB;AAEhC,SAASC,iBAAiBA,GAAG;EAC3B,OAAO;IACLC,WAAW,EAAE,EAAE;IACfC,iBAAiB,EAAE,EAAE;IACrBC,aAAa,EAAE,EAAE;IACjBC,SAAS,EAAE,EAAE;IACbC,eAAe,EAAE,EAAE;IACnBC,cAAc,EAAE,EAAE;IAClBC,WAAW,EAAE,EAAE;IACfC,YAAY,EAAE,EAAE;IAChBC,kBAAkB,EAAE,EAAE;IACtBC,UAAU,EAAE;EACd,CAAC;AACH;AAEA,eAAe;EACbC,IAAI,EAAE,uBAAuB;EAC7BC,IAAIA,GAAG;IACL,OAAO;MACLC,IAAI,EAAEb,iBAAiB,CAAC,CAAC;MACzBc,YAAY,EAAE,KAAK;MACnBC,OAAO,EAAE;QACPC,IAAI,EAAE,EAAE;QACRC,IAAI,EAAE;MACR;IACF,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACP,MAAMC,YAAYA,GAAG;MACnB,IAAI,CAACJ,OAAM,GAAI;QAAEC,IAAI,EAAE,EAAE;QAAEC,IAAI,EAAE;MAAG,CAAC;MAErC,IACE,CAAC,IAAI,CAACJ,IAAI,CAACZ,WAAU,IACrB,CAAC,IAAI,CAACY,IAAI,CAACX,iBAAgB,IAC3B,CAAC,IAAI,CAACW,IAAI,CAACV,aAAY,EACvB;QACA,IAAI,CAACY,OAAM,GAAI;UACbC,IAAI,EAAE,OAAO;UACbC,IAAI,EACF;QACJ,CAAC;QACD;MACF;MAEA,IAAI,CAACH,YAAW,GAAI,IAAI;MAExB,IAAI;QACF,MAAMM,QAAO,GAAI,MAAMrB,GAAG,CAACsB,IAAI,CAAC,aAAa,EAAE,IAAI,CAACR,IAAI,CAAC;QAEzD,IAAI,CAACE,OAAM,GAAI;UACbC,IAAI,EAAE,SAAS;UACfC,IAAI,EACFG,QAAQ,CAACR,IAAI,CAACG,OAAM,IACpB;QACJ,CAAC;QAED,IAAI,CAACF,IAAG,GAAIb,iBAAiB,CAAC,CAAC;MACjC,EAAE,OAAOsB,KAAK,EAAE;QACd,IAAI,CAACP,OAAM,GAAI;UACbC,IAAI,EAAE,OAAO;UACbC,IAAI,EACFK,KAAK,CAACF,QAAQ,EAAER,IAAI,EAAEG,OAAM,IAC5B;QACJ,CAAC;MACH,UAAU;QACR,IAAI,CAACD,YAAW,GAAI,KAAK;MAC3B;IACF;EACF;AACF,CAAC","names":["API","createInitialForm","operationId","operationCodeName","operationType","objective","plannedDateTime","actualDateTime","fullAddress","cityDistrict","operationCommander","teamLeader","name","data","form","isSubmitting","message","type","text","methods","handleSubmit","response","post","error"],"sourceRoot":"","sources":["D:\\joremiodotonline\\dashboard\\src\\views\\components\\operation.vue"],"sourcesContent":["<template>\n  <div class=\"min-h-screen bg-slate-100 p-4 text-slate-900 lg:p-6\">\n    <div class=\"mx-auto max-w-6xl\">\n      <div class=\"overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-2xl shadow-slate-900/5\">\n        <div class=\"grid lg:grid-cols-[0.9fr_1.1fr]\">\n          <section class=\"bg-[linear-gradient(165deg,_#0f172a_0%,_#0f766e_45%,_#22c55e_100%)] px-8 py-10 text-white sm:px-10 lg:px-12\">\n            <p class=\"text-sm font-semibold uppercase tracking-[0.35em] text-emerald-100/80\">\n              Operations\n            </p>\n            <h1 class=\"mt-4 text-4xl font-semibold leading-tight\">\n              Operation registration form\n            </h1>\n            <p class=\"mt-5 max-w-lg text-base leading-7 text-emerald-50/90\">\n              Register operational plans, command structure, and field location details in one dedicated form.\n            </p>\n\n            <div class=\"mt-10 grid gap-4\">\n              <div class=\"rounded-3xl border border-white/15 bg-white/10 p-5 backdrop-blur\">\n                Save both planned and actual date or time details for later comparison and audit.\n              </div>\n              <div class=\"rounded-3xl border border-white/15 bg-white/10 p-5 backdrop-blur\">\n                Capture the command chain and target address together so each operation record stays complete.\n              </div>\n            </div>\n\n            <div class=\"mt-10 rounded-3xl border border-white/15 bg-slate-950/20 p-5\">\n              <p class=\"text-xs font-semibold uppercase tracking-[0.25em] text-emerald-100/80\">\n                Summary\n              </p>\n              <div class=\"mt-4 grid gap-3 text-sm text-emerald-50/90\">\n                <p><span class=\"font-semibold\">Operation ID:</span> {{ form.operationId || \"Pending\" }}</p>\n                <p><span class=\"font-semibold\">Code name:</span> {{ form.operationCodeName || \"Pending\" }}</p>\n                <p><span class=\"font-semibold\">Commander:</span> {{ form.operationCommander || \"Pending\" }}</p>\n              </div>\n            </div>\n          </section>\n\n          <section class=\"px-6 py-8 sm:px-8 lg:px-10\">\n            <div class=\"mb-8\">\n              <p class=\"text-sm font-semibold uppercase tracking-[0.3em] text-primary/80\">\n                Operation Entry\n              </p>\n              <h2 class=\"mt-3 text-3xl font-semibold text-slate-900\">\n                Mission details\n              </h2>\n              <p class=\"mt-3 text-base leading-7 text-slate-500\">\n                Fill in the operation details below and save them directly to the database.\n              </p>\n            </div>\n\n            <form class=\"space-y-8\" @submit.prevent=\"handleSubmit\">\n              <div\n                v-if=\"message.text\"\n                :class=\"message.type === 'success' ? 'border-emerald-200 bg-emerald-50 text-emerald-700' : 'border-red-200 bg-red-50 text-red-700'\"\n                class=\"rounded-2xl border px-4 py-3 text-sm\"\n              >\n                {{ message.text }}\n              </div>\n\n              <div>\n                <div class=\"mb-4 flex items-center justify-between gap-4\">\n                  <h3 class=\"text-lg font-semibold text-slate-900\">Operation Profile</h3>\n                  <span class=\"rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500\">\n                    Required\n                  </span>\n                </div>\n\n                <div class=\"grid gap-5 sm:grid-cols-2\">\n                  <div>\n                    <label for=\"operationId\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                      Operation ID\n                    </label>\n                    <input\n                      id=\"operationId\"\n                      v-model.trim=\"form.operationId\"\n                      type=\"text\"\n                      class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                      placeholder=\"OP-2026-001\"\n                    />\n                  </div>\n\n                  <div>\n                    <label for=\"operationCodeName\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                      Operation Code Name\n                    </label>\n                    <input\n                      id=\"operationCodeName\"\n                      v-model.trim=\"form.operationCodeName\"\n                      type=\"text\"\n                      class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                      placeholder=\"Silent Falcon\"\n                    />\n                  </div>\n\n                  <div>\n                    <label for=\"operationType\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                      Operation Type\n                    </label>\n                    <input\n                      id=\"operationType\"\n                      v-model.trim=\"form.operationType\"\n                      type=\"text\"\n                      class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                      placeholder=\"Surveillance\"\n                    />\n                  </div>\n\n                  <div>\n                    <label for=\"cityDistrict\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                      City / District\n                    </label>\n                    <input\n                      id=\"cityDistrict\"\n                      v-model.trim=\"form.cityDistrict\"\n                      type=\"text\"\n                      class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                      placeholder=\"Quezon City District 2\"\n                    />\n                  </div>\n\n                  <div class=\"sm:col-span-2\">\n                    <label for=\"objective\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                      Objective\n                    </label>\n                    <textarea\n                      id=\"objective\"\n                      v-model.trim=\"form.objective\"\n                      rows=\"3\"\n                      class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                      placeholder=\"State the mission objective and expected result\"\n                    />\n                  </div>\n                </div>\n              </div>\n\n              <div>\n                <div class=\"mb-4 flex items-center justify-between gap-4\">\n                  <h3 class=\"text-lg font-semibold text-slate-900\">Date and Location</h3>\n                  <span class=\"rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-emerald-700\">\n                    Timeline\n                  </span>\n                </div>\n\n                <div class=\"grid gap-5 sm:grid-cols-2\">\n                  <div>\n                    <label for=\"plannedDateTime\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                      Planned Date / Time\n                    </label>\n                    <input\n                      id=\"plannedDateTime\"\n                      v-model=\"form.plannedDateTime\"\n                      type=\"datetime-local\"\n                      class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                    />\n                  </div>\n\n                  <div>\n                    <label for=\"actualDateTime\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                      Actual Date / Time\n                    </label>\n                    <input\n                      id=\"actualDateTime\"\n                      v-model=\"form.actualDateTime\"\n                      type=\"datetime-local\"\n                      class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                    />\n                  </div>\n\n                  <div class=\"sm:col-span-2\">\n                    <label for=\"fullAddress\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                      Full Address\n                    </label>\n                    <textarea\n                      id=\"fullAddress\"\n                      v-model.trim=\"form.fullAddress\"\n                      rows=\"3\"\n                      class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                      placeholder=\"House number, street, barangay, city, province\"\n                    />\n                  </div>\n                </div>\n              </div>\n\n              <div>\n                <div class=\"mb-4 flex items-center justify-between gap-4\">\n                  <h3 class=\"text-lg font-semibold text-slate-900\">Command Structure</h3>\n                  <span class=\"rounded-full bg-sky-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-sky-700\">\n                    Leadership\n                  </span>\n                </div>\n\n                <div class=\"grid gap-5 sm:grid-cols-2\">\n                  <div>\n                    <label for=\"operationCommander\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                      Operation Commander\n                    </label>\n                    <input\n                      id=\"operationCommander\"\n                      v-model.trim=\"form.operationCommander\"\n                      type=\"text\"\n                      class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                      placeholder=\"Chief Insp. Maria Santos\"\n                    />\n                  </div>\n\n                  <div>\n                    <label for=\"teamLeader\" class=\"mb-2 block text-sm font-medium text-slate-700\">\n                      Team Leader\n                    </label>\n                    <input\n                      id=\"teamLeader\"\n                      v-model.trim=\"form.teamLeader\"\n                      type=\"text\"\n                      class=\"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\"\n                      placeholder=\"SPO2 Juan Dela Cruz\"\n                    />\n                  </div>\n                </div>\n              </div>\n\n              <button\n                type=\"submit\"\n                class=\"flex w-full items-center justify-center rounded-2xl bg-slate-950 px-4 py-3.5 text-sm font-semibold text-white transition hover:bg-slate-800 disabled:cursor-not-allowed disabled:bg-slate-400\"\n                :disabled=\"isSubmitting\"\n              >\n                {{ isSubmitting ? \"Saving operation...\" : \"Save operation\" }}\n              </button>\n            </form>\n          </section>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\n  import API from \"@/services/api\";\n\n  function createInitialForm() {\n    return {\n      operationId: \"\",\n      operationCodeName: \"\",\n      operationType: \"\",\n      objective: \"\",\n      plannedDateTime: \"\",\n      actualDateTime: \"\",\n      fullAddress: \"\",\n      cityDistrict: \"\",\n      operationCommander: \"\",\n      teamLeader: \"\",\n    };\n  }\n\n  export default {\n    name: \"OperationRegistration\",\n    data() {\n      return {\n        form: createInitialForm(),\n        isSubmitting: false,\n        message: {\n          type: \"\",\n          text: \"\",\n        },\n      };\n    },\n    methods: {\n      async handleSubmit() {\n        this.message = { type: \"\", text: \"\" };\n\n        if (\n          !this.form.operationId ||\n          !this.form.operationCodeName ||\n          !this.form.operationType\n        ) {\n          this.message = {\n            type: \"error\",\n            text:\n              \"Operation ID, operation code name, and operation type are required.\",\n          };\n          return;\n        }\n\n        this.isSubmitting = true;\n\n        try {\n          const response = await API.post(\"/operations\", this.form);\n\n          this.message = {\n            type: \"success\",\n            text:\n              response.data.message ||\n              \"Operation registration saved successfully.\",\n          };\n\n          this.form = createInitialForm();\n        } catch (error) {\n          this.message = {\n            type: \"error\",\n            text:\n              error.response?.data?.message ||\n              \"Unable to save the operation right now.\",\n          };\n        } finally {\n          this.isSubmitting = false;\n        }\n      },\n    },\n  };\n</script>\n"]},"metadata":{},"sourceType":"module"}