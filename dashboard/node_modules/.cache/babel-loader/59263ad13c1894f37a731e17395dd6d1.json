{"ast":null,"code":"import { Icon } from \"@iconify/vue\";\nexport default {\n  props: {\n    collapsed: {\n      type: Boolean,\n      default: false\n    }\n  },\n  data() {\n    return {\n      isOpen: false\n    };\n  },\n  watch: {\n    collapsed(val) {\n      if (val) this.isOpen = false;\n    }\n  },\n  methods: {\n    toggleAccordion() {\n      this.isOpen = !this.isOpen;\n    }\n  },\n  components: {\n    Icon\n  }\n};","map":{"version":3,"mappings":"AAkCE,SAASA,IAAG,QAAS,cAAc;AACnC,eAAe;EACbC,KAAK,EAAE;IACLC,SAAS,EAAE;MACTC,IAAI,EAAEC,OAAO;MACbC,OAAO,EAAE;IACX;EACF,CAAC;EACDC,IAAIA,GAAG;IACL,OAAO;MACLC,MAAM,EAAE;IACV,CAAC;EACH,CAAC;EACDC,KAAK,EAAE;IACLN,SAASA,CAACO,GAAG,EAAE;MACb,IAAIA,GAAG,EAAE,IAAI,CAACF,MAAK,GAAI,KAAK;IAC9B;EACF,CAAC;EACDG,OAAO,EAAE;IACPC,eAAeA,GAAG;MAChB,IAAI,CAACJ,MAAK,GAAI,CAAC,IAAI,CAACA,MAAM;IAC5B;EACF,CAAC;EACDK,UAAU,EAAE;IAAEZ;EAAK;AACrB,CAAC","names":["Icon","props","collapsed","type","Boolean","default","data","isOpen","watch","val","methods","toggleAccordion","components"],"sourceRoot":"","sources":["D:\\joremiodotonline\\dashboard\\src\\components\\MenuAccordion.vue"],"sourcesContent":["<template>\n  <button\n    @click=\"!collapsed && toggleAccordion()\"\n    class=\"sidebar-tab text-gray-400 bg-transparent w-full flex rounded-md box-border p-3 transition-colors\"\n    :class=\"[\n      isOpen && !collapsed ? 'bg-case-elevated text-gray-200 is-active' : 'hover:bg-case-elevated hover:text-gray-200',\n      collapsed ? 'justify-center cursor-default' : 'text-left items-center'\n    ]\"\n    :title=\"collapsed ? String($slots.title?.()[0]?.children ?? '') : ''\"\n  >\n    <span class=\"text-xl flex-shrink-0\" :class=\"{ 'mr-3': !collapsed }\">\n      <slot name=\"icon\"></slot>\n    </span>\n    <span v-show=\"!collapsed\" class=\"w-full\">\n      <slot name=\"title\" />\n    </span>\n    <span\n      v-show=\"!collapsed\"\n      class=\"box-border mt-1 transition-transform text-gray-600 flex-shrink-0\"\n      :class=\"isOpen ? 'rotate-180' : 'rotate-0'\"\n    >\n      <Icon icon=\"fa6-solid:angle-down\" />\n    </span>\n  </button>\n\n  <div\n    v-show=\"isOpen && !collapsed\"\n    class=\"bg-case-bg rounded-md mt-1 p-2 text-gray-400\"\n  >\n    <slot name=\"content\" />\n  </div>\n</template>\n\n<script>\n  import { Icon } from \"@iconify/vue\";\n  export default {\n    props: {\n      collapsed: {\n        type: Boolean,\n        default: false,\n      },\n    },\n    data() {\n      return {\n        isOpen: false,\n      };\n    },\n    watch: {\n      collapsed(val) {\n        if (val) this.isOpen = false;\n      },\n    },\n    methods: {\n      toggleAccordion() {\n        this.isOpen = !this.isOpen;\n      },\n    },\n    components: { Icon },\n  };\n</script>\n"]},"metadata":{},"sourceType":"module"}