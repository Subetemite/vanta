{"ast":null,"code":"import { Icon } from \"@iconify/vue\";\nimport API from \"@/services/api\";\nexport default {\n  name: \"AdminDocumentsView\",\n  components: {\n    Icon\n  },\n  data() {\n    return {\n      record: null,\n      errorMessage: \"\"\n    };\n  },\n  computed: {\n    currentUser() {\n      try {\n        return JSON.parse(localStorage.getItem(\"auth_user\") || \"null\");\n      } catch {\n        return null;\n      }\n    },\n    encoderCode() {\n      const u = this.currentUser;\n      return u?.employee?.employeeId || u?.username?.toUpperCase() || \"—\";\n    }\n  },\n  methods: {\n    async loadRecord() {\n      this.errorMessage = \"\";\n      try {\n        const res = await API.get(`/admin/documents/${this.$route.params.id}`);\n        this.record = res.data?.record || null;\n        if (!this.record) this.errorMessage = \"Record not found.\";\n      } catch (err) {\n        this.errorMessage = err.response?.data?.message || \"Unable to load record.\";\n      }\n    },\n    formatDate(value) {\n      if (!value) return \"—\";\n      const d = new Date(value);\n      if (Number.isNaN(d.getTime())) return \"—\";\n      return d.toISOString().slice(0, 10);\n    }\n  },\n  mounted() {\n    this.loadRecord();\n  }\n};","map":{"version":3,"mappings":"AA2FE,SAASA,IAAG,QAAS,cAAc;AACnC,OAAOC,GAAE,MAAO,gBAAgB;AAEhC,eAAe;EACbC,IAAI,EAAE,oBAAoB;EAC1BC,UAAU,EAAE;IAAEH;EAAK,CAAC;EACpBI,IAAIA,GAAG;IACL,OAAO;MACLC,MAAM,EAAE,IAAI;MACZC,YAAY,EAAE;IAChB,CAAC;EACH,CAAC;EACDC,QAAQ,EAAE;IACRC,WAAWA,GAAG;MACZ,IAAI;QACF,OAAOC,IAAI,CAACC,KAAK,CAACC,YAAY,CAACC,OAAO,CAAC,WAAW,KAAK,MAAM,CAAC;MAChE,EAAE,MAAM;QACN,OAAO,IAAI;MACb;IACF,CAAC;IACDC,WAAWA,GAAG;MACZ,MAAMC,IAAI,IAAI,CAACN,WAAW;MAC1B,OAAOM,CAAC,EAAEC,QAAQ,EAAEC,UAAS,IAAKF,CAAC,EAAEG,QAAQ,EAAEC,WAAW,CAAC,KAAK,GAAG;IACrE;EACF,CAAC;EACDC,OAAO,EAAE;IACP,MAAMC,UAAUA,GAAG;MACjB,IAAI,CAACd,YAAW,GAAI,EAAE;MACtB,IAAI;QACF,MAAMe,GAAE,GAAI,MAAMpB,GAAG,CAACqB,GAAG,CAAC,oBAAoB,IAAI,CAACC,MAAM,CAACC,MAAM,CAACC,EAAE,EAAE,CAAC;QACtE,IAAI,CAACpB,MAAK,GAAIgB,GAAG,CAACjB,IAAI,EAAEC,MAAK,IAAK,IAAI;QACtC,IAAI,CAAC,IAAI,CAACA,MAAM,EAAE,IAAI,CAACC,YAAW,GAAI,mBAAmB;MAC3D,EAAE,OAAOoB,GAAG,EAAE;QACZ,IAAI,CAACpB,YAAW,GAAIoB,GAAG,CAACC,QAAQ,EAAEvB,IAAI,EAAEwB,OAAM,IAAK,wBAAwB;MAC7E;IACF,CAAC;IACDC,UAAUA,CAACC,KAAK,EAAE;MAChB,IAAI,CAACA,KAAK,EAAE,OAAO,GAAG;MACtB,MAAMC,IAAI,IAAIC,IAAI,CAACF,KAAK,CAAC;MACzB,IAAIG,MAAM,CAACC,KAAK,CAACH,CAAC,CAACI,OAAO,CAAC,CAAC,CAAC,EAAE,OAAO,GAAG;MACzC,OAAOJ,CAAC,CAACK,WAAW,CAAC,CAAC,CAACC,KAAK,CAAC,CAAC,EAAE,EAAE,CAAC;IACrC;EACF,CAAC;EACDC,OAAOA,GAAG;IACR,IAAI,CAAClB,UAAU,CAAC,CAAC;EACnB;AACF,CAAC","names":["Icon","API","name","components","data","record","errorMessage","computed","currentUser","JSON","parse","localStorage","getItem","encoderCode","u","employee","employeeId","username","toUpperCase","methods","loadRecord","res","get","$route","params","id","err","response","message","formatDate","value","d","Date","Number","isNaN","getTime","toISOString","slice","mounted"],"sourceRoot":"","sources":["D:\\joremiodotonline\\dashboard\\src\\views\\admin\\documents\\ViewRecord.vue"],"sourcesContent":["<template>\n  <div class=\"min-h-screen bg-case-bg px-6 py-8 sm:px-10 lg:px-12\">\n    <header class=\"mb-6 flex items-center justify-between\">\n      <div>\n        <p class=\"text-xs uppercase tracking-[0.35em] text-primary\">ADMIN / Documents Tracking System</p>\n        <h1 class=\"mt-2 text-2xl font-semibold text-white\">\n          User <span class=\"text-primary\">{{ encoderCode }}</span> Dashboard\n        </h1>\n      </div>\n      <button\n        type=\"button\"\n        class=\"rounded-xl bg-emerald-600/80 px-5 py-2 text-sm font-semibold text-white transition hover:bg-emerald-600\"\n        @click=\"$router.push('/admin/documents')\"\n      >\n        FINISH\n      </button>\n    </header>\n\n    <h2 class=\"mb-4 inline-block rounded-md bg-blue-600/20 px-4 py-1.5 text-sm font-semibold uppercase tracking-[0.25em] text-blue-300\">\n      View Record\n    </h2>\n\n    <div v-if=\"errorMessage\" class=\"mb-4 rounded-2xl border border-red-900/50 bg-red-950/30 px-4 py-3 text-sm text-red-400\">\n      {{ errorMessage }}\n    </div>\n\n    <div v-if=\"record\" class=\"space-y-6\">\n      <div class=\"grid gap-3 rounded-2xl border border-case-border bg-case-surface p-5 sm:grid-cols-3\">\n        <div>\n          <p class=\"text-xs uppercase tracking-[0.2em] text-gray-500\">Encoder</p>\n          <p class=\"mt-1 text-sm font-semibold text-white\">{{ record.encoder?.code || record.encoder?.username }}</p>\n        </div>\n        <div>\n          <p class=\"text-xs uppercase tracking-[0.2em] text-gray-500\">PAOCC Control No</p>\n          <p class=\"mt-1 text-sm font-semibold text-white tabular-nums\">{{ record.controlNumber }}</p>\n        </div>\n        <div>\n          <p class=\"text-xs uppercase tracking-[0.2em] text-gray-500\">Subject</p>\n          <p class=\"mt-1 text-sm font-semibold text-white\">{{ record.subject }}</p>\n        </div>\n      </div>\n\n      <div class=\"overflow-hidden rounded-2xl border border-case-border bg-case-surface\">\n        <table class=\"w-full text-left text-sm\">\n          <thead class=\"bg-case-elevated text-xs uppercase tracking-[0.2em] text-gray-500\">\n            <tr>\n              <th class=\"px-4 py-3 font-medium\">From</th>\n              <th class=\"px-4 py-3 font-medium\">To</th>\n              <th class=\"px-4 py-3 font-medium\">Action Requested</th>\n              <th class=\"px-4 py-3 font-medium\">Date</th>\n              <th class=\"px-4 py-3 font-medium\">Sender's Name</th>\n              <th class=\"px-4 py-3 font-medium\">Additional Remarks</th>\n            </tr>\n          </thead>\n          <tbody class=\"divide-y divide-case-border text-gray-300\">\n            <tr v-for=\"(line, idx) in record.lines\" :key=\"idx\">\n              <td class=\"px-4 py-3 text-gray-400\">\n                <span class=\"mr-2 text-xs text-gray-600\">Line {{ idx + 1 }}</span>\n                {{ line.from }}\n              </td>\n              <td class=\"px-4 py-3 text-gray-400\">{{ line.to }}</td>\n              <td class=\"px-4 py-3\">{{ line.actionRequested }}</td>\n              <td class=\"px-4 py-3 text-gray-400 tabular-nums\">{{ formatDate(line.date) }}</td>\n              <td class=\"px-4 py-3 text-gray-400\">{{ line.senderName }}</td>\n              <td class=\"px-4 py-3 text-gray-400\">{{ line.additionalRemarks || '—' }}</td>\n            </tr>\n          </tbody>\n        </table>\n      </div>\n\n      <div v-if=\"record.attachedFile?.url\" class=\"rounded-2xl border border-case-border bg-case-surface p-5\">\n        <p class=\"text-xs uppercase tracking-[0.2em] text-gray-500\">Attached File</p>\n        <a\n          :href=\"record.attachedFile.url\"\n          target=\"_blank\"\n          rel=\"noopener\"\n          class=\"mt-1 inline-flex items-center gap-2 text-sm text-primary hover:underline\"\n        >\n          <Icon icon=\"mdi:paperclip\" class=\"text-base\" />\n          {{ record.attachedFile.originalName }}\n        </a>\n      </div>\n    </div>\n\n    <div v-else-if=\"!errorMessage\" class=\"rounded-2xl border border-case-border bg-case-surface p-10 text-center text-sm text-gray-500\">\n      Loading record...\n    </div>\n  </div>\n</template>\n\n<script>\n  import { Icon } from \"@iconify/vue\";\n  import API from \"@/services/api\";\n\n  export default {\n    name: \"AdminDocumentsView\",\n    components: { Icon },\n    data() {\n      return {\n        record: null,\n        errorMessage: \"\",\n      };\n    },\n    computed: {\n      currentUser() {\n        try {\n          return JSON.parse(localStorage.getItem(\"auth_user\") || \"null\");\n        } catch {\n          return null;\n        }\n      },\n      encoderCode() {\n        const u = this.currentUser;\n        return u?.employee?.employeeId || u?.username?.toUpperCase() || \"—\";\n      },\n    },\n    methods: {\n      async loadRecord() {\n        this.errorMessage = \"\";\n        try {\n          const res = await API.get(`/admin/documents/${this.$route.params.id}`);\n          this.record = res.data?.record || null;\n          if (!this.record) this.errorMessage = \"Record not found.\";\n        } catch (err) {\n          this.errorMessage = err.response?.data?.message || \"Unable to load record.\";\n        }\n      },\n      formatDate(value) {\n        if (!value) return \"—\";\n        const d = new Date(value);\n        if (Number.isNaN(d.getTime())) return \"—\";\n        return d.toISOString().slice(0, 10);\n      },\n    },\n    mounted() {\n      this.loadRecord();\n    },\n  };\n</script>\n"]},"metadata":{},"sourceType":"module"}