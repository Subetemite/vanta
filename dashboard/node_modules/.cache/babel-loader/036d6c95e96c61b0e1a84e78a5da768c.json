AC,SAAS,EAAEyB,cAAc,CAAC;MAClD,EAAE,OAAOd,KAAK,EAAE;QACd,MAAM,IAAI,CAACX,UAAU,CACnB,OAAO,EACPW,KAAK,CAACJ,QAAQ,EAAE3B,IAAI,EAAEU,OAAM,IAC1B,yCACJ,CAAC;MACH,UAAU;QACR,IAAI,CAACP,YAAW,GAAI,KAAK;MAC3B;IACF;EACF,CAAC;EACD2C,OAAOA,GAAG;IACR,IAAI,CAACpB,cAAc,CAAC,CAAC;EACvB;AACF,CAAC","names":["nextTick","API","ConfirmationDialog","FormField","FormSection","createConfirmationDialogState","resolveConfirmation","fieldClass","selectOptions","operationType","createInitialForm","operationId","operationCodeName","objective","plannedDateTime","actualDateTime","fullAddress","cityDistrict","operationCommander","teamLeader","createFormFromOperation","operation","formatOperationMeta","formatOperationDate","filter","Boolean","join","value","date","Date","Number","isNaN","getTime","toLocaleString","createOperationConfirmationDialog","isEditing","visible","title","description","confirmText","name","components","data","form","selectedOperationId","isSubmitting","operations","operationSearch","isLoadingOperations","operationsError","confirmationDialog","confirmationResolver","message","type","text","computed","filteredOperations","keyword","toLowerCase","haystack","includes","methods","setMessage","$refs","messageBanner","scrollIntoView","behavior","block","loadOperations","response","get","Array","isArray","error","selectOperation","options","preserveMessage","_id","resetFormState","openConfirmationDialog","Promise","resolve","closeConfirmationDialog","confirmed","handleSubmit","put","post","successMessage","mounted"],"sourceRoot":"","sources":["D:\\joremiodotonline\\dashboard\\src\\views\\components\\operation.vue"],"sourcesContent":["<template>\n  <div class=\"min-h-screen bg-[radial-gradient(circle_at_top,_#064e3b_0%,_#052e2b_42%,_#021712_100%)] px-3 py-4 text-slate-900 sm:px-4 lg:px-6\">\n    <div class=\"mx-auto max-w-[1800px]\">\n      <div class=\"overflow-hidden rounded-[2rem] border border-emerald-950/40 bg-white/95 shadow-2xl shadow-black/30 backdrop-blur\">\n        <div class=\"grid lg:grid-cols-[0.95fr_1.25fr]\">\n          <section class=\"bg-[linear-gradient(165deg,_#022c22_0%,_#064e3b_20%,_#047857_55%,_#10b981_82%,_#6ee7b7_100%)] px-8 py-10 text-white sm:px-10 lg:px-12\">\n            <p class=\"text-sm font-semibold uppercase tracking-[0.35em] text-emerald-100/80\">\n              Operations\n            </p>\n\n            <div class=\"mt-8\">\n              <label for=\"operationSearch\" class=\"text-xs font-semibold uppercase tracking-[0.25em] text-emerald-100/80\">\n                Search\n              </label>\n              <input\n                id=\"operationSearch\"\n                v-model.trim=\"operationSearch\"\n                type=\"text\"\n                class=\"mt-3 w-full rounded-2xl border border-white/15 bg-white/10 px-4 py-3 text-white placeholder:text-emerald-100/60 outline-none backdrop-blur transition focus:border-emerald-200/80 focus:bg-white/15\"\n                placeholder=\"Search by ID, code name, type, commander, or city\"\n              />\n            </div>\n\n            <div class=\"operations-scrollbar mt-8 max-h-[34rem] overflow-y-auto pr-1\">\n              <div\n                v-if=\"isLoadingOperations\"\n                class=\"rounded-3xl border border-white/15 bg-white/10 p-5 text-sm text-emerald-100/85 backdrop-blur\"\n              >\n                Loading operations...\n              </div>\n              <div\n                v-else-if=\"operationsError\"\n                class=\"rounded-3xl border border-red-200/30 bg-red-500/10 p-5 text-sm text-red-100 backdrop-blur\"\n              >\n                {{ operationsError }}\n              </div>\n              <div\n                v-else-if=\"!filteredOperations.length\"\n                class=\"rounded-3xl border border-white/15 bg-white/10 p-5 text-sm text-emerald-100/85 backdrop-blur\"\n              >\n                No matching operations found.\n              </div>\n              <div\n                v-for=\"operation in filteredOperations\"\n                :key=\"operation._id\"\n                class=\"mt-4 rounded-3xl border p-4 transition first:mt-0\"\n                :class=\"selectedOperationId === operation._id ? 'border-emerald-200/80 bg-white/20 shadow-lg shadow-emerald-950/20 ring-1 ring-emerald-200/40' : 'border-white/15 bg-slate-950/25 hover:bg-white/10'\"\n                role=\"button\"\n                tabindex=\"0\"\n                @click=\"selectOperation(operation)\"\n              >\n                <div class=\"flex items-start justify-between gap-4\">\n                  <div class=\"min-w-0 text-sm text-emerald-50/90\">\n                    <p class=\"truncate font-semibold\">\n                      {{ operation.operationCodeName || \"Unnamed operation\" }}\n                    </p>\n                    <p class=\"mt-1 text-emerald-100/75\">\n                      {{ operation.operationId || \"Pending ID\" }}\n                    </p>\n                    <p class=\"mt-2 text-emerald-100/75\">\n                      {{ formatOperationMeta(operation) }}\n                    </p>\n                  </div>\n                  <span class=\"rounded-full bg-white/15 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.2em] text-white/90\">\n                    {{ operation.operationType || \"Type\" }}\n                  </span>\n                </div>\n              </div>\n            </div>\n          </section>\n\n          <section class=\"bg-[linear-gradient(180deg,_rgba(236,253,245,0.98)_0%,_rgba(240,253,250,0.98)_22%,_rgba(255,255,255,0.98)_100%)] px-6 py-8 sm:px-8 lg:px-10\">\n            <div class=\"mb-8\">\n              <p class=\"text-sm font-semibold uppercase tracking-[0.3em] text-emerald-700\">\n                OPERATION ENTRY\n              </p>\n              <h2 class=\"mt-3 text-3xl font-semibold text-slate-900\">\n                {{ isEditing ? \"Edit operation\" : \"Operation details\" }}\n              </h2>\n              <p class=\"mt-3 text-base leading-7 text-slate-500\">\n                {{ isEditing ? \"Update the selected operation and save the latest mission details.\" : \"Create a new operation record.\" }}\n              </p>\n              <div\n                v-if=\"isEditing\"\n                class=\"mt-4 flex flex-wrap items-center gap-3\"\n              >\n                <span class=\"rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-emerald-800\">\n                  Editing selected operation\n                </span>\n                <button\n                  type=\"button\"\n                  class=\"rounded-full border border-slate-200 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-slate-600 transition hover:border-slate-300 hover:bg-slate-50\"\n                  @click=\"resetFormState\"\n                >\n                  New operation\n                </button>\n              </div>\n            </div>\n\n            <form class=\"space-y-8\" @submit.prevent=\"handleSubmit\">\n              <div\n                ref=\"messageBanner\"\n                v-if=\"message.text\"\n                :class=\"message.type === 'success' ? 'border-emerald-200 bg-emerald-50 text-emerald-700' : 'border-red-200 bg-red-50 text-red-700'\"\n                class=\"rounded-2xl border px-4 py-3 text-sm\"\n              >\n                {{ message.text }}\n              </div>\n\n              <FormSection\n                title=\"Operation Profile\"\n                badge-text=\"Required\"\n                badge-class=\"bg-slate-100 text-slate-500\"\n              >\n                <div class=\"grid gap-5 sm:grid-cols-2\">\n                  <FormField label=\"Operation ID\" for-id=\"operationId\">\n                    <input\n                      id=\"operationId\"\n                      v-model.trim=\"form.operationId\"\n                      type=\"text\"\n                      :class=\"fieldClass\"\n                      placeholder=\"OP-2026-001\"\n                    />\n                  </FormField>\n\n                  <FormField label=\"Operation Code Name\" for-id=\"operationCodeName\">\n                    <input\n                      id=\"operationCodeName\"\n                      v-model.trim=\"form.operationCodeName\"\n                      type=\"text\"\n                      :class=\"fieldClass\"\n                      placeholder=\"Silent Falcon\"\n                    />\n                  </FormField>\n\n                  <FormField label=\"Operation Type\" for-id=\"operationType\">\n                    <select\n                      id=\"operationType\"\n                      v-model=\"form.operationType\"\n                      :class=\"fieldClass\"\n                    >\n                      <option disabled value=\"\">Select operation type</option>\n                      <option\n                        v-for=\"operationType in selectOptions.operationType\"\n                        :key=\"operationType\"\n                        :value=\"operationType\"\n                      >\n                        {{ operationType }}\n                      </option>\n                    </select>\n                  </FormField>\n\n                  <FormField label=\"City / District\" for-id=\"cityDistrict\">\n                    <input\n                      id=\"cityDistrict\"\n                      v-model.trim=\"form.cityDistrict\"\n                      type=\"text\"\n                      :class=\"fieldClass\"\n                      placeholder=\"Quezon City District 2\"\n                    />\n                  </FormField>\n\n                  <FormField label=\"Objective\" for-id=\"objective\" wrapper-class=\"sm:col-span-2\">\n                    <textarea\n                      id=\"objective\"\n                      v-model.trim=\"form.objective\"\n                      rows=\"3\"\n                      :class=\"fieldClass\"\n                      placeholder=\"State the mission objective and expected result\"\n                    />\n                  </FormField>\n                </div>\n              </FormSection>\n\n              <FormSection\n                title=\"Date and Location\"\n                badge-text=\"Timeline\"\n                badge-class=\"bg-emerald-50 text-emerald-700\"\n              >\n                <div class=\"grid gap-5 sm:grid-cols-2\">\n                  <FormField label=\"Planned Date / Time\" for-id=\"plannedDateTime\">\n                    <input\n                      id=\"plannedDateTime\"\n                      v-model=\"form.plannedDateTime\"\n                      type=\"datetime-local\"\n                      :class=\"fieldClass\"\n                    />\n                  </FormField>\n\n                  <FormField label=\"Actual Date / Time\" for-id=\"actualDateTime\">\n                    <input\n                      id=\"actualDateTime\"\n                      v-model=\"form.actualDateTime\"\n                      type=\"datetime-local\"\n                      :class=\"fieldClass\"\n                    />\n                  </FormField>\n\n                  <FormField label=\"Full Address\" for-id=\"fullAddress\" wrapper-class=\"sm:col-span-2\">\n                    <textarea\n                      id=\"fullAddress\"\n                      v-model.trim=\"form.fullAddress\"\n                      rows=\"3\"\n                      :class=\"fieldClass\"\n                      placeholder=\"House number, street, barangay, city, province\"\n                    />\n                  </FormField>\n                </div>\n              </FormSection>\n\n              <FormSection\n                title=\"Command Structure\"\n                badge-text=\"Leadership\"\n                badge-class=\"bg-sky-50 text-sky-700\"\n              >\n                <div class=\"grid gap-5 sm:grid-cols-2\">\n                  <FormField label=\"Operation Commander\" for-id=\"operationCommander\">\n                    <input\n                      id=\"operationCommander\"\n                      v-model.trim=\"form.operationCommander\"\n                      type=\"text\"\n                      :class=\"fieldClass\"\n                      placeholder=\"Chief Insp. Maria Santos\"\n                    />\n                  </FormField>\n\n                  <FormField label=\"Team Leader\" for-id=\"teamLeader\">\n                    <input\n                      id=\"teamLeader\"\n                      v-model.trim=\"form.teamLeader\"\n                      type=\"text\"\n                      :class=\"fieldClass\"\n                      placeholder=\"SPO2 Juan Dela Cruz\"\n                    />\n                  </FormField>\n                </div>\n              </FormSection>\n\n              <button\n                type=\"submit\"\n                class=\"flex w-full items-center justify-center rounded-2xl bg-[linear-gradient(135deg,_#022c22_0%,_#047857_50%,_#10b981_100%)] px-4 py-3.5 text-sm font-semibold text-white transition hover:opacity-95 disabled:cursor-not-allowed disabled:bg-slate-400\"\n                :disabled=\"isSubmitting\"\n              >\n                {{ isSubmitting ? \"Saving operation...\" : \"Save operation\" }}\n              </button>\n            </form>\n          </section>\n        </div>\n      </div>\n    </div>\n\n    <ConfirmationDialog\n      :visible=\"confirmationDialog.visible\"\n      :title=\"confirmationDialog.title\"\n      :description=\"confirmationDialog.description\"\n      :confirm-text=\"confirmationDialog.confirmText\"\n      @cancel=\"closeConfirmationDialog(false)\"\n      @confirm=\"closeConfirmationDialog(true)\"\n    />\n  </div>\n</template>\n\n<script>\n  import { nextTick } from \"vue\";\n  import API from \"@/services/api\";\n  import ConfirmationDialog from \"@/components/ConfirmationDialog.vue\";\n  import FormField from \"@/components/FormField.vue\";\n  import FormSection from \"@/components/FormSection.vue\";\n  import {\n    createConfirmationDialogState,\n    resolveConfirmation,\n  } from \"@/helper/record-confirmation\";\n\n  const fieldClass =\n    \"w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10\";\n\n  const selectOptions = {\n    operationType: [\n      \"Surveillance\",\n      \"Inspection\",\n      \"Apprehension\",\n      \"Monitoring\",\n      \"Rescue\",\n      \"Interdiction\",\n      \"Joint Operation\",\n      \"Special Assignment\",\n    ],\n  };\n\n  function createInitialForm() {\n    return {\n      operationId: \"\",\n      operationCodeName: \"\",\n      operationType: \"\",\n      objective: \"\",\n      plannedDateTime: \"\",\n      actualDateTime: \"\",\n      fullAddress: \"\",\n      cityDistrict: \"\",\n      operationCommander: \"\",\n      teamLeader: \"\",\n    };\n  }\n\n  function createFormFromOperation(operation) {\n    return {\n      ...createInitialForm(),\n      ...(operation || {}),\n    };\n  }\n\n  function formatOperationMeta(operation) {\n    return [\n      operation.operationCommander ? `Commander: ${operation.operationCommander}` : null,\n      operation.cityDistrict || null,\n      operation.plannedDateTime ? formatOperationDate(operation.plannedDateTime) : null,\n    ]\n      .filter(Boolean)\n      .join(\" | \");\n  }\n\n  function formatOperationDate(value) {\n    if (!value) {\n      return \"\";\n    }\n\n    const date = new Date(value);\n    if (Number.isNaN(date.getTime())) {\n      return value;\n    }\n\n    return date.toLocaleString();\n  }\n\n  function createOperationConfirmationDialog(isEditing) {\n    return {\n      visible: true,\n      title: isEditing ? \"Update operation?\" : \"Save new operation?\",\n      description: isEditing\n        ? \"This will apply your changes to the selected operation.\"\n        : \"This will save the current form as a new operation record.\",\n      confirmText: isEditing ? \"Yes, update\" : \"Yes, save\",\n    };\n  }\n\n  export default {\n    name: \"OperationRegistration\",\n    components: {\n      ConfirmationDialog,\n      FormField,\n      FormSection,\n    },\n    data() {\n      return {\n        form: createInitialForm(),\n        selectedOperationId: \"\",\n        isSubmitting: false,\n        operations: [],\n        operationSearch: \"\",\n        isLoadingOperations: false,\n        operationsError: \"\",\n        confirmationDialog: createConfirmationDialogState(),\n        confirmationResolver: null,\n        fieldClass,\n        selectOptions,\n        message: {\n          type: \"\",\n          text: \"\",\n        },\n      };\n    },\n    computed: {\n      isEditing() {\n        return Boolean(this.selectedOperationId);\n      },\n      filteredOperations() {\n        const keyword = this.operationSearch.toLowerCase();\n\n        if (!keyword) {\n          return this.operations;\n        }\n\n        return this.operations.filter((operation) => {\n          const haystack = [\n            operation.operationId,\n            operation.operationCodeName,\n            operation.operationType,\n            operation.operationCommander,\n            operation.teamLeader,\n            operation.cityDistrict,\n          ]\n            .filter(Boolean)\n            .join(\" \")\n            .toLowerCase();\n\n          return haystack.includes(keyword);\n        });\n      },\n    },\n    methods: {\n      async setMessage(type, text) {\n        this.message = { type, text };\n        await nextTick();\n        this.$refs.messageBanner?.scrollIntoView({\n          behavior: \"smooth\",\n          block: \"center\",\n        });\n      },\n      async loadOperations() {\n        this.isLoadingOperations = true;\n        this.operationsError = \"\";\n\n        try {\n          const response = await API.get(\"/operations\");\n          this.operations = Array.isArray(response.data) ? response.data : [];\n        } catch (error) {\n          this.operationsError =\n            error.response?.data?.message ||\n            \"Unable to load operations right now.\";\n        } finally {\n          this.isLoadingOperations = false;\n        }\n      },\n      formatOperationMeta,\n      selectOperation(operation, options = {}) {\n        const { preserveMessage = false } = options;\n        if (!preserveMessage) {\n          this.message = { type: \"\", text: \"\" };\n        }\n        this.selectedOperationId = operation._id;\n        this.form = createFormFromOperation(operation);\n      },\n      resetFormState(options = {}) {\n        const { preserveMessage = false } = options;\n        this.selectedOperationId = \"\";\n        this.form = createInitialForm();\n        if (!preserveMessage) {\n          this.message = { type: \"\", text: \"\" };\n        }\n      },\n      openConfirmationDialog() {\n        this.confirmationDialog = createOperationConfirmationDialog(this.isEditing);\n\n        return new Promise((resolve) => {\n          this.confirmationResolver = resolve;\n        });\n      },\n      closeConfirmationDialog(confirmed) {\n        this.confirmationDialog = createConfirmationDialogState();\n        resolveConfirmation(this.confirmationResolver, confirmed);\n        this.confirmationResolver = null;\n      },\n      async handleSubmit() {\n        this.message = { type: \"\", text: \"\" };\n\n        if (\n          !this.form.operationId ||\n          !this.form.operationCodeName ||\n          !this.form.operationType\n        ) {\n          await this.setMessage(\n            \"error\",\n            \"Operation ID, operation code name, and operation type are required.\"\n          );\n          return;\n        }\n\n        const confirmed = await this.openConfirmationDialog();\n        if (!confirmed) {\n          return;\n        }\n\n        this.isSubmitting = true;\n\n        try {\n          const response = this.isEditing\n            ? await API.put(`/operations/${this.selectedOperationId}`, this.form)\n            : await API.post(\"/operations\", this.form);\n\n          const successMessage =\n            response.data.message ||\n            (this.isEditing\n              ? \"Operation updated successfully.\"\n              : \"Operation registration saved successfully.\");\n\n          await this.loadOperations();\n          if (this.isEditing && response.data.operation) {\n            this.selectOperation(response.data.operation, { preserveMessage: true });\n          } else {\n            this.resetFormState({ preserveMessage: true });\n          }\n\n          await this.setMessage(\"success\", successMessage);\n        } catch (error) {\n          await this.setMessage(\n            \"error\",\n            error.response?.data?.message ||\n              \"Unable to save the operation right now.\"\n          );\n        } finally {\n          this.isSubmitting = false;\n        }\n      },\n    },\n    mounted() {\n      this.loadOperations();\n    },\n  };\n</script>\n\n<style scoped>\n  .operations-scrollbar {\n    scrollbar-width: thin;\n    scrollbar-color: rgba(110, 231, 183, 0.6) rgba(255, 255, 255, 0.06);\n  }\n\n  .operations-scrollbar::-webkit-scrollbar {\n    width: 10px;\n  }\n\n  .operations-scrollbar::-webkit-scrollbar-track {\n    border-radius: 9999px;\n    background: rgba(255, 255, 255, 0.06);\n  }\n\n  .operations-scrollbar::-webkit-scrollbar-thumb {\n    border: 2px solid transparent;\n    border-radius: 9999px;\n    background: linear-gradient(180deg, rgba(110, 231, 183, 0.9), rgba(16, 185, 129, 0.8));\n    background-clip: padding-box;\n  }\n\n  .operations-scrollbar::-webkit-scrollbar-thumb:hover {\n    background: linear-gradient(180deg, rgba(167, 243, 208, 0.98), rgba(52, 211, 153, 0.9));\n    background-clip: padding-box;\n  }\n</style>\n"]},"metadata":{},"sourceType":"module"}