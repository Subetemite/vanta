{"ast":null,"code":"import API from \"@/services/api\";\nexport default {\n  name: \"FilesView\",\n  data() {\n    return {\n      selectedFile: null,\n      isUploading: false,\n      isLoadingFiles: false,\n      statusMessage: \"\",\n      statusType: \"success\",\n      filesError: \"\",\n      uploadedFiles: []\n    };\n  },\n  methods: {\n    async loadFiles() {\n      this.isLoadingFiles = true;\n      this.filesError = \"\";\n      try {\n        const response = await API.get(\"/files\");\n        this.uploadedFiles = Array.isArray(response.data.files) ? response.data.files : [];\n      } catch (error) {\n        this.filesError = error.response?.data?.message || \"Unable to load files right now.\";\n      } finally {\n        this.isLoadingFiles = false;\n      }\n    },\n    handleFileChange(event) {\n      const [file] = event.target.files || [];\n      this.statusMessage = \"\";\n      this.statusType = \"success\";\n      if (!file) {\n        this.selectedFile = null;\n        return;\n      }\n      if (file.size > 5 * 1024 * 1024) {\n        this.selectedFile = null;\n        this.statusType = \"error\";\n        this.statusMessage = \"Please choose a file that is 5 MB or smaller.\";\n        event.target.value = \"\";\n        return;\n      }\n      this.selectedFile = file;\n    },\n    clearSelection() {\n      this.selectedFile = null;\n      this.statusMessage = \"\";\n      this.statusType = \"success\";\n      if (this.$refs.fileInput) {\n        this.$refs.fileInput.value = \"\";\n      }\n    },\n    readFileAsDataUrl(file) {\n      return new Promise((resolve, reject) => {\n        const reader = new FileReader();\n        reader.onload = () => resolve(reader.result);\n        reader.onerror = () => reject(new Error(\"Unable to read the selected file.\"));\n        reader.readAsDataURL(file);\n      });\n    },\n    async uploadSelectedFile() {\n      if (!this.selectedFile || this.isUploading) {\n        return;\n      }\n      this.isUploading = true;\n      this.statusMessage = \"\";\n      this.statusType = \"success\";\n      try {\n        const contentBase64 = await this.readFileAsDataUrl(this.selectedFile);\n        const response = await API.post(\"/files\", {\n          fileName: this.selectedFile.name,\n          mimeType: this.selectedFile.type,\n          contentBase64\n        });\n        this.statusMessage = response.data.message || \"File uploaded successfully.\";\n        this.uploadedFiles = response.data.file ? [response.data.file, ...this.uploadedFiles] : this.uploadedFiles;\n        this.clearSelection();\n      } catch (error) {\n        this.statusType = \"error\";\n        this.statusMessage = error.response?.data?.message || \"Unable to upload the file.\";\n      } finally {\n        this.isUploading = false;\n      }\n    },\n    formatFileSize(size = 0) {\n      if (size < 1024) {\n        return `${size} B`;\n      }\n      if (size < 1024 * 1024) {\n        return `${(size / 1024).toFixed(1)} KB`;\n      }\n      return `${(size / (1024 * 1024)).toFixed(2)} MB`;\n    },\n    formatDate(value) {\n      if (!value) {\n        return \"Unknown date\";\n      }\n      return new Date(value).toLocaleString();\n    }\n  },\n  mounted() {\n    this.loadFiles();\n  }\n};","map":{"version":3,"mappings":"AA8NE,OAAOA,GAAE,MAAO,gBAAgB;AAEhC,eAAe;EACbC,IAAI,EAAE,WAAW;EACjBC,IAAIA,GAAG;IACL,OAAO;MACLC,YAAY,EAAE,IAAI;MAClBC,WAAW,EAAE,KAAK;MAClBC,cAAc,EAAE,KAAK;MACrBC,aAAa,EAAE,EAAE;MACjBC,UAAU,EAAE,SAAS;MACrBC,UAAU,EAAE,EAAE;MACdC,aAAa,EAAE;IACjB,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACP,MAAMC,SAASA,GAAG;MAChB,IAAI,CAACN,cAAa,GAAI,IAAI;MAC1B,IAAI,CAACG,UAAS,GAAI,EAAE;MAEpB,IAAI;QACF,MAAMI,QAAO,GAAI,MAAMZ,GAAG,CAACa,GAAG,CAAC,QAAQ,CAAC;QACxC,IAAI,CAACJ,aAAY,GAAIK,KAAK,CAACC,OAAO,CAACH,QAAQ,CAACV,IAAI,CAACc,KAAK,IAClDJ,QAAQ,CAACV,IAAI,CAACc,KAAI,GAClB,EAAE;MACR,EAAE,OAAOC,KAAK,EAAE;QACd,IAAI,CAACT,UAAS,GACZS,KAAK,CAACL,QAAQ,EAAEV,IAAI,EAAEgB,OAAM,IAAK,iCAAiC;MACtE,UAAU;QACR,IAAI,CAACb,cAAa,GA