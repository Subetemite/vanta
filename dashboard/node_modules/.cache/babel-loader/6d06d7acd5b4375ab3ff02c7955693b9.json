{"ast":null,"code":"import \"core-js/modules/esnext.iterator.constructor.js\";\nimport \"core-js/modules/esnext.iterator.filter.js\";\nimport \"core-js/modules/esnext.iterator.map.js\";\nimport API from \"@/services/api\";\nimport FormField from \"@/components/FormField.vue\";\nimport FormSection from \"@/components/FormSection.vue\";\nimport ProfileUploadSection from \"@/components/ProfileUploadSection.vue\";\nimport { createInitialForm, fieldClass, selectOptions } from \"@/helper/record-form\";\nexport default {\n  name: \"RegisterRecord\",\n  components: {\n    FormField,\n    FormSection,\n    ProfileUploadSection\n  },\n  data() {\n    return {\n      form: createInitialForm(),\n      selectedRecordId: \"\",\n      isSubmitting: false,\n      profilePreview: \"\",\n      people: [],\n      peopleSearch: \"\",\n      isLoadingPeople: false,\n      peopleError: \"\",\n      fieldClass,\n      selectOptions,\n      message: {\n        type: \"\",\n        text: \"\"\n      }\n    };\n  },\n  computed: {\n    isEditing() {\n      return Boolean(this.selectedRecordId);\n    },\n    filteredPeople() {\n      const keyword = this.peopleSearch.toLowerCase();\n      if (!keyword) {\n        return this.people;\n      }\n      return this.people.filter(person => {\n        const info = person.personalInformation || {};\n        const haystack = [info.firstName, info.middleName, info.lastName, info.alias, info.nationality, info.country].filter(Boolean).join(\" \").toLowerCase();\n        return haystack.includes(keyword);\n      });\n    },\n    profileSummary() {\n      if (!this.form.profilePhoto.fileName) {\n        return \"No image selected yet.\";\n      }\n      const sizeInKb = this.form.profilePhoto.size ? `${(this.form.profilePhoto.size / 1024).toFixed(1)} KB` : \"Unknown size\";\n      return `${this.form.profilePhoto.mimeType || \"Image\"} | ${sizeInKb}`;\n    }\n  },\n  methods: {\n    async loadPeople() {\n      this.isLoadingPeople = true;\n      this.peopleError = \"\";\n      try {\n        const response = await API.get(\"/records\");\n        this.people = Array.isArray(response.data) ? response.data : [];\n      } catch (error) {\n        this.peopleError = error.response?.data?.message || \"Unable to load registered people right now.\";\n      } finally {\n        this.isLoadingPeople = false;\n      }\n    },\n    formatPersonName(person) {\n      const info = person.personalInformation || {};\n      return [info.firstName, info.middleName, info.lastName].filter(Boolean).join(\" \");\n    },\n    getPersonInitials(person) {\n      const info = person.personalInformation || {};\n      return [info.firstName, info.lastName].filter(Boolean).map(value => value.charAt(0)).join(\"\").slice(0, 2) || \"NA\";\n    },\n    formatPersonMeta(person) {\n      const info = person.personalInformation || {};\n      return [info.alias ? `Alias: ${info.alias}` : null, info.nationality || null, info.country || null].filter(Boolean).join(\" | \");\n    },\n    createFormFromRecord(record) {\n      return {\n        personalInformation: {\n          ...createInitialForm().personalInformation,\n          ...(record.personalInformation || {})\n        },\n        operationDetails: {\n          ...createInitialForm().operationDetails,\n          ...(record.operationDetails || {})\n        },\n        biometrics: {\n          ...createInitialForm().biometrics,\n          ...(record.biometrics || {})\n        },\n        profilePhoto: {\n          ...createInitialForm().profilePhoto,\n          ...(record.profilePhoto || {})\n        }\n      };\n    },\n    selectPerson(person) {\n      this.message = {\n        type: \"\",\n        text: \"\"\n      };\n      this.selectedRecordId = person._id;\n      this.form = this.createFormFromRecord(person);\n      this.profilePreview = person.profilePhoto?.dataUrl || \"\";\n    },\n    resetFormState() {\n      this.selectedRecordId = \"\";\n      this.form = createInitialForm();\n      this.profilePreview = \"\";\n      this.message = {\n        type: \"\",\n        text: \"\"\n      };\n    },\n    async handleProfileUpload(event) {\n      this.message = {\n        type: \"\",\n        text: \"\"\n      };\n      const [file] = event.target.files || [];\n      if (!file) {\n        this.form.profilePhoto = createInitialForm().profilePhoto;\n        this.profilePreview = \"\";\n        return;\n      }\n      if (file.size > 2 * 1024 * 1024) {\n        this.message = {\n          type: \"error\",\n          text: \"Please upload an image that is 2 MB or smaller.\"\n        };\n        event.target.value = \"\";\n        return;\n      }\n      const dataUrl = await this.readFileAsDataUrl(file);\n      this.form.profilePhoto = {\n        fileName: file.name,\n        mimeType: file.type,\n        size: file.size,\n        dataUrl\n      };\n      this.profilePreview = dataUrl;\n    },\n    readFileAsDataUrl(file) {\n      return new Promise((resolve, reject) => {\n        const reader = new FileReader();\n        reader.onload = () => resolve(reader.result);\n        reader.onerror = () => reject(new Error(\"Unable to read the selected file.\"));\n        reader.readAsDataURL(file);\n      });\n    },\n    async handleSubmit() {\n      this.message = {\n        type: \"\",\n        text: \"\"\n      };\n      if (!this.form.personalInformation.firstName || !this.form.personalInformation.lastName || !this.form.personalInformation.sex || !this.form.personalInformation.birthDate) {\n        this.message = {\n          type: \"error\",\n          text: \"First name, last name, sex, and birth date are required.\"\n        };\n        return;\n      }\n      this.isSubmitting = true;\n      try {\n        const response = this.isEditing ? await API.put(`/records/${this.selectedRecordId}`, this.form) : await API.post(\"/records\", this.form);\n        this.message = {\n          type: \"success\",\n          text: response.data.message || (this.isEditing ? \"Registration updated successfully.\" : \"Registration saved successfully.\")\n        };\n        await this.loadPeople();\n        if (this.isEditing && response.data.record) {\n          this.selectPerson(response.data.record);\n        } else {\n          this.resetFormState();\n        }\n      } catch (error) {\n        this.message = {\n          type: \"error\",\n          text: error.response?.data?.message || \"Unable to save the registration right now.\"\n        };\n      } finally {\n        this.isSubmitting = false;\n      }\n    }\n  },\n  mounted() {\n    this.loadPeople();\n  }\n};","map":{"version":3,"mappings":";;;AAofE,OAAOA,GAAE,MAAO,gBAAgB;AAChC,OAAOC,SAAQ,MAAO,4BAA4B;AAClD,OAAOC,WAAU,MAAO,8BAA8B;AACtD,OAAOC,oBAAmB,MAAO,uCAAuC;AACxE,SAASC,iBAAiB,EAAEC,UAAU,EAAEC,aAAY,QAAS,sBAAsB;AAEnF,eAAe;EACbC,IAAI,EAAE,gBAAgB;EACtBC,UAAU,EAAE;IACVP,SAAS;IACTC,WAAW;IACXC;EACF,CAAC;EACDM,IAAIA,GAAG;IACL,OAAO;MACLC,IAAI,EAAEN,iBAAiB,CAAC,CAAC;MACzBO,gBAAgB,EAAE,EAAE;MACpBC,YAAY,EAAE,KAAK;MACnBC,cAAc,EAAE,EAAE;MAClBC,MAAM,EAAE,EAAE;MACVC,YAAY,EAAE,EAAE;MAChBC,eAAe,EAAE,KAAK;MACtBC,WAAW,EAAE,EAAE;MACfZ,UAAU;MACVC,aAAa;MACbY,OAAO,EAAE;QACPC,IAAI,EAAE,EAAE;QACRC,IAAI,EAAE;MACR;IACF,CAAC;EACH,CAAC;EACDC,QAAQ,EAAE;IACRC,SAASA,GAAG;MACV,OAAOC,OAAO,CAAC,IAAI,CAACZ,gBAAgB,CAAC;IACvC,CAAC;IACDa,cAAcA,GAAG;MACf,MAAMC,OAAM,GAAI,IAAI,CAACV,YAAY,CAACW,WAAW,CAAC,CAAC;MAE/C,IAAI,CAACD,OAAO,EAAE;QACZ,OAAO,IAAI,CAACX,MAAM;MACpB;MAEA,OAAO,IAAI,CAACA,MAAM,CAACa,MAAM,CAAEC,MAAM,IAAK;QACpC,MAAMC,IAAG,GAAID,MAAM,CAACE,mBAAkB,IAAK,CAAC,CAAC;QAC7C,MAAMC,QAAO,GAAI,CACfF,IAAI,CAACG,SAAS,EACdH,IAAI,CAACI,UAAU,EACfJ,IAAI,CAACK,QAAQ,EACbL,IAAI,CAACM,KAAK,EACVN,IAAI,CAACO,WAAW,EAChBP,IAAI,CAACQ,OAAO,CACd,CACGV,MAAM,CAACJ,OAAO,EACde,IAAI,CAAC,GAAG,EACRZ,WAAW,CAAC,CAAC;QAEhB,OAAOK,QAAQ,CAACQ,QAAQ,CAACd,OAAO,CAAC;MACnC,CAAC,CAAC;IACJ,CAAC;IACDe,cAAcA,GAAG;MACf,IAAI,CAAC,IAAI,CAAC9B,IAAI,CAAC+B,YAAY,CAACC,QAAQ,EAAE;QACpC,OAAO,wBAAwB;MACjC;MAEA,MAAMC,QAAO,GAAI,IAAI,CAACjC,IAAI,CAAC+B,YAAY,CAACG,IAAG