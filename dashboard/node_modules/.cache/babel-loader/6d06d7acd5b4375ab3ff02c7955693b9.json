:\\joremiodotonline\\dashboard\\src\\views\\records\\RegisterRecord.vue"],"sourcesContent":["<template>\n  <div class=\"min-h-screen bg-[radial-gradient(circle_at_top,_#1e3a8a_0%,_#0f172a_42%,_#020617_100%)] px-3 py-4 text-slate-900 sm:px-4 lg:px-6\">\n    <div class=\"mx-auto max-w-[1800px]\">\n        <div class=\"overflow-hidden rounded-[2rem] border border-blue-950/40 bg-white/95 shadow-2xl shadow-black/30 backdrop-blur\">\n        <div class=\"grid lg:grid-cols-[0.95fr_1.25fr]\">\n          <section class=\"bg-[linear-gradient(165deg,_#020617_0%,_#0f172a_18%,_#172554_52%,_#1d4ed8_82%,_#38bdf8_100%)] px-8 py-10 text-white sm:px-10 lg:px-12\">\n            <p class=\"text-sm font-semibold uppercase tracking-[0.35em] text-cyan-100/80\">\n              Records\n            </p>\n             \n\n            <div class=\"mt-8\">\n              <label for=\"peopleSearch\" class=\"text-xs font-semibold uppercase tracking-[0.25em] text-cyan-100/80\">\n                Search  \n              </label>\n              <input\n                id=\"peopleSearch\"\n                v-model.trim=\"peopleSearch\"\n                type=\"text\"\n                class=\"mt-3 w-full rounded-2xl border border-white/15 bg-white/10 px-4 py-3 text-white placeholder:text-sky-100/60 outline-none backdrop-blur transition focus:border-cyan-200/80 focus:bg-white/15\"\n                placeholder=\"Search by name, alias, nationality, or country\"\n              />\n            </div>\n\n            <div class=\"mt-8 max-h-[34rem] overflow-y-auto pr-1\">\n              <div\n                v-if=\"isLoadingPeople\"\n                class=\"rounded-3xl border border-white/15 bg-white/10 p-5 text-sm text-sky-100/85 backdrop-blur\"\n              >\n                Loading registered people...\n              </div>\n              <div\n                v-else-if=\"peopleError\"\n                class=\"rounded-3xl border border-red-200/30 bg-red-500/10 p-5 text-sm text-red-100 backdrop-blur\"\n              >\n                {{ peopleError }}\n              </div>\n              <div\n                v-else-if=\"!filteredPeople.length\"\n                class=\"rounded-3xl border border-white/15 bg-white/10 p-5 text-sm text-sky-100/85 backdrop-blur\"\n              >\n                No matching people found.\n              </div>\n              <div\n                v-for=\"person in filteredPeople\"\n                :key=\"person._id\"\n                class=\"mt-4 flex w-full items-center gap-4 rounded-3xl border p-4 text-left transition first:mt-0\"\n                :class=\"selectedRecordId === person._id ? 'border-cyan-200/80 bg-white/20 shadow-lg shadow-slate-950/20 ring-1 ring-cyan-200/40' : 'border-white/15 bg-slate-950/25 hover:bg-white/10'\"\n                role=\"button\"\n                tabindex=\"0\"\n                @click=\"selectPerson(person)\"\n              >\n                <img\n                  v-if=\"person.profilePhoto?.dataUrl\"\n                  :src=\"person.profilePhoto.dataUrl\"\n                  :alt=\"formatPersonName(person)\"\n                  class=\"h-16 w-16 rounded-2xl object-cover ring-2 ring-white/20\"\n                />\n                <div\n                  v-else\n                  class=\"flex h-16 w-16 items-center justify-center rounded-2xl bg-white/15 text-sm font-semibold uppercase text-white ring-2 ring-white/10\"\n                >\n                  {{ getPersonInitials(person) }}\n                </div>\n                <div class=\"text-sm text-sky-50/90\">\n                  <p class=\"font-medium\">{{ formatPersonName(person) }}</p>\n                  <p class=\"mt-1 text-sky-100/75\">\n                    {{ formatPersonMeta(person) }}\n                  </p>\n                </div>\n              </div>\n            </div>\n          </section>\n\n          <section class=\"bg-[linear-gradient(180deg,_rgba(239,246,255,0.98)_0%,_rgba(248,250,252,0.98)_22%,_rgba(255,255,255,0.98)_100%)] px-6 py-8 sm:px-8 lg:px-10\">\n            <div class=\"mb-8\">\n              <p class=\"text-sm font-semibold uppercase tracking-[0.3em] text-blue-700\">\n                INFORMATION ENTRY\n              </p>\n              <h2 class=\"mt-3 text-3xl font-semibold text-slate-900\">\n                {{ isEditing ? \"Edit record\" : \"Record details\" }}\n              </h2>\n              <p class=\"mt-3 text-base leading-7 text-slate-500\">\n                {{ isEditing ? \"Update the selected person and save the latest information.\" : \"Create a new registration record.\" }}\n              </p>\n              <div\n                v-if=\"isEditing\"\n                class=\"mt-4 flex flex-wrap items-center gap-3\"\n              >\n                <span class=\"rounded-full bg-blue-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-blue-800\">\n                  Editing selected record\n                </span>\n                <button\n                  type=\"button\"\n                  class=\"rounded-full border border-slate-200 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-slate-600 transition hover:border-slate-300 hover:bg-slate-50\"\n                  @click=\"resetFormState\"\n                >\n                  New record\n                </button>\n              </div>\n            </div>\n\n            <form class=\"space-y-8\" @submit.prevent=\"handleSubmit\">\n              <div\n                v-if=\"message.text\"\n                :class=\"message.type === 'success' ? 'border-emerald-200 bg-emerald-50 text-emerald-700' : 'border-red-200 bg-red-50 text-red-700'\"\n                class=\"rounded-2xl border px-4 py-3 text-sm\"\n              >\n                {{ message.text }}\n              </div>\n\n              <FormSection\n                title=\"Personal Information\"\n                badge-text=\"Required\"\n                badge-class=\"bg-slate-100 text-slate-500\"\n              >\n                <div class=\"grid gap-5 sm:grid-cols-2\">\n                  <FormField label=\"First name\" for-id=\"firstName\">\n                    <input\n                      id=\"firstName\"\n                      v-model.trim=\"form.personalInformation.firstName\"\n                      type=\"text\"\n                      :class=\"fieldClass\"\n                      placeholder=\"Juan\"\n                    />\n                  </FormField>\n\n                  <FormField label=\"Middle name\" for-id=\"middleName\">\n                    <input\n                      id=\"middleName\"\n                      v-model.trim=\"form.personalInformation.middleName\"\n                      type=\"text\"\n                      :class=\"fieldClass\"\n                      placeholder=\"Santos\"\n                    />\n                  </FormField>\n\n                  <FormField label=\"Alias\" for-id=\"alias\">\n                    <input\n                      id=\"alias\"\n                      v-model.trim=\"form.personalInformation.alias\"\n                      type=\"text\"\n                      :class=\"fieldClass\"\n                      placeholder=\"Jun\"\n                    />\n                  </FormField>\n\n                  <FormField label=\"Last name\" for-id=\"lastName\">\n                    <input\n                      id=\"lastName\"\n                      v-model.trim=\"form.personalInformation.lastName\"\n                      type=\"text\"\n                      :class=\"fieldClass\"\n                      placeholder=\"Dela Cruz\"\n                    />\n                  </FormField>\n\n                  <FormField label=\"Birth date\" for-id=\"birthDate\">\n                    <input\n                      id=\"birthDate\"\n                      v-model=\"form.personalInformation.birthDate\"\n                      type=\"date\"\n                      :class=\"fieldClass\"\n                    />\n                  </FormField>\n\n                  <FormField label=\"Sex\" for-id=\"sex\">\n                    <select\n                      id=\"sex\"\n                      v-model=\"form.personalInformation.sex\"\n                      :class=\"fieldClass\"\n                    >\n                      <option disabled value=\"\">Select sex</option>\n                      <option\n                        v-for=\"sex in selectOptions.sex\"\n                        :key=\"sex\"\n                        :value=\"sex\"\n                      >\n                        {{ sex }}\n                      </option>\n                    </select>\n                  </FormField>\n\n                  <FormField label=\"Civil status\" for-id=\"civilStatus\">\n                    <select\n                      id=\"civilStatus\"\n                      v-model=\"form.personalInformation.civilStatus\"\n                      :class=\"fieldClass\"\n                    >\n                      <option disabled value=\"\">Select civil status</option>\n                      <option\n                        v-for=\"civilStatus in selectOptions.civilStatus\"\n                        :key=\"civilStatus\"\n                        :value=\"civilStatus\"\n                      >\n                        {{ civilStatus }}\n                      </option>\n                    </select>\n                  </FormField>\n\n                  <FormField label=\"Contact number\" for-id=\"contactNumber\">\n                    <input\n                      id=\"contactNumber\"\n                      v-model.trim=\"form.personalInformation.contactNumber\"\n                      type=\"text\"\n                      :class=\"fieldClass\"\n                      placeholder=\"09171234567\"\n                    />\n                  </FormField>\n\n                  <FormField label=\"Email address\" for-id=\"emailAddress\">\n                    <input\n                      id=\"emailAddress\"\n                      v-model.trim=\"form.personalInformation.emailAddress\"\n                      type=\"email\"\n                      :class=\"fieldClass\"\n                      placeholder=\"juan@example.com\"\n                    />\n                  </FormField>\n\n                  <FormField label=\"Nationality\" for-id=\"nationality\">\n                    <select\n                      id=\"nationality\"\n                      v-model=\"form.personalInformation.nationality\"\n                      :class=\"fieldClass\"\n                    >\n                      <option disabled value=\"\">Select nationality</option>\n                      <option\n                        v-for=\"nationality in selectOptions.nationality\"\n                        :key=\"nationality\"\n                        :value=\"nationality\"\n                      >\n                        {{ nationality }}\n                      </option>\n                    </select>\n                  </FormField>\n\n                  <FormField label=\"Country\" for-id=\"country\">\n                    <select\n                      id=\"country\"\n                      v-model=\"form.personalInformation.country\"\n                      :class=\"fieldClass\"\n                    >\n                      <option disabled value=\"\">Select country</option>\n                      <option\n                        v-for=\"country in selectOptions.country\"\n                        :key=\"country\"\n                        :value=\"country\"\n                      >\n                        {{ country }}\n                      </option>\n                    </select>\n                  </FormField>\n\n                  <FormField label=\"Address\" for-id=\"address\" wrapper-class=\"sm:col-span-2\">\n                    <textarea\n                      id=\"address\"\n                      v-model.trim=\"form.personalInformation.address\"\n                      rows=\"3\"\n                      :class=\"fieldClass\"\n                      placeholder=\"House no., street, barangay, municipality\"\n                    />\n                  </FormField>\n                </div>\n              </FormSection>\n\n              <FormSection\n                title=\"Operation Details\"\n                badge-text=\"Additional\"\n                badge-class=\"bg-indigo-50 text-indigo-700\"\n              >\n                <div class=\"grid gap-5 sm:grid-cols-2\">\n                  <FormField label=\"Operation name\" for-id=\"operationName\">\n                    <input\n                      id=\"operationName\"\n                      v-model.trim=\"form.operationDetails.operationName\"\n                      type=\"text\"\n                      :class=\"fieldClass\"\n                      placeholder=\"Operation Sunrise\"\n                    />\n                  </FormField>\n\n                  <FormField label=\"Operation date\" for-id=\"operationDate\">\n                    <input\n                      id=\"operationDate\"\n                      v-model=\"form.operationDetails.operationDate\"\n                      type=\"date\"\n                      :class=\"fieldClass\"\n                    />\n                  </FormField>\n\n                  <FormField label=\"Operation address\" for-id=\"operationAddress\" wrapper-class=\"sm:col-span-2\">\n                    <textarea\n                      id=\"operationAddress\"\n                      v-model.trim=\"form.operationDetails.operationAddress\"\n                      rows=\"3\"\n                      :class=\"fieldClass\"\n                      placeholder=\"Street, barangay, municipality, province\"\n                    />\n                  </FormField>\n\n                  <FormField label=\"Disposition\" for-id=\"disposition\">\n                    <select\n                      id=\"disposition\"\n                      v-model=\"form.operationDetails.disposition\"\n                      :class=\"fieldClass\"\n                    >\n                      <option disabled value=\"\">Select disposition</option>\n                      <option\n                        v-for=\"disposition in selectOptions.disposition\"\n                        :key=\"disposition\"\n                        :value=\"disposition\"\n                      >\n                        {{ disposition }}\n                      </option>\n                    </select>\n                  </FormField>\n\n                  <FormField label=\"Visa status\" for-id=\"visaStatus\">\n                    <select\n                      id=\"visaStatus\"\n                      v-model=\"form.operationDetails.visaStatus\"\n                      :class=\"fieldClass\"\n                    >\n                      <option disabled value=\"\">Select visa status</option>\n                      <option\n                        v-for=\"visaStatus in selectOptions.visaStatus\"\n                        :key=\"visaStatus\"\n                        :value=\"visaStatus\"\n                      >\n                        {{ visaStatus }}\n                      </option>\n                    </select>\n                  </FormField>\n\n                  <FormField label=\"Remarks\" for-id=\"remarks\" wrapper-class=\"sm:col-span-2\">\n                    <textarea\n                      id=\"remarks\"\n                      v-model.trim=\"form.operationDetails.remarks\"\n                      rows=\"3\"\n                      :class=\"fieldClass\"\n                      placeholder=\"Additional notes about the operation or person\"\n                    />\n                  </FormField>\n\n                  <FormField label=\"Actions\" for-id=\"actions\" wrapper-class=\"sm:col-span-2\">\n                    <textarea\n                      id=\"actions\"\n                      v-model.trim=\"form.operationDetails.actions\"\n                      rows=\"3\"\n                      :class=\"fieldClass\"\n                      placeholder=\"Documented actions taken\"\n                    />\n                  </FormField>\n                </div>\n              </FormSection>\n\n              <FormSection\n                title=\"Biometrics\"\n                badge-text=\"Optional\"\n                badge-class=\"bg-sky-50 text-sky-700\"\n              >\n                <div class=\"grid gap-5 sm:grid-cols-2\">\n                  <FormField label=\"Height (cm)\" for-id=\"heightCm\">\n                    <input\n                      id=\"heightCm\"\n                      v-model=\"form.biometrics.heightCm\"\n                      type=\"number\"\n                      min=\"0\"\n                      step=\"0.01\"\n                      :class=\"fieldClass\"\n                      placeholder=\"165\"\n                    />\n                  </FormField>\n\n                  <FormField label=\"Weight (kg)\" for-id=\"weightKg\">\n                    <input\n                      id=\"weightKg\"\n                      v-model=\"form.biometrics.weightKg\"\n                      type=\"number\"\n                      min=\"0\"\n                      step=\"0.01\"\n                      :class=\"fieldClass\"\n                      placeholder=\"60\"\n                    />\n                  </FormField>\n\n                  <FormField label=\"Blood type\" for-id=\"bloodType\">\n                    <select\n                      id=\"bloodType\"\n                      v-model=\"form.biometrics.bloodType\"\n                      :class=\"fieldClass\"\n                    >\n                      <option disabled value=\"\">Select blood type</option>\n                      <option\n                        v-for=\"bloodType in selectOptions.bloodType\"\n                        :key=\"bloodType\"\n                        :value=\"bloodType\"\n                      >\n                        {{ bloodType }}\n                      </option>\n                    </select>\n                  </FormField>\n\n                  <FormField label=\"Fingerprint code\" for-id=\"fingerprintCode\">\n                    <input\n                      id=\"fingerprintCode\"\n                      v-model.trim=\"form.biometrics.fingerprintCode\"\n                      type=\"text\"\n                      :class=\"fieldClass\"\n                      placeholder=\"FP-2026-0001\"\n                    />\n                  </FormField>\n\n                  <FormField label=\"Eye color\" for-id=\"eyeColor\">\n                    <select\n                      id=\"eyeColor\"\n                      v-model=\"form.biometrics.eyeColor\"\n                      :class=\"fieldClass\"\n                    >\n                      <option disabled value=\"\">Select eye color</option>\n                      <option\n                        v-for=\"eyeColor in selectOptions.eyeColor\"\n                        :key=\"eyeColor\"\n                        :value=\"eyeColor\"\n                      >\n                        {{ eyeColor }}\n                      </option>\n                    </select>\n                  </FormField>\n\n                  <FormField label=\"Hair color\" for-id=\"hairColor\">\n                    <select\n                      id=\"hairColor\"\n                      v-model=\"form.biometrics.hairColor\"\n                      :class=\"fieldClass\"\n                    >\n                      <option disabled value=\"\">Select hair color</option>\n                      <option\n                        v-for=\"hairColor in selectOptions.hairColor\"\n                        :key=\"hairColor\"\n                        :value=\"hairColor\"\n                      >\n                        {{ hairColor }}\n                      </option>\n                    </select>\n                  </FormField>\n\n                  <FormField label=\"Complexion\" for-id=\"complexion\">\n                    <select\n                      id=\"complexion\"\n                      v-model=\"form.biometrics.complexion\"\n                      :class=\"fieldClass\"\n                    >\n                      <option disabled value=\"\">Select complexion</option>\n                      <option\n                        v-for=\"complexion in selectOptions.complexion\"\n                        :key=\"complexion\"\n                        :value=\"complexion\"\n                      >\n                        {{ complexion }}\n                      </option>\n                    </select>\n                  </FormField>\n\n                  <FormField label=\"Distinguishing marks\" for-id=\"distinguishingMarks\" wrapper-class=\"sm:col-span-2\">\n                    <textarea\n                      id=\"distinguishingMarks\"\n                      v-model.trim=\"form.biometrics.distinguishingMarks\"\n                      rows=\"3\"\n                      :class=\"fieldClass\"\n                      placeholder=\"Birthmark on left cheek, scar on right hand\"\n                    />\n                  </FormField>\n                </div>\n              </FormSection>\n\n              <ProfileUploadSection\n                :file-name=\"form.profilePhoto.fileName\"\n                :profile-summary=\"profileSummary\"\n                :profile-preview=\"profilePreview\"\n                @change=\"handleProfileUpload\"\n              />\n\n              <button\n                type=\"submit\"\n                class=\"flex w-full items-center justify-center rounded-2xl bg-[linear-gradient(135deg,_#020617_0%,_#172554_45%,_#1d4ed8_100%)] px-4 py-3.5 text-sm font-semibold text-white transition hover:opacity-95 disabled:cursor-not-allowed disabled:bg-slate-400\"\n                :disabled=\"isSubmitting\"\n              >\n                {{ isSubmitting ? \"Saving registration...\" : \"Save registration\" }}\n              </button>\n            </form>\n          </section>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\n  import API from \"@/services/api\";\n  import FormField from \"@/components/FormField.vue\";\n  import FormSection from \"@/components/FormSection.vue\";\n  import ProfileUploadSection from \"@/components/ProfileUploadSection.vue\";\n  import { createInitialForm, fieldClass, selectOptions } from \"@/helper/record-form\";\n\n  export default {\n    name: \"RegisterRecord\",\n    components: {\n      FormField,\n      FormSection,\n      ProfileUploadSection,\n    },\n    data() {\n      return {\n        form: createInitialForm(),\n        selectedRecordId: \"\",\n        isSubmitting: false,\n        profilePreview: \"\",\n        people: [],\n        peopleSearch: \"\",\n        isLoadingPeople: false,\n        peopleError: \"\",\n        fieldClass,\n        selectOptions,\n        message: {\n          type: \"\",\n          text: \"\",\n        },\n      };\n    },\n    computed: {\n      isEditing() {\n        return Boolean(this.selectedRecordId);\n      },\n      filteredPeople() {\n        const keyword = this.peopleSearch.toLowerCase();\n\n        if (!keyword) {\n          return this.people;\n        }\n\n        return this.people.filter((person) => {\n          const info = person.personalInformation || {};\n          const haystack = [\n            info.firstName,\n            info.middleName,\n            info.lastName,\n            info.alias,\n            info.nationality,\n            info.country,\n          ]\n            .filter(Boolean)\n            .join(\" \")\n            .toLowerCase();\n\n          return haystack.includes(keyword);\n        });\n      },\n      profileSummary() {\n        if (!this.form.profilePhoto.fileName) {\n          return \"No image selected yet.\";\n        }\n\n        const sizeInKb = this.form.profilePhoto.size\n          ? `${(this.form.profilePhoto.size / 1024).toFixed(1)} KB`\n          : \"Unknown size\";\n\n        return `${this.form.profilePhoto.mimeType || \"Image\"} | ${sizeInKb}`;\n      },\n    },\n    methods: {\n      async loadPeople() {\n        this.isLoadingPeople = true;\n        this.peopleError = \"\";\n\n        try {\n          const response = await API.get(\"/records\");\n          this.people = Array.isArray(response.data) ? response.data : [];\n        } catch (error) {\n          this.peopleError =\n            error.response?.data?.message ||\n            \"Unable to load registered people right now.\";\n        } finally {\n          this.isLoadingPeople = false;\n        }\n      },\n      formatPersonName(person) {\n        const info = person.personalInformation || {};\n\n        return [info.firstName, info.middleName, info.lastName]\n          .filter(Boolean)\n          .join(\" \");\n      },\n      getPersonInitials(person) {\n        const info = person.personalInformation || {};\n\n        return [info.firstName, info.lastName]\n          .filter(Boolean)\n          .map((value) => value.charAt(0))\n          .join(\"\")\n          .slice(0, 2) || \"NA\";\n      },\n      formatPersonMeta(person) {\n        const info = person.personalInformation || {};\n\n        return [\n          info.alias ? `Alias: ${info.alias}` : null,\n          info.nationality || null,\n          info.country || null,\n        ]\n          .filter(Boolean)\n          .join(\" | \");\n      },\n      createFormFromRecord(record) {\n        return {\n          personalInformation: {\n            ...createInitialForm().personalInformation,\n            ...(record.personalInformation || {}),\n          },\n          operationDetails: {\n            ...createInitialForm().operationDetails,\n            ...(record.operationDetails || {}),\n          },\n          biometrics: {\n            ...createInitialForm().biometrics,\n            ...(record.biometrics || {}),\n          },\n          profilePhoto: {\n            ...createInitialForm().profilePhoto,\n            ...(record.profilePhoto || {}),\n          },\n        };\n      },\n      selectPerson(person) {\n        this.message = { type: \"\", text: \"\" };\n        this.selectedRecordId = person._id;\n        this.form = this.createFormFromRecord(person);\n        this.profilePreview = person.profilePhoto?.dataUrl || \"\";\n      },\n      resetFormState() {\n        this.selectedRecordId = \"\";\n        this.form = createInitialForm();\n        this.profilePreview = \"\";\n        this.message = { type: \"\", text: \"\" };\n      },\n      async handleProfileUpload(event) {\n        this.message = { type: \"\", text: \"\" };\n        const [file] = event.target.files || [];\n\n        if (!file) {\n          this.form.profilePhoto = createInitialForm().profilePhoto;\n          this.profilePreview = \"\";\n          return;\n        }\n\n        if (file.size > 2 * 1024 * 1024) {\n          this.message = {\n            type: \"error\",\n            text: \"Please upload an image that is 2 MB or smaller.\",\n          };\n          event.target.value = \"\";\n          return;\n        }\n\n        const dataUrl = await this.readFileAsDataUrl(file);\n\n        this.form.profilePhoto = {\n          fileName: file.name,\n          mimeType: file.type,\n          size: file.size,\n          dataUrl,\n        };\n        this.profilePreview = dataUrl;\n      },\n      readFileAsDataUrl(file) {\n        return new Promise((resolve, reject) => {\n          const reader = new FileReader();\n          reader.onload = () => resolve(reader.result);\n          reader.onerror = () =>\n            reject(new Error(\"Unable to read the selected file.\"));\n          reader.readAsDataURL(file);\n        });\n      },\n      async handleSubmit() {\n        this.message = { type: \"\", text: \"\" };\n\n        if (\n          !this.form.personalInformation.firstName ||\n          !this.form.personalInformation.lastName ||\n          !this.form.personalInformation.sex ||\n          !this.form.personalInformation.birthDate\n        ) {\n          this.message = {\n            type: \"error\",\n            text: \"First name, last name, sex, and birth date are required.\",\n          };\n          return;\n        }\n\n        this.isSubmitting = true;\n\n        try {\n          const response = this.isEditing\n            ? await API.put(`/records/${this.selectedRecordId}`, this.form)\n            : await API.post(\"/records\", this.form);\n\n          this.message = {\n            type: \"success\",\n            text:\n              response.data.message ||\n              (this.isEditing\n                ? \"Registration updated successfully.\"\n                : \"Registration saved successfully.\"),\n          };\n\n          await this.loadPeople();\n          if (this.isEditing && response.data.record) {\n            this.selectPerson(response.data.record);\n          } else {\n            this.resetFormState();\n          }\n        } catch (error) {\n          this.message = {\n            type: \"error\",\n            text:\n              error.response?.data?.message ||\n              \"Unable to save the registration right now.\",\n          };\n        } finally {\n          this.isSubmitting = false;\n        }\n      },\n    },\n    mounted() {\n      this.loadPeople();\n    },\n  };\n</script>\n"]},"metadata":{},"sourceType":"module"}