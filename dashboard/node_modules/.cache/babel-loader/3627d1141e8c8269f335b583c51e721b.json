{"ast":null,"code":"import \"core-js/modules/esnext.iterator.constructor.js\";\nimport \"core-js/modules/esnext.iterator.filter.js\";\nimport \"core-js/modules/esnext.iterator.map.js\";\nimport API from \"@/services/api\";\nfunction createInitialForm() {\n  return {\n    personalInformation: {\n      firstName: \"\",\n      middleName: \"\",\n      alias: \"\",\n      lastName: \"\",\n      sex: \"\",\n      civilStatus: \"\",\n      birthDate: \"\",\n      contactNumber: \"\",\n      emailAddress: \"\",\n      nationality: \"\",\n      country: \"\",\n      address: \"\"\n    },\n    operationDetails: {\n      operationName: \"\",\n      operationAddress: \"\",\n      operationDate: \"\",\n      disposition: \"\",\n      visaStatus: \"\",\n      remarks: \"\",\n      actions: \"\"\n    },\n    biometrics: {\n      heightCm: \"\",\n      weightKg: \"\",\n      bloodType: \"\",\n      eyeColor: \"\",\n      hairColor: \"\",\n      complexion: \"\",\n      distinguishingMarks: \"\",\n      fingerprintCode: \"\"\n    },\n    profilePhoto: {\n      fileName: \"\",\n      mimeType: \"\",\n      size: 0,\n      dataUrl: \"\"\n    }\n  };\n}\nexport default {\n  name: \"RegisterRecord\",\n  data() {\n    return {\n      form: createInitialForm(),\n      isSubmitting: false,\n      profilePreview: \"\",\n      people: [],\n      peopleSearch: \"\",\n      isLoadingPeople: false,\n      peopleError: \"\",\n      message: {\n        type: \"\",\n        text: \"\"\n      }\n    };\n  },\n  computed: {\n    filteredPeople() {\n      const keyword = this.peopleSearch.toLowerCase();\n      if (!keyword) {\n        return this.people;\n      }\n      return this.people.filter(person => {\n        const info = person.personalInformation || {};\n        const haystack = [info.firstName, info.middleName, info.lastName, info.alias, info.nationality, info.country].filter(Boolean).join(\" \").toLowerCase();\n        return haystack.includes(keyword);\n      });\n    },\n    profileSummary() {\n      if (!this.form.profilePhoto.fileName) {\n        return \"No image selected yet.\";\n      }\n      const sizeInKb = this.form.profilePhoto.size ? `${(this.form.profilePhoto.size / 1024).toFixed(1)} KB` : \"Unknown size\";\n      return `${this.form.profilePhoto.mimeType || \"Image\"} | ${sizeInKb}`;\n    }\n  },\n  methods: {\n    async loadPeople() {\n      this.isLoadingPeople = true;\n      this.peopleError = \"\";\n      try {\n        const response = await API.get(\"/records\");\n        this.people = Array.isArray(response.data) ? response.data : [];\n      } catch (error) {\n        this.peopleError = error.response?.data?.message || \"Unable to load registered people right now.\";\n      } finally {\n        this.isLoadingPeople = false;\n      }\n    },\n    formatPersonName(person) {\n      const info = person.personalInformation || {};\n      return [info.firstName, info.middleName, info.lastName].filter(Boolean).join(\" \");\n    },\n    getPersonInitials(person) {\n      const info = person.personalInformation || {};\n      return [info.firstName, info.lastName].filter(Boolean).map(value => value.charAt(0)).join(\"\").slice(0, 2) || \"NA\";\n    },\n    formatPersonMeta(person) {\n      const info = person.personalInformation || {};\n      return [info.alias ? `Alias: ${info.alias}` : null, info.nationality || null, info.country || null].filter(Boolean).join(\" | \");\n    },\n    async handleProfileUpload(event) {\n      this.message = {\n        type: \"\",\n        text: \"\"\n      };\n      const [file] = event.target.files || [];\n      if (!file) {\n        this.form.profilePhoto = createInitialForm().profilePhoto;\n        this.profilePreview = \"\";\n        return;\n      }\n      if (file.size > 2 * 1024 * 1024) {\n        this.message = {\n          type: \"error\",\n          text: \"Please upload an image that is 2 MB or smaller.\"\n        };\n        event.target.value = \"\";\n        return;\n      }\n      const dataUrl = await this.readFileAsDataUrl(file);\n      this.form.profilePhoto = {\n        fileName: file.name,\n        mimeType: file.type,\n        size: file.size,\n        dataUrl\n      };\n      this.profilePreview = dataUrl;\n    },\n    readFileAsDataUrl(file) {\n      return new Promise((resolve, reject) => {\n        const reader = new FileReader();\n        reader.onload = () => resolve(reader.result);\n        reader.onerror = () => reject(new Error(\"Unable to read the selected file.\"));\n        reader.readAsDataURL(file);\n      });\n    },\n    async handleSubmit() {\n      this.message = {\n        type: \"\",\n        text: \"\"\n      };\n      if (!this.form.personalInformation.firstName || !this.form.personalInformation.lastName || !this.form.personalInformation.sex || !this.form.personalInformation.birthDate) {\n        this.message = {\n          type: \"error\",\n          text: \"First name, last name, sex, and birth date are required.\"\n        };\n        return;\n      }\n      this.isSubmitting = true;\n      try {\n        const response = await API.post(\"/records\", this.form);\n        this.message = {\n          type: \"success\",\n          text: response.data.message || \"Registration saved successfully.\"\n        };\n        this.form = createInitialForm();\n        this.profilePreview = \"\";\n        await this.loadPeople();\n      } catch (error) {\n        this.message = {\n          type: \"error\",\n          text: error.response?.data?.message || \"Unable to save the registration right now.\"\n        };\n      } finally {\n        this.isSubmitting = false;\n      }\n    }\n  },\n  mounted() {\n    this.loadPeople();\n  }\n};","map":{"version":3,"mappings":";;;AA4hBE,OAAOA,GAAE,MAAO,gBAAgB;AAEhC,SAASC,iBAAiBA,GAAG;EAC3B,OAAO;IACLC,mBAAmB,EAAE;MACnBC,SAAS,EAAE,EAAE;MACbC,UAAU,EAAE,EAAE;MACdC,KAAK,EAAE,EAAE;MACTC,QAAQ,EAAE,EAAE;MACZC,GAAG,EAAE,EAAE;MACPC,WAAW,EAAE,EAAE;MACfC,SAAS,EAAE,EAAE;MACbC,aAAa,EAAE,EAAE;MACjBC,YAAY,EAAE