{"ast":null,"code":"import \"core-js/modules/esnext.iterator.constructor.js\";\nimport \"core-js/modules/esnext.iterator.filter.js\";\nimport \"core-js/modules/esnext.iterator.find.js\";\nimport { Icon } from \"@iconify/vue\";\nimport API from \"@/services/api\";\nimport EntryFormModal from \"./components/EntryFormModal.vue\";\nconst CLUSTER_GROUPS = [{\n  id: \"group-1\",\n  areas: [{\n    key: \"trafficking-illegal-recruitment\",\n    title: \"Trafficking-in-Persons / Illegal Recruitment\"\n  }, {\n    key: \"cybercrime-online-fraud\",\n    title: \"Cybercrime / Online Scam / Fraud\"\n  }, {\n    key: \"illegal-gambling\",\n    title: \"Illegal Gambling\"\n  }, {\n    key: \"kidnapping-for-ransom\",\n    title: \"Kidnapping-for-Ransom\"\n  }, {\n    key: \"money-laundering\",\n    title: \"Money Laundering\"\n  }, {\n    key: \"tax-evasion\",\n    title: \"Tax Evasion\"\n  }]\n}, {\n  id: \"group-2\",\n  areas: [{\n    key: \"environmental-crimes\",\n    title: \"Environmental Crimes\"\n  }, {\n    key: \"crimes-against-cultural-properties\",\n    title: \"Crimes Against Cultural Properties\"\n  }, {\n    key: \"smuggling\",\n    title: \"Smuggling\"\n  }, {\n    key: \"ipr-theft\",\n    title: \"Intellectual Property Rights Theft\"\n  }, {\n    key: \"economic-sabotage-food-security\",\n    title: \"Economic Sabotage / Crimes Related to Food Security\"\n  }, {\n    key: \"carnapping\",\n    title: \"Carnapping\"\n  }]\n}, {\n  id: \"group-3\",\n  areas: [{\n    key: \"terrorism\",\n    title: \"Terrorism\"\n  }, {\n    key: \"drug-trafficking\",\n    title: \"Drug Trafficking / Illegal Drugs\"\n  }, {\n    key: \"gunrunning-private-armed-groups\",\n    title: \"Gunrunning / Private Armed Groups\"\n  }, {\n    key: \"insurgency\",\n    title: \"Insurgency\"\n  }, {\n    key: \"robbery\",\n    title: \"Robbery\"\n  }, {\n    key: \"graft-and-corruption\",\n    title: \"Graft and Corruption\"\n  }]\n}];\nexport default {\n  name: \"CrimeClusters\",\n  components: {\n    Icon,\n    EntryFormModal\n  },\n  data() {\n    return {\n      groups: CLUSTER_GROUPS,\n      entries: [],\n      loading: false,\n      error: \"\",\n      selected: null,\n      showModal: false,\n      editingEntry: null,\n      searchQuery: \"\",\n      searchDebounce: null\n    };\n  },\n  computed: {\n    allAreas() {\n      return CLUSTER_GROUPS.flatMap(g => g.areas);\n    },\n    selectedEntries() {\n      if (!this.selected) return [];\n      return this.entries.filter(e => e.subCategory === this.selected.key);\n    }\n  },\n  methods: {\n    countFor(key) {\n      return this.entries.filter(e => e.subCategory === key).length;\n    },\n    selectArea(area) {\n      this.selected = area;\n    },\n    formatDate(d) {\n      if (!d) return \"—\";\n      return new Date(d).toLocaleDateString(\"en-US\", {\n        month: \"short\",\n        day: \"numeric\",\n        year: \"numeric\"\n      });\n    },\n    async load() {\n      this.loading = true;\n      this.error = \"\";\n      try {\n        const params = {};\n        if (this.searchQuery.trim()) params.q = this.searchQuery.trim();\n        const queryString = new URLSearchParams(params).toString();\n        const url = `/cases/entries/crime-clusters${queryString ? `?${queryString}` : \"\"}`;\n        const res = await API.get(url);\n        this.entries = Array.isArray(res.data) ? res.data : [];\n      } catch (err) {\n        this.error = err.response?.data?.message || \"Unable to load crime cluster entries.\";\n      } finally {\n        this.loading = false;\n      }\n    },\n    onSearchInput() {\n      clearTimeout(this.searchDebounce);\n      this.searchDebounce = setTimeout(() => this.load(), 300);\n    },\n    openCreate() {\n      this.editingEntry = null;\n      this.showModal = true;\n    },\n    openEdit(entry) {\n      this.editingEntry = entry;\n      this.showModal = true;\n    },\n    closeModal() {\n      this.showModal = false;\n      this.editingEntry = null;\n    },\n    onEntrySaved(entry) {\n      if (!entry) {\n        this.load();\n        return;\n      }\n      const idx = this.entries.findIndex(e => e._id === entry._id);\n      if (idx >= 0) {\n        this.entries.splice(idx, 1, entry);\n      } else {\n        this.entries.unshift(entry);\n      }\n      if (entry.subCategory) {\n        const area = this.allAreas.find(a => a.key === entry.subCategory);\n        if (area) this.selected = area;\n      }\n    },\n    onEntryDeleted(id) {\n      this.entries = this.entries.filter(e => e._id !== id);\n    }\n  },\n  mounted() {\n    this.load();\n  }\n};","map":{"version":3,"mappings":";;;AAiJE,SAASA,IAAG,QAAS,cAAc;AACnC,OAAOC,GAAE,MAAO,gBAAgB;AAChC,OAAOC,cAAa,MAAO,iCAAiC;AAE5D,MAAMC,cAAa,GAAI,CACrB;EACEC,EAAE,EAAE,SAAS;EACbC,KAAK,EAAE,CACL;IAAEC,GAAG,EAAE,iCAAiC;IAAEC,KAAK,EAAE;EAA+C,CAAC,EACjG;IAAED,GAAG,EAAE,yBAAyB;IAAEC,KAAK,EAAE;EAAmC,CAAC,EAC7E;IAAED,GAAG,EAAE,kBAAkB;IAAEC,KAAK,EAAE;EAAmB,CAAC,EACtD;IAAED,GAAG,EAAE,uBAAuB;IAAEC,KAAK,EAAE;EAAwB,CAAC,EAChE;IAAED,GAAG,EAAE,kBAAkB;IAAEC,KAAK,EAAE;EAAmB,CAAC,EACtD;IAAED,GAAG,EAAE,aAAa;IAAEC,KAAK,EAAE;EAAc,CAAC;AAEhD,CAAC,EACD;EACEH,EAAE,EAAE,SAAS;EACbC,KAAK,EAAE,CACL;IAAEC,GAAG,EAAE,sBAAsB;IAAEC,KAAK,EAAE;EAAuB,CAAC,EAC9D;IAAED,GAAG,EAAE,oCAAoC;IAAEC,KAAK,EAAE;EAAqC,CAAC,EAC1F;IAAED,GAAG,EAAE,WAAW;IAAEC,KAAK,EAAE;EAAY,CAAC,EACxC;IAAED,GAAG,EAAE,WAAW;IAAEC,KAAK,EAAE;EAAqC,CAAC,EACjE;IAAED,GAAG,EAAE,iCAAiC;IAAEC,KAAK,EAAE;EAAsD,CAAC,EACxG;IAAED,GAAG,EAAE,YAAY;IAAEC,KAAK,EAAE;EAAa,CAAC;AAE9C,CAAC,EACD;EACEH,EAAE,EAAE,SAAS;EACbC,KAAK,EAAE,CACL;IAAEC,GAAG,EAAE,WAAW;IAAEC,KAAK,EAAE;EAAY,CAAC,EACxC;IAAED,GAAG,EAAE,kBAAkB;IAAEC,KAAK,EAAE;EAAmC,CAAC,EACtE;IAAED,GAAG,EAAE,iCAAiC;IAAEC,KAAK,EAAE;EAAoC,CAAC,EACtF;IAAED,GAAG,EAAE,YAAY;IAAEC,KAAK,EAAE;EAAa,CAAC,EAC1C;IAAED,GAAG,EAAE,SAAS;IAAEC,KAAK,EAAE;EAAU,CAAC,EACpC;IAAED,GAAG,EAAE,sBAAsB;IAAEC,KAAK,EAAE;EAAuB,CAAC;AAElE,CAAC,CACF;AAED,eAAe;EACbC,IAAI,EAAE,eAAe;EACrBC,UAAU,EAAE;IAAET,IAAI;IAAEE;EAAe,CAAC;EACpCQ,IAAIA,GAAG;IACL,OAAO;MACLC,MAAM,EAAER,cAAc;MACtBS,OAAO,EAAE,EAAE;MACXC,OAAO,EAAE,KAAK;MACdC,KAAK,EAAE,EAAE;MACTC,QAAQ,EAAE,IAAI;MACdC,SAAS,EAAE,KAAK;MAChBC,YAAY,EAAE,IAAI;MAClBC,WAAW,EAAE,EAAE;MACfC,cAAc,EAAE;IAClB,CAAC;EACH,CAAC;EACDC,QAAQ,EAAE;IACRC,QAAQA,GAAG;MACT,OAAOlB,cAAc,CAACmB,OAAO,CAAEC,CAAC,IAAKA,CAAC,CAAClB,KAAK,CAAC;IAC/C,CAAC;IACDmB,eAAeA,GAAG;MAChB,IAAI,CAAC,IAAI,CAACT,QAAQ,EAAE,OAAO,EAAE;MAC7B,OAAO,IAAI,CAACH,OAAO,CAACa,MAAM,CAAEC,CAAC,IAAKA,CAAC,CAACC,WAAU,KAAM,IAAI,CAACZ,QAAQ,CAACT,GAAG,CAAC;IACxE;EACF,CAAC;EACDsB,OAAO,EAAE;IACPC,QAAQA,CAACvB,GAAG,EAAE;MACZ,OAAO,IAAI,CAACM,OAAO,CAACa,MAAM,CAAEC,CAAC,IAAKA,CAAC,CAACC,WAAU,KAAMrB,GAAG,CAAC,CAACwB,MAAM;IACjE,CAAC;IACDC,UAAUA,CAACC,IAAI,EAAE;MACf,IAAI,CAACjB,QAAO,GAAIiB,IAAI;IACtB,CAAC;IACDC,UAAUA,CAACC,CAAC,EAAE;MACZ,IAAI,CAACA,CAAC,EAAE,OAAO,GAAG;MAClB,OAAO,IAAIC,IAAI,CAACD,CAAC,CAAC,CAACE,kBAAkB,CAAC,OAAO,EAAE;QAAEC,KAAK,EAAE,OAAO;QAAEC,GAAG,EAAE,SAAS;QAAEC,IAAI,EAAE;MAAU,CAAC,CAAC;IACrG,CAAC;IACD,MAAMC,IAAIA,GAAG;MACX,IAAI,CAAC3B,OAAM,GAAI,IAAI;MACnB,IAAI,CAACC,KAAI,GAAI,EAAE;MACf,IAAI;QACF,MAAM2B,MAAK,GAAI,CAAC,CAAC;QACjB,IAAI,IAAI,CAACvB,WAAW,CAACwB,IAAI,CAAC,CAAC,EAAED,MAAM,CAACE,IAAI,IAAI,CAACzB,WAAW,CAACwB,IAAI,CAAC,CAAC;QAC/D,MAAME,WAAU,GAAI,IAAIC,eAAe,CAACJ,MAAM,CAAC,CAACK,QAAQ,CAAC,CAAC;QAC1D,MAAMC,GAAE,GAAI,gCAAgCH,WAAU,GAAI,IAAIA,WAAW,EAAC,GAAI,EAAE,EAAE;QAClF,MAAMI,GAAE,GAAI,MAAM/C,GAAG,CAACgD,GAAG,CAACF,GAAG,CAAC;QAC9B,IAAI,CAACnC,OAAM,GAAIsC,KAAK,CAACC,OAAO,CAACH,GAAG,CAACtC,IAAI,IAAIsC,GAAG,CAACtC,IAAG,GAAI,EAAE;MACxD,EAAE,OAAO0C,GAAG,EAAE;QACZ,IAAI,CAACtC,KAAI,GAAIsC,GAAG,CAACC,QAAQ,EAAE3C,IAAI,EAAE4C,OAAM,IAAK,uCAAuC;MACrF,UAAU;QACR,IAAI,CAACzC,OAAM,GAAI,KAAK;MACtB;IACF,CAAC;IACD0C,aAAaA,GAAG;MACdC,YAAY,CAAC,IAAI,CAACrC,cAAc,CAAC;MACjC,IAAI,CAACA,cAAa,GAAIsC,UAAU,CAAC,MAAM,IAAI,CAACjB,IAAI,CAAC,CAAC,EAAE,GAAG,CAAC;IAC1D,CAAC;IACDkB,UAAUA,GAAG;MACX,IAAI,CAACzC,YAAW,GAAI,IAAI;MACxB,IAAI,CAACD,SAAQ,GAAI,IAAI;IACvB,CAAC;IACD2C,QAAQA,CAACC,KAAK,EAAE;MACd,IAAI,CAAC3C,YAAW,GAAI2C,KAAK;MACzB,IAAI,CAAC5C,SAAQ,GAAI,IAAI;IACvB,CAAC;IACD6C,UAAUA,GAAG;MACX,IAAI,CAAC7C,SAAQ,GAAI,KAAK;MACtB,IAAI,CAACC,YAAW,GAAI,IAAI;IAC1B,CAAC;IACD6C,YAAYA,CAACF,KAAK,EAAE;MAClB,IAAI,CAACA,KAAK,EAAE;QACV,IAAI,CAACpB,IAAI,CAAC,CAAC;QACX;MACF;MACA,MAAMuB,GAAE,GAAI,IAAI,CAACnD,OAAO,CAACoD,SAAS,CAAEtC,CAAC,IAAKA,CAAC,CAACuC,GAAE,KAAML,KAAK,CAACK,GAAG,CAAC;MAC9D,IAAIF,GAAE,IAAK,CAAC,EAAE;QACZ,IAAI,CAACnD,OAAO,CAACsD,MAAM,CAACH,GAAG,EAAE,CAAC,EAAEH,KAAK,CAAC;MACpC,OAAO;QACL,IAAI,CAAChD,OAAO,CAACuD,OAAO,CAACP,KAAK,CAAC;MAC7B;MACA,IAAIA,KAAK,CAACjC,WAAW,EAAE;QACrB,MAAMK,IAAG,GAAI,IAAI,CAACX,QAAQ,CAAC+C,IAAI,CAAEC,CAAC,IAAKA,CAAC,CAAC/D,GAAE,KAAMsD,KAAK,CAACjC,WAAW,CAAC;QACnE,IAAIK,IAAI,EAAE,IAAI,CAACjB,QAAO,GAAIiB,IAAI;MAChC;IACF,CAAC;IACDsC,cAAcA,CAAClE,EAAE,EAAE;MACjB,IAAI,CAACQ,OAAM,GAAI,IAAI,CAACA,OAAO,CAACa,MAAM,CAAEC,CAAC,IAAKA,CAAC,CAACuC,GAAE,KAAM7D,EAAE,CAAC;IACzD;EACF,CAAC;EACDmE,OAAOA,GAAG;IACR,IAAI,CAAC/B,IAAI,CAAC,CAAC;EACb;AACF,CAAC","names":["Icon","API","EntryFormModal","CLUSTER_GROUPS","id","areas","key","title","name","components","data","groups","entries","loading","error","selected","showModal","editingEntry","searchQuery","searchDebounce","computed","allAreas","flatMap","g","selectedEntries","filter","e","subCategory","methods","countFor","length","selectArea","area","formatDate","d","Date","toLocaleDateString","month","day","year","load","params","trim","q","queryString","URLSearchParams","toString","url","res","get","Array","isArray","err","response","message","onSearchInput","clearTimeout","setTimeout","openCreate","openEdit","entry","closeModal","onEntrySaved","idx","findIndex","_id","splice","unshift","find","a","onEntryDeleted","mounted"],"sourceRoot":"","sources":["D:\\joremiodotonline\\dashboard\\src\\views\\cases\\CrimeClusters.vue"],"sourcesContent":["<template>\n  <div class=\"min-h-screen bg-case-bg p-3 sm:p-5 space-y-5\">\n\n    <!-- ── Header ──────────────────────────────────────────────────────── -->\n    <header class=\"flex flex-wrap items-end justify-between gap-4\">\n      <div>\n        <p class=\"text-[10px] font-semibold uppercase tracking-[0.35em] text-primary\">Case Management</p>\n        <h1 class=\"mt-2 text-2xl font-semibold text-white\">18 Crime Clusters</h1>\n        <p class=\"mt-1 text-xs text-gray-500 max-w-2xl\">\n          Focused-Operations crime cluster groupings. Three groups, six crime areas each — select an\n          area to file or review entries.\n        </p>\n      </div>\n      <div class=\"flex items-center gap-2\">\n        <span class=\"text-[10px] uppercase tracking-[0.2em] text-gray-600\">Total</span>\n        <span class=\"rounded-full border border-case-border bg-case-surface px-3 py-1 text-primary font-semibold text-xs\">\n          {{ entries.length }}\n        </span>\n        <button\n          @click=\"openCreate\"\n          class=\"rounded-md bg-primary px-3 py-2 text-xs font-semibold text-black hover:bg-primary/90 transition-colors flex items-center gap-2\">\n          <Icon icon=\"mdi:plus\" class=\"text-base\" /> New Data Entry\n        </button>\n      </div>\n    </header>\n\n    <EntryFormModal\n      :open=\"showModal\"\n      category=\"crime-clusters\"\n      context-label=\"18 Crime Clusters\"\n      :category-options=\"allAreas\"\n      :default-sub-category=\"selected?.key || ''\"\n      :entry=\"editingEntry\"\n      @close=\"closeModal\"\n      @saved=\"onEntrySaved\"\n      @deleted=\"onEntryDeleted\" />\n\n    <!-- ── Search bar ──────────────────────────────────────────────────── -->\n    <div class=\"flex items-center gap-3\">\n      <div class=\"relative flex-1 max-w-md\">\n        <Icon icon=\"mdi:magnify\" class=\"absolute left-3 top-1/2 -translate-y-1/2 text-gray-600 text-base\" />\n        <input\n          v-model=\"searchQuery\"\n          @input=\"onSearchInput\"\n          type=\"text\"\n          placeholder=\"Search across all crime clusters...\"\n          class=\"w-full rounded-md border border-case-border bg-case-surface pl-9 pr-3 py-2 text-xs text-gray-200 placeholder:text-gray-600 focus:border-primary focus:outline-none transition-colors\" />\n      </div>\n      <span v-if=\"searchQuery\" class=\"text-[10px] text-gray-600\">\n        {{ entries.length }} match{{ entries.length === 1 ? \"\" : \"es\" }}\n      </span>\n    </div>\n\n    <!-- ── Three groups, six areas each ────────────────────────────────── -->\n    <section v-if=\"loading\" class=\"grid grid-cols-1 lg:grid-cols-3 gap-4\">\n      <div v-for=\"i in 3\" :key=\"i\" class=\"bg-case-surface border border-case-border rounded-xl p-5 space-y-3\">\n        <div class=\"h-4 w-24 animate-pulse rounded bg-case-elevated\"></div>\n        <div v-for=\"j in 6\" :key=\"j\" class=\"h-10 animate-pulse rounded-lg bg-case-elevated\"></div>\n      </div>\n    </section>\n\n    <section v-else class=\"grid grid-cols-1 lg:grid-cols-3 gap-4\">\n      <div\n        v-for=\"(group, gi) in groups\"\n        :key=\"group.id\"\n        class=\"bg-case-surface border border-case-border rounded-xl overflow-hidden flex flex-col\">\n        <header class=\"bg-primary/90 px-4 py-2.5 flex items-center justify-between\">\n          <p class=\"text-[11px] font-bold uppercase tracking-[0.25em] text-black\">Crime Areas</p>\n          <span class=\"text-[10px] font-semibold text-black/70\">Group {{ gi + 1 }}</span>\n        </header>\n        <ul class=\"divide-y divide-case-border\">\n          <li\n            v-for=\"(area, ai) in group.areas\"\n            :key=\"area.key\"\n            @click=\"selectArea(area)\"\n            class=\"flex items-center justify-between gap-3 px-4 py-3 cursor-pointer hover:bg-case-card transition-colors\"\n            :class=\"{ 'bg-case-card': selected?.key === area.key }\">\n            <div class=\"flex items-start gap-3 min-w-0\">\n              <span class=\"mt-0.5 text-[10px] font-semibold text-gray-600 w-4 flex-shrink-0\">{{ ai + 1 }}.</span>\n              <div class=\"min-w-0\">\n                <p class=\"text-xs text-gray-200 truncate\">{{ area.title }}</p>\n              </div>\n            </div>\n            <span\n              class=\"flex-shrink-0 rounded-full bg-case-elevated px-2 py-0.5 text-[10px] font-semibold\"\n              :class=\"countFor(area.key) > 0 ? 'text-primary' : 'text-gray-600'\">\n              {{ countFor(area.key) }}\n            </span>\n          </li>\n        </ul>\n      </div>\n    </section>\n\n    <!-- ── Selected area panel ─────────────────────────────────────────── -->\n    <section v-if=\"selected\" class=\"bg-case-surface border border-case-border rounded-xl\">\n      <header class=\"flex items-center justify-between border-b border-case-border px-5 py-3\">\n        <div>\n          <p class=\"text-[10px] uppercase tracking-[0.25em] text-gray-600\">Selected crime area</p>\n          <h2 class=\"text-sm font-semibold text-white mt-1\">{{ selected.title }}</h2>\n        </div>\n        <div class=\"flex items-center gap-2\">\n          <button\n            @click=\"openCreate\"\n            class=\"rounded-md bg-primary/10 border border-primary/40 px-3 py-1.5 text-[11px] font-semibold text-primary hover:bg-primary/20 transition-colors flex items-center gap-1.5\">\n            <Icon icon=\"mdi:plus\" /> Add to this area\n          </button>\n          <button\n            @click=\"selected = null\"\n            class=\"text-gray-600 hover:text-gray-300 transition-colors\">\n            <Icon icon=\"mdi:close\" class=\"text-lg\" />\n          </button>\n        </div>\n      </header>\n      <div class=\"p-5\">\n        <div v-if=\"error\" class=\"rounded-md border border-red-900/50 bg-red-950/30 p-4 text-xs text-red-400\">\n          {{ error }}\n        </div>\n        <div v-else-if=\"selectedEntries.length\" class=\"space-y-2\">\n          <div\n            v-for=\"entry in selectedEntries\"\n            :key=\"entry._id\"\n            @click=\"openEdit(entry)\"\n            class=\"rounded-lg border border-case-border bg-case-card p-3 flex items-start justify-between gap-3 cursor-pointer hover:bg-case-elevated transition-colors\">\n            <div class=\"min-w-0\">\n              <div class=\"flex items-center gap-2\">\n                <p class=\"text-sm text-gray-200 truncate\">{{ entry.title }}</p>\n                <Icon v-if=\"entry.attachments?.length\" icon=\"mdi:paperclip\" class=\"text-primary text-sm flex-shrink-0\" />\n              </div>\n              <p class=\"text-[11px] text-gray-500 mt-0.5\">{{ entry.leadAgency || \"—\" }} · {{ formatDate(entry.createdAt) }}</p>\n            </div>\n            <span class=\"rounded-full bg-case-elevated px-2 py-0.5 text-[10px] uppercase tracking-wide text-gray-400 flex-shrink-0\">\n              {{ entry.status || \"open\" }}\n            </span>\n          </div>\n        </div>\n        <div v-else class=\"py-10 flex flex-col items-center justify-center text-center\">\n          <Icon icon=\"mdi:database-search-outline\" class=\"text-3xl text-gray-700 mb-2\" />\n          <p class=\"text-xs text-gray-500\">No entries filed under {{ selected.title }} yet.</p>\n        </div>\n      </div>\n    </section>\n  </div>\n</template>\n\n<script>\n  import { Icon } from \"@iconify/vue\";\n  import API from \"@/services/api\";\n  import EntryFormModal from \"./components/EntryFormModal.vue\";\n\n  const CLUSTER_GROUPS = [\n    {\n      id: \"group-1\",\n      areas: [\n        { key: \"trafficking-illegal-recruitment\", title: \"Trafficking-in-Persons / Illegal Recruitment\" },\n        { key: \"cybercrime-online-fraud\", title: \"Cybercrime / Online Scam / Fraud\" },\n        { key: \"illegal-gambling\", title: \"Illegal Gambling\" },\n        { key: \"kidnapping-for-ransom\", title: \"Kidnapping-for-Ransom\" },\n        { key: \"money-laundering\", title: \"Money Laundering\" },\n        { key: \"tax-evasion\", title: \"Tax Evasion\" },\n      ],\n    },\n    {\n      id: \"group-2\",\n      areas: [\n        { key: \"environmental-crimes\", title: \"Environmental Crimes\" },\n        { key: \"crimes-against-cultural-properties\", title: \"Crimes Against Cultural Properties\" },\n        { key: \"smuggling\", title: \"Smuggling\" },\n        { key: \"ipr-theft\", title: \"Intellectual Property Rights Theft\" },\n        { key: \"economic-sabotage-food-security\", title: \"Economic Sabotage / Crimes Related to Food Security\" },\n        { key: \"carnapping\", title: \"Carnapping\" },\n      ],\n    },\n    {\n      id: \"group-3\",\n      areas: [\n        { key: \"terrorism\", title: \"Terrorism\" },\n        { key: \"drug-trafficking\", title: \"Drug Trafficking / Illegal Drugs\" },\n        { key: \"gunrunning-private-armed-groups\", title: \"Gunrunning / Private Armed Groups\" },\n        { key: \"insurgency\", title: \"Insurgency\" },\n        { key: \"robbery\", title: \"Robbery\" },\n        { key: \"graft-and-corruption\", title: \"Graft and Corruption\" },\n      ],\n    },\n  ];\n\n  export default {\n    name: \"CrimeClusters\",\n    components: { Icon, EntryFormModal },\n    data() {\n      return {\n        groups: CLUSTER_GROUPS,\n        entries: [],\n        loading: false,\n        error: \"\",\n        selected: null,\n        showModal: false,\n        editingEntry: null,\n        searchQuery: \"\",\n        searchDebounce: null,\n      };\n    },\n    computed: {\n      allAreas() {\n        return CLUSTER_GROUPS.flatMap((g) => g.areas);\n      },\n      selectedEntries() {\n        if (!this.selected) return [];\n        return this.entries.filter((e) => e.subCategory === this.selected.key);\n      },\n    },\n    methods: {\n      countFor(key) {\n        return this.entries.filter((e) => e.subCategory === key).length;\n      },\n      selectArea(area) {\n        this.selected = area;\n      },\n      formatDate(d) {\n        if (!d) return \"—\";\n        return new Date(d).toLocaleDateString(\"en-US\", { month: \"short\", day: \"numeric\", year: \"numeric\" });\n      },\n      async load() {\n        this.loading = true;\n        this.error = \"\";\n        try {\n          const params = {};\n          if (this.searchQuery.trim()) params.q = this.searchQuery.trim();\n          const queryString = new URLSearchParams(params).toString();\n          const url = `/cases/entries/crime-clusters${queryString ? `?${queryString}` : \"\"}`;\n          const res = await API.get(url);\n          this.entries = Array.isArray(res.data) ? res.data : [];\n        } catch (err) {\n          this.error = err.response?.data?.message || \"Unable to load crime cluster entries.\";\n        } finally {\n          this.loading = false;\n        }\n      },\n      onSearchInput() {\n        clearTimeout(this.searchDebounce);\n        this.searchDebounce = setTimeout(() => this.load(), 300);\n      },\n      openCreate() {\n        this.editingEntry = null;\n        this.showModal = true;\n      },\n      openEdit(entry) {\n        this.editingEntry = entry;\n        this.showModal = true;\n      },\n      closeModal() {\n        this.showModal = false;\n        this.editingEntry = null;\n      },\n      onEntrySaved(entry) {\n        if (!entry) {\n          this.load();\n          return;\n        }\n        const idx = this.entries.findIndex((e) => e._id === entry._id);\n        if (idx >= 0) {\n          this.entries.splice(idx, 1, entry);\n        } else {\n          this.entries.unshift(entry);\n        }\n        if (entry.subCategory) {\n          const area = this.allAreas.find((a) => a.key === entry.subCategory);\n          if (area) this.selected = area;\n        }\n      },\n      onEntryDeleted(id) {\n        this.entries = this.entries.filter((e) => e._id !== id);\n      },\n    },\n    mounted() {\n      this.load();\n    },\n  };\n</script>\n"]},"metadata":{},"sourceType":"module"}