{"ast":null,"code":"import API from \"@/services/api\";\nexport default {\n  name: \"LoginHistoryPage\",\n  data() {\n    return {\n      isLoading: false,\n      entries: [],\n      message: {\n        type: \"\",\n        text: \"\"\n      }\n    };\n  },\n  mounted() {\n    this.fetchHistory();\n  },\n  methods: {\n    async fetchHistory() {\n      this.isLoading = true;\n      this.message = {\n        type: \"\",\n        text: \"\"\n      };\n      try {\n        const response = await API.get(\"/auth/login-history\");\n        this.entries = response.data.entries || [];\n      } catch (error) {\n        this.message = {\n          type: \"error\",\n          text: error.response?.data?.message || \"Unable to load login history right now.\"\n        };\n      } finally {\n        this.isLoading = false;\n      }\n    },\n    formatDate(value) {\n      if (!value) return \"—\";\n      return new Intl.DateTimeFormat(\"en-US\", {\n        month: \"short\",\n        day: \"numeric\",\n        year: \"numeric\",\n        hour: \"numeric\",\n        minute: \"2-digit\"\n      }).format(new Date(value));\n    }\n  }\n};","map":{"version":3,"mappings":"AA0FE,OAAOA,GAAE,MAAO,gBAAgB;AAEhC,eAAe;EACbC,IAAI,EAAE,kBAAkB;EACxBC,IAAIA,GAAG;IACL,OAAO;MACLC,SAAS,EAAE,KAAK;MAChBC,OAAO,EAAE,EAAE;MACXC,OAAO,EAAE;QAAEC,IAAI,EAAE,EAAE;QAAEC,IAAI,EAAE;MAAG;IAChC,CAAC;EACH,CAAC;EACDC,OAAOA,GAAG;IACR,IAAI,CAACC,YAAY,CAAC,CAAC;EACrB,CAAC;EACDC,OAAO,EAAE;IACP,MAAMD,YAAYA,GAAG;MACnB,IAAI,CAACN,SAAQ,GAAI,IAAI;MACrB,IAAI,CAACE,OAAM,GAAI;QAAEC,IAAI,EAAE,EAAE;QAAEC,IAAI,EAAE;MAAG,CAAC;MACrC,IAAI;QACF,MAAMI,QAAO,GAAI,MAAMX,GAAG,CAACY,GAAG,CAAC,qBAAqB,CAAC;QACrD,IAAI,CAACR,OAAM,GAAIO,QAAQ,CAACT,IAAI,CAACE,OAAM,IAAK,EAAE;MAC5C,EAAE,OAAOS,KAAK,EAAE;QACd,IAAI,CAACR,OAAM,GAAI;UACbC,IAAI,EAAE,OAAO;UACbC,IAAI,EAAEM,KAAK,CAACF,QAAQ,EAAET,IAAI,EAAEG,OAAM,IAAK;QACzC,CAAC;MACH,UAAU;QACR,IAAI,CAACF,SAAQ,GAAI,KAAK;MACxB;IACF,CAAC;IACDW,UAAUA,CAACC,KAAK,EAAE;MAChB,IAAI,CAACA,KAAK,EAAE,OAAO,GAAG;MACtB,OAAO,IAAIC,IAAI,CAACC,cAAc,CAAC,OAAO,EAAE;QACtCC,KAAK,EAAE,OAAO;QAAEC,GAAG,EAAE,SAAS;QAAEC,IAAI,EAAE,SAAS;QAC/CC,IAAI,EAAE,SAAS;QAAEC,MAAM,EAAE;MAC3B,CAAC,CAAC,CAACC,MAAM,CAAC,IAAIC,IAAI,CAACT,KAAK,CAAC,CAAC;IAC5B;EACF;AACF,CAAC","names":["API","name","data","isLoading","entries","message","type","text","mounted","fetchHistory","methods","response","get","error","formatDate","value","Intl","DateTimeFormat","month","day","year","hour","minute","format","Date"],"sourceRoot":"","sources":["D:\\joremiodotonline\\dashboard\\src\\views\\system\\LoginHistory.vue"],"sourcesContent":["<template>\n  <div class=\"min-h-screen bg-case-bg p-6 sm:p-8\">\n    <div class=\"mx-auto max-w-5xl space-y-6\">\n\n      <div class=\"border-b border-case-border pb-5\">\n        <p class=\"text-xs font-semibold uppercase tracking-[0.3em] text-primary\">System / User &amp; Account</p>\n        <h1 class=\"mt-2 text-2xl font-semibold text-white\">Login History</h1>\n        <p class=\"mt-1 text-sm text-gray-500\">Review recent sign-ins and check who accessed the system.</p>\n      </div>\n\n      <div class=\"flex items-center justify-between\">\n        <p class=\"text-sm text-gray-500\">{{ entries.length }} entr{{ entries.length !== 1 ? \"ies\" : \"y\" }}</p>\n        <button\n          type=\"button\"\n          class=\"rounded-xl border border-case-border px-4 py-2 text-sm font-medium text-gray-400 transition hover:bg-case-elevated hover:text-gray-200\"\n          :disabled=\"isLoading\"\n          @click=\"fetchHistory\"\n        >\n          {{ isLoading ? \"Refreshing...\" : \"Refresh\" }}\n        </button>\n      </div>\n\n      <div\n        v-if=\"message.text\"\n        :class=\"message.type === 'error' ? 'border-red-900/50 bg-red-950/30 text-red-400' : 'border-emerald-800/50 bg-emerald-950/30 text-emerald-400'\"\n        class=\"rounded-xl border px-4 py-3 text-sm\"\n      >\n        {{ message.text }}\n      </div>\n\n      <div v-if=\"isLoading\" class=\"space-y-2\">\n        <div v-for=\"i in 5\" :key=\"i\" class=\"h-12 animate-pulse rounded-xl bg-case-elevated\"></div>\n      </div>\n\n      <div v-else-if=\"!entries.length\" class=\"py-12 text-center text-sm text-gray-600\">\n        No login history records found yet.\n      </div>\n\n      <div v-else class=\"rounded-xl border border-case-border bg-case-surface overflow-hidden\">\n        <div class=\"overflow-x-auto\">\n          <table class=\"min-w-full divide-y divide-case-border\">\n            <thead class=\"bg-case-card\">\n              <tr class=\"text-left text-[10px] uppercase tracking-[0.22em] text-gray-600\">\n                <th class=\"px-4 py-3 font-medium\">User</th>\n                <th class=\"px-4 py-3 font-medium\">Role</th>\n                <th class=\"px-4 py-3 font-medium\">Time</th>\n                <th class=\"px-4 py-3 font-medium\">IP Address</th>\n                <th class=\"px-4 py-3 font-medium\">Device</th>\n                <th class=\"px-4 py-3 font-medium\">Status</th>\n              </tr>\n            </thead>\n            <tbody class=\"divide-y divide-case-border/50\">\n              <tr\n                v-for=\"entry in entries\"\n                :key=\"entry.id\"\n                class=\"align-top hover:bg-case-card transition-colors\"\n              >\n                <td class=\"px-4 py-3.5\">\n                  <div class=\"font-medium text-gray-200\">{{ entry.username || \"Unknown\" }}</div>\n                  <div class=\"mt-0.5 text-xs text-gray-500\">{{ entry.email || \"—\" }}</div>\n                </td>\n                <td class=\"px-4 py-3.5\">\n                  <span class=\"rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-semibold uppercase tracking-[0.15em] text-primary\">\n                    {{ entry.role || \"viewer\" }}\n                  </span>\n                </td>\n                <td class=\"px-4 py-3.5 text-sm text-gray-400\">{{ formatDate(entry.createdAt) }}</td>\n                <td class=\"px-4 py-3.5 font-mono text-xs text-gray-500\">{{ entry.ipAddress || \"—\" }}</td>\n                <td class=\"px-4 py-3.5 text-xs text-gray-500 max-w-[180px]\">\n                  <span class=\"truncate block\">{{ entry.userAgent || \"—\" }}</span>\n                </td>\n                <td class=\"px-4 py-3.5\">\n                  <span\n                    :class=\"entry.status === 'success' ? 'bg-emerald-900/20 text-emerald-400' : 'bg-red-900/20 text-red-400'\"\n                    class=\"rounded-full px-2.5 py-0.5 text-xs font-semibold uppercase tracking-[0.15em]\"\n                  >\n                    {{ entry.status || \"success\" }}\n                  </span>\n                </td>\n              </tr>\n            </tbody>\n          </table>\n        </div>\n      </div>\n\n    </div>\n  </div>\n</template>\n\n<script>\n  import API from \"@/services/api\";\n\n  export default {\n    name: \"LoginHistoryPage\",\n    data() {\n      return {\n        isLoading: false,\n        entries: [],\n        message: { type: \"\", text: \"\" },\n      };\n    },\n    mounted() {\n      this.fetchHistory();\n    },\n    methods: {\n      async fetchHistory() {\n        this.isLoading = true;\n        this.message = { type: \"\", text: \"\" };\n        try {\n          const response = await API.get(\"/auth/login-history\");\n          this.entries = response.data.entries || [];\n        } catch (error) {\n          this.message = {\n            type: \"error\",\n            text: error.response?.data?.message || \"Unable to load login history right now.\",\n          };\n        } finally {\n          this.isLoading = false;\n        }\n      },\n      formatDate(value) {\n        if (!value) return \"—\";\n        return new Intl.DateTimeFormat(\"en-US\", {\n          month: \"short\", day: \"numeric\", year: \"numeric\",\n          hour: \"numeric\", minute: \"2-digit\",\n        }).format(new Date(value));\n      },\n    },\n  };\n</script>\n"]},"metadata":{},"sourceType":"module"}