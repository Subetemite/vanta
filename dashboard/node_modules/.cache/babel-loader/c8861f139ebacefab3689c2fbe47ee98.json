{"ast":null,"code":"import API from \"@/services/api\";\nexport default {\n  name: \"LoginHistoryPage\",\n  data() {\n    return {\n      isLoading: false,\n      entries: [],\n      message: {\n        type: \"\",\n        text: \"\"\n      }\n    };\n  },\n  mounted() {\n    this.fetchHistory();\n  },\n  methods: {\n    async fetchHistory() {\n      this.isLoading = true;\n      this.message = {\n        type: \"\",\n        text: \"\"\n      };\n      try {\n        const response = await API.get(\"/auth/login-history\");\n        this.entries = response.data.entries || [];\n      } catch (error) {\n        this.message = {\n          type: \"error\",\n          text: error.response?.data?.message || \"Unable to load login history right now.\"\n        };\n      } finally {\n        this.isLoading = false;\n      }\n    },\n    formatDate(value) {\n      if (!value) {\n        return \"Unavailable\";\n      }\n      return new Intl.DateTimeFormat(\"en-US\", {\n        month: \"short\",\n        day: \"numeric\",\n        year: \"numeric\",\n        hour: \"numeric\",\n        minute: \"2-digit\"\n      }).format(new Date(value));\n    }\n  }\n};","map":{"version":3,"mappings":"AA8FE,OAAOA,GAAE,MAAO,gBAAgB;AAEhC,eAAe;EACbC,IAAI,EAAE,kBAAkB;EACxBC,IAAIA,GAAG;IACL,OAAO;MACLC,SAAS,EAAE,KAAK;MAChBC,OAAO,EAAE,EAAE;MACXC,OAAO,EAAE;QACPC,IAAI,EAAE,EAAE;QACRC,IAAI,EAAE;MACR;IACF,CAAC;EACH,CAAC;EACDC,OAAOA,GAAG;IACR,IAAI,CAACC,YAAY,CAAC,CAAC;EACrB,CAAC;EACDC,OAAO,EAAE;IACP,MAAMD,YAAYA,GAAG;MACnB,IAAI,CAACN,SAAQ,GAAI,IAAI;MACrB,IAAI,CAACE,OAAM,GAAI;QAAEC,IAAI,EAAE,EAAE;QAAEC,IAAI,EAAE;MAAG,CAAC;MAErC,IAAI;QACF,MAAMI,QAAO,GAAI,MAAMX,GAAG,CAACY,GAAG,CAAC,qBAAqB,CAAC;QACrD,IAAI,CAACR,OAAM,GAAIO,QAAQ,CAACT,IAAI,CAACE,OAAM,IAAK,EAAE;MAC5C,EAAE,OAAOS,KAAK,EAAE;QACd,IAAI,CAACR,OAAM,GAAI;UACbC,IAAI,EAAE,OAAO;UACbC,IAAI,EACFM,KAAK,CAACF,QAAQ,EAAET,IAAI,EAAEG,OAAM,IAC5B;QACJ,CAAC;MACH,UAAU;QACR,IAAI,CAACF,SAAQ,GAAI,KAAK;MACxB;IACF,CAAC;IACDW,UAAUA,CAACC,KAAK,EAAE;MAChB,IAAI,CAACA,KAAK,EAAE;QACV,OAAO,aAAa;MACtB;MAEA,OAAO,IAAIC,IAAI,CAACC,cAAc,CAAC,OAAO,EAAE;QACtCC,KAAK,EAAE,OAAO;QACdC,GAAG,EAAE,SAAS;QACdC,IAAI,EAAE,SAAS;QACfC,IAAI,EAAE,SAAS;QACfC,MAAM,EAAE;MACV,CAAC,CAAC,CAACC,MAAM,CAAC,IAAIC,IAAI,CAACT,KAAK,CAAC,CAAC;IAC5B;EACF;AACF,CAAC","names":["API","name","data","isLoading","entries","message","type","text","mounted","fetchHistory","methods","response","get","error","formatDate","value","Intl","DateTimeFormat","month","day","year","hour","minute","format","Date"],"sourceRoot":"","sources":["D:\\joremiodotonline\\dashboard\\src\\views\\system\\LoginHistory.vue"],"sourcesContent":["<template>\n  <div class=\"min-h-screen bg-slate-100 p-6 sm:p-8\">\n    <div class=\"mx-auto max-w-6xl space-y-6\">\n      <section class=\"rounded-[2rem] bg-[linear-gradient(145deg,_#020617_0%,_#0f172a_35%,_#1d4ed8_100%)] p-8 text-white shadow-2xl shadow-slate-900/20\">\n        <p class=\"text-sm font-semibold uppercase tracking-[0.35em] text-cyan-200/70\">\n          User activity\n        </p>\n        <h1 class=\"mt-3 text-3xl font-semibold sm:text-4xl\">Login history</h1>\n        <p class=\"mt-4 max-w-2xl text-sm leading-7 text-slate-300 sm:text-base\">\n          Review recent successful sign-ins across the dashboard and check who accessed the system.\n        </p>\n      </section>\n\n      <section class=\"rounded-[2rem] border border-slate-200 bg-white p-6 shadow-xl shadow-slate-900/5 sm:p-8\">\n        <div class=\"flex flex-col gap-3 border-b border-slate-200 pb-5 sm:flex-row sm:items-center sm:justify-between\">\n          <div>\n            <h2 class=\"text-2xl font-semibold text-slate-900\">Recent access events</h2>\n            <p class=\"mt-2 text-sm text-slate-500\">\n              Showing the latest successful login attempts recorded by the backend.\n            </p>\n          </div>\n          <button\n            type=\"button\"\n            class=\"rounded-2xl border border-slate-200 px-4 py-2 text-sm font-medium text-slate-600 transition hover:border-slate-300 hover:bg-slate-50\"\n            :disabled=\"isLoading\"\n            @click=\"fetchHistory\"\n          >\n            {{ isLoading ? \"Refreshing...\" : \"Refresh history\" }}\n          </button>\n        </div>\n\n        <div\n          v-if=\"message.text\"\n          :class=\"message.type === 'error' ? 'border-red-200 bg-red-50 text-red-600' : 'border-emerald-200 bg-emerald-50 text-emerald-700'\"\n          class=\"mt-6 rounded-2xl border px-4 py-3 text-sm\"\n        >\n          {{ message.text }}\n        </div>\n\n        <div v-if=\"isLoading\" class=\"py-12 text-center text-sm text-slate-500\">\n          Loading login history...\n        </div>\n\n        <div v-else-if=\"!entries.length\" class=\"py-12 text-center text-sm text-slate-500\">\n          No login history records found yet.\n        </div>\n\n        <div v-else class=\"mt-6 overflow-x-auto\">\n          <table class=\"min-w-full divide-y divide-slate-200\">\n            <thead>\n              <tr class=\"text-left text-xs uppercase tracking-[0.22em] text-slate-400\">\n                <th class=\"px-4 py-3 font-medium\">User</th>\n                <th class=\"px-4 py-3 font-medium\">Role</th>\n                <th class=\"px-4 py-3 font-medium\">Time</th>\n                <th class=\"px-4 py-3 font-medium\">IP address</th>\n                <th class=\"px-4 py-3 font-medium\">Device</th>\n                <th class=\"px-4 py-3 font-medium\">Status</th>\n              </tr>\n            </thead>\n            <tbody class=\"divide-y divide-slate-100\">\n              <tr v-for=\"entry in entries\" :key=\"entry.id\" class=\"align-top\">\n                <td class=\"px-4 py-4\">\n                  <div class=\"font-medium text-slate-900\">{{ entry.username || \"Unknown user\" }}</div>\n                  <div class=\"mt-1 text-sm text-slate-500\">{{ entry.email || \"No email\" }}</div>\n                </td>\n                <td class=\"px-4 py-4\">\n                  <span class=\"rounded-full bg-slate-900 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-white\">\n                    {{ entry.role || \"viewer\" }}\n                  </span>\n                </td>\n                <td class=\"px-4 py-4 text-sm text-slate-600\">\n                  {{ formatDate(entry.createdAt) }}\n                </td>\n                <td class=\"px-4 py-4 text-sm text-slate-600\">\n                  {{ entry.ipAddress || \"Unavailable\" }}\n                </td>\n                <td class=\"px-4 py-4 text-sm text-slate-600\">\n                  {{ entry.userAgent || \"Unavailable\" }}\n                </td>\n                <td class=\"px-4 py-4\">\n                  <span class=\"rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-emerald-700\">\n                    {{ entry.status }}\n                  </span>\n                </td>\n              </tr>\n            </tbody>\n          </table>\n        </div>\n      </section>\n    </div>\n  </div>\n</template>\n\n<script>\n  import API from \"@/services/api\";\n\n  export default {\n    name: \"LoginHistoryPage\",\n    data() {\n      return {\n        isLoading: false,\n        entries: [],\n        message: {\n          type: \"\",\n          text: \"\",\n        },\n      };\n    },\n    mounted() {\n      this.fetchHistory();\n    },\n    methods: {\n      async fetchHistory() {\n        this.isLoading = true;\n        this.message = { type: \"\", text: \"\" };\n\n        try {\n          const response = await API.get(\"/auth/login-history\");\n          this.entries = response.data.entries || [];\n        } catch (error) {\n          this.message = {\n            type: \"error\",\n            text:\n              error.response?.data?.message ||\n              \"Unable to load login history right now.\",\n          };\n        } finally {\n          this.isLoading = false;\n        }\n      },\n      formatDate(value) {\n        if (!value) {\n          return \"Unavailable\";\n        }\n\n        return new Intl.DateTimeFormat(\"en-US\", {\n          month: \"short\",\n          day: \"numeric\",\n          year: \"numeric\",\n          hour: \"numeric\",\n          minute: \"2-digit\",\n        }).format(new Date(value));\n      },\n    },\n  };\n</script>\n"]},"metadata":{},"sourceType":"module"}