{"ast":null,"code":"import \"core-js/modules/esnext.iterator.constructor.js\";\nimport \"core-js/modules/esnext.iterator.filter.js\";\nimport { Icon } from \"@iconify/vue\";\nimport API from \"@/services/api\";\nimport EntryFormModal from \"./components/EntryFormModal.vue\";\nexport default {\n  name: \"AccomplishmentReports\",\n  components: {\n    Icon,\n    EntryFormModal\n  },\n  data() {\n    return {\n      entries: [],\n      loading: false,\n      error: \"\",\n      showModal: false,\n      editingEntry: null,\n      searchQuery: \"\",\n      searchDebounce: null\n    };\n  },\n  methods: {\n    formatDate(d) {\n      if (!d) return \"—\";\n      return new Date(d).toLocaleDateString(\"en-US\", {\n        month: \"short\",\n        day: \"numeric\",\n        year: \"numeric\"\n      });\n    },\n    async load() {\n      this.loading = true;\n      this.error = \"\";\n      try {\n        const params = {};\n        if (this.searchQuery.trim()) params.q = this.searchQuery.trim();\n        const queryString = new URLSearchParams(params).toString();\n        const url = `/cases/entries/accomplishment-reports${queryString ? `?${queryString}` : \"\"}`;\n        const res = await API.get(url);\n        this.entries = Array.isArray(res.data) ? res.data : [];\n      } catch (err) {\n        this.error = err.response?.data?.message || \"Unable to load reports.\";\n      } finally {\n        this.loading = false;\n      }\n    },\n    onSearchInput() {\n      clearTimeout(this.searchDebounce);\n      this.searchDebounce = setTimeout(() => this.load(), 300);\n    },\n    openCreate() {\n      this.editingEntry = null;\n      this.showModal = true;\n    },\n    openEdit(entry) {\n      this.editingEntry = entry;\n      this.showModal = true;\n    },\n    closeModal() {\n      this.showModal = false;\n      this.editingEntry = null;\n    },\n    onEntrySaved(entry) {\n      if (!entry) {\n        this.load();\n        return;\n      }\n      const idx = this.entries.findIndex(e => e._id === entry._id);\n      if (idx >= 0) {\n        this.entries.splice(idx, 1, entry);\n      } else {\n        this.entries.unshift(entry);\n      }\n    },\n    onEntryDeleted(id) {\n      this.entries = this.entries.filter(e => e._id !== id);\n    }\n  },\n  mounted() {\n    this.load();\n  }\n};","map":{"version":3,"mappings":";;AAwFE,SAASA,IAAG,QAAS,cAAc;AACnC,OAAOC,GAAE,MAAO,gBAAgB;AAChC,OAAOC,cAAa,MAAO,iCAAiC;AAE5D,eAAe;EACbC,IAAI,EAAE,uBAAuB;EAC7BC,UAAU,EAAE;IAAEJ,IAAI;IAAEE;EAAe,CAAC;EACpCG,IAAIA,GAAG;IACL,OAAO;MACLC,OAAO,EAAE,EAAE;MACXC,OAAO,EAAE,KAAK;MACdC,KAAK,EAAE,EAAE;MACTC,SAAS,EAAE,KAAK;MAChBC,YAAY,EAAE,IAAI;MAClBC,WAAW,EAAE,EAAE;MACfC,cAAc,EAAE;IAClB,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACPC,UAAUA,CAACC,CAAC,EAAE;MACZ,IAAI,CAACA,CAAC,EAAE,OAAO,GAAG;MAClB,OAAO,IAAIC,IAAI,CAACD,CAAC,CAAC,CAACE,kBAAkB,CAAC,OAAO,EAAE;QAAEC,KAAK,EAAE,OAAO;QAAEC,GAAG,EAAE,SAAS;QAAEC,IAAI,EAAE;MAAU,CAAC,CAAC;IACrG,CAAC;IACD,MAAMC,IAAIA,GAAG;MACX,IAAI,CAACd,OAAM,GAAI,IAAI;MACnB,IAAI,CAACC,KAAI,GAAI,EAAE;MACf,IAAI;QACF,MAAMc,MAAK,GAAI,CAAC,CAAC;QACjB,IAAI,IAAI,CAACX,WAAW,CAACY,IAAI,CAAC,CAAC,EAAED,MAAM,CAACE,IAAI,IAAI,CAACb,WAAW,CAACY,IAAI,CAAC,CAAC;QAC/D,MAAME,WAAU,GAAI,IAAIC,eAAe,CAACJ,MAAM,CAAC,CAACK,QAAQ,CAAC,CAAC;QAC1D,MAAMC,GAAE,GAAI,wCAAwCH,WAAU,GAAI,IAAIA,WAAW,EAAC,GAAI,EAAE,EAAE;QAC1F,MAAMI,GAAE,GAAI,MAAM5B,GAAG,CAAC6B,GAAG,CAACF,GAAG,CAAC;QAC9B,IAAI,CAACtB,OAAM,GAAIyB,KAAK,CAACC,OAAO,CAACH,GAAG,CAACxB,IAAI,IAAIwB,GAAG,CAACxB,IAAG,GAAI,EAAE;MACxD,EAAE,OAAO4B,GAAG,EAAE;QACZ,IAAI,CAACzB,KAAI,GAAIyB,GAAG,CAACC,QAAQ,EAAE7B,IAAI,EAAE8B,OAAM,IAAK,yBAAyB;MACvE,UAAU;QACR,IAAI,CAAC5B,OAAM,GAAI,KAAK;MACtB;IACF,CAAC;IACD6B,aAAaA,GAAG;MACdC,YAAY,CAAC,IAAI,CAACzB,cAAc,CAAC;MACjC,IAAI,CAACA,cAAa,GAAI0B,UAAU,CAAC,MAAM,IAAI,CAACjB,IAAI,CAAC,CAAC,EAAE,GAAG,CAAC;IAC1D,CAAC;IACDkB,UAAUA,GAAG;MACX,IAAI,CAAC7B,YAAW,GAAI,IAAI;MACxB,IAAI,CAACD,SAAQ,GAAI,IAAI;IACvB,CAAC;IACD+B,QAAQA,CAACC,KAAK,EAAE;MACd,IAAI,CAAC/B,YAAW,GAAI+B,KAAK;MACzB,IAAI,CAAChC,SAAQ,GAAI,IAAI;IACvB,CAAC;IAC