{"ast":null,"code":"import \"core-js/modules/es.json.stringify.js\";\nimport API from \"@/services/api\";\nexport default {\n  name: \"LoginPage\",\n  data() {\n    return {\n      form: {\n        email: \"\",\n        password: \"\",\n        remember: true\n      },\n      showPassword: false,\n      isSubmitting: false,\n      errorMessage: \"\"\n    };\n  },\n  methods: {\n    async handleLogin() {\n      this.errorMessage = \"\";\n      if (!this.form.email || !this.form.password) {\n        this.errorMessage = \"Enter both your email and password to continue.\";\n        return;\n      }\n      this.isSubmitting = true;\n      try {\n        const response = await API.post(\"/auth/login\", {\n          email: this.form.email,\n          password: this.form.password\n        });\n        localStorage.setItem(\"auth_token\", response.data.token);\n        localStorage.setItem(\"auth_user\", JSON.stringify(response.data.user));\n        this.$router.push(\"/dashboard\");\n      } catch (error) {\n        this.errorMessage = error.response?.data?.message || \"Unable to sign in with those credentials.\";\n      } finally {\n        this.isSubmitting = false;\n      }\n    }\n  }\n};","map":{"version":3,"mappings":";AA+HE,OAAOA,GAAE,MAAO,gBAAgB;AAEhC,eAAe;EACbC,IAAI,EAAE,WAAW;EACjBC,IAAIA,GAAG;IACL,OAAO;MACLC,IAAI,EAAE;QACJC,KAAK,EAAE,EAAE;QACTC,QAAQ,EAAE,EAAE;QACZC,QAAQ,EAAE;MACZ,CAAC;MACDC,YAAY,EAAE,KAAK;MACnBC,YAAY,EAAE,KAAK;MACnBC,YAAY,EAAE;IAChB,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACP,MAAMC,WAAWA,GAAG;MAClB,IAAI,CAACF,YAAW,GAAI,EAAE;MACtB,IAAI,CAAC,IAAI,CAACN,IAAI,CAACC,KAAI,IAAK,CAAC,IAAI,CAACD,IAAI,CAACE,QAAQ,EAAE;QAC3C,IAAI,CAACI,YAAW,GAAI,iDAAiD;QACrE;MACF;MACA,IAAI,CAACD,YAAW,GAAI,IAAI;MACxB,IAAI;QACF,MAAMI,QAAO,GAAI,MAAMZ,GAAG,CAACa,IAAI,CAAC,aAAa,EAAE;UAC7CT,KAAK,EAAE,IAAI,CAACD,IAAI,CAACC,KAAK;UACtBC,QAAQ,EAAE,IAAI,CAACF,IAAI,CAACE;QACtB,CAAC,CAAC;QACFS,YAAY,CAACC,OAAO,CAAC,YAAY,EAAEH,QAAQ,CAACV,IAAI,CAACc,KAAK,CAAC;QACvDF,YAAY,CAACC,OAAO,CAAC,WAAW,EAAEE,I