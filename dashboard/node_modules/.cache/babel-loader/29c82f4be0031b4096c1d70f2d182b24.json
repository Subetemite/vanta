{"ast":null,"code":"import { Icon } from \"@iconify/vue\";\nimport API from \"@/services/api\";\nfunction emptyForm() {\n  return {\n    subCategory: \"\",\n    title: \"\",\n    referenceNo: \"\",\n    leadAgency: \"\",\n    status: \"open\",\n    priority: \"normal\",\n    description: \"\"\n  };\n}\nexport default {\n  name: \"EntryFormModal\",\n  components: {\n    Icon\n  },\n  props: {\n    open: {\n      type: Boolean,\n      default: false\n    },\n    category: {\n      type: String,\n      required: true\n    },\n    contextLabel: {\n      type: String,\n      default: \"Case Monitoring\"\n    },\n    categoryOptions: {\n      type: Array,\n      required: true\n    },\n    defaultSubCategory: {\n      type: String,\n      default: \"\"\n    }\n  },\n  emits: [\"close\", \"saved\"],\n  data() {\n    return {\n      form: emptyForm(),\n      file: null,\n      previewUrl: \"\",\n      uploadedFile: null,\n      scanStatus: \"idle\",\n      scanError: \"\",\n      isDragging: false,\n      submitting: false,\n      submitError: \"\"\n    };\n  },\n  computed: {\n    canSubmit() {\n      return !this.submitting && this.form.title.trim() && this.form.subCategory;\n    }\n  },\n  watch: {\n    open(value) {\n      if (value) this.reset();\n    }\n  },\n  methods: {\n    reset() {\n      this.form = emptyForm();\n      this.form.subCategory = this.defaultSubCategory || this.categoryOptions[0]?.key || \"\";\n      this.clearFile();\n      this.submitting = false;\n      this.submitError = \"\";\n    },\n    close() {\n      if (this.submitting) return;\n      this.$emit(\"close\");\n    },\n    formatBytes(bytes) {\n      if (!bytes) return \"0 B\";\n      const units = [\"B\", \"KB\", \"MB\", \"GB\"];\n      const i = Math.floor(Math.log(bytes) / Math.log(1024));\n      return `${(bytes / Math.pow(1024, i)).toFixed(1)} ${units[i]}`;\n    },\n    clearFile() {\n      if (this.previewUrl) URL.revokeObjectURL(this.previewUrl);\n      this.file = null;\n      this.previewUrl = \"\";\n      this.uploadedFile = null;\n      this.scanStatus = \"idle\";\n      this.scanError = \"\";\n      if (this.$refs.fileInput) this.$refs.fileInput.value = \"\";\n      if (this.$refs.cameraInput) this.$refs.cameraInput.value = \"\";\n    },\n    onFilePicked(event) {\n      const file = event.target.files?.[0];\n      if (file) this.handleFile(file);\n    },\n    onDrop(event) {\n      this.isDragging = false;\n      const file = event.dataTransfer?.files?.[0];\n      if (file) this.handleFile(file);\n    },\n    async handleFile(file) {\n      if (file.size > 5 * 1024 * 1024) {\n        this.scanStatus = \"failed\";\n        this.scanError = \"File exceeds 5 MB limit.\";\n        return;\n      }\n      this.file = file;\n      this.previewUrl = file.type.startsWith(\"image/\") ? URL.createObjectURL(file) : \"\";\n      await this.scanFile(file);\n    },\n    async scanFile(file) {\n      this.scanStatus = \"scanning\";\n      this.scanError = \"\";\n      try {\n        const base64 = await this.toBase64(file);\n        const res = await API.post(\"/files\", {\n          fileName: file.name,\n          mimeType: file.type,\n          contentBase64: base64\n        });\n        this.uploadedFile = res.data?.file || null;\n        const extracted = this.uploadedFile?.extractedTextPreview || \"\";\n        if (extracted) {\n          this.form.description = this.form.description ? `${this.form.description}\\n\\n${extracted}` : extracted;\n        }\n        this.scanStatus = this.uploadedFile?.extractionStatus === \"failed\" ? \"failed\" : \"completed\";\n        if (this.scanStatus === \"failed\") {\n          this.scanError = this.uploadedFile?.extractionError || \"OCR failed\";\n        }\n      } catch (err) {\n        this.scanStatus = \"failed\";\n        this.scanError = err.response?.data?.message || \"Unable to scan the document.\";\n      }\n    },\n    toBase64(file) {\n      return new Promise((resolve, reject) => {\n        const reader = new FileReader();\n        reader.onload = () => {\n          const dataUrl = reader.result;\n          resolve(String(dataUrl).split(\",\")[1] || \"\");\n        };\n        reader.onerror = () => reject(reader.error);\n        reader.readAsDataURL(file);\n      });\n    },\n    async submit() {\n      if (!this.canSubmit) return;\n      this.submitting = true;\n      this.submitError = \"\";\n      try {\n        const payload = {\n          ...this.form,\n          attachments: this.uploadedFile ? [{\n            fileName: this.uploadedFile.originalName,\n            fileUrl: this.uploadedFile.url,\n            mimeType: this.uploadedFile.mimeType,\n            size: this.uploadedFile.size\n          }] : []\n        };\n        const res = await API.post(`/cases/entries/${this.category}`, payload);\n        this.$emit(\"saved\", res.data?.entry);\n        this.$emit(\"close\");\n      } catch (err) {\n        this.submitError = err.response?.data?.message || \"Unable to save the entry.\";\n      } finally {\n        this.submitting = false;\n      }\n    }\n  },\n  beforeUnmount() {\n    if (this.previewUrl) URL.revokeObjectURL(this.previewUrl);\n  }\n};","map":{"version":3,"mappings":"AA4ME,SAASA,IAAG,QAAS,cAAc;AACnC,OAAOC,GAAE,MAAO,gBAAgB;AAEhC,SAASC,SAASA,GAAG;EACnB,OAAO;IACLC,WAAW,EAAE,EAAE;IACfC,KAAK,EAAE,EAAE;IACTC,WAAW,EAAE,EAAE;IACfC,UAAU,EAAE,EAAE;IACdC,MAAM,EAAE,MAAM;IACdC,QAAQ,EAAE,QAAQ;IAClBC,WAAW,EAAE;EACf,CAAC;AACH;AAEA,eAAe;EACbC,IAAI,EAAE,gBAAgB;EACtBC,UAAU,EAAE;IAAEX;EAAK,CAAC;EACpBY,KAAK,EAAE;IACLC,IAAI,EAAE;MAAEC,IAAI,EAAEC,OAAO;MAAEC,OAAO,EAAE;IAAM,CAAC;IACvCC,QAAQ,EAAE;MAAEH,IAAI,EAAEI,MAAM;MAAEC,QAAQ,EAAE;IAAK,CAAC;IAC1CC,YAAY,EAAE;MAAEN,IAAI,EAAEI,MAAM;MAAEF,OAAO,EAAE;IAAkB,CAAC;IAC1DK,eAAe,EAAE;MAAEP,IAAI,EAAEQ,KAAK;MAAEH,QAAQ,EAAE;IAAK,CAAC;IAChDI,kBAAkB,EAAE;MAAET,IAAI,EAAEI,MAAM;MAAEF,OAAO,EAAE;IAAG;EAClD,CAAC;EACDQ,KAAK,EAAE,CAAC,OAAO,EAAE,OAAO,CAAC;EACzBC,IAAIA,GAAG;IACL,OAAO;MACLC,IAAI,EAAExB,SAAS,CAAC,CAAC;MACjByB,IAAI,EAAE