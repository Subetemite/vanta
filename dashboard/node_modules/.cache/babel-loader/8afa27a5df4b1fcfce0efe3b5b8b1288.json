st res = await API.get(\"/cases/entries/focus-operations\");\n        this.entries = Array.isArray(res.data) ? res.data : [];\n      } catch (err) {\n        this.error = err.response?.data?.message || \"Unable to load focus operations.\";\n      } finally {\n        this.loading = false;\n      }\n    },\n    openCreate() {\n      // TODO: wire to entry-create modal/route once form is built\n    }\n  },\n  mounted() {\n    this.load();\n  }\n};","map":{"version":3,"mappings":";;;AA8GE,SAASA,IAAG,QAAS,cAAc;AACnC,OAAOC,GAAE,MAAO,gBAAgB;AAChC,OAAOC,cAAa,MAAO,iCAAiC;AAE5D,MAAMC,WAAU,GAAI,CAClB;EAAEC,GAAG,EAAE,mBAAmB;EAAEC,GAAG,EAAE,IAAI;EAAEC,KAAK,EAAE,mBAAmB;EAAEC,QAAQ,EAAE,uCAAuC;EAAEC,IAAI,EAAE;AAAyB,CAAC,EACtJ;EAAEJ,GAAG,EAAE,WAAW;EAAEC,GAAG,EAAE,IAAI;EAAEC,KAAK,EAAE,WAAW;EAAEC,QAAQ,EAAE,sCAAsC;EAAEC,IAAI,EAAE;AAA4B,CAAC,EACxI;EAAEJ,GAAG,EAAE,kBAAkB;EAAEC,GAAG,EAAE,IAAI;EAAEC,KAAK,EAAE,kBAAkB;EAAEC,QAAQ,EAAE,qCAAqC;EAAEC,IAAI,EAAE;AAA4B,CAAC,EACrJ;EAAEJ,GAAG,EAAE,kBAAkB;EAAEC,GAAG,EAAE,IAAI;EAAEC,KAAK,EAAE,oBAAoB;EAAEC,QAAQ,EAAE,2BAA2B;EAAEC,IAAI,EAAE;AAAoB,CAAC,CACtI;AAED,eAAe;EACbC,IAAI,EAAE,iBAAiB;EACvBC,UAAU,EAAE;IAAEV,IAAI;IAAEE;EAAe,CAAC;EACpCS,IAAIA,GAAG;IACL,OAAO;MACLC,UAAU,EAAET,WAAW;MACvBU,WAAW,EAAEV,WAAW,CAAC,CAAC,CAAC,CAACC,GAAG;MAC/BU,OAAO,EAAE,EAAE;MACXC,OAAO,EAAE,KAAK;MACdC,KAAK,EAAE,EAAE;MACTC,SAAS,EAAE;IACb,CAAC;EACH,CAAC;EACDC,QAAQ,EAAE;IACRC,gBAAgBA,GAAG;MACjB,OAAO,IAAI,CAACP,UAAU,CAACQ,IAAI,CAAEC,CAAC,IAAKA,CAAC,CAACjB,GAAE,KAAM,IAAI,CAACS,WAAW,CAAC,EAAEP,KAAI,IAAK,EAAE;IAC7E,CAAC;IACDgB,eAAeA,GAAG;MAChB,OAAO,IAAI,CAACR,OAAO,CAACS,MAAM,CAAEC,CAAC,IAAKA,CAAC,CAACC,WAAU,KAAM,IAAI,CAACZ,WAAW,CAAC;IACvE;EACF,CAAC;EACDa,OAAO,EAAE;IACPC,QAAQA,CAACvB,GAAG,EAAE;MACZ,OAAO,IAAI,CAACU,OAAO,CAACS,MAAM,CAAEC,CAAC,IAAKA,CAAC,CAACC,WAAU,KAAMrB,GAAG,CAAC,CAACwB,MAAM;IACjE,CAAC;IACDC,UAAUA,CAACC,CAAC,EAAE;MACZ,IAAI,CAACA,CAAC,EAAE,OAAO,GAAG;MAClB,OAAO,IAAIC,IAAI,CAACD,CAAC,CAAC,CAACE,kBAAkB,CAAC,OAAO,EAAE;QAAEC,KAAK,EAAE,OAAO;QAAEC,GAAG,EAAE,SAAS;QAAEC,IAAI,EAAE