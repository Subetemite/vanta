{"ast":null,"code":"import \"core-js/modules/es.json.stringify.js\";\nimport \"core-js/modules/esnext.iterator.constructor.js\";\nimport \"core-js/modules/esnext.iterator.filter.js\";\nimport { Icon } from \"@iconify/vue\";\nimport API from \"@/services/api\";\nexport default {\n  name: \"MyProfile\",\n  components: {\n    Icon\n  },\n  data() {\n    return {\n      user: {\n        id: \"\",\n        username: \"\",\n        email: \"\",\n        role: \"\",\n        modulePermissions: {}\n      },\n      form: {\n        username: \"\",\n        email: \"\"\n      },\n      original: {\n        username: \"\",\n        email: \"\"\n      },\n      profileSaving: false,\n      profileMessage: {\n        text: \"\",\n        type: \"success\"\n      },\n      pwForm: {\n        current: \"\",\n        next: \"\",\n        confirm: \"\"\n      },\n      pwSaving: false,\n      pwMessage: {\n        text: \"\",\n        type: \"success\"\n      }\n    };\n  },\n  computed: {\n    activeModules() {\n      const mp = this.user.modulePermissions || {};\n      return Object.keys(mp).filter(k => mp[k]);\n    },\n    profileChanged() {\n      return this.form.username !== this.original.username || this.form.email !== this.original.email;\n    },\n    pwReady() {\n      return this.pwForm.current.length > 0 && this.pwForm.next.length >= 6 && this.pwForm.next === this.pwForm.confirm;\n    }\n  },\n  methods: {\n    async loadProfile() {\n      try {\n        const res = await API.get(\"/auth/me\");\n        const u = res.data?.user || {};\n        this.user = u;\n        this.form.username = u.username || \"\";\n        this.form.email = u.email || \"\";\n        this.original = {\n          ...this.form\n        };\n      } catch (err) {\n        this.profileMessage = {\n          type: \"error\",\n          text: err.response?.data?.message || \"Unable to load profile.\"\n        };\n      }\n    },\n    resetProfile() {\n      this.form = {\n        ...this.original\n      };\n      this.profileMessage = {\n        text: \"\",\n        type: \"success\"\n      };\n    },\n    async saveProfile() {\n      if (!this.profileChanged || this.profileSaving) return;\n      this.profileSaving = true;\n      this.profileMessage = {\n        text: \"\",\n        type: \"success\"\n      };\n      try {\n        const res = await API.put(\"/auth/me\", {\n          username: this.form.username,\n          email: this.form.email\n        });\n        const u = res.data?.user || {};\n        this.user = u;\n        this.form.username = u.username || \"\";\n        this.form.email = u.email || \"\";\n        this.original = {\n          ...this.form\n        };\n        localStorage.setItem(\"auth_user\", JSON.stringify(u));\n        this.profileMessage = {\n          type: \"success\",\n          text: \"Profile updated.\"\n        };\n      } catch (err) {\n        this.profileMessage = {\n          type: \"error\",\n          text: err.response?.data?.message || \"Unable to update profile.\"\n        };\n      } finally {\n        this.profileSaving = false;\n      }\n    },\n    async changePassword() {\n      if (!this.pwReady || this.pwSaving) return;\n      if (this.pwForm.next !== this.pwForm.confirm) {\n        this.pwMessage = {\n          type: \"error\",\n          text: \"New passwords do not match.\"\n        };\n        return;\n      }\n      this.pwSaving = true;\n      this.pwMessage = {\n        text: \"\",\n        type: \"success\"\n      };\n      try {\n        await API.post(\"/auth/me/password\", {\n          currentPassword: this.pwForm.current,\n          newPassword: this.pwForm.next\n        });\n        this.pwForm = {\n          current: \"\",\n          next: \"\",\n          confirm: \"\"\n        };\n        this.pwMessage = {\n          type: \"success\",\n          text: \"Password updated successfully.\"\n        };\n      } catch (err) {\n        this.pwMessage = {\n          type: \"error\",\n          text: err.response?.data?.message || \"Unable to change password.\"\n        };\n      } finally {\n        this.pwSaving = false;\n      }\n    }\n  },\n  mounted() {\n    this.loadProfile();\n  }\n};","map":{"version":3,"mappings":";;;AAmIE,SAASA,IAAG,QAAS,cAAc;AACnC,OAAOC,GAAE,MAAO,gBAAgB;AAEhC,eAAe;EACbC,IAAI,EAAE,WAAW;EACjBC,UAAU,EAAE;IAAEH;EAAK,CAAC;EACpBI,IAAIA,GAAG;IACL,OAAO;MACLC,IAAI,EAAE;QAAEC,EAAE,EAAE,EAAE;QAAEC,QAAQ,EAAE,EAAE;QAAEC,KAAK,EAAE,EAAE;QAAEC,IAAI,EAAE,EAAE;QAAEC,iBAAiB,EAAE,CAAC;MAAE,CAAC;MAC1EC,IAAI,EAAE;QAAEJ,QAAQ,EAAE,EAAE;QAAEC,KAAK,EAAE;MAAG,CAAC;MACjCI,QAAQ,EAAE;QAAEL,QAAQ,EAAE,EAAE;QAAEC,KAAK,EAAE;MAAG,CAAC;MACrCK,aAAa,EAAE,KAAK;MACpBC,cAAc,EAAE;QAAEC,IAAI,EAAE,EAAE;QAAEC,IAAI,EAAE;MAAU,CAAC;MAC7CC,MAAM,EAAE;QAAEC,OAAO,EAAE,EAAE;QAAEC,IAAI,EAAE,EAAE;QAAEC,OAAO,EAAE;MAAG,CAAC;MAC9CC,QAAQ,EAAE,KAAK;MACfC,SAAS,EAAE;QAAEP,IAAI,EAAE,EAAE;QAAEC,IAAI,EAAE;MAAU;IACzC,CAAC;EACH,CAAC;EACDO,QAAQ,EAAE;IACRC,aAAaA,GAAG;MACd,MAAMC,EAAC,GAAI,IAAI,CAACpB,IAAI,CAACK,iBAAgB,IAAK,CAAC,CAAC;MAC5C,OAAOgB,MAAM,CAACC,IAAI,CAACF,EAAE,CAAC,CAACG,MAAM,CAAEC,CAAC,IAAKJ,EAAE,CAACI,CAAC,CAAC,CAAC;IAC7C,CAAC;IACDC,cAAcA,GAAG;MACf,OAAO,IAAI,CAACnB,IAAI,CAACJ,QAAO,KAAM,IAAI,CAACK,QAAQ,CAACL,QAAO,IAAK,IAAI,CAACI,IAAI,CAACH,KAAI,KAAM,IAAI,CAACI,QAAQ,CAACJ,KAAK;IACjG,CAAC;IACDuB,OAAOA,GAAG;MACR,OACE,IAAI,CAACd,MAAM,CAACC,OAAO,CAACc,MAAK,GAAI,KAC7B,IAAI,CAACf,MAAM,CAACE,IAAI,CAACa,MAAK,IAAK,KAC3B,IAAI,CAACf,MAAM,CAACE,IAAG,KAAM,IAAI,CAACF,MAAM,CAACG,OAAM;IAE3C;EACF,CAAC;EACDa,OAAO,EAAE;IACP,MAAMC,WAAWA,GAAG;MAClB,IAAI;QACF,MAAMC,GAAE,GAAI,MAAMlC,GAAG,CAACmC,GAAG,CAAC,UAAU,CAAC;QACrC,MAAMC,IAAIF,GAAG,CAAC/B,IAAI,EAAEC,IAAG,IAAK,CAAC,CAAC;QAC9B,IAAI,CAACA,IAAG,GAAIgC,CAAC;QACb,IAAI,CAAC1B,IAAI,CAACJ,QAAO,GAAI8B,CAAC,CAAC9B,QAAO,IAAK,EAAE;QACrC,IAAI,CAACI,IAAI,CAACH,KAAI,GAAI6B,CAAC,CAAC7B,KAAI,IAAK,EAAE;QAC/B,IAAI,CAACI,QAAO,GAAI;UAAE,GAAG,IAAI,CAACD;QAAK,CAAC;MAClC,EAAE,OAAO2B,GAAG,EAAE;QACZ,IAAI,CAACxB,cAAa,GAAI;UAAEE,IAAI,EAAE,OAAO;UAAED,IAAI,EAAEuB,GAAG,CAACC,QAAQ,EAAEnC,IAA