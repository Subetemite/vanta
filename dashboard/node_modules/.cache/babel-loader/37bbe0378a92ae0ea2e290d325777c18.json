{"ast":null,"code":"import { Icon } from \"@iconify/vue\";\nimport API from \"@/services/api\";\nimport ConfirmationDialog from \"@/components/ConfirmationDialog.vue\";\nimport { createConfirmationDialogState, resolveConfirmation } from \"@/helper/record-confirmation\";\nexport default {\n  name: \"AdminHris\",\n  components: {\n    Icon,\n    ConfirmationDialog\n  },\n  data() {\n    return {\n      employees: [],\n      search: \"\",\n      searchTimer: null,\n      isLoading: false,\n      errorMessage: \"\",\n      deletingId: \"\",\n      confirmationDialog: createConfirmationDialogState(),\n      confirmationResolver: null\n    };\n  },\n  methods: {\n    openConfirmationDialog({\n      title,\n      description,\n      confirmText\n    }) {\n      this.confirmationDialog = {\n        visible: true,\n        title,\n        description,\n        confirmText\n      };\n      return new Promise(resolve => {\n        this.confirmationResolver = resolve;\n      });\n    },\n    closeConfirmationDialog(confirmed) {\n      this.confirmationDialog = createConfirmationDialogState();\n      resolveConfirmation(this.confirmationResolver, confirmed);\n      this.confirmationResolver = null;\n    },\n    async loadEmployees() {\n      this.isLoading = true;\n      this.errorMessage = \"\";\n      try {\n        const path = this.search.trim() ? `/admin/hris/employees?q=${encodeURIComponent(this.search.trim())}` : \"/admin/hris/employees\";\n        const res = await API.get(path);\n        this.employees = Array.isArray(res.data?.employees) ? res.data.employees : [];\n      } catch (err) {\n        this.errorMessage = err.response?.data?.message || \"Unable to load employees.\";\n      } finally {\n        this.isLoading = false;\n      }\n    },\n    onSearchInput() {\n      clearTimeout(this.searchTimer);\n      this.searchTimer = setTimeout(() => this.loadEmployees(), 300);\n    },\n    async confirmDelete(employee) {\n      const confirmed = await this.openConfirmationDialog({\n        title: \"Delete employee?\",\n        description: `Employee \"${employee.fullName}\" (${employee.employeeId}) and ALL related documents will be permanently removed. This cannot be undone.`,\n        confirmText: \"Yes, delete\"\n      });\n      if (!confirmed) return;\n      this.deletingId = employee.id;\n      try {\n        await API.delete(`/admin/hris/employees/${employee.id}`);\n        await this.loadEmployees();\n      } catch (err) {\n        this.errorMessage = err.response?.data?.message || \"Unable to delete employee.\";\n      } finally {\n        this.deletingId = \"\";\n      }\n    },\n    statusBadgeClass(status) {\n      const map = {\n        Active: \"bg-emerald-500/15 text-emerald-300\",\n        \"On Leave\": \"bg-amber-500/15 text-amber-300\",\n        Resigned: \"bg-gray-500/15 text-gray-300\",\n        Retired: \"bg-blue-500/15 text-blue-300\",\n        Terminated: \"bg-red-500/15 text-red-300\"\n      };\n      return map[status] || \"bg-gray-500/15 text-gray-300\";\n    },\n    initialsFor(employee) {\n      const a = (employee?.firstName || \" \").charAt(0);\n      const b = (employee?.lastName || \" \").charAt(0);\n      const initials = `${a}${b}`.trim().toUpperCase();\n      return initials || \"?\";\n    }\n  },\n  mounted() {\n    this.loadEmployees();\n  },\n  beforeUnmount() {\n    clearTimeout(this.searchTimer);\n  }\n};","map":{"version":3,"mappings":"AAmIE,SAASA,IAAG,QAAS,cAAc;AACnC,OAAOC,GAAE,MAAO,gBAAgB;AAChC,OAAOC,kBAAiB,MAAO,qCAAqC;AACpE,SACEC,6BAA6B,EAC7BC,mBAAmB,QACd,8BAA8B;AAErC,eAAe;EACbC,IAAI,EAAE,WAAW;EACjBC,UAAU,EAAE;IAAEN,IAAI;IAAEE;EAAmB,CAAC;EACxCK,IAAIA,GAAG;IACL,OAAO;MACLC,SAAS,EAAE,EAAE;MACbC,MAAM,EAAE,EAAE;MACVC,WAAW,EAAE,IAAI;MACjBC,SAAS,EAAE,KAAK;MAChBC,YAAY,EAAE,EAAE;MAChBC,UAAU,EAAE,EAAE;MACdC,kBAAkB,EAAEX,6BAA6B,CAAC,CAAC;MACnDY,oBAAoB,EAAE;IACxB,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACPC,sBAAsBA,CAAC;MAAEC,KAAK;MAAEC,WAAW;MAAEC;IAAY,CAAC,EAAE;MAC1D,IAAI,CAACN,kBAAiB,GAAI;QAAEO,OAAO,EAAE,IAAI;QAAEH,KAAK;QAAEC,WAAW;QAAEC;MAAY,CAAC;MAC5E,OAAO,IAAIE,OAAO,CAAEC,OAAO,IAAK;QAC9B,IAAI,CAACR,oBAAmB,GAAIQ,OAAO;MACrC,CAAC,CAAC;IACJ,CAAC;IACDC,uBAAuBA,CAACC,SAAS,EAAE;MACjC,IAAI,CAACX,kBAAiB,GAAIX,6BAA6B,CAAC,CAAC;MACzDC,mBAAmB,CAAC,IAAI,CAACW,oBAAoB,EAAEU,SAAS,CAAC;MACzD,IAAI,CAACV,oBAAmB,GAAI,IAAI;IAClC,CAAC;IACD,MAAMW,aAAaA,GAAG;MACpB,IAAI,CAACf,SAAQ,GAAI,IAAI;MACrB,IAAI,CAACC,YAAW,GAAI,EAAE;MACtB,IAAI;QACF,MAAMe,IAAG,GAAI,IAAI,CAAClB,MAAM,CAACmB,IAAI,CAAC,IAC1B,2BAA2BC,kBAAkB,CAAC,IAAI,CAACpB,MAAM,CAACmB,IAAI,CAAC,CAAC,CAAC,EAAC,GAClE,uBAAuB;QAC3B,MAAME,GAAE,GAAI,MAAM7B,GAAG,CAAC8B,GAAG,CAACJ,IAAI,CAAC;QAC/B,IAAI,CAACnB,SAAQ,GAAIwB,KAAK,CAACC,OAAO,CAACH,GAAG,CAACvB,IAAI,EAAEC,SAAS,IAAIsB,GAAG,CAACvB,IAAI,CAACC,SAAQ,GAAI,EAAE;MAC/E,EAAE,OAAO0B,GAAG,EAAE;QACZ,IAAI,CAACtB,YAAW,GAAIsB,GAAG,CAACC,QAAQ,EAAE5B,IAAI,EAAE6B,OAAM,IAAK,2BAA2B;MAChF,UAAU;QACR,IAAI,CAACzB,SAAQ,GAAI,KAAK;MACxB;IACF,CAAC;IACD0B,aAAaA,GAAG;MACdC,YAAY,CAAC,IAAI,CAAC5B,WAAW,CAAC;MAC9B,IAAI,CAACA,WAAU,GAAI6B,UAAU,CAAC,MAAM,IAAI,CAACb,aAAa,CAAC,CAAC,EAAE,GAAG,CAAC;IAChE,CAAC;IACD,MAAMc,aAAaA,CAACC,QAAQ,EAAE;MAC5B,MAAMhB,SAAQ,GAAI,MAAM,IAAI,CAACR,sBAAsB,CAAC;QAClDC,KAAK,EAAE,kBAAkB;QACzBC,WAAW,EAAE,aAAasB,QAAQ,CAACC,QAAQ,MAAMD,QAAQ,CAACE,UAAU,iFAAiF;QACrJvB,WAAW,EAAE;MACf,CAAC,CAAC;MACF,IAAI,CAACK,SAAS,EAAE;MAChB,IAAI,CAACZ,UAAS,GAAI4B,QAAQ,CAACG,EAAE;MAC7B,IAAI;QACF,MAAM3C,GAAG,CAAC4C,MAAM,CAAC,yBAAyBJ,QAAQ,CAACG,EAAE,EAAE,CAAC;QACxD,MAAM,IAAI,CAAClB,aAAa,CAAC,CAAC;MAC5B,EAAE,OAAOQ,GAAG,EAAE;QACZ,IAAI,CAACtB,YAAW,GAAIsB,GAAG,CAACC,QAAQ,EAAE5B,IAAI,EAAE6B,OAAM,IAAK,4BAA4B;MACjF,UAAU;QACR,IAAI,CAACvB,UAAS,GAAI,EAAE;MACtB;IACF,CAAC;IACDiC,gBAAgBA,CAACC,MAAM,EAAE;MACvB,MAAMC,GAAE,GAAI;QACVC,MAAM,EAAE,oCAAoC;QAC5C,UAAU,EAAE,gCAAgC;QAC5CC,QAAQ,EAAE,8BAA8B;QACxCC,OAAO,EAAE,8BAA8B;QACvCC,UAAU,EAAE;MACd,CAAC;MACD,OAAOJ,GAAG,CAACD,MAAM,KAAK,8BAA8B;IACtD,CAAC;IACDM,WAAWA,CAACZ,QAAQ,EAAE;MACpB,MAAMa,IAAI,CAACb,QAAQ,EAAEc,SAAQ,IAAK,GAAG,EAAEC,MAAM,CAAC,CAAC,CAAC;MAChD,MAAMC,IAAI,CAAChB,QAAQ,EAAEiB,QAAO,IAAK,GAAG,EAAEF,MAAM,CAAC,CAAC,CAAC;MAC/C,MAAMG,QAAO,GAAI,GAAGL,CAAC,GAAGG,CAAC,EAAE,CAAC7B,IAAI,CAAC,CAAC,CAACgC,WAAW,CAAC,CAAC;MAChD,OAAOD,QAAO,IAAK,GAAG;IACxB;EACF,CAAC;EACDE,OAAOA,GAAG;IACR,IAAI,CAACnC,aAAa,CAAC,CAAC;EACtB,CAAC;EACDoC,aAAaA,GAAG;IACdxB,YAAY,CAAC,IAAI,CAAC5B,WAAW,CAAC;EAChC;AACF,CAAC","names":["Icon","API","ConfirmationDialog","createConfirmationDialogState","resolveConfirmation","name","components","data","employees","search","searchTimer","isLoading","errorMessage","deletingId","confirmationDialog","confirmationResolver","methods","openConfirmationDialog","title","description","confirmText","visible","Promise","resolve","closeConfirmationDialog","confirmed","loadEmployees","path","trim","encodeURIComponent","res","get","Array","isArray","err","response","message","onSearchInput","clearTimeout","setTimeout","confirmDelete","employee","fullName","employeeId","id","delete","statusBadgeClass","status","map","Active","Resigned","Retired","Terminated","initialsFor","a","firstName","charAt","b","lastName","initials","toUpperCase","mounted","beforeUnmount"],"sourceRoot":"","sources":["D:\\joremiodotonline\\dashboard\\src\\views\\admin\\hris\\Hris.vue"],"sourcesContent":["<template>\n  <div class=\"min-h-screen bg-case-bg px-6 py-8 sm:px-10 lg:px-12\">\n    <header class=\"mb-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between\">\n      <div>\n        <p class=\"text-xs uppercase tracking-[0.35em] text-primary\">ADMIN / HRIS</p>\n        <h1 class=\"mt-2 text-2xl font-semibold text-white\">Personnel</h1>\n        <p class=\"mt-1 text-sm text-gray-500\">Employee profiles and 201 file documents.</p>\n      </div>\n      <button\n        v-if=\"canEdit\"\n        type=\"button\"\n        class=\"rounded-xl bg-primary px-4 py-2 text-sm font-semibold text-black transition hover:bg-amber-500\"\n        @click=\"$router.push('/admin/hris/new')\"\n      >\n        + Add Employee\n      </button>\n      <span v-else class=\"rounded-full border border-case-border bg-case-elevated px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.2em] text-gray-500\">\n        Read-only\n      </span>\n    </header>\n\n    <div class=\"mb-5 flex items-center rounded-xl border border-case-border bg-case-surface px-3 py-2\">\n      <Icon icon=\"mdi:magnify\" class=\"text-lg text-gray-500\" />\n      <input\n        v-model=\"search\"\n        type=\"search\"\n        placeholder=\"Search by employee ID, name, position, department...\"\n        class=\"w-full bg-transparent px-2 py-1 text-sm text-gray-200 outline-none placeholder:text-gray-600\"\n        @input=\"onSearchInput\"\n      />\n    </div>\n\n    <div v-if=\"errorMessage\" class=\"mb-3 rounded-2xl border border-red-900/50 bg-red-950/30 px-4 py-3 text-sm text-red-400\">\n      {{ errorMessage }}\n    </div>\n\n    <div class=\"overflow-hidden rounded-2xl border border-case-border bg-case-surface\">\n      <table class=\"w-full text-left text-sm\">\n        <thead class=\"bg-case-elevated text-xs uppercase tracking-[0.2em] text-gray-500\">\n          <tr>\n            <th class=\"px-4 py-3 font-medium w-14\"></th>\n            <th class=\"px-4 py-3 font-medium\">Employee ID</th>\n            <th class=\"px-4 py-3 font-medium\">Full Name</th>\n            <th class=\"px-4 py-3 font-medium\">Position</th>\n            <th class=\"px-4 py-3 font-medium\">Department</th>\n            <th class=\"px-4 py-3 font-medium\">Status</th>\n            <th class=\"px-4 py-3 font-medium\">Docs</th>\n            <th class=\"px-4 py-3 text-right font-medium\">Actions</th>\n          </tr>\n        </thead>\n        <tbody class=\"divide-y divide-case-border text-gray-300\">\n          <tr v-if=\"isLoading\">\n            <td colspan=\"8\" class=\"px-4 py-6 text-center text-gray-500\">Loading employees...</td>\n          </tr>\n          <tr v-else-if=\"!employees.length\">\n            <td colspan=\"8\" class=\"px-4 py-6 text-center text-gray-500\">No employees yet.</td>\n          </tr>\n          <tr\n            v-for=\"employee in employees\"\n            :key=\"employee.id\"\n            class=\"hover:bg-case-card transition-colors cursor-pointer\"\n            @click=\"$router.push(`/admin/hris/${employee.id}`)\"\n          >\n            <td class=\"px-4 py-3\">\n              <div class=\"h-10 w-10 overflow-hidden rounded-full border border-case-border bg-primary/15\">\n                <img\n                  v-if=\"employee.profilePicture?.url\"\n                  :src=\"employee.profilePicture.url\"\n                  :alt=\"employee.fullName\"\n                  class=\"h-full w-full object-cover\"\n                />\n                <div v-else class=\"flex h-full w-full items-center justify-center text-xs font-semibold text-primary\">\n                  {{ initialsFor(employee) }}\n                </div>\n              </div>\n            </td>\n            <td class=\"px-4 py-3 font-medium text-white tabular-nums\">{{ employee.employeeId }}</td>\n            <td class=\"px-4 py-3\">{{ employee.fullName }}</td>\n            <td class=\"px-4 py-3 text-gray-400\">{{ employee.position || '—' }}</td>\n            <td class=\"px-4 py-3 text-gray-400\">{{ employee.department || '—' }}</td>\n            <td class=\"px-4 py-3\">\n              <span :class=\"statusBadgeClass(employee.status)\" class=\"rounded-full px-2 py-1 text-[10px] font-semibold uppercase tracking-[0.15em]\">\n                {{ employee.status }}\n              </span>\n            </td>\n            <td class=\"px-4 py-3 text-gray-400 tabular-nums\">{{ employee.documentCount }}</td>\n            <td class=\"px-4 py-3 text-right\" @click.stop>\n              <div class=\"inline-flex items-center gap-1\">\n                <button\n                  type=\"button\"\n                  class=\"rounded-md bg-primary/10 px-3 py-1 text-xs font-semibold text-primary transition hover:bg-primary/20\"\n                  @click=\"$router.push(`/admin/hris/${employee.id}`)\"\n                >\n                  View\n                </button>\n                <button\n                  v-if=\"canEdit\"\n                  type=\"button\"\n                  class=\"rounded-md bg-blue-500/10 px-3 py-1 text-xs font-semibold text-blue-300 transition hover:bg-blue-500/20\"\n                  @click=\"$router.push(`/admin/hris/${employee.id}/edit`)\"\n                >\n                  Edit\n                </button>\n                <button\n                  v-if=\"canEdit\"\n                  type=\"button\"\n                  class=\"rounded-md bg-red-500/10 px-3 py-1 text-xs font-semibold text-red-400 transition hover:bg-red-500/20 disabled:cursor-not-allowed disabled:opacity-50\"\n                  :disabled=\"deletingId === employee.id\"\n                  @click=\"confirmDelete(employee)\"\n                >\n                  {{ deletingId === employee.id ? \"…\" : \"Delete\" }}\n                </button>\n              </div>\n            </td>\n          </tr>\n        </tbody>\n      </table>\n    </div>\n\n    <ConfirmationDialog\n      :visible=\"confirmationDialog.visible\"\n      :title=\"confirmationDialog.title\"\n      :description=\"confirmationDialog.description\"\n      :confirm-text=\"confirmationDialog.confirmText\"\n      @cancel=\"closeConfirmationDialog(false)\"\n      @confirm=\"closeConfirmationDialog(true)\"\n    />\n  </div>\n</template>\n\n<script>\n  import { Icon } from \"@iconify/vue\";\n  import API from \"@/services/api\";\n  import ConfirmationDialog from \"@/components/ConfirmationDialog.vue\";\n  import {\n    createConfirmationDialogState,\n    resolveConfirmation,\n  } from \"@/helper/record-confirmation\";\n\n  export default {\n    name: \"AdminHris\",\n    components: { Icon, ConfirmationDialog },\n    data() {\n      return {\n        employees: [],\n        search: \"\",\n        searchTimer: null,\n        isLoading: false,\n        errorMessage: \"\",\n        deletingId: \"\",\n        confirmationDialog: createConfirmationDialogState(),\n        confirmationResolver: null,\n      };\n    },\n    methods: {\n      openConfirmationDialog({ title, description, confirmText }) {\n        this.confirmationDialog = { visible: true, title, description, confirmText };\n        return new Promise((resolve) => {\n          this.confirmationResolver = resolve;\n        });\n      },\n      closeConfirmationDialog(confirmed) {\n        this.confirmationDialog = createConfirmationDialogState();\n        resolveConfirmation(this.confirmationResolver, confirmed);\n        this.confirmationResolver = null;\n      },\n      async loadEmployees() {\n        this.isLoading = true;\n        this.errorMessage = \"\";\n        try {\n          const path = this.search.trim()\n            ? `/admin/hris/employees?q=${encodeURIComponent(this.search.trim())}`\n            : \"/admin/hris/employees\";\n          const res = await API.get(path);\n          this.employees = Array.isArray(res.data?.employees) ? res.data.employees : [];\n        } catch (err) {\n          this.errorMessage = err.response?.data?.message || \"Unable to load employees.\";\n        } finally {\n          this.isLoading = false;\n        }\n      },\n      onSearchInput() {\n        clearTimeout(this.searchTimer);\n        this.searchTimer = setTimeout(() => this.loadEmployees(), 300);\n      },\n      async confirmDelete(employee) {\n        const confirmed = await this.openConfirmationDialog({\n          title: \"Delete employee?\",\n          description: `Employee \"${employee.fullName}\" (${employee.employeeId}) and ALL related documents will be permanently removed. This cannot be undone.`,\n          confirmText: \"Yes, delete\",\n        });\n        if (!confirmed) return;\n        this.deletingId = employee.id;\n        try {\n          await API.delete(`/admin/hris/employees/${employee.id}`);\n          await this.loadEmployees();\n        } catch (err) {\n          this.errorMessage = err.response?.data?.message || \"Unable to delete employee.\";\n        } finally {\n          this.deletingId = \"\";\n        }\n      },\n      statusBadgeClass(status) {\n        const map = {\n          Active: \"bg-emerald-500/15 text-emerald-300\",\n          \"On Leave\": \"bg-amber-500/15 text-amber-300\",\n          Resigned: \"bg-gray-500/15 text-gray-300\",\n          Retired: \"bg-blue-500/15 text-blue-300\",\n          Terminated: \"bg-red-500/15 text-red-300\",\n        };\n        return map[status] || \"bg-gray-500/15 text-gray-300\";\n      },\n      initialsFor(employee) {\n        const a = (employee?.firstName || \" \").charAt(0);\n        const b = (employee?.lastName || \" \").charAt(0);\n        const initials = `${a}${b}`.trim().toUpperCase();\n        return initials || \"?\";\n      },\n    },\n    mounted() {\n      this.loadEmployees();\n    },\n    beforeUnmount() {\n      clearTimeout(this.searchTimer);\n    },\n  };\n</script>\n"]},"metadata":{},"sourceType":"module"}