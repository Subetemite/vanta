.employeeId || \"\");\n      this.close();\n    },\n    syncEmployeeId() {\n      const match = this.options.find(o => o.label === this.modelValue);\n      const id = match ? match.employeeId || \"\" : \"\";\n      if (id !== this.employeeId) {\n        this.$emit(\"update:employeeId\", id);\n      }\n    },\n    moveHighlight(delta) {\n      if (!this.open) {\n        this.open = true;\n        return;\n      }\n      const len = this.filteredOptions.length;\n      if (!len) return;\n      this.highlight = (this.highlight + delta + len) % len;\n    },\n    commitHighlight() {\n      if (this.open && this.highlight >= 0 && this.filteredOptions[this.highlight]) {\n        this.select(this.filteredOptions[this.highlight]);\n      } else {\n        this.close();\n      }\n    },\n    close() {\n      this.open = false;\n      this.highlight = -1;\n    }\n  }\n};","map":{"version":3,"mappings":";;;AA+DE,SAASA,IAAG,QAAS,cAAc;AAEnC,MAAMC,YAAW,GAAI;EACnBC,WAAWA,CAACC,EAAE,EAAEC,OAAO,EAAE;IACvBD,EAAE,CAACE,aAAY,GAAKC,KAAK,IAAK;MAC5B,IAAI,EAAEH,EAAC,KAAMG,KAAK,CAACC,MAAK,IAAKJ,EAAE,CAACK,QAAQ,CAACF,KAAK,CAACC,MAAM,CAAC,CAAC,EAAE;QACvDH,OAAO,CAACK,KAAK,CAACH,KAAK,CAAC;MACtB;IACF,CAAC;IACDI,QAAQ,CAACC,gBAAgB,CAAC,WAAW,EAAER,EAAE,CAACE,aAAa,CAAC;EAC1D,CAAC;EACDO,SAASA,CAACT,EAAE,EAAE;IACZO,QAAQ,CAACG,mBAAmB,CAAC,WAAW,EAAEV,EAAE,CAACE,aAAa,CAAC;EAC7D;AACF,CAAC;AAED,eAAe;EACbS,IAAI,EAAE,kBAAkB;EACxBC,UAAU,EAAE;IAAEf;EAAK,CAAC;EACpBgB,UAAU,EAAE;IAAEf;EAAa,CAAC;EAC5BgB,KAAK,EAAE;IACLC,UAAU,EAAE;MAAEC,IAAI,EAAEC,MAAM;MAAEC,OAAO,EAAE;IAAG,CAAC;IACzCC,UAAU,EAAE;MAAEH,IAAI,EAAEC,MAAM;MAAEC,OAAO,EAAE;IAAG,CAAC;IACzCE,OAAO,EAAE;MAAEJ,IAAI,EAAEK,KAAK;MAAEH,OAAO,EAAEA,MAAM;IAAG,CAAC;IAC3CI,WAAW,EAAE;MAAEN,IAAI,EAAEC,MAAM;MAAEC,OAAO,EAAE;IAAkB;EAC1D,CAAC;EACDK,KAAK,EAAE,CAAC,mBAAmB,EAAE,mBAAmB,EAAE,OAAO,CAAC;EAC1DC,IAAIA,GAAG;IACL,OAAO;MACLC,IAAI,EAAE,KAAK;MACXC,SAAS,EAAE,CAAC;IACd,CAAC;EACH,CAAC;EACDC,QAAQ,EAAE;IACRC,eAAeA,GAAG;MAChB,MAAMC,IAAIZ,MAAM,CAAC,IAAI,CAACF,UAAS,IAAK,EAAE,CAAC,CAA