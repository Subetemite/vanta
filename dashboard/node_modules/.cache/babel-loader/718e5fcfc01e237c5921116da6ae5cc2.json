C;MACtB,MAAMC,SAAQ,GAAIL,KAAK,CAACM,qBAAqB,CAAC,CAAC;MAC/C,IAAI,CAAClG,gBAAe,GAAI;QACtBmG,EAAE,EAAE7F,MAAM,CAACC,GAAG;QACdwD,KAAK,EAAEgC,QAAQ,CAAChC,KAAI,IAAKgC,QAAQ,CAAC/B,IAAI;QACtCC,MAAM,EAAE8B,QAAQ,CAAC9B,MAAK,IAAK8B,QAAQ,CAAC/B,IAAI;QACxCoC,OAAO,EACLT,KAAK,CAACU,OAAM,GAAIJ,SAAS,CAACnC,IAAG,GAC5BwC,UAAU,CAACP,QAAQ,CAACjC,IAAI,IAAI,GAAG,GAAImC,SAAS,CAAClC,KAAK;QACrDwC,OAAO,EACLZ,KAAK,CAACa,OAAM,GAAIP,SAAS,CAACpC,GAAE,GAC3ByC,UAAU,CAACP,QAAQ,CAAClC,GAAG,IAAI,GAAG,GAAIoC,SAAS,CAAChC;MACjD,CAAC;IACH,CAAC;IACDwC,gBAAgBA,CAACd,KAAK,EAAE;MACtB,MAAMC,KAAI,GAAI,IAAI,CAACC,KAAK,CAACC,WAAW;MACpC,MAAMY,IAAG,GAAI,IAAI,CAAC1G,gBAAgB;MAClC,IAAI,CAAC4F,KAAI,IAAK,CAACc,IAAI,EAAE;MACrB,MAAMT,SAAQ,GAAIL,KAAK,CAACM,qBAAqB,CAAC,CAAC;MAC/C,MAAMS,IAAG,GAAI5B,IAAI,CAAC6B,GAAG,CAACX,SAAS,CAAClC,KAAI,GAAI2C,IAAI,CAAC3C,KAAK,EAAE,CAAC,CAAC;MACtD,MAAM8C,IAAG,GAAI9B,IAAI,CAAC6B,GAAG,CAACX,SAAS,CAAChC,MAAK,GAAIyC,IAAI,CAACzC,MAAM,EAAE,CAAC,CAAC;MACxD,MAAM6C,KAAI,GAAI/B,IAAI,CAACgC,GAAG,CAAChC,IAAI,CAAC6B,GAAG,CAACjB,KAAK,CAACU,OAAM,GAAIJ,SAAS,CAACnC,IAAG,GAAI4C,IAAI,CAACN,OAAO,EAAE,CAAC,CAAC,EAAEO,IAAI,CAAC;MACxF,MAAMK,KAAI,GAAIjC,IAAI,CAACgC,GAAG,CAAChC,IAAI,CAAC6B,GAAG,CAACjB,KAAK,CAACa,OAAM,GAAIP,SAAS,CAACpC,GAAE,GAAI6C,IAAI,CAACH,OAAO,EAAE,CAAC,CAAC,EAAEM,IAAI,CAAC;MACvF,IAAI,CAAC9G,eAAc,GAAI;QACrB,GAAG,IAAI,CAACA,eAAe;QACvB,CAAC2G,IAAI,CAACP,EAAE,GAAG;UACTtC,GAAG,EAAE,GAAImD,KAAI,GAAIf,SAAS,CAAChC,MAAM,GAAI,GAAG,GAAG;UAC3CH,IAAI,EAAE,GAAIgD,KAAI,GAAIb,SAAS,CAAClC,KAAK,GAAI,GAAG,GAAG;UAC3CA,KAAK,EAAE2C,IAAI,CAAC3C,KAAK;UACjBE,MAAM,EAAEyC,IAAI,CAACzC;QACf;MACF,CAAC;IACH,CAAC;IACDgD,cAAcA,GAAG;MACf,IAAI,CAACjH,gBAAe,GAAI,IAAI;IAC9B,CAAC;IACDkH,gBAAgBA,CAACC,QAAQ,EAAE;MACzB,OAAO,IAAI,CAACnH,gBAAgB,EAAEmG,EAAC,KAAMgB,QAAQ;IAC/C;EACF,CAAC;EACDC,OAAOA,GAAG;IACRC,MAAM,CAACC,gBAAgB,CAAC,aAAa,EAAE,IAAI,CAACb,gBAAgB,CAAC;IAC7DY,MAAM,CAACC,gBAAgB,CAAC,WAAW,EAAE,IAAI,CAACL,cAAc,CAAC;IACzD,IAAI,CAAC/E,iBAAiB,CAAC,CAAC;EAC1B,CAAC;EACDqF,aAAaA,GAAG;IACdF,MAAM,CAACG,mBAAmB,CAAC,aAAa,EAAE,IAAI,CAACf,gBAAgB,CAAC;IAChEY,MAAM,CAACG,mBAAmB,CAAC,WAAW,EAAE,IAAI,CAACP,cAAc,CAAC;EAC9D;AACF,CAAC","names":["Icon","API","name","data","recentRecords","recentRecordsSearch","isLoadingRecords","recordsError","bubblePositions","activeBubbleDrag","selectedBubbleRecordId","bubbleDisplayLimit","computed","selectedBubbleRecord","find","record","_id","filteredRecentRecords","query","trim","toLowerCase","filter","info","personalInformation","operation","operationDetails","firstName","middleName","lastName","alias","operationName","Boolean","some","value","includes","bubbleRecords","slice","selectedRecord","remainingRecords","linkedOperationRecords","recordOperation","components","methods","loadRecentRecords","response","get","Array","isArray","initializeBubblePositions","error","message","formatRecordName","join","getRecordInitials","map","charAt","formatRecordMeta","createdAt","Date","toLocaleDateString","formatRecordCreatedAt","formatOperationDate","operationDate","getBubbleSubtitle","getLinkedRecordSummary","nationality","getBubbleStyle","index","bubble","getBubbleConfig","top","left","width","size","height","animationDelay","animationDuration","focusLayout","fallback","getGeneratedBubbleLayout","isSelectedState","sizePattern","columns","columnGap","rowGap","baseLeft","baseTop","row","Math","floor","col","length","leftOffset","topOffset","nextPositions","forEach","existingPosition","selectRecordForBubble","$nextTick","startBubbleDrag","event","board","$refs","bubbleBoard","position","preventDefault","boardRect","getBoundingClientRect","id","offsetX","clientX","parseFloat","offsetY","clientY","handleBubbleDrag","drag","maxX","max","maxY","nextX","min","nextY","stopBubbleDrag","isBubbleDragging","recordId","mounted","window","addEventListener","beforeUnmount","removeEventListener"],"sourceRoot":"","sources":["D:\\joremiodotonline\\dashboard\\src\\views\\Dashboard.vue"],"sourcesContent":["<template>\n  <div class=\"dashboard p-4\">\n    <div class=\"mt-2 w-full\">\n      <div class=\"lg:flex grid-cols-1 lg:space-y-0 space-y-3 gap-5 justify-between\">\n        <div class=\"flex gap-2\">\n          <button\n            class=\"bg-primary border-0 flex gap-2 text-black font-semibold hover:bg-amber-500 rounded py-3 px-5 transition-colors\"\n          >\n            <span class=\"icon text-2xl\"><Icon icon=\"ic:twotone-plus\" /></span>\n            <span class=\"text\"> Create New Report</span>\n          </button>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"mt-4 lg:flex block lg:gap-2 relative\">\n      <div class=\"bg-case-surface lg:w-3/4 w-full rounded-md border border-case-border overflow-hidden\">\n        <div class=\"p-5 flex justify-between items-center border-b border-case-border\">\n          <div>\n            <h2 class=\"text-base font-semibold text-white\">Subject Board</h2>\n            <p class=\"text-xs text-gray-600 mt-0.5\">Drag to reposition — click a subject to expand</p>\n          </div>\n          <span class=\"rounded-full bg-amber-900/30 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-primary\">\n            {{ bubbleRecords.length }} subjects\n          </span>\n        </div>\n\n        <div class=\"px-5 pb-5 pt-4\">\n          <div\n            v-if=\"isLoadingRecords\"\n            class=\"flex h-[500px] items-center justify-center rounded-2xl bg-case-card text-sm text-gray-600\"\n          >\n            Loading subject board...\n          </div>\n          <div\n            v-else-if=\"recordsError\"\n            class=\"flex h-[500px] items-center justify-center rounded-2xl bg-red-950/20 px-6 text-sm text-red-500\"\n          >\n            {{ recordsError }}\n          </div>\n          <div\n            v-else-if=\"!bubbleRecords.length\"\n            class=\"flex h-[500px] items-center justify-center rounded-2xl bg-case-card text-sm text-gray-600\"\n          >\n            No registered subjects yet.\n          </div>\n          <div\n            v-else\n            ref=\"bubbleBoard\"\n            class=\"relative h-[500px] overflow-hidden rounded-2xl border border-amber-900/20 bg-[radial-gradient(circle_at_50%_40%,_rgba(217,119,6,0.07),_transparent_30%),linear-gradient(145deg,_#0d0f12_0%,_#111318_60%,_#0d0f12_100%)]\"\n          >\n            <div class=\"pointer-events-none absolute inset-0\">\n              <div class=\"absolute left-1/2 top-1/2 h-[320px] w-[320px] -translate-x-1/2 -translate-y-1/2 rounded-full border border-amber-800/10\"></div>\n              <div class=\"absolute left-1/2 top-1/2 h-[440px] w-[440px] -translate-x-1/2 -translate-y-1/2 rounded-full border border-amber-800/7\"></div>\n            </div>\n            <div\n              v-for=\"(record, index) in bubbleRecords\"\n              :key=\"record._id\"\n              class=\"absolute flex cursor-grab select-none border text-center shadow-lg backdrop-blur-sm transition-[transform,box-shadow] duration-300 active:cursor-grabbing\"\n              :class=\"[\n                record._id === selectedBubbleRecordId\n                  ? 'z-20 flex-col overflow-hidden rounded-[3rem] border-amber-700/40 bg-case-card shadow-2xl shadow-amber-500/10 ring-2 ring-amber-700/25'\n                  : 'z-10 flex-col items-center justify-center rounded-full border-amber-800/25 bg-case-card/90 shadow-black/30 hover:scale-[1.02]',\n                record._id === selectedBubbleRecordId\n                  ? 'bubble-static'\n                  : !isBubbleDragging(record._id)\n                    ? 'bubble-float'\n                    : 'bubble-dragging',\n              ]\"\n              :style=\"getBubbleStyle(index)\"\n              @pointerdown=\"startBubbleDrag($event, record, index)\"\n            >\n              <template v-if=\"record._id === selectedBubbleRecordId\">\n                <div class=\"flex h-[50%] w-full items-center justify-center overflow-hidden bg-case-elevated px-5 py-5\">\n                  <img\n                    v-if=\"record.profilePhoto?.dataUrl\"\n                    :src=\"record.profilePhoto.dataUrl\"\n                    :alt=\"formatRecordName(record)\"\n                    class=\"h-full max-h-full w-full rounded-[1.75rem] object-cover object-top shadow-lg shadow-black/40\"\n                  />\n                  <div\n                    v-else\n                    class=\"flex h-full w-full items-center justify-center rounded-[1.75rem] bg-case-bg text-5xl font-semibold uppercase text-gray-500\"\n                  >\n                    {{ getRecordInitials(record) }}\n                  </div>\n                </div>\n                <div class=\"flex h-[50%] w-full flex-col justify-between px-6 py-5 text-left\">\n                  <div>\n                    <p class=\"text-[11px] font-semibold uppercase tracking-[0.26em] text-primary/80\">\n                      {{ getBubbleSubtitle(record) }}\n                    </p>\n                    <h3 class=\"mt-2 text-xl font-semibold leading-6 text-white\">\n                      {{ formatRecordName(record) }}\n                    </h3>\n                    <p class=\"mt-1 text-sm text-gray-500\">\n                      {{ formatRecordMeta(record) }}\n                    </p>\n                  </div>\n                  <div class=\"grid grid-cols-2 gap-3 text-sm\">\n                    <div class=\"rounded-2xl bg-case-elevated px-3 py-2\">\n                      <p class=\"text-[10px] uppercase tracking-[0.2em] text-gray-600\">Alias</p>\n                      <p class=\"mt-1 truncate font-medium text-gray-200\">\n                        {{ record.personalInformation?.alias || \"None\" }}\n                      </p>\n                    </div>\n                    <div class=\"rounded-2xl bg-case-elevated px-3 py-2\">\n                      <p class=\"text-[10px] uppercase tracking-[0.2em] text-gray-600\">Sex</p>\n                      <p class=\"mt-1 truncate font-medium text-gray-200\">\n                        {{ record.personalInformation?.sex || \"N/A\" }}\n                      </p>\n                    </div>\n                    <div class=\"rounded-2xl bg-case-elevated px-3 py-2\">\n                      <p class=\"text-[10px] uppercase tracking-[0.2em] text-gray-600\">Nationality</p>\n                      <p class=\"mt-1 truncate font-medium text-gray-200\">\n                        {{ record.personalInformation?.nationality || \"N/A\" }}\n                      </p>\n                    </div>\n                    <div class=\"rounded-2xl bg-case-elevated px-3 py-2\">\n                      <p class=\"text-[10px] uppercase tracking-[0.2em] text-gray-600\">Date Added</p>\n                      <p class=\"mt-1 truncate font-medium text-gray-200\">\n                        {{ formatRecordCreatedAt(record) }}\n                      </p>\n                    </div>\n                  </div>\n                </div>\n              </template>\n              <template v-else>\n                <img\n                  v-if=\"record.profilePhoto?.dataUrl\"\n                  :src=\"record.profilePhoto.dataUrl\"\n                  :alt=\"formatRecordName(record)\"\n                  class=\"mb-2 h-12 w-12 rounded-full object-cover ring-2 ring-amber-800/30\"\n                />\n                <div\n                  v-else\n                  class=\"mb-2 flex h-12 w-12 items-center justify-center rounded-full bg-case-elevated text-xs font-semibold uppercase text-gray-500 ring-2 ring-amber-800/20\"\n                >\n                  {{ getRecordInitials(record) }}\n                </div>\n                <p class=\"max-w-[90%] overflow-hidden text-ellipsis whitespace-nowrap text-xs font-semibold leading-4 text-gray-300\">\n                  {{ formatRecordName(record) }}\n                </p>\n              </template>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"wrapper-button p-5 flex justify-between items-center border-t border-case-border\">\n          <select\n            class=\"bg-case-elevated border border-case-border px-4 py-3 block rounded-md text-gray-400 focus:outline-none focus:border-primary\"\n          >\n            <option value=\"\">Last 3 years</option>\n          </select>\n          <button class=\"uppercase border-b border-red-700 text-red-500 text-sm tracking-wider hover:text-red-400 transition-colors\">\n            Crime Report\n          </button>\n        </div>\n      </div>\n\n      <div class=\"bg-case-surface p-5 lg:mt-0 mt-4 lg:w-2/4 border border-case-border rounded-md w-full\">\n        <div class=\"\">\n          <h2 class=\"text-lg font-semibold text-white\">RECENT REGISTRATIONS</h2>\n          <p class=\"text-gray-600 text-sm mt-0.5\">Latest records from the registration form</p>\n        </div>\n        <div class=\"mt-4\">\n          <label class=\"relative block\">\n            <span class=\"pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3 text-gray-600\">\n              <Icon icon=\"ic:round-search\" class=\"text-lg\" />\n            </span>\n            <input\n              v-model.trim=\"recentRecordsSearch\"\n              type=\"text\"\n              placeholder=\"Search registrations...\"\n              class=\"w-full rounded-md border border-case-border bg-case-card py-3 pl-10 pr-4 text-sm text-gray-200 outline-none transition placeholder:text-gray-600 focus:border-primary focus:ring-2 focus:ring-primary/10\"\n            />\n          </label>\n        </div>\n        <perfect-scrollbar class=\"divide-y divide-case-border h-96 mt-5\">\n          <div\n            v-if=\"isLoadingRecords\"\n            class=\"p-4 text-sm text-gray-600\"\n          >\n            Loading recent registrations...\n          </div>\n          <div\n            v-else-if=\"recordsError\"\n            class=\"p-4 text-sm text-red-500\"\n          >\n            {{ recordsError }}\n          </div>\n          <div\n            v-else-if=\"!filteredRecentRecords.length\"\n            class=\"p-4 text-sm text-gray-600\"\n          >\n            {{\n              recentRecordsSearch\n                ? \"No registrations matched your search.\"\n                : \"No registrations found yet.\"\n            }}\n          </div>\n          <button\n            v-for=\"record in filteredRecentRecords\"\n            :key=\"record._id\"\n            type=\"button\"\n            class=\"w-full p-3 text-left transition\"\n            :class=\"record._id === selectedBubbleRecordId ? 'bg-amber-900/20' : 'hover:bg-case-card'\"\n            @click=\"selectRecordForBubble(record)\"\n          >\n            <div class=\"flex gap-5\">\n              <div>\n                <img\n                  v-if=\"record.profilePhoto?.dataUrl\"\n                  class=\"h-14 w-14 rounded-md object-cover\"\n                  :src=\"record.profilePhoto.dataUrl\"\n                  :alt=\"formatRecordName(record)\"\n                />\n                <div\n                  v-else\n                  class=\"flex h-14 w-14 items-center justify-center rounded-md bg-case-elevated text-sm font-semibold uppercase text-gray-500\"\n                >\n                  {{ getRecordInitials(record) }}\n                </div>\n              </div>\n              <div class=\"mt-1 min-w-0\">\n                <h2 class=\"truncate text-gray-200\">{{ formatRecordName(record) }}</h2>\n                <p class=\"truncate text-sm text-gray-600\">{{ formatRecordMeta(record) }}</p>\n              </div>\n            </div>\n          </button>\n        </perfect-scrollbar>\n      </div>\n    </div>\n\n    <div class=\"mt-4 bg-case-surface p-5 w-full rounded-md border border-case-border\">\n      <h2 class=\"font-bold text-lg text-white\">Operation Details</h2>\n      <p class=\"text-gray-600 font-lexend font-normal text-sm mt-0.5\">\n        Linked records for the currently selected subject\n      </p>\n      <div\n        v-if=\"!selectedBubbleRecord\"\n        class=\"mt-6 rounded-2xl bg-case-card px-6 py-10 text-sm text-gray-600\"\n      >\n        Select a subject to view operation details and linked people.\n      </div>\n      <div v-else class=\"mt-6 grid gap-5 lg:grid-cols-[1.2fr_1fr]\">\n        <div class=\"rounded-[1.75rem] border border-case-border bg-case-card p-5\">\n          <div class=\"grid gap-4 md:grid-cols-2\">\n            <div class=\"rounded-2xl bg-case-elevated px-4 py-4\">\n              <p class=\"text-[11px] uppercase tracking-[0.22em] text-gray-600\">Operation Name</p>\n              <p class=\"mt-2 text-base font-semibold text-gray-100\">\n                {{ selectedBubbleRecord.operationDetails?.operationName || \"No operation assigned\" }}\n              </p>\n            </div>\n            <div class=\"rounded-2xl bg-case-elevated px-4 py-4\">\n              <p class=\"text-[11px] uppercase tracking-[0.22em] text-gray-600\">Operation Date</p>\n              <p class=\"mt-2 text-base font-semibold text-gray-100\">\n                {{ formatOperationDate(selectedBubbleRecord) }}\n              </p>\n            </div>\n            <div class=\"rounded-2xl bg-case-elevated px-4 py-4 md:col-span-2\">\n              <p class=\"text-[11px] uppercase tracking-[0.22em] text-gray-600\">Operation Address</p>\n              <p class=\"mt-2 text-base font-semibold text-gray-100\">\n                {{ selectedBubbleRecord.operationDetails?.operationAddress || \"No address available\" }}\n              </p>\n            </div>\n            <div class=\"rounded-2xl bg-case-elevated px-4 py-4\">\n              <p class=\"text-[11px] uppercase tracking-[0.22em] text-gray-600\">Disposition</p>\n              <p class=\"mt-2 text-base font-semibold text-gray-100\">\n                {{ selectedBubbleRecord.operationDetails?.disposition || \"No disposition\" }}\n              </p>\n            </div>\n            <div class=\"rounded-2xl bg-case-elevated px-4 py-4\">\n              <p class=\"text-[11px] uppercase tracking-[0.22em] text-gray-600\">Visa Status</p>\n              <p class=\"mt-2 text-base font-semibold text-gray-100\">\n                {{ selectedBubbleRecord.operationDetails?.visaStatus || \"No visa status\" }}\n              </p>\n            </div>\n            <div class=\"rounded-2xl bg-case-elevated px-4 py-4 md:col-span-2\">\n              <p class=\"text-[11px] uppercase tracking-[0.22em] text-gray-600\">Remarks</p>\n              <p class=\"mt-2 text-sm leading-6 text-gray-400\">\n                {{ selectedBubbleRecord.operationDetails?.remarks || \"No remarks available.\" }}\n              </p>\n            </div>\n          </div>\n        </div>\n        <div class=\"rounded-[1.75rem] border border-case-border bg-case-card p-5\">\n          <div class=\"flex items-center justify-between\">\n            <div>\n              <h3 class=\"text-base font-semibold text-gray-100\">Linked People</h3>\n              <p class=\"text-sm text-gray-600\">\n                People under the same operation as the selected record\n              </p>\n            </div>\n            <span class=\"rounded-full bg-amber-900/30 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-primary\">\n              {{ linkedOperationRecords.length }}\n            </span>\n          </div>\n          <div\n            v-if=\"!linkedOperationRecords.length\"\n            class=\"mt-5 rounded-2xl bg-case-elevated px-4 py-8 text-sm text-gray-600\"\n          >\n            No linked people found for this operation yet.\n          </div>\n          <div v-else class=\"mt-5 space-y-3\">\n            <button\n              v-for=\"record in linkedOperationRecords\"\n              :key=\"record._id\"\n              type=\"button\"\n              class=\"flex w-full items-center gap-4 rounded-2xl border border-case-border bg-case-elevated px-4 py-3 text-left transition hover:border-amber-700/40 hover:bg-amber-900/10\"\n              @click=\"selectRecordForBubble(record)\"\n            >\n              <img\n                v-if=\"record.profilePhoto?.dataUrl\"\n                class=\"h-12 w-12 rounded-xl object-cover\"\n                :src=\"record.profilePhoto.dataUrl\"\n                :alt=\"formatRecordName(record)\"\n              />\n              <div\n                v-else\n                class=\"flex h-12 w-12 items-center justify-center rounded-xl bg-case-bg text-sm font-semibold uppercase text-gray-500\"\n              >\n                {{ getRecordInitials(record) }}\n              </div>\n              <div class=\"min-w-0 flex-1\">\n                <p class=\"truncate font-semibold text-gray-100\">\n                  {{ formatRecordName(record) }}\n                </p>\n                <p class=\"truncate text-sm text-gray-500\">\n                  {{ getLinkedRecordSummary(record) }}\n                </p>\n              </div>\n            </button>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\n  import { Icon } from \"@iconify/vue\";\n  import API from \"@/services/api\";\n\n  export default {\n    name: \"Dashboard\",\n    data() {\n      return {\n        recentRecords: [],\n        recentRecordsSearch: \"\",\n        isLoadingRecords: false,\n        recordsError: \"\",\n        bubblePositions: {},\n        activeBubbleDrag: null,\n        selectedBubbleRecordId: \"\",\n        bubbleDisplayLimit: 31,\n      };\n    },\n    computed: {\n      selectedBubbleRecord() {\n        return (\n          this.recentRecords.find(\n            (record) => record._id === this.selectedBubbleRecordId\n          ) || null\n        );\n      },\n      filteredRecentRecords() {\n        const query = this.recentRecordsSearch.trim().toLowerCase();\n        if (!query) return this.recentRecords;\n        return this.recentRecords.filter((record) => {\n          const info = record.personalInformation || {};\n          const operation = record.operationDetails || {};\n          return [\n            info.firstName, info.middleName, info.lastName,\n            info.alias, operation.operationName,\n          ]\n            .filter(Boolean)\n            .some((value) => value.toLowerCase().includes(query));\n        });\n      },\n      bubbleRecords() {\n        if (!this.selectedBubbleRecordId) {\n          return this.recentRecords.slice(0, this.bubbleDisplayLimit);\n        }\n        const selectedRecord = this.recentRecords.find(\n          (record) => record._id === this.selectedBubbleRecordId\n        );\n        const remainingRecords = this.recentRecords.filter(\n          (record) => record._id !== this.selectedBubbleRecordId\n        );\n        return [selectedRecord, ...remainingRecords]\n          .filter(Boolean)\n          .slice(0, this.bubbleDisplayLimit);\n      },\n      linkedOperationRecords() {\n        const operationName =\n          this.selectedBubbleRecord?.operationDetails?.operationName?.trim();\n        if (!operationName) return [];\n        return this.recentRecords.filter((record) => {\n          const recordOperation = record.operationDetails?.operationName?.trim();\n          return (\n            record._id !== this.selectedBubbleRecordId &&\n            recordOperation === operationName\n          );\n        });\n      },\n    },\n    components: {\n      Icon,\n    },\n    methods: {\n      async loadRecentRecords() {\n        this.isLoadingRecords = true;\n        this.recordsError = \"\";\n        try {\n          const response = await API.get(\"/records\");\n          this.recentRecords = Array.isArray(response.data) ? response.data : [];\n          this.selectedBubbleRecordId =\n            this.selectedBubbleRecordId &&\n            this.recentRecords.some(\n              (record) => record._id === this.selectedBubbleRecordId\n            )\n              ? this.selectedBubbleRecordId\n              : this.recentRecords[0]?._id || \"\";\n          this.initializeBubblePositions();\n        } catch (error) {\n          this.recordsError =\n            error.response?.data?.message ||\n            \"Unable to load recent registrations.\";\n        } finally {\n          this.isLoadingRecords = false;\n        }\n      },\n      formatRecordName(record) {\n        const info = record.personalInformation || {};\n        return [info.firstName, info.middleName, info.lastName]\n          .filter(Boolean)\n          .join(\" \");\n      },\n      getRecordInitials(record) {\n        const info = record.personalInformation || {};\n        return (\n          [info.firstName, info.lastName]\n            .filter(Boolean)\n            .map((value) => value.charAt(0))\n            .join(\"\")\n            .slice(0, 2) || \"NA\"\n        );\n      },\n      formatRecordMeta(record) {\n        const info = record.personalInformation || {};\n        const operation = record.operationDetails || {};\n        const createdAt = record.createdAt\n          ? new Date(record.createdAt).toLocaleDateString()\n          : \"No date\";\n        return [\n          info.alias ? `Alias: ${info.alias}` : null,\n          operation.operationName || null,\n          createdAt,\n        ]\n          .filter(Boolean)\n          .join(\" | \");\n      },\n      formatRecordCreatedAt(record) {\n        return record.createdAt\n          ? new Date(record.createdAt).toLocaleDateString()\n          : \"No date\";\n      },\n      formatOperationDate(record) {\n        const value = record?.operationDetails?.operationDate;\n        return value ? new Date(value).toLocaleDateString() : \"No operation date\";\n      },\n      getBubbleSubtitle(record) {\n        const operation = record.operationDetails || {};\n        return operation.operationName || \"Recent registration\";\n      },\n      getLinkedRecordSummary(record) {\n        const info = record.personalInformation || {};\n        return [\n          info.alias ? `Alias: ${info.alias}` : null,\n          info.nationality || null,\n          this.formatRecordCreatedAt(record),\n        ]\n          .filter(Boolean)\n          .join(\" | \");\n      },\n      getBubbleStyle(index) {\n        const bubble = this.getBubbleConfig(index);\n        return {\n          top: bubble.top,\n          left: bubble.left,\n          width: `${bubble.width || bubble.size}px`,\n          height: `${bubble.height || bubble.size}px`,\n          animationDelay: `${index * 0.8}s`,\n          animationDuration: `${6 + index * 0.6}s`,\n        };\n      },\n      getBubbleConfig(index) {\n        const focusLayout = { top: \"6%\", left: \"56%\", width: 320, height: 430 };\n        const fallback = { top: \"35%\", left: \"40%\", size: 110 };\n        if (this.selectedBubbleRecordId && index === 0) return focusLayout;\n        if (this.selectedBubbleRecordId) {\n          return this.getGeneratedBubbleLayout(index - 1, true) || fallback;\n        }\n        return this.getGeneratedBubbleLayout(index, false) || fallback;\n      },\n      getGeneratedBubbleLayout(index, isSelectedState) {\n        const sizePattern = isSelectedState ? [78, 70, 74, 68, 72] : [82, 76, 80, 72, 78, 74];\n        const columns = isSelectedState ? 4 : 6;\n        const columnGap = isSelectedState ? 11.5 : 14;\n        const rowGap = isSelectedState ? 12.5 : 14;\n        const baseLeft = isSelectedState ? 3 : 5;\n        const baseTop = isSelectedState ? 6 : 5;\n        const row = Math.floor(index / columns);\n        const col = index % columns;\n        const size = sizePattern[index % sizePattern.length];\n        const leftOffset = row % 2 === 0 ? 0 : isSelectedState ? 4.5 : 3.5;\n        const topOffset = isSelectedState\n          ? [0, 3, 1, 4][col % 4]\n          : col % 2 === 0 ? 0 : 2;\n        return {\n          top: `${baseTop + row * rowGap + topOffset}%`,\n          left: `${baseLeft + col * columnGap + leftOffset}%`,\n          size,\n        };\n      },\n      initializeBubblePositions() {\n        const nextPositions = {};\n        this.bubbleRecords.forEach((record, index) => {\n          const existingPosition = this.bubblePositions[record._id];\n          nextPositions[record._id] = existingPosition || this.getBubbleConfig(index);\n        });\n        this.bubblePositions = nextPositions;\n      },\n      selectRecordForBubble(record) {\n        this.selectedBubbleRecordId = record._id;\n        this.$nextTick(() => { this.initializeBubblePositions(); });\n      },\n      startBubbleDrag(event, record, index) {\n        const board = this.$refs.bubbleBoard;\n        const position = this.bubblePositions[record._id] || this.getBubbleConfig(index);\n        if (!board) return;\n        event.preventDefault();\n        const boardRect = board.getBoundingClientRect();\n        this.activeBubbleDrag = {\n          id: record._id,\n          width: position.width || position.size,\n          height: position.height || position.size,\n          offsetX:\n            event.clientX - boardRect.left -\n            (parseFloat(position.left) / 100) * boardRect.width,\n          offsetY:\n            event.clientY - boardRect.top -\n            (parseFloat(position.top) / 100) * boardRect.height,\n        };\n      },\n      handleBubbleDrag(event) {\n        const board = this.$refs.bubbleBoard;\n        const drag = this.activeBubbleDrag;\n        if (!board || !drag) return;\n        const boardRect = board.getBoundingClientRect();\n        const maxX = Math.max(boardRect.width - drag.width, 0);\n        const maxY = Math.max(boardRect.height - drag.height, 0);\n        const nextX = Math.min(Math.max(event.clientX - boardRect.left - drag.offsetX, 0), maxX);\n        const nextY = Math.min(Math.max(event.clientY - boardRect.top - drag.offsetY, 0), maxY);\n        this.bubblePositions = {\n          ...this.bubblePositions,\n          [drag.id]: {\n            top: `${(nextY / boardRect.height) * 100}%`,\n            left: `${(nextX / boardRect.width) * 100}%`,\n            width: drag.width,\n            height: drag.height,\n          },\n        };\n      },\n      stopBubbleDrag() {\n        this.activeBubbleDrag = null;\n      },\n      isBubbleDragging(recordId) {\n        return this.activeBubbleDrag?.id === recordId;\n      },\n    },\n    mounted() {\n      window.addEventListener(\"pointermove\", this.handleBubbleDrag);\n      window.addEventListener(\"pointerup\", this.stopBubbleDrag);\n      this.loadRecentRecords();\n    },\n    beforeUnmount() {\n      window.removeEventListener(\"pointermove\", this.handleBubbleDrag);\n      window.removeEventListener(\"pointerup\", this.stopBubbleDrag);\n    },\n  };\n</script>\n\n<style scoped>\n.bubble-float {\n  animation-name: bubbleFloat;\n  animation-timing-function: ease-in-out;\n  animation-iteration-count: infinite;\n}\n\n.bubble-dragging {\n  animation: none;\n}\n\n.bubble-static {\n  animation: none;\n}\n\n@keyframes bubbleFloat {\n  0%   { transform: translate3d(0, 0, 0); }\n  25%  { transform: translate3d(8px, -12px, 0); }\n  50%  { transform: translate3d(-6px, 10px, 0); }\n  75%  { transform: translate3d(10px, 4px, 0); }\n  100% { transform: translate3d(0, 0, 0); }\n}\n</style>\n"]},"metadata":{},"sourceType":"module"}