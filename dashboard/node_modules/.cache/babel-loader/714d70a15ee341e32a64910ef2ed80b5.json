{"ast":null,"code":"import { Icon } from \"@iconify/vue\";\nexport default {\n  data() {\n    return {\n      isOpen: false\n    };\n  },\n  methods: {\n    toggleAccordion() {\n      this.isOpen = !this.isOpen;\n    }\n  },\n  components: {\n    Icon\n  }\n};","map":{"version":3,"mappings":"AA6BE,SAASA,IAAG,QAAS,cAAc;AACnC,eAAe;EACbC,IAAIA,GAAG;IACL,OAAO;MACLC,MAAM,EAAE;IACV,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACPC,eAAeA,GAAG;MAChB,IAAI,CAACF,MAAK,GAAI,CAAC,IAAI,CAACA,MAAM;IAC5B;EACF,CAAC;EACDG,UAAU,EAAE;IAAEL;EAAK;AACrB,CAAC","names":["Icon","data","isOpen","methods","toggleAccordion","components"],"sourceRoot":"","sources":["D:\\joremiodotonline\\dashboard\\src\\components\\MenuAccordion.vue"],"sourcesContent":["<template>\n  <button\n    @click=\"toggleAccordion\"\n    class=\"text-gray-400 bg-transparent w-full flex text-left rounded-md box-border p-3 transition-colors\"\n    :class=\"isOpen ? 'bg-case-elevated text-gray-200' : 'hover:bg-case-elevated hover:text-gray-200'\"\n  >\n    <span class=\"mr-3 text-xl\">\n      <slot name=\"icon\"></slot>\n    </span>\n    <span class=\"w-full\">\n      <slot name=\"title\" />\n    </span>\n    <span\n      class=\"box-border mt-1 transition-transform text-gray-600\"\n      :class=\"isOpen ? 'rotate-180' : 'rotate-0'\"\n    >\n      <Icon icon=\"fa6-solid:angle-down\" />\n    </span>\n  </button>\n\n  <div\n    v-show=\"isOpen\"\n    class=\"bg-case-bg rounded-md mt-1 p-2 text-gray-400\"\n  >\n    <slot name=\"content\" />\n  </div>\n</template>\n\n<script>\n  import { Icon } from \"@iconify/vue\";\n  export default {\n    data() {\n      return {\n        isOpen: false,\n      };\n    },\n    methods: {\n      toggleAccordion() {\n        this.isOpen = !this.isOpen;\n      },\n    },\n    components: { Icon },\n  };\n</script>\n"]},"metadata":{},"sourceType":"module"}