{"ast":null,"code":"import { Icon } from \"@iconify/vue\";\nlet _uid = 0;\nexport default {\n  data() {\n    _uid += 1;\n    return {\n      isOpen: false,\n      uid: `collapse${_uid}`\n    };\n  },\n  methods: {\n    toggleAccordion() {\n      this.isOpen = !this.isOpen;\n    }\n  },\n  components: {\n    Icon\n  }\n};","map":{"version":3,"mappings":"AA0CE,SAASA,IAAG,QAAS,cAAc;AACnC,IAAIC,IAAG,GAAI,CAAC;AAEZ,eAAe;EACbC,IAAIA,GAAG;IACLD,IAAG,IAAK,CAAC;IACT,OAAO;MACLE,MAAM,EAAE,KAAK;MACbC,GAAG,EAAE,WAAWH,IAAI;IACtB,CAAC;EACH,CAAC;EAEDI,OAAO,EAAE;IACPC,eAAeA,GAAG;MAChB,IAAI,CAACH,MAAK,GAAI,CAAC,IAAI,CAACA,MAAM;IAC5B;EACF,CAAC;EACDI,UAAU,EAAE;IACVP;EACF;AACF,CAAC","names":["Icon","_uid","data","isOpen","uid","methods","toggleAccordion","components"],"sourceRoot":"","sources":["D:\\joremiodotonline\\dashboard\\src\\components\\AppAccordion.vue"],"sourcesContent":["<template>\n  <button\n    @click=\"toggleAccordion()\"\n    class=\"text-gray-800 dark:text-gray-500 transition-all bg-transparent border dark:border-gray-700 dark:hover:bg-gray-700 hover:bg-gray-200 w-full flex text-left rounded-md box-border p-3\"\n    :aria-expanded=\"isOpen\"\n    :aria-controls=\"`collapse${uid}`\"\n    :class=\"{\n      'bg-gray-200 dark:bg-gray-700': isOpen,\n      'bg-transparent': !isOpen,\n    }\"\n  >\n    <!-- icon accordion -->\n    <span class=\"mr-3 text-xl\">\n      <slot name=\"icon\"></slot>\n    </span>\n    <!-- title accordion -->\n    <span class=\"w-full\">\n      <slot name=\"title\" />\n    </span>\n    <span\n      class=\"box-border mt-1 text-gray-500 dark:text-gray-600\"\n      :class=\"{\n        'rotate-180': isOpen,\n        'rotate-0': !isOpen,\n      }\"\n    >\n      <span class=\"float-right\">\n        <Icon icon=\"fa6-solid:angle-down\" />\n      </span>\n    </span>\n  </button>\n\n  <div\n    v-show=\"isOpen\"\n    :id=\"uid\"\n    class=\"p-3 mt-2 bg-gray-100 dark:bg-gray-700\"\n  >\n    <slot name=\"content\" />\n  </div>\n</template>\n\n<script>\n  import { Icon } from \"@iconify/vue\";\n  let _uid = 0;\n\n  export default {\n    data() {\n      _uid += 1;\n      return {\n        isOpen: false,\n        uid: `collapse${_uid}`,\n      };\n    },\n\n    methods: {\n      toggleAccordion() {\n        this.isOpen = !this.isOpen;\n      },\n    },\n    components: {\n      Icon,\n    },\n  };\n</script>\n"]},"metadata":{},"sourceType":"module"}