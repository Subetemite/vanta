{"ast":null,"code":"import API from \"@/services/api\";\nconst ACTION_OPTIONS = [\"01 – Approval\", \"02 – Signature\", \"03 – Appropriate Action\", \"04 – Comment/Recommendation\", \"05 – For Study\", \"06 – Reply Direct to Writer\", \"07 – Retype/Redraft\", \"08 – Attn to HWI\", \"09 – Pls see me\", \"10 – Calendar/Remind me\", \"11 – Dispatch\", \"12 – Dissemination\", \"13 – Notation/Information\", \"14 – File\"];\nfunction emptyLine() {\n  return {\n    from: \"\",\n    to: \"\",\n    actionRequested: ACTION_OPTIONS[0],\n    date: \"\",\n    senderName: \"\",\n    additionalRemarks: \"\"\n  };\n}\nexport default {\n  name: \"AdminDocumentsNew\",\n  data() {\n    return {\n      form: {\n        controlNumber: \"\",\n        subject: \"\",\n        lines: [emptyLine()]\n      },\n      actionOptions: ACTION_OPTIONS,\n      uploadedFile: null,\n      isUploading: false,\n      uploadError: \"\",\n      isSubmitting: false,\n      errorMessage: \"\"\n    };\n  },\n  methods: {\n    addLine() {\n      if (this.form.lines.length >= 5) return;\n      this.form.lines.push(emptyLine());\n    },\n    removeLine(idx) {\n      this.form.lines.splice(idx, 1);\n    },\n    formatBytes(bytes) {\n      if (!bytes) return \"0 B\";\n      const units = [\"B\", \"KB\", \"MB\", \"GB\"];\n      let i = 0;\n      let n = bytes;\n      while (n >= 1024 && i < units.length - 1) {\n        n /= 1024;\n        i++;\n      }\n      return `${n.toFixed(1)} ${units[i]}`;\n    },\n    async handleFileSelect(event) {\n      const [file] = event.target.files || [];\n      if (!file) return;\n      if (file.size > 5 * 1024 * 1024) {\n        this.uploadError = \"Please choose a file 5 MB or smaller.\";\n        event.target.value = \"\";\n        return;\n      }\n      this.uploadError = \"\";\n      this.isUploading = true;\n      try {\n        const base64 = await this.fileToBase64(file);\n        const res = await API.post(\"/files\", {\n          fileName: file.name,\n          mimeType: file.type,\n          contentBase64: base64\n        });\n        const f = res.data?.file;\n        if (!f?.id) throw new Error(\"Upload returned no file id.\");\n        this.uploadedFile = {\n          id: f.id,\n          originalName: f.originalName,\n          url: f.url,\n          mimeType: f.mimeType,\n          size: f.size\n        };\n      } catch (err) {\n        this.uploadError = err.response?.data?.message || err.message || \"Upload failed.\";\n      } finally {\n        this.isUploading = false;\n        event.target.value = \"\";\n      }\n    },\n    fileToBase64(file) {\n      return new Promise((resolve, reject) => {\n        const reader = new FileReader();\n        reader.onload = () => resolve(reader.result);\n        reader.onerror = reject;\n        reader.readAsDataURL(file);\n      });\n    },\n    async handleSubmit() {\n      this.errorMessage = \"\";\n      if (!this.uploadedFile) {\n        this.errorMessage = \"An attached file is required.\";\n        return;\n      }\n      this.isSubmitting = true;\n      try {\n        await API.post(\"/admin/documents\", {\n          controlNumber: this.form.controlNumber,\n          subject: this.form.subject,\n          lines: this.form.lines,\n          attachedFile: this.uploadedFile\n        });\n        this.$router.push(\"/admin/documents\");\n      } catch (err) {\n        this.errorMessage = err.response?.data?.message || \"Unable to save the record.\";\n      } finally {\n        this.isSubmitting = false;\n      }\n    }\n  }\n};","map":{"version":3,"mappings":"AAuLE,OAAOA,GAAE,MAAO,gBAAgB;AAEhC,MAAMC,cAAa,GAAI,CACrB,eAAe,EACf,gBAAgB,EAChB,yBAAyB,EACzB,6BAA6B,EAC7B,gBAAgB,EAChB,6BAA6B,EAC7B,qBAAqB,EACrB,kBAAkB,EAClB,iBAAiB,EACjB,yBAAyB,EACzB,eAAe,EACf,oBAAoB,EACpB,2BAA2B,EAC3B,WAAW,CACZ;AAED,SAASC,SAASA,GAAG;EACnB,OAAO;IACLC,IAAI,EAAE,EAAE;IACRC,EAAE,EAAE,EAAE;IACNC,eAAe,EAAEJ,cAAc,CAAC,CAAC,CAAC;IAClCK,IAAI,EAAE,EAAE;IACRC,UAAU,EAAE,EAAE;IACdC,iBAAiB,EAAE;EACrB,CAAC;AACH;AAEA,eAAe