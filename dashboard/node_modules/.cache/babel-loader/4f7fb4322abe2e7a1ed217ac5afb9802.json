{"ast":null,"code":"import API from \"@/services/api\";\nexport default {\n  name: \"FilesView\",\n  data() {\n    return {\n      selectedFile: null,\n      isDragOver: false,\n      isUploading: false,\n      isLoadingFiles: false,\n      searchQuery: \"\",\n      searchDebounce: null,\n      activeSearchQuery: \"\",\n      searchSummaryFile: null,\n      searchMatchCount: 0,\n      statusMessage: \"\",\n      statusType: \"success\",\n      filesError: \"\",\n      uploadedFiles: []\n    };\n  },\n  methods: {\n    async loadFiles() {\n      this.isLoadingFiles = true;\n      this.filesError = \"\";\n      try {\n        const query = this.searchQuery ? `/files?q=${encodeURIComponent(this.searchQuery)}` : \"/files\";\n        const response = await API.get(query);\n        const nextFiles = Array.isArray(response.data.files) ? response.data.files : [];\n        this.uploadedFiles = nextFiles;\n        if (this.searchQuery) {\n          this.activeSearchQuery = this.searchQuery;\n          this.searchSummaryFile = nextFiles[0] || null;\n          this.searchMatchCount = nextFiles.length;\n        } else {\n          this.activeSearchQuery = \"\";\n          this.searchSummaryFile = null;\n          this.searchMatchCount = 0;\n        }\n      } catch (error) {\n        this.filesError = error.response?.data?.message || \"Unable to load files right now.\";\n      } finally {\n        this.isLoadingFiles = false;\n      }\n    },\n    handleSearchInput() {\n      clearTimeout(this.searchDebounce);\n      this.searchDebounce = setTimeout(() => {\n        this.loadFiles();\n      }, 250);\n    },\n    handleFileChange(event) {\n      const [file] = event.target.files || [];\n      this.setSelectedFile(file);\n    },\n    handleFileDrop(event) {\n      const [file] = event.dataTransfer?.files || [];\n      this.setDragOver(false);\n      this.setSelectedFile(file);\n    },\n    setDragOver(value) {\n      this.isDragOver = value;\n    },\n    triggerFilePicker() {\n      this.$refs.fileInput?.click();\n    },\n    setSelectedFile(file) {\n      this.statusMessage = \"\";\n      this.statusType = \"success\";\n      if (!file) {\n        this.selectedFile = null;\n        return;\n      }\n      if (file.size > 5 * 1024 * 1024) {\n        this.selectedFile = null;\n        this.statusType = \"error\";\n        this.statusMessage = \"Please choose a file that is 5 MB or smaller.\";\n        if (this.$refs.fileInput) {\n          this.$refs.fileInput.value = \"\";\n        }\n        return;\n      }\n      this.selectedFile = file;\n    },\n    clearSelection() {\n      this.selectedFile = null;\n      this.isDragOver = false;\n      this.statusMessage = \"\";\n      this.statusType = \"success\";\n      if (this.$refs.fileInput) {\n        this.$refs.fileInput.value = \"\";\n      }\n    },\n    readFileAsDataUrl(file) {\n      return new Promise((resolve, reject) => {\n        const reader = new FileReader();\n        reader.onload = () => resolve(reader.result);\n        reader.onerror = () => reject(new Error(\"Unable to read the selected file.\"));\n        reader.readAsDataURL(file);\n      });\n    },\n    async uploadSelectedFile() {\n      if (!this.selectedFile || this.isUploading) {\n        return;\n      }\n      this.isUploading = true;\n      this.statusMessage = \"\";\n      this.statusType = \"success\";\n      try {\n        const contentBase64 = await this.readFileAsDataUrl(this.selectedFile);\n        const response = await API.post(\"/files\", {\n          fileName: this.selectedFile.name,\n          mimeType: this.selectedFile.type,\n          contentBase64\n        });\n        this.statusMessage = response.data.message || \"File uploaded successfully.\";\n        this.clearSelection();\n        await this.loadFiles();\n      } catch (error) {\n        this.statusType = \"error\";\n        this.statusMessage = error.response?.data?.message || \"Unable to upload the file.\";\n      } finally {\n        this.isUploading = false;\n      }\n    },\n    formatFileSize(size = 0) {\n      if (size < 1024) {\n        return `${size} B`;\n      }\n      if (size < 1024 * 1024) {\n        return `${(size / 1024).toFixed(1)} KB`;\n      }\n      return `${(size / (1024 * 1024)).toFixed(2)} MB`;\n    },\n    formatDate(value) {\n      if (!value) {\n        return \"Unknown date\";\n      }\n      return new Date(value).toLocaleString();\n    },\n    formatExtractionStatus(value) {\n      if (value === \"completed\") {\n        return \"Indexed\";\n      }\n      if (value === \"failed\") {\n        return \"Failed\";\n      }\n      if (value === \"pending\") {\n        return \"Processing\";\n      }\n      return \"N/A\";\n    },\n    getSummaryPreview(file) {\n      if (!file?.extractedTextPreview) {\n        return \"No extracted PDF text is available for this result.\";\n      }\n      return file.extractedTextPreview;\n    }\n  },\n  mounted() {\n    this.loadFiles();\n  },\n  beforeUnmount() {\n    clearTimeout(this.searchDebounce);\n  }\n};","map":{"version":3,"mappings":"AA4SE,OAAOA,GAAE,MAAO,gBAAgB;AAEhC,eAAe;EACbC,IAAI,EAAE,WAAW;EACjBC,IAAIA,GAAG;IACL,OAAO;MACLC,YAAY,EAAE,IAAI;MAClBC,UAAU,EAAE,KAAK;MACjBC,WAAW,EAAE,KAAK;MAClBC,cAAc,EAAE,KAAK;MACrBC,WAAW,EAAE,EAAE;MACfC,cAAc,EAAE,IAAI;MACpBC,iBAAiB,EAAE,EAAE;MACrBC,iBAAiB,EAAE,IAAI;MACvBC,gBAAgB,EAAE,CAAC;MACnBC,aAAa,EAAE,EAAE;MACjBC,UAAU,EAAE,SAAS;MACrBC,UAAU,EAAE,EAAE;MACdC,aAAa,EAAE;IACjB,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACP,MAAMC,SAASA,GAAG;MAChB,IAAI,CAACX,cAAa,GAAI,IAAI;MAC1B,IAAI,CAACQ,UAAS,GAAI,EAAE;MAEpB,IAAI;QACF,MAAMI,KAAI,GAAI,IAAI,CAACX,WAAU,GACzB,YAAYY,kBAAkB,CAAC,IAAI,CAACZ,WAAW,CAAC,EAAC,GACjD,QAAQ;QACZ,MAAMa,QAAO,GAAI,MAAMpB,GAAG,CAACqB,GAAG,CAACH,KAAK,CAAC;QACrC,MAAMI,SAAQ,GAAIC,KAAK,CAACC,OAAO,CAACJ,QAAQ,CAAClB,IAAI,CAACuB,KAAK,IAC/CL,QAAQ,CAAClB,IAAI,CAACuB,KAAI,GAClB,EAAE;QACN,IAAI,CAACV,aAAY,GAAIO,SAAS;QAE9B,IAAI,IAAI,CAACf,WAAW,EAAE;UACpB,IAAI,CAACE,iBAAgB,GAAI,IAAI,CAACF,WAAW;UACzC,IAAI,CAACG,iBAAgB,GAAIY,SAAS,CAAC,CAAC,KAAK,IAAI;UAC7C,IAAI,CAACX,gBAAe,GAAIW,SAAS,CAACI,MAAM;QAC1C,OAAO;UACL,IAAI,CAACjB,iBAAgB,GAAI,EAAE;UAC3B,IAAI,CAACC,iBAAgB,GAAI,IAAI;UAC7B,IAAI,CAACC,gBAAe,GAAI,CAAC;QAC3B;MACF,EAAE,OAAOgB,KAAK,EAAE;QACd,IAAI,CAACb,UAAS,GACZa,KAAK,CAACP,QAAQ,EAAElB,IAAI,EAAE0B,OAAM,IAAK,iCAAiC;MACtE,UAAU;QACR,IAAI,CAACtB,cAAa,GAAI,KAAK;MAC7B;IACF,CAAC;IACDuB,iBAAiBA,GAAG;MAClBC,YAAY,CAAC,IAAI,CAACtB,cAAc,CAAC;MACjC,IAAI,CAACA,cAAa,GAAIuB,UAAU,CAAC,MAAM;QACrC,IAAI,CAACd,SAAS,CAAC,CAAC;MAClB,CAAC,EAAE,GAAG,CAAC;IACT,CAAC;IACDe,gBAAgBA,CAACC,KAAK,EAAE;MACtB,MAAM,CAACC,IAAI,IAAID,KAAK,CAACE,MAAM,CAACV,KAAI,IAAK,EAAE;MACvC,IAAI,CAACW,eAAe,CAACF,IAAI,CAAC;IAC5B,CAAC;IACDG,cAAcA,CAACJ,KAAK,EAAE;MACpB,MAAM,CAACC,IAAI,IAAID,KAAK,CAACK,YAAY,EAAEb,KAAI,IAAK,EAAE;MAC9C,IAAI,CAACc,WAAW,CAAC,KAAK,CAAC;MACvB,IAAI,CAACH,eAAe,CAACF,IAAI,CAAC;IAC5B,CAAC;IACDK,WAAWA,CAACC,KAAK,EAAE;MACjB,IAAI,CAACpC,UAAS,GAAIoC,KAAK;IACzB,CAAC;IACDC,iBAAiBA,GAAG;MAClB,IAAI,CAACC,KAAK,CAACC,SAAS,EAAEC,KAAK,CAAC,CAAC;IAC/B,CAAC;IACDR,eAAeA,CAACF,IAAI,EAAE;MACpB,IAAI,CAACtB,aAAY,GAAI,EAAE;MACvB,IAAI,CAACC,UAAS,GAAI,SAAS;MAE3B,IAAI,CAACqB,IAAI,EAAE;QACT,IAAI,CAAC/B,YAAW,GAAI,IAAI;QACxB;MACF;MAEA,IAAI+B,IAAI,CAACW,IAAG,GAAI,IAAI,IAAG,GAAI,IAAI,EAAE;QAC/B,IAAI,CAAC1C,YAAW,GAAI,IAAI;QACxB,IAAI,CAACU,UAAS,GAAI,OAAO;QACzB,IAAI,CAACD,aAAY,GAAI,+CAA+C;QAEpE,IAAI,IAAI,CAAC8B,KAAK,CAACC,SAAS,EAAE;UACxB,IAAI,CAACD,KAAK,CAACC,SAAS,CAACH,KAAI,GAAI,EAAE;QACjC;QAEA;MACF;MAEA,IAAI,CAACrC,YAAW,GAAI+B,IAAI;IAC1B,CAAC;IACDY,cAAcA,GAAG;MACf,IAAI,CAAC3C,YAAW,GAAI,IAAI;MACxB,IAAI,CAACC,UAAS,GAAI,KAAK;MACvB,IAAI,CAACQ,aAAY,GAAI,EAAE;MACvB,IAAI,CAACC,UAAS,GAAI,SAAS;MAE3B,IAAI,IAAI,CAAC6B,KAAK,CAACC,SAAS,EAAE;QACxB,IAAI,CAACD,KAAK,CAACC,SAAS,CAACH,KAAI,GAAI,EAAE;MACjC;IACF,CAAC;IACDO,iBAAiBA,CAACb,IAAI,EAAE;MACtB,OAAO,IAAIc,OAAO,CAAC,CAACC,OAAO,EAAEC,MAAM,KAAK;QACtC,MAAMC,MAAK,GAAI,IAAIC,UAAU,CAAC,CAAC;QAE/BD,MAAM,CAACE,MAAK,GAAI,MAAMJ,OAAO,CAACE,MAAM,CAACG,MAAM,CAAC;QAC5CH,MAAM,CAACI,OAAM,GAAI,MACfL,MAAM,CAAC,IAAIM,KAAK,CAAC,mCAAmC,CAAC,CAAC;QACxDL,MAAM,CAACM,aAAa,CAACvB,IAAI,CAAC;MAC5B,CAAC,CAAC;IACJ,CAAC;IACD,MAAMwB,kBAAkBA,GAAG;MACzB,IAAI,CAAC,IAAI,CAACvD,YAAW,IAAK,IAAI,CAACE,WAAW,EAAE;QAC1C;MACF;MAEA,IAAI,CAACA,WAAU,GAAI,IAAI;MACvB,IAAI,CAACO,aAAY,GAAI,EAAE;MACvB,IAAI,CAACC,UAAS,GAAI,SAAS;MAE3B,IAAI;QACF,MAAM8C,aAAY,GAAI,MAAM,IAAI,CAACZ,iBAAiB,CAAC,IAAI,CAAC5C,YAAY,CAAC;QAErE,MAAMiB,QAAO,GAAI,MAAMpB,GAAG,CAAC4D,IAAI,CAAC,QAAQ,EAAE;UACxCC,QAAQ,EAAE,IAAI,CAAC1D,YAAY,CAACF,IAAI;UAChC6D,QAAQ,EAAE,IAAI,CAAC3D,YAAY,CAAC4D,IAAI;UAChCJ;QACF,CAAC,CAAC;QAEF,IAAI,CAAC/C,aAAY,GACfQ,QAAQ,CAAClB,IAAI,CAAC0B,OAAM,IAAK,6BAA6B;QACxD,IAAI,CAACkB,cAAc,CAAC,CAAC;QACrB,MAAM,IAAI,CAAC7B,SAAS,CAAC,CAAC;MACxB,EAAE,OAAOU,KAAK,EAAE;QACd,IAAI,CAACd,UAAS,GAAI,OAAO;QACzB,IAAI,CAACD,aAAY,GACfe,KAAK,CAACP,QAAQ,EAAElB,IAAI,EAAE0B,OAAM,IAAK,4BAA4B;MACjE,UAAU;QACR,IAAI,CAACvB,WAAU,GAAI,KAAK;MAC1B;IACF,CAAC;IACD2D,cAAcA,CAACnB,IAAG,GAAI,CAAC,EAAE;MACvB,IAAIA,IAAG,GAAI,IAAI,EAAE;QACf,OAAO,GAAGA,IAAI,IAAI;MACpB;MAEA,IAAIA,IAAG,GAAI,IAAG,GAAI,IAAI,EAAE;QACtB,OAAO,GAAG,CAACA,IAAG,GAAI,IAAI,EAAEoB,OAAO,CAAC,CAAC,CAAC,KAAK;MACzC;MAEA,OAAO,GAAG,CAACpB,IAAG,IAAK,IAAG,GAAI,IAAI,CAAC,EAAEoB,OAAO,CAAC,CAAC,CAAC,KAAK;IAClD,CAAC;IACDC,UAAUA,CAAC1B,KAAK,EAAE;MAChB,IAAI,CAACA,KAAK,EAAE;QACV,OAAO,cAAc;MACvB;MAEA,OAAO,IAAI2B,IAAI,CAAC3B,KAAK,CAAC,CAAC4B,cAAc,CAAC,CAAC;IACzC,CAAC;IACDC,sBAAsBA,CAAC7B,KAAK,EAAE;MAC5B,IAAIA,KAAI,KAAM,WAAW,EAAE;QACzB,OAAO,SAAS;MAClB;MAEA,IAAIA,KAAI,KAAM,QAAQ,EAAE;QACtB,OAAO,QAAQ;MACjB;MAEA,IAAIA,KAAI,KAAM,SAAS,EAAE;QACvB,OAAO,YAAY;MACrB;MAEA,OAAO,KAAK;IACd,CAAC;IACD8B,iBAAiBA,CAACpC,IAAI,EAAE;MACtB,IAAI,CAACA,IAAI,EAAEqC,oBAAoB,EAAE;QAC/B,OAAO,qDAAqD;MAC9D;MAEA,OAAOrC,IAAI,CAACqC,oBAAoB;IAClC;EACF,CAAC;EACDC,OAAOA,GAAG;IACR,IAAI,CAACvD,SAAS,CAAC,CAAC;EAClB,CAAC;EACDwD,aAAaA,GAAG;IACd3C,YAAY,CAAC,IAAI,CAACtB,cAAc,CAAC;EACnC;AACF,CAAC","names":["API","name","data","selectedFile","isDragOver","isUploading","isLoadingFiles","searchQuery","searchDebounce","activeSearchQuery","searchSummaryFile","searchMatchCount","statusMessage","statusType","filesError","uploadedFiles","methods","loadFiles","query","encodeURIComponent","response","get","nextFiles","Array","isArray","files","length","error","message","handleSearchInput","clearTimeout","setTimeout","handleFileChange","event","file","target","setSelectedFile","handleFileDrop","dataTransfer","setDragOver","value","triggerFilePicker","$refs","fileInput","click","size","clearSelection","readFileAsDataUrl","Promise","resolve","reject","reader","FileReader","onload","result","onerror","Error","readAsDataURL","uploadSelectedFile","contentBase64","post","fileName","mimeType","type","formatFileSize","toFixed","formatDate","Date","toLocaleString","formatExtractionStatus","getSummaryPreview","extractedTextPreview","mounted","beforeUnmount"],"sourceRoot":"","sources":["D:\\joremiodotonline\\dashboard\\src\\views\\Files.vue"],"sourcesContent":["<template>\n  <div class=\"p-4\">\n    <div\n      class=\"rounded-md border bg-white p-6 dark:border-gray-700 dark:bg-gray-800\"\n    >\n      <div class=\"flex items-start justify-between gap-4\">\n        <div>\n          <p class=\"text-sm font-medium uppercase tracking-[0.2em] text-primary\">\n            Files\n          </p>\n          <h1 class=\"mt-2 text-2xl font-semibold text-gray-800 dark:text-gray-100\">\n            File Management\n          </h1>\n          <p class=\"mt-2 max-w-2xl text-sm text-gray-500 dark:text-gray-400\">\n            Upload a file from this page and it will be saved on the API server\n            with metadata stored in the database.\n          </p>\n        </div>\n        <span\n          class=\"rounded-full bg-gray-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-gray-500 dark:bg-gray-700 dark:text-gray-300\"\n        >\n          Server Uploads\n        </span>\n      </div>\n\n      <div class=\"mt-6 grid gap-6 lg:grid-cols-[1.1fr_0.9fr]\">\n        <div\n          class=\"rounded-md border border-dashed border-gray-300 p-5 dark:border-gray-600\"\n        >\n          <div class=\"flex items-center justify-between gap-4\">\n            <div>\n              <h2 class=\"text-sm font-semibold text-gray-800 dark:text-gray-100\">\n                Upload File\n              </h2>\n              <p class=\"mt-2 text-sm text-gray-500 dark:text-gray-400\">\n                Accepted limit: 5 MB. The file is sent to the server and saved\n                under the API uploads folder.\n              </p>\n            </div>\n            <span\n              class=\"rounded-full bg-sky-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-sky-700\"\n            >\n              API Save\n            </span>\n          </div>\n\n          <div class=\"mt-5 rounded-md bg-gray-50 p-4 dark:bg-gray-900/50\">\n            <div\n              class=\"cursor-pointer rounded-xl border-2 border-dashed p-6 text-center transition\"\n              :class=\"\n                isDragOver\n                  ? 'border-primary bg-primary/5'\n                  : 'border-gray-300 bg-white dark:border-gray-600 dark:bg-gray-800'\n              \"\n              @click=\"triggerFilePicker\"\n              @dragenter.prevent=\"setDragOver(true)\"\n              @dragover.prevent=\"setDragOver(true)\"\n              @dragleave.prevent=\"setDragOver(false)\"\n              @drop.prevent=\"handleFileDrop\"\n            >\n              <p class=\"text-sm font-semibold text-gray-800 dark:text-gray-100\">\n                Drag and drop a file here\n              </p>\n              <p class=\"mt-2 text-sm text-gray-500 dark:text-gray-400\">\n                or click to browse from your device\n              </p>\n              <p class=\"mt-3 text-xs uppercase tracking-[0.18em] text-gray-400\">\n                Maximum file size: 5 MB\n              </p>\n            </div>\n\n            <input\n              ref=\"fileInput\"\n              type=\"file\"\n              class=\"hidden\"\n              @change=\"handleFileChange\"\n            />\n\n            <button\n              type=\"button\"\n              class=\"mt-4 rounded-md border border-gray-300 bg-white px-4 py-3 text-sm font-semibold text-gray-700 transition hover:bg-gray-100 dark:border-gray-600 dark:bg-gray-800 dark:text-gray-200 dark:hover:bg-gray-700\"\n              @click=\"triggerFilePicker\"\n            >\n              Browse Files\n            </button>\n\n            <div\n              v-if=\"selectedFile\"\n              class=\"mt-4 rounded-md border border-gray-200 bg-white p-4 text-sm dark:border-gray-700 dark:bg-gray-800\"\n            >\n              <p class=\"font-semibold text-gray-800 dark:text-gray-100\">\n                {{ selectedFile.name }}\n              </p>\n              <p class=\"mt-1 text-gray-500 dark:text-gray-400\">\n                {{ formatFileSize(selectedFile.size) }} |\n                {{ selectedFile.type || \"Unknown type\" }}\n              </p>\n            </div>\n\n            <p\n              v-if=\"statusMessage\"\n              class=\"mt-4 text-sm\"\n              :class=\"statusType === 'error' ? 'text-red-500' : 'text-emerald-600'\"\n            >\n              {{ statusMessage }}\n            </p>\n\n            <div class=\"mt-5 flex gap-3\">\n              <button\n                type=\"button\"\n                class=\"rounded-md bg-primary px-5 py-3 text-sm font-semibold text-white transition hover:bg-primary/90 disabled:cursor-not-allowed disabled:opacity-60\"\n                :disabled=\"!selectedFile || isUploading\"\n                @click=\"uploadSelectedFile\"\n              >\n                {{ isUploading ? \"Uploading...\" : \"Upload to Server\" }}\n              </button>\n              <button\n                type=\"button\"\n                class=\"rounded-md border border-gray-300 px-5 py-3 text-sm font-semibold text-gray-700 transition hover:bg-gray-100 dark:border-gray-600 dark:text-gray-200 dark:hover:bg-gray-700\"\n                :disabled=\"isUploading\"\n                @click=\"clearSelection\"\n              >\n                Clear\n              </button>\n            </div>\n          </div>\n        </div>\n        <div\n          class=\"rounded-md border border-gray-200 p-5 dark:border-gray-700\"\n        >\n          <div class=\"flex items-center justify-between gap-4\">\n            <div>\n              <h2 class=\"text-sm font-semibold text-gray-800 dark:text-gray-100\">\n                Extracted PDF Data\n              </h2>\n              <p class=\"mt-2 text-sm text-gray-500 dark:text-gray-400\">\n                Search results from indexed PDF text will appear here.\n              </p>\n            </div>\n            <button\n              type=\"button\"\n              class=\"rounded-md border border-gray-300 px-3 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-gray-600 transition hover:bg-gray-100 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700\"\n              :disabled=\"isLoadingFiles\"\n              @click=\"loadFiles\"\n            >\n              Refresh\n            </button>\n          </div>\n\n          <div\n            v-if=\"!activeSearchQuery\"\n            class=\"mt-5 rounded-md bg-gray-50 p-5 text-sm text-gray-500 dark:bg-gray-900/50 dark:text-gray-400\"\n          >\n            Type in the search bar below to pull matching content from extracted\n            PDF text.\n          </div>\n          <div\n            v-else-if=\"isLoadingFiles\"\n            class=\"mt-5 rounded-md bg-gray-50 p-5 text-sm text-gray-500 dark:bg-gray-900/50 dark:text-gray-400\"\n          >\n            Searching indexed PDF text...\n          </div>\n          <div\n            v-else-if=\"activeSearchQuery && !searchMatchCount\"\n            class=\"mt-5 rounded-md bg-gray-50 p-5 text-sm text-gray-500 dark:bg-gray-900/50 dark:text-gray-400\"\n          >\n            No extracted PDF text matched \"{{ activeSearchQuery }}\".\n          </div>\n          <div v-else class=\"mt-5 grid gap-4\">\n            <div class=\"rounded-md bg-gray-50 p-4 dark:bg-gray-900/50\">\n              <p class=\"text-xs uppercase tracking-[0.18em] text-gray-400\">\n                Search Query\n              </p>\n              <p class=\"mt-2 text-lg font-semibold text-gray-800 dark:text-gray-100\">\n                {{ activeSearchQuery }}\n              </p>\n              <p class=\"mt-1 text-xs text-gray-500 dark:text-gray-400\">\n                {{ searchMatchCount }} matching file{{ searchMatchCount === 1 ? \"\" : \"s\" }}\n              </p>\n            </div>\n            <div class=\"rounded-md bg-gray-50 p-4 dark:bg-gray-900/50\">\n              <p class=\"text-xs uppercase tracking-[0.18em] text-gray-400\">\n                Top Matching File\n              </p>\n              <p class=\"mt-2 text-sm font-semibold text-gray-800 dark:text-gray-100\">\n                {{ searchSummaryFile?.originalName || \"No matching file\" }}\n              </p>\n              <p class=\"mt-1 text-xs text-gray-500 dark:text-gray-400\">\n                {{ searchSummaryFile ? formatDate(searchSummaryFile.createdAt) : \"Waiting for result\" }}\n              </p>\n            </div>\n            <div class=\"rounded-md bg-gray-50 p-4 dark:bg-gray-900/50\">\n              <p class=\"text-xs uppercase tracking-[0.18em] text-gray-400\">\n                Extracted Text Preview\n              </p>\n              <p class=\"mt-2 text-sm leading-6 text-gray-700 dark:text-gray-300\">\n                {{ getSummaryPreview(searchSummaryFile) }}\n              </p>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"mt-6 rounded-md border border-gray-200 p-5 dark:border-gray-700\">\n        <div class=\"flex items-center justify-between gap-4\">\n          <div>\n            <h2 class=\"text-sm font-semibold text-gray-800 dark:text-gray-100\">\n              Saved Files\n            </h2>\n            <p class=\"mt-2 text-sm text-gray-500 dark:text-gray-400\">\n              Files listed here have already been written to the server.\n            </p>\n          </div>\n          <div class=\"w-full max-w-sm\">\n            <input\n              v-model.trim=\"searchQuery\"\n              type=\"text\"\n              placeholder=\"Search PDF text or file name\"\n              class=\"w-full rounded-md border border-gray-300 bg-white px-4 py-3 text-sm text-gray-700 outline-none transition focus:border-primary dark:border-gray-600 dark:bg-gray-800 dark:text-gray-200\"\n              @input=\"handleSearchInput\"\n            />\n          </div>\n        </div>\n\n        <div\n          v-if=\"isLoadingFiles\"\n          class=\"mt-5 rounded-md bg-gray-50 px-4 py-6 text-sm text-gray-500 dark:bg-gray-900/50 dark:text-gray-400\"\n        >\n          Loading uploaded files...\n        </div>\n        <div\n          v-else-if=\"filesError\"\n          class=\"mt-5 rounded-md bg-red-50 px-4 py-6 text-sm text-red-500\"\n        >\n          {{ filesError }}\n        </div>\n        <div\n          v-else-if=\"!uploadedFiles.length\"\n          class=\"mt-5 rounded-md bg-gray-50 px-4 py-6 text-sm text-gray-500 dark:bg-gray-900/50 dark:text-gray-400\"\n        >\n          No files have been uploaded yet.\n        </div>\n        <div v-else class=\"mt-5 overflow-x-auto\">\n          <table class=\"min-w-full divide-y divide-gray-200 dark:divide-gray-700\">\n            <thead>\n              <tr class=\"text-left text-xs uppercase tracking-[0.18em] text-gray-400\">\n                <th class=\"px-3 py-3 font-semibold\">File</th>\n                <th class=\"px-3 py-3 font-semibold\">Size</th>\n                <th class=\"px-3 py-3 font-semibold\">Uploaded By</th>\n                <th class=\"px-3 py-3 font-semibold\">Index</th>\n                <th class=\"px-3 py-3 font-semibold\">Date</th>\n                <th class=\"px-3 py-3 font-semibold\">Open</th>\n              </tr>\n            </thead>\n            <tbody class=\"divide-y divide-gray-100 dark:divide-gray-800\">\n              <tr\n                v-for=\"file in uploadedFiles\"\n                :key=\"file.id\"\n                class=\"text-sm text-gray-700 dark:text-gray-200\"\n              >\n                <td class=\"px-3 py-4\">\n                  <p class=\"font-semibold\">{{ file.originalName }}</p>\n                  <p class=\"mt-1 text-xs text-gray-500 dark:text-gray-400\">\n                    {{ file.mimeType || \"Unknown type\" }}\n                  </p>\n                  <p\n                    v-if=\"file.extractedTextPreview\"\n                    class=\"mt-1 max-w-md text-xs text-gray-500 dark:text-gray-400\"\n                  >\n                    {{ file.extractedTextPreview }}\n                  </p>\n                </td>\n                <td class=\"px-3 py-4\">{{ formatFileSize(file.size) }}</td>\n                <td class=\"px-3 py-4\">\n                  {{ file.uploadedBy?.username || file.uploadedBy?.email || \"Unknown\" }}\n                </td>\n                <td class=\"px-3 py-4\">\n                  {{ formatExtractionStatus(file.extractionStatus) }}\n                </td>\n                <td class=\"px-3 py-4\">{{ formatDate(file.createdAt) }}</td>\n                <td class=\"px-3 py-4\">\n                  <a\n                    :href=\"file.url\"\n                    target=\"_blank\"\n                    rel=\"noreferrer\"\n                    class=\"font-semibold text-primary hover:underline\"\n                  >\n                    View\n                  </a>\n                </td>\n              </tr>\n            </tbody>\n          </table>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\n  import API from \"@/services/api\";\n\n  export default {\n    name: \"FilesView\",\n    data() {\n      return {\n        selectedFile: null,\n        isDragOver: false,\n        isUploading: false,\n        isLoadingFiles: false,\n        searchQuery: \"\",\n        searchDebounce: null,\n        activeSearchQuery: \"\",\n        searchSummaryFile: null,\n        searchMatchCount: 0,\n        statusMessage: \"\",\n        statusType: \"success\",\n        filesError: \"\",\n        uploadedFiles: [],\n      };\n    },\n    methods: {\n      async loadFiles() {\n        this.isLoadingFiles = true;\n        this.filesError = \"\";\n\n        try {\n          const query = this.searchQuery\n            ? `/files?q=${encodeURIComponent(this.searchQuery)}`\n            : \"/files\";\n          const response = await API.get(query);\n          const nextFiles = Array.isArray(response.data.files)\n            ? response.data.files\n            : [];\n          this.uploadedFiles = nextFiles;\n\n          if (this.searchQuery) {\n            this.activeSearchQuery = this.searchQuery;\n            this.searchSummaryFile = nextFiles[0] || null;\n            this.searchMatchCount = nextFiles.length;\n          } else {\n            this.activeSearchQuery = \"\";\n            this.searchSummaryFile = null;\n            this.searchMatchCount = 0;\n          }\n        } catch (error) {\n          this.filesError =\n            error.response?.data?.message || \"Unable to load files right now.\";\n        } finally {\n          this.isLoadingFiles = false;\n        }\n      },\n      handleSearchInput() {\n        clearTimeout(this.searchDebounce);\n        this.searchDebounce = setTimeout(() => {\n          this.loadFiles();\n        }, 250);\n      },\n      handleFileChange(event) {\n        const [file] = event.target.files || [];\n        this.setSelectedFile(file);\n      },\n      handleFileDrop(event) {\n        const [file] = event.dataTransfer?.files || [];\n        this.setDragOver(false);\n        this.setSelectedFile(file);\n      },\n      setDragOver(value) {\n        this.isDragOver = value;\n      },\n      triggerFilePicker() {\n        this.$refs.fileInput?.click();\n      },\n      setSelectedFile(file) {\n        this.statusMessage = \"\";\n        this.statusType = \"success\";\n\n        if (!file) {\n          this.selectedFile = null;\n          return;\n        }\n\n        if (file.size > 5 * 1024 * 1024) {\n          this.selectedFile = null;\n          this.statusType = \"error\";\n          this.statusMessage = \"Please choose a file that is 5 MB or smaller.\";\n\n          if (this.$refs.fileInput) {\n            this.$refs.fileInput.value = \"\";\n          }\n\n          return;\n        }\n\n        this.selectedFile = file;\n      },\n      clearSelection() {\n        this.selectedFile = null;\n        this.isDragOver = false;\n        this.statusMessage = \"\";\n        this.statusType = \"success\";\n\n        if (this.$refs.fileInput) {\n          this.$refs.fileInput.value = \"\";\n        }\n      },\n      readFileAsDataUrl(file) {\n        return new Promise((resolve, reject) => {\n          const reader = new FileReader();\n\n          reader.onload = () => resolve(reader.result);\n          reader.onerror = () =>\n            reject(new Error(\"Unable to read the selected file.\"));\n          reader.readAsDataURL(file);\n        });\n      },\n      async uploadSelectedFile() {\n        if (!this.selectedFile || this.isUploading) {\n          return;\n        }\n\n        this.isUploading = true;\n        this.statusMessage = \"\";\n        this.statusType = \"success\";\n\n        try {\n          const contentBase64 = await this.readFileAsDataUrl(this.selectedFile);\n\n          const response = await API.post(\"/files\", {\n            fileName: this.selectedFile.name,\n            mimeType: this.selectedFile.type,\n            contentBase64,\n          });\n\n          this.statusMessage =\n            response.data.message || \"File uploaded successfully.\";\n          this.clearSelection();\n          await this.loadFiles();\n        } catch (error) {\n          this.statusType = \"error\";\n          this.statusMessage =\n            error.response?.data?.message || \"Unable to upload the file.\";\n        } finally {\n          this.isUploading = false;\n        }\n      },\n      formatFileSize(size = 0) {\n        if (size < 1024) {\n          return `${size} B`;\n        }\n\n        if (size < 1024 * 1024) {\n          return `${(size / 1024).toFixed(1)} KB`;\n        }\n\n        return `${(size / (1024 * 1024)).toFixed(2)} MB`;\n      },\n      formatDate(value) {\n        if (!value) {\n          return \"Unknown date\";\n        }\n\n        return new Date(value).toLocaleString();\n      },\n      formatExtractionStatus(value) {\n        if (value === \"completed\") {\n          return \"Indexed\";\n        }\n\n        if (value === \"failed\") {\n          return \"Failed\";\n        }\n\n        if (value === \"pending\") {\n          return \"Processing\";\n        }\n\n        return \"N/A\";\n      },\n      getSummaryPreview(file) {\n        if (!file?.extractedTextPreview) {\n          return \"No extracted PDF text is available for this result.\";\n        }\n\n        return file.extractedTextPreview;\n      },\n    },\n    mounted() {\n      this.loadFiles();\n    },\n    beforeUnmount() {\n      clearTimeout(this.searchDebounce);\n    },\n  };\n</script>\n"]},"metadata":{},"sourceType":"module"}