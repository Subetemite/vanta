{"ast":null,"code":"import { Icon } from \"@iconify/vue\";\nimport API from \"@/services/api\";\nimport ConfirmationDialog from \"@/components/ConfirmationDialog.vue\";\nimport { createConfirmationDialogState, resolveConfirmation } from \"@/helper/record-confirmation\";\nexport default {\n  name: \"AdminDocumentsView\",\n  components: {\n    Icon,\n    ConfirmationDialog\n  },\n  data() {\n    return {\n      record: null,\n      errorMessage: \"\",\n      isDeleting: false,\n      confirmationDialog: createConfirmationDialogState(),\n      confirmationResolver: null\n    };\n  },\n  methods: {\n    openConfirmationDialog({\n      title,\n      description,\n      confirmText\n    }) {\n      this.confirmationDialog = {\n        visible: true,\n        title,\n        description,\n        confirmText\n      };\n      return new Promise(resolve => {\n        this.confirmationResolver = resolve;\n      });\n    },\n    closeConfirmationDialog(confirmed) {\n      this.confirmationDialog = createConfirmationDialogState();\n      resolveConfirmation(this.confirmationResolver, confirmed);\n      this.confirmationResolver = null;\n    },\n    async loadRecord() {\n      this.errorMessage = \"\";\n      try {\n        const res = await API.get(`/admin/documents/${this.$route.params.id}`);\n        this.record = res.data?.record || null;\n        if (!this.record) this.errorMessage = \"Record not found.\";\n      } catch (err) {\n        this.errorMessage = err.response?.data?.message || \"Unable to load record.\";\n      }\n    },\n    editRecord() {\n      this.$router.push(`/admin/documents/${this.$route.params.id}/edit`);\n    },\n    async deleteRecord() {\n      if (!this.record) return;\n      const confirmed = await this.openConfirmationDialog({\n        title: \"Delete record?\",\n        description: `Record \"${this.record.controlNumber}\" will be permanently removed. This cannot be undone.`,\n        confirmText: \"Yes, delete\"\n      });\n      if (!confirmed) return;\n      this.isDeleting = true;\n      try {\n        await API.delete(`/admin/documents/${this.$route.params.id}`);\n        this.$router.push(\"/admin/documents\");\n      } catch (err) {\n        this.errorMessage = err.response?.data?.message || \"Unable to delete record.\";\n        this.isDeleting = false;\n      }\n    },\n    formatDate(value) {\n      if (!value) return \"—\";\n      const d = new Date(value);\n      if (Number.isNaN(d.getTime())) return \"—\";\n      return d.toISOString().slice(0, 10);\n    }\n  },\n  mounted() {\n    this.loadRecord();\n  }\n};","map":{"version":3,"mappings":"AAmHE,SAASA,IAAG,QAAS,cAAc;AACnC,OAAOC,GAAE,MAAO,gBAAgB;AAChC,OAAOC,kBAAiB,MAAO,qCAAqC;AACpE,SACEC,6BAA6B,EAC7BC,mBAAmB,QACd,8BAA8B;AAErC,eAAe;EACbC,IAAI,EAAE,oBAAoB;EAC1BC,UAAU,EAAE;IAAEN,IAAI;IAAEE;EAAmB,CAAC;EACxCK,IAAIA,GAAG;IACL,OAAO;MACLC,MAAM,EAAE,IAAI;MACZC,YAAY,EAAE,EAAE;MAChBC,UAAU,EAAE,KAAK;MACjBC,kBAAkB,EAAER,6BAA6B,CAAC,CAAC;MACnDS,oBAAoB,EAAE;IACxB,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACPC,sBAAsBA,CAAC;MAAEC,KAAK;MAAEC,WAAW;MAAEC;IAAY,CAAC,EAAE;MAC1D,IAAI,CAACN,kBAAiB,GAAI;QACxBO,OAAO,EAAE,IAAI;QACbH,KAAK;QACLC,WAAW;QACXC;MACF,CAAC;MACD,OAAO,IAAIE,OAAO,CAAEC,OAAO,IAAK;QAC9B,IAAI,CAACR,oBAAmB,GAAIQ,OAAO;MACrC,CAAC,CAAC;IACJ,CAAC;IACDC,uBAAuBA,CAACC,SAAS,EAAE;MACjC,IAAI,CAACX,kBAAiB,GAAIR,6BAA6B,CAAC,CAAC;MACzDC,mBAAmB,CAAC,IAAI,CAACQ,oBAAoB,EAAEU,SAAS,CAAC;MACzD,IAAI,CAACV,oBAAmB,GAAI,IAAI;IAClC,CAAC;IACD,MAAMW,UAAUA,GAAG;MACjB,IAAI,CAACd,YAAW,GAAI,EAAE;MACtB,IAAI;QACF,MAAMe,GAAE,GAAI,MAAMvB,GAAG,CAACwB,GAAG,CAAC,oBAAoB,IAAI,CAACC,MAAM,CAACC,MAAM,CAACC,EAAE,EAAE,CAAC;QACtE,IAAI,CAACpB,MAAK,GAAIgB,GAAG,CAACjB,IAAI,EAAEC,MAAK,IAAK,IAAI;QACtC,IAAI,CAAC,IAAI,CAACA,MAAM,EAAE,IAAI,CAACC,YAAW,GAAI,mBAAmB;MAC3D,EAAE,OAAOoB,GAAG,EAAE;QACZ,IAAI,CAACpB,YAAW,GAAIoB,GAAG,CAACC,QAAQ,EAAEvB,IAAI,EAAEwB,OAAM,IAAK,wBAAwB;MAC7E;IACF,CAAC;IACDC,UAAUA,GAAG;MACX,IAAI,CAACC,OAAO,CAACC,IAAI,CAAC,oBAAoB,IAAI,CAACR,MAAM,CAACC,MAAM,CAACC,EAAE,OAAO,CAAC;IACrE,CAAC;IACD,MAAMO,YAAYA,GAAG;MACnB,IAAI,CAAC,IAAI,CAAC3B,MAAM,EAAE;MAClB,MAAMc,SAAQ,GAAI,MAAM,IAAI,CAACR,sBAAsB,CAAC;QAClDC,KAAK,EAAE,gBAAgB;QACvBC,WAAW,EAAE,WAAW,IAAI,CAACR,MAAM,CAAC4B,aAAa,uDAAuD;QACxGnB,WAAW,EAAE;MACf,CAAC,CAAC;MACF,IAAI,CAACK,SAAS,EAAE;MAChB,IAAI,CAACZ,UAAS,GAAI,IAAI;MACtB,IAAI;QACF,MAAMT,GAAG,CAACoC,MAAM,CAAC,oBAAoB,IAAI,CAACX,MAAM,CAACC,MAAM,CAACC,EAAE,EAAE,CAAC;QAC7D,IAAI,CAACK,OAAO,CAACC,IAAI,CAAC,kBAAkB,CAAC;MACvC,EAAE,OAAOL,GAAG,EAAE;QACZ,IAAI,CAACpB,YAAW,GAAIoB,GAAG,CAACC,QAAQ,EAAEvB,IAAI,EAAEwB,OAAM,IAAK,0BAA0B;QAC7E,IAAI,CAACrB,UAAS,GAAI,KAAK;MACzB;IACF,CAAC;IACD4B,UAAUA,CAACC,KAAK,EAAE;MAChB,IAAI,CAACA,KAAK,EAAE,OAAO,GAAG;MACtB,MAAMC,IAAI,IAAIC,IAAI,CAACF,KAAK,CAAC;MACzB,IAAIG,MAAM,CAACC,KAAK,CAACH,CAAC,CAACI,OAAO,CAAC,CAAC,CAAC,EAAE,OAAO,GAAG;MACzC,OAAOJ,CAAC,CAACK,WAAW,CAAC,CAAC,CAACC,KAAK,CAAC,CAAC,EAAE,EAAE,CAAC;IACrC;EACF,CAAC;EACDC,OAAOA,GAAG;IACR,IAAI,CAACxB,UAAU,CAAC,CAAC;EACnB;AACF,CAAC","names":["Icon","API","ConfirmationDialog","createConfirmationDialogState","resolveConfirmation","name","components","data","record","errorMessage","isDeleting","confirmationDialog","confirmationResolver","methods","openConfirmationDialog","title","description","confirmText","visible","Promise","resolve","closeConfirmationDialog","confirmed","loadRecord","res","get","$route","params","id","err","response","message","editRecord","$router","push","deleteRecord","controlNumber","delete","formatDate","value","d","Date","Number","isNaN","getTime","toISOString","slice","mounted"],"sourceRoot":"","sources":["D:\\joremiodotonline\\dashboard\\src\\views\\admin\\documents\\ViewRecord.vue"],"sourcesContent":["<template>\n  <div class=\"min-h-screen bg-case-bg px-6 py-8 sm:px-10 lg:px-12\">\n    <header class=\"mb-6 flex items-center justify-between\">\n      <p class=\"text-xs uppercase tracking-[0.35em] text-primary\">ADMIN / Documents Tracking System</p>\n      <div class=\"flex items-center gap-2\">\n        <button\n          type=\"button\"\n          class=\"rounded-xl bg-blue-600/80 px-4 py-2 text-sm font-semibold text-white transition hover:bg-blue-600\"\n          :disabled=\"!record\"\n          @click=\"editRecord\"\n        >\n          EDIT\n        </button>\n        <button\n          type=\"button\"\n          class=\"rounded-xl bg-red-600/80 px-4 py-2 text-sm font-semibold text-white transition hover:bg-red-600 disabled:cursor-not-allowed disabled:opacity-50\"\n          :disabled=\"!record || isDeleting\"\n          @click=\"deleteRecord\"\n        >\n          {{ isDeleting ? \"Deleting...\" : \"DELETE\" }}\n        </button>\n        <button\n          type=\"button\"\n          class=\"rounded-xl bg-emerald-600/80 px-5 py-2 text-sm font-semibold text-white transition hover:bg-emerald-600\"\n          @click=\"$router.push('/admin/documents')\"\n        >\n          BACK\n        </button>\n      </div>\n    </header>\n\n    <h2 class=\"mb-4 inline-block rounded-md bg-blue-600/20 px-4 py-1.5 text-sm font-semibold uppercase tracking-[0.25em] text-blue-300\">\n      View Record\n    </h2>\n\n    <div v-if=\"errorMessage\" class=\"mb-4 rounded-2xl border border-red-900/50 bg-red-950/30 px-4 py-3 text-sm text-red-400\">\n      {{ errorMessage }}\n    </div>\n\n    <div v-if=\"record\" class=\"space-y-6\">\n      <div class=\"grid gap-3 rounded-2xl border border-case-border bg-case-surface p-5 sm:grid-cols-3\">\n        <div>\n          <p class=\"text-xs uppercase tracking-[0.2em] text-gray-500\">Encoder</p>\n          <p class=\"mt-1 text-sm font-semibold text-white\">{{ record.encoder?.code || record.encoder?.username }}</p>\n        </div>\n        <div>\n          <p class=\"text-xs uppercase tracking-[0.2em] text-gray-500\">PAOCC Control No</p>\n          <p class=\"mt-1 text-sm font-semibold text-white tabular-nums\">{{ record.controlNumber }}</p>\n        </div>\n        <div>\n          <p class=\"text-xs uppercase tracking-[0.2em] text-gray-500\">Subject</p>\n          <p class=\"mt-1 text-sm font-semibold text-white\">{{ record.subject }}</p>\n        </div>\n      </div>\n\n      <div class=\"overflow-hidden rounded-2xl border border-case-border bg-case-surface\">\n        <table class=\"w-full text-left text-sm\">\n          <thead class=\"bg-case-elevated text-xs uppercase tracking-[0.2em] text-gray-500\">\n            <tr>\n              <th class=\"w-12 px-4 py-3 text-center font-medium\">#</th>\n              <th class=\"px-4 py-3 font-medium\">From</th>\n              <th class=\"px-4 py-3 font-medium\">To</th>\n              <th class=\"px-4 py-3 font-medium\">Action Requested</th>\n              <th class=\"px-4 py-3 font-medium\">Date</th>\n              <th class=\"px-4 py-3 font-medium\">Sender's Name</th>\n            </tr>\n          </thead>\n          <tbody class=\"divide-y divide-case-border text-gray-300\">\n            <tr v-for=\"(line, idx) in record.lines\" :key=\"idx\">\n              <td class=\"px-4 py-3 text-center text-xs text-gray-600\">{{ idx + 1 }}</td>\n              <td class=\"px-4 py-3 text-gray-400\">{{ line.from }}</td>\n              <td class=\"px-4 py-3 text-gray-400\">{{ line.to }}</td>\n              <td class=\"px-4 py-3\">{{ line.actionRequested }}</td>\n              <td class=\"px-4 py-3 text-gray-400 tabular-nums\">{{ formatDate(line.date) }}</td>\n              <td class=\"px-4 py-3 text-gray-400\">{{ line.senderName }}</td>\n            </tr>\n          </tbody>\n        </table>\n      </div>\n\n      <div class=\"rounded-2xl border border-case-border bg-case-surface p-5\">\n        <p class=\"text-xs uppercase tracking-[0.2em] text-gray-500\">Additional Remarks</p>\n        <p class=\"mt-2 whitespace-pre-line text-sm text-gray-300\">{{ record.remarks || '—' }}</p>\n      </div>\n\n      <div v-if=\"record.attachedFile?.url\" class=\"rounded-2xl border border-case-border bg-case-surface p-5\">\n        <p class=\"text-xs uppercase tracking-[0.2em] text-gray-500\">Attached File</p>\n        <a\n          :href=\"record.attachedFile.url\"\n          target=\"_blank\"\n          rel=\"noopener\"\n          class=\"mt-1 inline-flex items-center gap-2 text-sm text-primary hover:underline\"\n        >\n          <Icon icon=\"mdi:paperclip\" class=\"text-base\" />\n          {{ record.attachedFile.originalName }}\n        </a>\n      </div>\n    </div>\n\n    <div v-else-if=\"!errorMessage\" class=\"rounded-2xl border border-case-border bg-case-surface p-10 text-center text-sm text-gray-500\">\n      Loading record...\n    </div>\n\n    <ConfirmationDialog\n      :visible=\"confirmationDialog.visible\"\n      :title=\"confirmationDialog.title\"\n      :description=\"confirmationDialog.description\"\n      :confirm-text=\"confirmationDialog.confirmText\"\n      @cancel=\"closeConfirmationDialog(false)\"\n      @confirm=\"closeConfirmationDialog(true)\"\n    />\n  </div>\n</template>\n\n<script>\n  import { Icon } from \"@iconify/vue\";\n  import API from \"@/services/api\";\n  import ConfirmationDialog from \"@/components/ConfirmationDialog.vue\";\n  import {\n    createConfirmationDialogState,\n    resolveConfirmation,\n  } from \"@/helper/record-confirmation\";\n\n  export default {\n    name: \"AdminDocumentsView\",\n    components: { Icon, ConfirmationDialog },\n    data() {\n      return {\n        record: null,\n        errorMessage: \"\",\n        isDeleting: false,\n        confirmationDialog: createConfirmationDialogState(),\n        confirmationResolver: null,\n      };\n    },\n    methods: {\n      openConfirmationDialog({ title, description, confirmText }) {\n        this.confirmationDialog = {\n          visible: true,\n          title,\n          description,\n          confirmText,\n        };\n        return new Promise((resolve) => {\n          this.confirmationResolver = resolve;\n        });\n      },\n      closeConfirmationDialog(confirmed) {\n        this.confirmationDialog = createConfirmationDialogState();\n        resolveConfirmation(this.confirmationResolver, confirmed);\n        this.confirmationResolver = null;\n      },\n      async loadRecord() {\n        this.errorMessage = \"\";\n        try {\n          const res = await API.get(`/admin/documents/${this.$route.params.id}`);\n          this.record = res.data?.record || null;\n          if (!this.record) this.errorMessage = \"Record not found.\";\n        } catch (err) {\n          this.errorMessage = err.response?.data?.message || \"Unable to load record.\";\n        }\n      },\n      editRecord() {\n        this.$router.push(`/admin/documents/${this.$route.params.id}/edit`);\n      },\n      async deleteRecord() {\n        if (!this.record) return;\n        const confirmed = await this.openConfirmationDialog({\n          title: \"Delete record?\",\n          description: `Record \"${this.record.controlNumber}\" will be permanently removed. This cannot be undone.`,\n          confirmText: \"Yes, delete\",\n        });\n        if (!confirmed) return;\n        this.isDeleting = true;\n        try {\n          await API.delete(`/admin/documents/${this.$route.params.id}`);\n          this.$router.push(\"/admin/documents\");\n        } catch (err) {\n          this.errorMessage = err.response?.data?.message || \"Unable to delete record.\";\n          this.isDeleting = false;\n        }\n      },\n      formatDate(value) {\n        if (!value) return \"—\";\n        const d = new Date(value);\n        if (Number.isNaN(d.getTime())) return \"—\";\n        return d.toISOString().slice(0, 10);\n      },\n    },\n    mounted() {\n      this.loadRecord();\n    },\n  };\n</script>\n"]},"metadata":{},"sourceType":"module"}