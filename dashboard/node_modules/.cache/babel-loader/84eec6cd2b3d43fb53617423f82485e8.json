_-15px_rgba(15,23,42,0.45)] backdrop-blur-xl\"\n    >\n      <h1 class=\"mb-5 text-center text-[15px] font-medium tracking-wide text-slate-700/90\">\n        Login\n      </h1>\n\n      <div class=\"flex items-center justify-center gap-4\">\n        <button\n          type=\"button\"\n          aria-label=\"Previous user\"\n          class=\"text-slate-600/70 transition hover:text-slate-900\"\n          @click=\"prevUser\"\n        >\n          <svg class=\"h-4 w-4\" viewBox=\"0 0 20 20\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n            <polyline points=\"12 4 6 10 12 16\" />\n          </svg>\n        </button>\n\n        <div class=\"flex items-end gap-3\">\n          <div class=\"flex flex-col items-center\">\n            <div class=\"h-10 w-10 overflow-hidden rounded-full border-2 border-white/70 opacity-75 shadow-md\">\n              <img :src=\"prevAvatar\" alt=\"\" class=\"h-full w-full object-cover\" />\n            </div>\n            <span class=\"mt-1 h-1 w-1 rounded-full bg-slate-400/60\"></span>\n          </div>\n\n          <div class=\"flex flex-col items-center\">\n            <div class=\"h-16 w-16 overflow-hidden rounded-full border-[3px] border-white shadow-lg ring-1 ring-white/60\">\n              <img :src=\"currentUser.avatar\" alt=\"\" class=\"h-full w-full object-cover\" />\n            </div>\n            <span class=\"mt-1 h-1.5 w-1.5 rounded-full bg-slate-700/70\"></span>\n          </div>\n\n          <div class=\"flex flex-col items-center\">\n            <div class=\"h-10 w-10 overflow-hidden rounded-full border-2 border-white/70 opacity-75 shadow-md\">\n              <img :src=\"nextAvatar\" alt=\"\" class=\"h-full w-full object-cover\" />\n            </div>\n            <span class=\"mt-1 h-1 w-1 rounded-full bg-slate-400/60\"></span>\n          </div>\n        </div>\n\n        <button\n          type=\"button\"\n          aria-label=\"Next user\"\n          class=\"text-slate-600/70 transition hover:text-slate-900\"\n          @click=\"nextUser\"\n        >\n          <svg class=\"h-4 w-4\" viewBox=\"0 0 20 20\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n            <polyline points=\"8 4 14 10 8 16\" />\n          </svg>\n        </button>\n      </div>\n\n      <p class=\"mt-3 text-center text-[15px] font-medium text-slate-800\">\n        {{ currentUser.name }}\n      </p>\n\n      <form class=\"mt-5\" @submit.prevent=\"handleLogin\">\n        <div class=\"relative\">\n          <input\n            v-model=\"password\"\n            :type=\"showPassword ? 'text' : 'password'\"\n            autocomplete=\"current-password\"\n            placeholder=\"password\"\n            class=\"w-full rounded-[10px] border border-white/60 bg-white/60 px-4 py-2.5 pr-10 text-sm text-slate-700 placeholder:text-slate-400 focus:border-white focus:bg-white/80 focus:outline-none\"\n          />\n          <button\n            type=\"button\"\n            class=\"absolute inset-y-0 right-0 flex items-center px-3 text-slate-500 transition hover:text-slate-700\"\n            :aria-label=\"showPassword ? 'Hide password' : 'Show password'\"\n            @click=\"showPassword = !showPassword\"\n          >\n            <svg v-if=\"!showPassword\" class=\"h-4 w-4\" viewBox=\"0 0 20 20\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n              <rect x=\"4\" y=\"9\" width=\"12\" height=\"8\" rx=\"1.5\" />\n              <path d=\"M7 9V6.5a3 3 0 0 1 6 0V9\" />\n            </svg>\n            <svg v-else class=\"h-4 w-4\" viewBox=\"0 0 20 20\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n              <path d=\"M2 10s3-5 8-5 8 5 8 5-3 5-8 5-8-5-8-5z\" />\n              <circle cx=\"10\" cy=\"10\" r=\"2\" />\n            </svg>\n          </button>\n        </div>\n\n        <button type=\"submit\" class=\"sr-only\">Sign in</button>\n\n        <p\n          v-if=\"errorMessage\"\n          class=\"mt-3 rounded-lg bg-red-500/20 px-3 py-2 text-center text-xs text-red-900\"\n        >\n          {{ errorMessage }}\n        </p>\n      </form>\n    </div>\n  </div>\n</template>\n\n<script>\n  import API from \"@/services/api\";\n  import user1 from \"@/assets/img/user1.png\";\n  import user2 from \"@/assets/img/user2.png\";\n  import user3 from \"@/assets/img/user3.png\";\n  import user4 from \"@/assets/img/user4.png\";\n  import user5 from \"@/assets/img/user5.png\";\n\n  export default {\n    name: \"LoginPage\",\n    data() {\n      return {\n        backgroundUrl:\n          \"https://images.unsplash.com/photo-1519681393784-d120267933ba?auto=format&fit=crop&w=1600&q=80\",\n        users: [\n          { name: \"Meris Kaano\", email: \"meris.kaano@agency.gov\", avatar: user1 },\n          { name: \"Aiden Vale\", email: \"aiden.vale@agency.gov\", avatar: user2 },\n          { name: \"Nova Reyes\", email: \"nova.reyes@agency.gov\", avatar: user3 },\n          { name: \"Kai Brennan\", email: \"kai.brennan@agency.gov\", avatar: user4 },\n          { name: \"Sora Iwasaki\", email: \"sora.iwasaki@agency.gov\", avatar: user5 },\n        ],\n        selectedIndex: 0,\n        password: \"\",\n        showPassword: false,\n        isSubmitting: false,\n        errorMessage: \"\",\n      };\n    },\n    computed: {\n      currentUser() {\n        return this.users[this.selectedIndex];\n      },\n      prevAvatar() {\n        const i = (this.selectedIndex - 1 + this.users.length) % this.users.length;\n        return this.users[i].avatar;\n      },\n      nextAvatar() {\n        const i = (this.selectedIndex + 1) % this.users.length;\n        return this.users[i].avatar;\n      },\n    },\n    methods: {\n      prevUser() {\n        this.selectedIndex =\n          (this.selectedIndex - 1 + this.users.length) % this.users.length;\n        this.errorMessage = \"\";\n      },\n      nextUser() {\n        this.selectedIndex = (this.selectedIndex + 1) % this.users.length;\n        this.errorMessage = \"\";\n      },\n      async handleLogin() {\n        this.errorMessage = \"\";\n        if (!this.password) {\n          this.errorMessage = \"Enter your password to continue.\";\n          return;\n        }\n        this.isSubmitting = true;\n        try {\n          const response = await API.post(\"/auth/login\", {\n            email: this.currentUser.email,\n            password: this.password,\n          });\n          localStorage.setItem(\"auth_token\", response.data.token);\n          localStorage.setItem(\"auth_user\", JSON.stringify(response.data.user));\n          this.$router.push(\"/dashboard\");\n        } catch (error) {\n          this.errorMessage =\n            error.response?.data?.message ||\n            \"Unable to sign in with those credentials.\";\n        } finally {\n          this.isSubmitting = false;\n        }\n      },\n    },\n  };\n</script>\n"]},"metadata":{},"sourceType":"module"}