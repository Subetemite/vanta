{"ast":null,"code":"import \"core-js/modules/es.json.stringify.js\";\nimport API from \"@/services/api\";\nimport user1 from \"@/assets/img/user1.png\";\nimport user2 from \"@/assets/img/user2.png\";\nimport user3 from \"@/assets/img/user3.png\";\nimport user4 from \"@/assets/img/user4.png\";\nimport user5 from \"@/assets/img/user5.png\";\nexport default {\n  name: \"LoginPage\",\n  data() {\n    return {\n      backgroundUrl: \"https://images.unsplash.com/photo-1519681393784-d120267933ba?auto=format&fit=crop&w=1600&q=80\",\n      users: [{\n        name: \"Meris Kaano\",\n        email: \"meris.kaano@agency.gov\",\n        avatar: user1\n      }, {\n        name: \"Aiden Vale\",\n        email: \"aiden.vale@agency.gov\",\n        avatar: user2\n      }, {\n        name: \"Nova Reyes\",\n        email: \"nova.reyes@agency.gov\",\n        avatar: user3\n      }, {\n        name: \"Kai Brennan\",\n        email: \"kai.brennan@agency.gov\",\n        avatar: user4\n      }, {\n        name: \"Sora Iwasaki\",\n        email: \"sora.iwasaki@agency.gov\",\n        avatar: user5\n      }],\n      selectedIndex: 0,\n      password: \"\",\n      showPassword: false,\n      isSubmitting: false,\n      errorMessage: \"\"\n    };\n  },\n  computed: {\n    currentUser() {\n      return this.users[this.selectedIndex];\n    },\n    prevAvatar() {\n      const i = (this.selectedIndex - 1 + this.users.length) % this.users.length;\n      return this.users[i].avatar;\n    },\n    nextAvatar() {\n      const i = (this.selectedIndex + 1) % this.users.length;\n      return this.users[i].avatar;\n    }\n  },\n  methods: {\n    prevUser() {\n      this.selectedIndex = (this.selectedIndex - 1 + this.users.length) % this.users.length;\n      this.errorMessage = \"\";\n    },\n    nextUser() {\n      this.selectedIndex = (this.selectedIndex + 1) % this.users.length;\n      this.errorMessage = \"\";\n    },\n    async handleLogin() {\n      this.errorMessage = \"\";\n      if (!this.password) {\n        this.errorMessage = \"Enter your password to continue.\";\n        return;\n      }\n      this.isSubmitting = true;\n      try {\n        const response = await API.post(\"/auth/login\", {\n          email: this.currentUser.email,\n          password: this.password\n        });\n        localStorage.setItem(\"auth_token\", response.data.token);\n        localStorage.setItem(\"auth_user\", JSON.stringify(response.data.user));\n        this.$router.push(\"/dashboard\");\n      } catch (error) {\n        this.errorMessage = error.response?.data?.message || \"Unable to sign in with those credentials.\";\n      } finally {\n        this.isSubmitting = false;\n      }\n    }\n  }\n};","map":{"version":3,"mappings":";AAyGE,OAAOA,GAAE,MAAO,gBAAgB;AAChC,OAAOC,KAAI,MAAO,wBAAwB;AAC1C,OAAOC,KAAI,MAAO,wBAAwB;AAC1C,OAAOC,KAAI,MAAO,wBAAwB;AAC1C,OAAOC,KAAI,MAAO,wBAAwB;AAC1C,OAAOC,KAAI,MAAO,wBAAwB;AAE1C,eAAe;EACbC,IAAI,EAAE,WAAW;EACjBC,IAAIA,GAAG;IACL,OAAO;MACLC,aAAa,EACX,+FAA+F;MACjGC,KAAK,EAAE,CACL;QAAEH,IAAI,EAAE,aAAa;QAAEI,KAAK,EAAE,wBAAwB;QAAEC,MAAM,EAAEV;MAAM,CAAC,EACvE;QAAEK,IAAI,EAAE,YAAY;QAAEI,KAAK,EAAE,uBAAuB;QAAEC,MAAM,EAAET;MAAM,CAAC,EACrE;QAAEI,IAAI,EAAE,YAAY;QAAEI,KAAK,EAAE,uBAAuB;QAAEC,MAAM,EAAER;MAAM,CAAC,EACrE;QAAEG,IAAI,EAAE,aAAa;QAAEI,KAAK,EAAE,wBAAwB;QAAEC,MAAM,EAAEP;MAAM,CAAC,EACvE;QAAEE,IAAI,EAAE,cAAc;QAAEI,KAAK,EAAE,yBAAyB;QAAEC,MAAM,EAAEN;MAAM,CAAC,CAC1E;MACDO,aAAa,EAAE,CAAC;MAChBC,QAAQ,EAAE,EAAE;MACZC,YAAY,EAAE,KAAK;MACnBC,YAAY,EAAE,KAAK;MACnBC,YAAY,EAAE;IAChB,CAAC;EACH,CAAC;EACDC,QAAQ,EAAE;IACRC,WAAWA,GAAG;MACZ,OAAO,IAAI,CAACT,KAAK,CAAC,IAAI,CAACG,aAAa,CAAC;IACvC,CAAC;IACDO,UAAUA,GAAG;MACX,MAAMC,IAAI,CAAC,IAAI,CAACR,aAAY,GAAI,IAAI,IAAI,CAACH,KAAK,CAACY,MAAM,IAAI,IAAI,CAACZ,KAAK,CAACY,MAAM;MAC1E,OAAO,IAAI,CAACZ,KAAK,CAACW,CAAC,CAAC,CAACT,MAAM;IAC7B,CAAC;IACDW,UAAUA,GAAG;MACX,MAAMF,IAAI,CAAC,IAAI,CAACR,aAAY,GAAI,CAAC,IAAI,IAAI,CAACH,KAAK,CAACY,MAAM;MACtD,OAAO,IAAI,CAACZ,KAAK,CAACW,CAAC,CAAC,CAACT,MAAM;IAC7B;EACF,CAAC;EACDY,OAAO,EAAE;IACPC,QAAQA,GAA