{"ast":null,"code":"import \"core-js/modules/esnext.iterator.constructor.js\";\nimport \"core-js/modules/esnext.iterator.for-each.js\";\nimport { Icon } from \"@iconify/vue\";\nimport API from \"@/services/api\";\nimport ConfirmationDialog from \"@/components/ConfirmationDialog.vue\";\nimport { createConfirmationDialogState, resolveConfirmation } from \"@/helper/record-confirmation\";\nconst ACTION_OPTIONS = [\"01 – Approval\", \"02 – Signature\", \"03 – Appropriate Action\", \"04 – Comment/Recommendation\", \"05 – For Study\", \"06 – Reply Direct to Writer\", \"07 – Retype/Redraft\", \"08 – Attn to HWI\", \"09 – Pls see me\", \"10 – Calendar/Remind me\", \"11 – Dispatch\", \"12 – Dissemination\", \"13 – Notation/Information\", \"14 – File\"];\nconst MAX_LINES = 5;\nfunction emptyLine() {\n  return {\n    from: \"\",\n    to: \"\",\n    actionRequested: \"\",\n    date: null,\n    senderName: \"\"\n  };\n}\nexport default {\n  name: \"AdminDocumentsView\",\n  components: {\n    Icon,\n    ConfirmationDialog\n  },\n  data() {\n    return {\n      record: null,\n      errorMessage: \"\",\n      isDeleting: false,\n      focusedIdx: 0,\n      actionOptions: ACTION_OPTIONS,\n      confirmationDialog: createConfirmationDialogState(),\n      confirmationResolver: null\n    };\n  },\n  computed: {\n    displayLines() {\n      const lines = Array.isArray(this.record?.lines) ? this.record.lines.slice(0, MAX_LINES) : [];\n      const padded = Array.from({\n        length: MAX_LINES\n      }, () => emptyLine());\n      lines.forEach((l, i) => {\n        padded[i] = l;\n      });\n      return padded;\n    },\n    focusedAction() {\n      return this.displayLines[this.focusedIdx]?.actionRequested || \"\";\n    }\n  },\n  methods: {\n    actionCode(value) {\n      if (!value) return \"\";\n      const match = String(value).match(/^(\\d{2})/);\n      return match ? match[1] : \"\";\n    },\n    focusRow(idx) {\n      if (idx < 0 || idx >= MAX_LINES) return;\n      this.focusedIdx = idx;\n    },\n    openConfirmationDialog({\n      title,\n      description,\n      confirmText\n    }) {\n      this.confirmationDialog = {\n        visible: true,\n        title,\n        description,\n        confirmText\n      };\n      return new Promise(resolve => {\n        this.confirmationResolver = resolve;\n      });\n    },\n    closeConfirmationDialog(confirmed) {\n      this.confirmationDialog = createConfirmationDialogState();\n      resolveConfirmation(this.confirmationResolver, confirmed);\n      this.confirmationResolver = null;\n    },\n    async loadRecord() {\n      this.errorMessage = \"\";\n      try {\n        const res = await API.get(`/admin/documents/${this.$route.params.id}`);\n        this.record = res.data?.record || null;\n        if (!this.record) this.errorMessage = \"Record not found.\";\n        this.focusedIdx = 0;\n      } catch (err) {\n        this.errorMessage = err.response?.data?.message || \"Unable to load record.\";\n      }\n    },\n    editRecord() {\n      this.$router.push(`/admin/documents/${this.$route.params.id}/edit`);\n    },\n    async deleteRecord() {\n      if (!this.record) return;\n      const confirmed = await this.openConfirmationDialog({\n        title: \"Delete record?\",\n        description: `Record \"${this.record.controlNumber}\" will be permanently removed. This cannot be undone.`,\n        confirmText: \"Yes, delete\"\n      });\n      if (!confirmed) return;\n      this.isDeleting = true;\n      try {\n        await API.delete(`/admin/documents/${this.$route.params.id}`);\n        this.$router.push(\"/admin/documents\");\n      } catch (err) {\n        this.errorMessage = err.response?.data?.message || \"Unable to delete record.\";\n        this.isDeleting = false;\n      }\n    },\n    formatDate(value) {\n      if (!value) return \"—\";\n      const d = new Date(value);\n      if (Number.isNaN(d.getTime())) return \"—\";\n      return d.toISOString().slice(0, 10);\n    }\n  },\n  mounted() {\n    this.loadRecord();\n  }\n};","map":{"version":3,"mappings":";;AA0LE,SAASA,IAAG,QAAS,cAAc;AACnC,OAAOC,GAAE,MAAO,gBAAgB;AAChC,OAAOC,kBAAiB,MAAO,qCAAqC;AACpE,SACEC,6BAA6B,EAC7BC,mBAAmB,QACd,8BAA8B;AAErC,MAAMC,cAAa,GAAI,CACrB,eAAe,EACf,gBAAgB,EAChB,yBAAyB,EACzB,6BAA6B,EAC7B,gBAAgB,EAChB,6BAA6B,EAC7B,qBAAqB,EACrB,kBAAkB,EAClB,iBAAiB,EACjB,yBAAyB,EACzB,eAAe,EACf,oBAAoB,EACpB,2BAA2B,EAC3B,WAAW,CACZ;AAED,MAAMC,SAAQ,GAAI,CAAC;AAEnB,SAASC,SAASA,GAAG;EACnB,OAAO;IAAEC,IAAI,EAAE,EAAE;IAAEC,EAAE,EAAE,EAAE;IAAEC,eAAe,EAAE,EAAE;IAAEC,IAAI,EAAE,IAAI;IAAEC,UAAU,EAAE;EAAG,CAAC;AAC9E;AAEA,eAAe;EACbC,IAAI,EAAE,oBAAoB;EAC1BC,UAAU,EAAE;IAAEd,IAAI;IAAEE;EAAmB,CAAC;EACxCa,IAAIA,GAAG;IACL,OAAO;MACLC,MAAM,EAAE,IAAI;MACZC,YAAY,EAAE,EAAE;MAChBC,UAAU,EAAE,KAAK;MACjBC,UAAU,EAAE,CAAC;MACbC,aAAa,EAAEf,cAAc;MAC7BgB,kBAAkB,EAAElB,6BAA6B,CAAC,CAAC;MACnDmB,oBAAoB,EAAE;IACxB,CAAC;EACH,CAAC;EACDC,QAAQ,EAAE;IACRC,YAAYA,GAAG;MACb,MAAMC,KAAI,GAAIC,KAAK,CAACC,OAAO,CAAC,IAAI,CAACX,MAAM,EAAES,KAAK,IAAI,IAAI,CAACT,MAAM,CAACS,KAAK,CAACG,KAAK,CAAC,CAAC,EAAEtB,SAAS,IAAI,EAAE;MAC5F,MAAMuB,MAAK,GAAIH,KAAK,CAAClB,IAAI,CAAC;QAAEsB,MAAM,EAAExB;MAAU,CAAC,EAAE,MAAMC,SAAS,CAAC,CAAC,CAAC;MACnEkB,KAAK,CAACM,OAAO,CAAC,CAACC,CAAC,EAAEC,CAAC,KAAK;QAAEJ,MAAM,CAACI,CAAC,IAAID,CAAC;MAAE,CAAC,CAAC;MAC3C,OAAOH,MAAM;IACf,CAAC;IACDK,aAAaA,GAAG;MACd,OAAO,IAAI,CAACV,YAAY,CAAC,IAAI,CAACL,UAAU,CAAC,EAAET,eAAc,IAAK,EAAE;IAClE;EACF,CAAC;EACDyB,OAAO,EAAE;IACPC,UAAUA,CAACC,KAAK,EAAE;MAChB,IAAI,CAACA,KAAK,EAAE,OAAO,EAAE;MACrB,MAAMC,KAAI,GAAIC,MAAM,CAACF,KAAK,CAAC,CAACC,KAAK,CAAC,UAAU,CAAC;MAC7C,OAAOA,KAAI,GAAIA,KAAK,CAAC,CAAC,IAAI,EAAE;IAC9B,CAAC;IACDE,QAAQA,CAACC,GAAG,EAAE;MACZ,IAAIA,GAAE,GAAI,KAAKA,GAAE,IAAKnC,SAAS,EAAE;MACjC,IAAI,CAACa,UAAS,GAAIsB,GAAG;IACvB,CAAC;IACDC,sBAAsBA,CAAC;MAAEC,KAAK;MAAEC,WAAW;MAAEC;IAAY,CAAC,EAAE;MAC1D,IAAI,CAACxB,kBAAiB,GAAI;QAAEyB,OAAO,EAAE,IAAI;QAAEH,KAAK;QAAEC,WAAW;QAAEC;MAAY,CAAC;MAC5E,OAAO,IAAIE,OAAO,CAAEC,OAAO,IAAK;QAC9B,IAAI,CAAC1B,oBAAmB,GAAI0B,OAAO;MACrC,CAAC,CAAC;IACJ,CAAC;IACDC,uBAAuBA,CAACC,SAAS,EAAE;MACjC,IAAI,CAAC7B,kBAAiB,GAAIlB,6BAA6B,CAAC,CAAC;MACzDC,mBAAmB,CAAC,IAAI,CAACkB,oBAAoB,EAAE4B,SAAS,CAAC;MACzD,IAAI,CAAC5B,oBAAmB,GAAI,IAAI;IAClC,CAAC;IACD,MAAM6B,UAAUA,GAAG;MACjB,IAAI,CAAClC,YAAW,GAAI,EAAE;MACtB,IAAI;QACF,MAAMmC,GAAE,GAAI,MAAMnD,GAAG,CAACoD,GAAG,CAAC,oBAAoB,IAAI,CAACC,MAAM,CAACC,MAAM,CAACC,EAAE,EAAE,CAAC;QACtE,IAAI,CAACxC,MAAK,GAAIoC,GAAG,CAACrC,IAAI,EAAEC,MAAK,IAAK,IAAI;QACtC,IAAI,CAAC,IAAI,CAACA,MAAM,EAAE,IAAI,CAACC,YAAW,GAAI,mBAAmB;QACzD,IAAI,CAACE,UAAS,GAAI,CAAC;MACrB,EAAE,OAAOsC,GAAG,EAAE;QACZ,IAAI,CAACxC,YAAW,GAAIwC,GAAG,CAACC,QAAQ,EAAE3C,IAAI,EAAE4C,OAAM,IAAK,wBAAwB;MAC7E;IACF,CAAC;IACDC,UAAUA,GAAG;MACX,IAAI,CAACC,OAAO,CAACC,IAAI,CAAC,oBAAoB,IAAI,CAACR,MAAM,CAACC,MAAM,CAACC,EAAE,OAAO,CAAC;IACrE,CAAC;IACD,MAAMO,YAAYA,GAAG;MACnB,IAAI,CAAC,IAAI,CAAC/C,MAAM,EAAE;MAClB,MAAMkC,SAAQ,GAAI,MAAM,IAAI,CAACR,sBAAsB,CAAC;QAClDC,KAAK,EAAE,gBAAgB;QACvBC,WAAW,EAAE,WAAW,IAAI,CAAC5B,MAAM,CAACgD,aAAa,uDAAuD;QACxGnB,WAAW,EAAE;MACf,CAAC,CAAC;MACF,IAAI,CAACK,SAAS,EAAE;MAChB,IAAI,CAAChC,UAAS,GAAI,IAAI;MACtB,IAAI;QACF,MAAMjB,GAAG,CAACgE,MAAM,CAAC,oBAAoB,IAAI,CAACX,MAAM,CAACC,MAAM,CAACC,EAAE,EAAE,CAAC;QAC7D,IAAI,CAACK,OAAO,CAACC,IAAI,CAAC,kBAAkB,CAAC;MACvC,EAAE,OAAOL,GAAG,EAAE;QACZ,IAAI,CAACxC,YAAW,GAAIwC,GAAG,CAACC,QAAQ,EAAE3C,IAAI,EAAE4C,OAAM,IAAK,0BAA0B;QAC7E,IAAI,CAACzC,UAAS,GAAI,KAAK;MACzB;IACF,CAAC;IACDgD,UAAUA,CAAC7B,KAAK,EAAE;MAChB,IAAI,CAACA,KAAK,EAAE,OAAO,GAAG;MACtB,MAAM8B,IAAI,IAAIC,IAAI,CAAC/B,KAAK,CAAC;MACzB,IAAIgC,MAAM,CAACC,KAAK,CAACH,CAAC,CAACI,OAAO,CAAC,CAAC,CAAC,EAAE,OAAO,GAAG;MACzC,OAAOJ,CAAC,CAACK,WAAW,CAAC,CAAC,CAAC5C,KAAK,CAAC,CAAC,EAAE,EAAE,CAAC;IACrC;EACF,CAAC;EACD6C,OAAOA,GAAG;IACR,IAAI,CAACtB,UAAU,CAAC,CAAC;EACnB;AACF,CAAC","names":["Icon","API","ConfirmationDialog","createConfirmationDialogState","resolveConfirmation","ACTION_OPTIONS","MAX_LINES","emptyLine","from","to","actionRequested","date","senderName","name","components","data","record","errorMessage","isDeleting","focusedIdx","actionOptions","confirmationDialog","confirmationResolver","computed","displayLines","lines","Array","isArray","slice","padded","length","forEach","l","i","focusedAction","methods","actionCode","value","match","String","focusRow","idx","openConfirmationDialog","title","description","confirmText","visible","Promise","resolve","closeConfirmationDialog","confirmed","loadRecord","res","get","$route","params","id","err","response","message","editRecord","$router","push","deleteRecord","controlNumber","delete","formatDate","d","Date","Number","isNaN","getTime","toISOString","mounted"],"sourceRoot":"","sources":["D:\\joremiodotonline\\dashboard\\src\\views\\admin\\documents\\ViewRecord.vue"],"sourcesContent":["<template>\n  <div class=\"min-h-screen bg-case-bg px-6 py-8 sm:px-10 lg:px-12\">\n    <header class=\"mb-6 flex items-center justify-between\">\n      <p class=\"text-xs uppercase tracking-[0.35em] text-primary\">ADMIN / Documents Tracking System</p>\n      <div class=\"flex items-center gap-2\">\n        <button\n          type=\"button\"\n          class=\"rounded-xl bg-blue-600/80 px-4 py-2 text-sm font-semibold text-white transition hover:bg-blue-600\"\n          :disabled=\"!record\"\n          @click=\"editRecord\"\n        >\n          EDIT\n        </button>\n        <button\n          type=\"button\"\n          class=\"rounded-xl bg-red-600/80 px-4 py-2 text-sm font-semibold text-white transition hover:bg-red-600 disabled:cursor-not-allowed disabled:opacity-50\"\n          :disabled=\"!record || isDeleting\"\n          @click=\"deleteRecord\"\n        >\n          {{ isDeleting ? \"Deleting...\" : \"DELETE\" }}\n        </button>\n        <button\n          type=\"button\"\n          class=\"rounded-xl bg-emerald-600/80 px-5 py-2 text-sm font-semibold text-white transition hover:bg-emerald-600\"\n          @click=\"$router.push('/admin/documents')\"\n        >\n          BACK\n        </button>\n      </div>\n    </header>\n\n    <h2 class=\"mb-4 inline-block rounded-md bg-blue-600/20 px-4 py-1.5 text-sm font-semibold uppercase tracking-[0.25em] text-blue-300\">\n      View Routing Slip\n    </h2>\n\n    <div v-if=\"errorMessage\" class=\"mb-4 rounded-2xl border border-red-900/50 bg-red-950/30 px-4 py-3 text-sm text-red-400\">\n      {{ errorMessage }}\n    </div>\n\n    <div v-if=\"record\" class=\"space-y-5\">\n      <!-- Title bar: ROUTING SLIP + PAOCC Control No. -->\n      <div class=\"rounded-2xl border border-case-border bg-case-surface p-5 sm:p-6\">\n        <div class=\"flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between\">\n          <div>\n            <p class=\"text-[10px] font-semibold uppercase tracking-[0.4em] text-primary\">Routing Slip</p>\n            <h3 class=\"mt-1 text-lg font-semibold text-white\">Document Routing</h3>\n            <p v-if=\"record.encoder?.code || record.encoder?.username\" class=\"mt-1 text-[11px] text-gray-500\">\n              Encoded by <span class=\"text-gray-300\">{{ record.encoder?.code || record.encoder?.username }}</span>\n            </p>\n          </div>\n          <div class=\"sm:w-1/2\">\n            <p class=\"mb-1 text-xs font-medium uppercase tracking-[0.2em] text-gray-500\">PAOCC Control No</p>\n            <p class=\"rounded-xl border border-case-border bg-case-card px-3 py-2 text-sm font-semibold text-white tabular-nums\">\n              {{ record.controlNumber }}\n            </p>\n          </div>\n        </div>\n        <div class=\"mt-4\">\n          <p class=\"mb-1 text-xs font-medium uppercase tracking-[0.2em] text-gray-500\">Subject</p>\n          <p class=\"rounded-xl border border-case-border bg-case-card px-3 py-2 text-sm text-white\">\n            {{ record.subject }}\n          </p>\n        </div>\n      </div>\n\n      <!-- Routing rows + action panel -->\n      <div class=\"grid gap-5 lg:grid-cols-[2fr,1fr]\">\n        <!-- Routing table -->\n        <div class=\"rounded-2xl border border-case-border bg-case-surface p-5 sm:p-6\">\n          <div class=\"mb-3 flex items-center justify-between\">\n            <h3 class=\"text-sm font-semibold uppercase tracking-[0.25em] text-gray-300\">Routing Lines</h3>\n            <p class=\"text-[10px] text-gray-500\">Click a row to view its action.</p>\n          </div>\n\n          <div class=\"overflow-x-auto\">\n            <table class=\"w-full min-w-[640px] table-fixed text-left text-sm\">\n              <thead>\n                <tr class=\"border-b border-case-border text-[10px] uppercase tracking-[0.18em] text-gray-500\">\n                  <th class=\"w-8 px-2 py-2 font-medium\"></th>\n                  <th class=\"px-2 py-2 font-medium\">From</th>\n                  <th class=\"px-2 py-2 font-medium\">To</th>\n                  <th class=\"w-16 px-2 py-2 text-center font-medium\">Action</th>\n                  <th class=\"w-32 px-2 py-2 font-medium\">Date</th>\n                  <th class=\"px-2 py-2 font-medium\">Sender's Name</th>\n                </tr>\n              </thead>\n              <tbody>\n                <tr\n                  v-for=\"(line, idx) in displayLines\"\n                  :key=\"idx\"\n                  class=\"border-b border-case-border/60 cursor-pointer transition-colors\"\n                  :class=\"focusedIdx === idx ? 'bg-primary/5' : 'hover:bg-case-card'\"\n                  @click=\"focusRow(idx)\"\n                >\n                  <td class=\"px-2 py-2 text-center text-[10px] font-semibold uppercase tracking-wide\"\n                      :class=\"focusedIdx === idx ? 'text-primary' : 'text-gray-600'\">\n                    {{ idx + 1 }}\n                  </td>\n                  <td class=\"px-2 py-2 text-xs text-gray-300\">{{ line.from || '—' }}</td>\n                  <td class=\"px-2 py-2 text-xs text-gray-300\">{{ line.to || '—' }}</td>\n                  <td class=\"px-2 py-2 text-center\">\n                    <span\n                      class=\"inline-flex h-7 min-w-7 items-center justify-center rounded-md border px-2 text-xs font-semibold tabular-nums\"\n                      :class=\"line.actionRequested\n                        ? 'border-primary/40 bg-primary/10 text-primary'\n                        : 'border-case-border bg-case-card text-gray-600'\"\n                    >\n                      {{ actionCode(line.actionRequested) || '—' }}\n                    </span>\n                  </td>\n                  <td class=\"px-2 py-2 text-xs text-gray-400 tabular-nums\">{{ formatDate(line.date) }}</td>\n                  <td class=\"px-2 py-2 text-xs text-gray-300\">{{ line.senderName || '—' }}</td>\n                </tr>\n              </tbody>\n            </table>\n          </div>\n        </div>\n\n        <!-- Action Requested radio panel (read-only) -->\n        <div class=\"rounded-2xl border border-case-border bg-case-surface p-5 sm:p-6\">\n          <div class=\"mb-3 flex items-center justify-between\">\n            <h3 class=\"text-sm font-semibold uppercase tracking-[0.25em] text-gray-300\">Action Requested</h3>\n            <span class=\"rounded-full bg-primary/10 px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-[0.2em] text-primary\">\n              Row {{ focusedIdx + 1 }}\n            </span>\n          </div>\n          <div class=\"space-y-1.5\">\n            <label\n              v-for=\"opt in actionOptions\"\n              :key=\"opt\"\n              class=\"flex cursor-default items-center gap-2.5 rounded-md border border-transparent px-2.5 py-1.5 text-xs\"\n              :class=\"focusedAction === opt ? 'border-primary/40 bg-primary/5' : ''\"\n            >\n              <input\n                type=\"radio\"\n                :value=\"opt\"\n                :checked=\"focusedAction === opt\"\n                disabled\n                class=\"h-3.5 w-3.5 accent-primary\"\n              />\n              <span :class=\"focusedAction === opt ? 'text-primary' : 'text-gray-400'\">{{ opt }}</span>\n            </label>\n          </div>\n          <p v-if=\"!focusedAction\" class=\"mt-3 text-[11px] text-gray-600\">No action set on this row.</p>\n        </div>\n      </div>\n\n      <!-- Additional Remarks -->\n      <div class=\"rounded-2xl border border-case-border bg-case-surface p-5 sm:p-6\">\n        <p class=\"mb-2 text-xs font-semibold uppercase tracking-[0.25em] text-gray-300\">Additional Remarks</p>\n        <p class=\"whitespace-pre-line rounded-xl border border-case-border bg-case-card px-3 py-2 text-sm text-gray-200\" :class=\"!record.remarks && 'text-gray-600'\">\n          {{ record.remarks || '—' }}\n        </p>\n      </div>\n\n      <!-- Attached file -->\n      <div v-if=\"record.attachedFile?.url\" class=\"rounded-2xl border border-case-border bg-case-surface p-5\">\n        <p class=\"text-xs uppercase tracking-[0.2em] text-gray-500\">Attached File</p>\n        <a\n          :href=\"record.attachedFile.url\"\n          target=\"_blank\"\n          rel=\"noopener\"\n          class=\"mt-1 inline-flex items-center gap-2 text-sm text-primary hover:underline\"\n        >\n          <Icon icon=\"mdi:paperclip\" class=\"text-base\" />\n          {{ record.attachedFile.originalName }}\n        </a>\n      </div>\n    </div>\n\n    <div v-else-if=\"!errorMessage\" class=\"rounded-2xl border border-case-border bg-case-surface p-10 text-center text-sm text-gray-500\">\n      Loading record...\n    </div>\n\n    <ConfirmationDialog\n      :visible=\"confirmationDialog.visible\"\n      :title=\"confirmationDialog.title\"\n      :description=\"confirmationDialog.description\"\n      :confirm-text=\"confirmationDialog.confirmText\"\n      @cancel=\"closeConfirmationDialog(false)\"\n      @confirm=\"closeConfirmationDialog(true)\"\n    />\n  </div>\n</template>\n\n<script>\n  import { Icon } from \"@iconify/vue\";\n  import API from \"@/services/api\";\n  import ConfirmationDialog from \"@/components/ConfirmationDialog.vue\";\n  import {\n    createConfirmationDialogState,\n    resolveConfirmation,\n  } from \"@/helper/record-confirmation\";\n\n  const ACTION_OPTIONS = [\n    \"01 – Approval\",\n    \"02 – Signature\",\n    \"03 – Appropriate Action\",\n    \"04 – Comment/Recommendation\",\n    \"05 – For Study\",\n    \"06 – Reply Direct to Writer\",\n    \"07 – Retype/Redraft\",\n    \"08 – Attn to HWI\",\n    \"09 – Pls see me\",\n    \"10 – Calendar/Remind me\",\n    \"11 – Dispatch\",\n    \"12 – Dissemination\",\n    \"13 – Notation/Information\",\n    \"14 – File\",\n  ];\n\n  const MAX_LINES = 5;\n\n  function emptyLine() {\n    return { from: \"\", to: \"\", actionRequested: \"\", date: null, senderName: \"\" };\n  }\n\n  export default {\n    name: \"AdminDocumentsView\",\n    components: { Icon, ConfirmationDialog },\n    data() {\n      return {\n        record: null,\n        errorMessage: \"\",\n        isDeleting: false,\n        focusedIdx: 0,\n        actionOptions: ACTION_OPTIONS,\n        confirmationDialog: createConfirmationDialogState(),\n        confirmationResolver: null,\n      };\n    },\n    computed: {\n      displayLines() {\n        const lines = Array.isArray(this.record?.lines) ? this.record.lines.slice(0, MAX_LINES) : [];\n        const padded = Array.from({ length: MAX_LINES }, () => emptyLine());\n        lines.forEach((l, i) => { padded[i] = l; });\n        return padded;\n      },\n      focusedAction() {\n        return this.displayLines[this.focusedIdx]?.actionRequested || \"\";\n      },\n    },\n    methods: {\n      actionCode(value) {\n        if (!value) return \"\";\n        const match = String(value).match(/^(\\d{2})/);\n        return match ? match[1] : \"\";\n      },\n      focusRow(idx) {\n        if (idx < 0 || idx >= MAX_LINES) return;\n        this.focusedIdx = idx;\n      },\n      openConfirmationDialog({ title, description, confirmText }) {\n        this.confirmationDialog = { visible: true, title, description, confirmText };\n        return new Promise((resolve) => {\n          this.confirmationResolver = resolve;\n        });\n      },\n      closeConfirmationDialog(confirmed) {\n        this.confirmationDialog = createConfirmationDialogState();\n        resolveConfirmation(this.confirmationResolver, confirmed);\n        this.confirmationResolver = null;\n      },\n      async loadRecord() {\n        this.errorMessage = \"\";\n        try {\n          const res = await API.get(`/admin/documents/${this.$route.params.id}`);\n          this.record = res.data?.record || null;\n          if (!this.record) this.errorMessage = \"Record not found.\";\n          this.focusedIdx = 0;\n        } catch (err) {\n          this.errorMessage = err.response?.data?.message || \"Unable to load record.\";\n        }\n      },\n      editRecord() {\n        this.$router.push(`/admin/documents/${this.$route.params.id}/edit`);\n      },\n      async deleteRecord() {\n        if (!this.record) return;\n        const confirmed = await this.openConfirmationDialog({\n          title: \"Delete record?\",\n          description: `Record \"${this.record.controlNumber}\" will be permanently removed. This cannot be undone.`,\n          confirmText: \"Yes, delete\",\n        });\n        if (!confirmed) return;\n        this.isDeleting = true;\n        try {\n          await API.delete(`/admin/documents/${this.$route.params.id}`);\n          this.$router.push(\"/admin/documents\");\n        } catch (err) {\n          this.errorMessage = err.response?.data?.message || \"Unable to delete record.\";\n          this.isDeleting = false;\n        }\n      },\n      formatDate(value) {\n        if (!value) return \"—\";\n        const d = new Date(value);\n        if (Number.isNaN(d.getTime())) return \"—\";\n        return d.toISOString().slice(0, 10);\n      },\n    },\n    mounted() {\n      this.loadRecord();\n    },\n  };\n</script>\n"]},"metadata":{},"sourceType":"module"}