{"ast":null,"code":"import API from \"@/services/api\";\nexport default {\n  name: \"GeneralSettingsPage\",\n  data() {\n    return {\n      isLoading: false,\n      isSaving: false,\n      message: {\n        type: \"\",\n        text: \"\"\n      },\n      form: {\n        appName: \"VANTA\",\n        appVersion: \"1.0.0\",\n        language: \"en\",\n        timezone: \"UTC\",\n        dateFormat: \"MM/DD/YYYY\"\n      }\n    };\n  },\n  mounted() {\n    this.loadSettings();\n  },\n  methods: {\n    async loadSettings() {\n      this.isLoading = true;\n      this.message = {\n        type: \"\",\n        text: \"\"\n      };\n      try {\n        const res = await API.get(\"/system/settings\");\n        const s = res.data.settings || res.data || {};\n        this.form.appName = s.appName || \"VANTA\";\n        this.form.appVersion = s.appVersion || \"1.0.0\";\n        this.form.language = s.language || \"en\";\n        this.form.timezone = s.timezone || \"UTC\";\n        this.form.dateFormat = s.dateFormat || \"MM/DD/YYYY\";\n      } catch {\n        /* endpoint may not exist yet — defaults are fine */\n      } finally {\n        this.isLoading = false;\n      }\n    },\n    async saveSettings() {\n      this.isSaving = true;\n      this.message = {\n        type: \"\",\n        text: \"\"\n      };\n      try {\n        await API.put(\"/system/settings\", {\n          appName: this.form.appName,\n          language: this.form.language,\n          timezone: this.form.timezone,\n          dateFormat: this.form.dateFormat\n        });\n        this.message = {\n          type: \"success\",\n          text: \"Settings saved successfully.\"\n        };\n      } catch (err) {\n        this.message = {\n          type: \"error\",\n          text: err.response?.data?.message || \"Unable to save settings right now.\"\n        };\n      } finally {\n        this.isSaving = false;\n      }\n    }\n  }\n};","map":{"version":3,"mappings":"AA8HE,OAAOA,GAAE,MAAO,gBAAgB;AAEhC,eAAe;EACbC,IAAI,EAAE,qBAAqB;EAC3BC,IAAIA,GAAG;IACL,OAAO;MACLC,SAAS,EAAE,KAAK;MAChBC,QAAQ,EAAE,KAAK;MACfC,OAAO,EAAE;QAAEC,IAAI,EAAE,EAAE;QAAEC,IAAI,EAAE;MAAG,CAAC;MAC/BC,IAAI,EAAE;QACJC,OAAO,EAAE,OAAO;QAChBC,UAAU,EAAE,OAAO;QACnBC,QAAQ,EAAE,IAAI;QACdC,QAAQ,EAAE,KAAK;QACfC,UAAU,EAAE;MACd;IACF,CAAC;EACH,CAAC;EACDC,OAAOA,GAAG;IACR,IAAI,CAACC,YAAY,CAAC,CAAC;EACrB,CAAC;EACDC,OAAO,EAAE;IACP,MAAMD,YAAYA,GAAG;MACnB,IAAI,CAACZ,SAAQ,GAAI,IAAI;MACrB,IAAI,CAACE,OAAM,GAAI;QAAEC,IAAI,EAAE,EAAE;QAAEC,IAAI,EAAE;MAAG,CAAC;MACrC,IAAI;QACF,MAAMU,GAAE,GAAI,MAAMjB,GAAG,CAACkB,GAAG,CAAC,kBAAkB,CAAC;QAC7C,MAAMC,IAAIF,GAAG,CAACf,IAAI,CAACkB,QAAO,IAAKH,GAAG,CAACf,IAAG,IAAK,CAAC,CAAC;QAC7C,IAAI,CAACM,IAAI,CAACC,OAAM,GAAOU,CAAC,CAACV,OAAM,IAAQ,OAAO;QAC9C,IAAI,CAACD,IAAI,CAACE,UAAS,GAAIS,CAAC,CAACT,UAAS,IAAK,OAAO;QAC9C,IAAI,CAACF,IAAI,CAACG,QAAO,GAAMQ,CAAC,CAACR,QAAO,IAAO,IAAI;QAC3C,IAAI,CAACH,IAAI,CAACI,QAAO,GAAMO,CAAC,CAACP,QAAO,IAAO,KAAK;QAC5C,IAAI,CAACJ,IAAI,CAACK,UAAS,GAAIM,CAAC,CAACN,UAAS,IAAK,YAAY;MACrD,EAAE,MAAM;QACN;MAAA,CACF,SAAU;QACR,IAAI,CAACV,SAAQ,GAAI,KAAK;MACxB;IACF,CAAC;IACD,MAAMkB,YAAYA,GAAG;MACnB,IAAI,CAACjB,QAAO,GAAI,IAAI;MACpB,IAAI,CAACC,OAAM,GAAI;QAAEC,IAAI,EAAE,EAAE;QAAEC,IAAI,EAAE;MAAG,CAAC;MACrC,IAAI;QACF,MAAMP,GAAG,CAACsB,GAAG,CAAC,kBAAkB,EAAE;UAChCb,OAAO,EAAK,IAAI,CAACD,IAAI,CAACC,OAAO;UAC7BE,QAAQ,EAAI,IAAI,CAACH,IAAI,CAACG,QAAQ;UAC9BC,QAAQ,EAAI,IAAI,CAACJ,IAAI,CAACI,QAAQ;UAC9BC,UAAU,EAAE,IAAI,CAACL,IAAI,CAACK;QACxB,CAAC,CAAC;QACF,IAAI,CAACR,OAAM,GAAI;UAAEC,IAAI,EAAE,SAAS;UAAEC,IAAI,EAAE;QAA+B,CAAC;MAC1E,EAAE,OAAOgB,GAAG,EAAE;QACZ,IAAI,CAAClB,OAAM,GAAI;UACbC,IAAI,EAAE,OAAO;UACbC,IAAI,EAAEgB,GAAG,CAACC,QAAQ,EAAEtB,IAAI,EAAEG,OAAM,IAAK;QACvC,CAAC;MACH,UAAU;QACR,IAAI,CAACD,QAAO,GAAI,KAAK;MACvB;IACF;EACF;AACF,CAAC","names":["API","name","data","isLoading","isSaving","message","type","text","form","appName","appVersion","language","timezone","dateFormat","mounted","loadSettings","methods","res","get","s","settings","saveSettings","put","err","response"],"sourceRoot":"","sources":["D:\\joremiodotonline\\dashboard\\src\\views\\system\\GeneralSettings.vue"],"sourcesContent":["<template>\n  <div class=\"min-h-screen bg-case-bg p-6 sm:p-8\">\n    <div class=\"mx-auto max-w-3xl space-y-6\">\n\n      <div class=\"border-b border-case-border pb-5\">\n        <p class=\"text-xs font-semibold uppercase tracking-[0.3em] text-primary\">System / General Settings</p>\n        <h1 class=\"mt-2 text-2xl font-semibold text-white\">General Settings</h1>\n        <p class=\"mt-1 text-sm text-gray-500\">Configure application identity and localization preferences.</p>\n      </div>\n\n      <div\n        v-if=\"message.text\"\n        :class=\"message.type === 'success' ? 'border-emerald-800/50 bg-emerald-950/30 text-emerald-400' : 'border-red-900/50 bg-red-950/30 text-red-400'\"\n        class=\"rounded-xl border px-4 py-3 text-sm\"\n      >\n        {{ message.text }}\n      </div>\n\n      <div v-if=\"isLoading\" class=\"py-12 text-center text-sm text-gray-600\">\n        Loading settings...\n      </div>\n\n      <form v-else @submit.prevent=\"saveSettings\" class=\"space-y-6\">\n\n        <!-- App Identification -->\n        <section class=\"rounded-xl border border-case-border bg-case-surface p-6\">\n          <h2 class=\"mb-5 text-xs font-semibold uppercase tracking-[0.2em] text-gray-500\">App Identification</h2>\n          <div class=\"space-y-4\">\n            <div>\n              <label class=\"mb-2 block text-sm font-medium text-gray-400\">App Name</label>\n              <input\n                v-model.trim=\"form.appName\"\n                type=\"text\"\n                class=\"w-full rounded-xl border border-case-border bg-case-card px-4 py-3 text-gray-200 outline-none transition placeholder:text-gray-600 focus:border-primary focus:ring-4 focus:ring-primary/10\"\n                placeholder=\"VANTA\"\n              />\n            </div>\n            <div>\n              <label class=\"mb-2 block text-sm font-medium text-gray-400\">App Version</label>\n              <input\n                :value=\"form.appVersion\"\n                type=\"text\"\n                readonly\n                class=\"w-full cursor-not-allowed rounded-xl border border-case-border bg-case-card px-4 py-3 text-gray-600 outline-none opacity-60\"\n              />\n              <p class=\"mt-1.5 text-xs text-gray-600\">Version is managed by the deployment pipeline.</p>\n            </div>\n          </div>\n        </section>\n\n        <!-- Localization -->\n        <section class=\"rounded-xl border border-case-border bg-case-surface p-6\">\n          <h2 class=\"mb-5 text-xs font-semibold uppercase tracking-[0.2em] text-gray-500\">Localization</h2>\n          <div class=\"space-y-4\">\n            <div>\n              <label class=\"mb-2 block text-sm font-medium text-gray-400\">Default Language</label>\n              <select\n                v-model=\"form.language\"\n                class=\"w-full rounded-xl border border-case-border bg-case-card px-4 py-3 text-gray-200 outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10 appearance-none cursor-pointer\"\n              >\n                <option value=\"en\">English</option>\n                <option value=\"fr\">French</option>\n                <option value=\"es\">Spanish</option>\n                <option value=\"de\">German</option>\n                <option value=\"ja\">Japanese</option>\n              </select>\n            </div>\n            <div>\n              <label class=\"mb-2 block text-sm font-medium text-gray-400\">Timezone</label>\n              <select\n                v-model=\"form.timezone\"\n                class=\"w-full rounded-xl border border-case-border bg-case-card px-4 py-3 text-gray-200 outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10 appearance-none cursor-pointer\"\n              >\n                <option value=\"UTC\">UTC (Coordinated Universal Time)</option>\n                <option value=\"America/New_York\">America/New_York (UTC-5)</option>\n                <option value=\"America/Chicago\">America/Chicago (UTC-6)</option>\n                <option value=\"America/Denver\">America/Denver (UTC-7)</option>\n                <option value=\"America/Los_Angeles\">America/Los_Angeles (UTC-8)</option>\n                <option value=\"Europe/London\">Europe/London (UTC+0)</option>\n                <option value=\"Europe/Paris\">Europe/Paris (UTC+1)</option>\n                <option value=\"Asia/Dubai\">Asia/Dubai (UTC+4)</option>\n                <option value=\"Asia/Kolkata\">Asia/Kolkata (UTC+5:30)</option>\n                <option value=\"Asia/Manila\">Asia/Manila (UTC+8)</option>\n                <option value=\"Asia/Tokyo\">Asia/Tokyo (UTC+9)</option>\n                <option value=\"Australia/Sydney\">Australia/Sydney (UTC+10)</option>\n              </select>\n            </div>\n            <div>\n              <label class=\"mb-2 block text-sm font-medium text-gray-400\">Date &amp; Time Format</label>\n              <select\n                v-model=\"form.dateFormat\"\n                class=\"w-full rounded-xl border border-case-border bg-case-card px-4 py-3 text-gray-200 outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10 appearance-none cursor-pointer\"\n              >\n                <option value=\"MM/DD/YYYY\">MM/DD/YYYY — 04/21/2026</option>\n                <option value=\"DD/MM/YYYY\">DD/MM/YYYY — 21/04/2026</option>\n                <option value=\"YYYY-MM-DD\">YYYY-MM-DD — 2026-04-21 (ISO)</option>\n                <option value=\"MMM DD, YYYY\">MMM DD, YYYY — Apr 21, 2026</option>\n                <option value=\"DD MMM YYYY\">DD MMM YYYY — 21 Apr 2026</option>\n              </select>\n            </div>\n          </div>\n        </section>\n\n        <div class=\"flex items-center justify-end gap-3\">\n          <button\n            type=\"button\"\n            @click=\"loadSettings\"\n            class=\"rounded-xl border border-case-border px-4 py-2.5 text-sm font-medium text-gray-400 transition hover:bg-case-elevated hover:text-gray-200\"\n          >\n            Reset\n          </button>\n          <button\n            type=\"submit\"\n            :disabled=\"isSaving\"\n            class=\"rounded-xl bg-primary px-5 py-2.5 text-sm font-semibold text-black transition hover:bg-amber-500 disabled:cursor-not-allowed disabled:opacity-50\"\n          >\n            {{ isSaving ? \"Saving...\" : \"Save settings\" }}\n          </button>\n        </div>\n\n      </form>\n    </div>\n  </div>\n</template>\n\n<script>\n  import API from \"@/services/api\";\n\n  export default {\n    name: \"GeneralSettingsPage\",\n    data() {\n      return {\n        isLoading: false,\n        isSaving: false,\n        message: { type: \"\", text: \"\" },\n        form: {\n          appName: \"VANTA\",\n          appVersion: \"1.0.0\",\n          language: \"en\",\n          timezone: \"UTC\",\n          dateFormat: \"MM/DD/YYYY\",\n        },\n      };\n    },\n    mounted() {\n      this.loadSettings();\n    },\n    methods: {\n      async loadSettings() {\n        this.isLoading = true;\n        this.message = { type: \"\", text: \"\" };\n        try {\n          const res = await API.get(\"/system/settings\");\n          const s = res.data.settings || res.data || {};\n          this.form.appName    = s.appName    || \"VANTA\";\n          this.form.appVersion = s.appVersion || \"1.0.0\";\n          this.form.language   = s.language   || \"en\";\n          this.form.timezone   = s.timezone   || \"UTC\";\n          this.form.dateFormat = s.dateFormat || \"MM/DD/YYYY\";\n        } catch {\n          /* endpoint may not exist yet — defaults are fine */\n        } finally {\n          this.isLoading = false;\n        }\n      },\n      async saveSettings() {\n        this.isSaving = true;\n        this.message = { type: \"\", text: \"\" };\n        try {\n          await API.put(\"/system/settings\", {\n            appName:    this.form.appName,\n            language:   this.form.language,\n            timezone:   this.form.timezone,\n            dateFormat: this.form.dateFormat,\n          });\n          this.message = { type: \"success\", text: \"Settings saved successfully.\" };\n        } catch (err) {\n          this.message = {\n            type: \"error\",\n            text: err.response?.data?.message || \"Unable to save settings right now.\",\n          };\n        } finally {\n          this.isSaving = false;\n        }\n      },\n    },\n  };\n</script>\n"]},"metadata":{},"sourceType":"module"}